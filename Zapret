-- Скрипт обновления текста (Local Script)
local player = game.Players.LocalPlayer
-- Ждем, пока папка и значение появятся (т.к. они создаются сервером)
local privateStats = player:WaitForChild("PrivateStats")
local energyValue = privateStats:WaitForChild("Energy")
local label = script.Parent

-- Функция обновления текста на экране
local function updateText()
	label.Text = "ЭНЕРГИЯ: " .. energyValue.Value
end

-- Обновляем текст сразу и каждый раз, когда значение меняется
updateText()
energyValue:GetPropertyChangedSignal("Value"):Connect(updateText)
