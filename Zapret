import asyncio
import os
import logging
import uuid
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command

from engine import DeobfuscatorEngine

# --- CONFIG ---
API_TOKEN = 'ТВОЙ_ТОКЕН_СЮДА'

# Logging
logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(message)s")
logger = logging.getLogger("DeobfBot")

bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "👁️ **Mel Deobfuscator V4 (God Mode)**\n\n"
        "Отправь `.lua` файл.\n"
        "Я применю агрессивный статический анализ и эмуляцию V6.\n\n"
        "⚡ **Features:**\n"
        "- Ignore Luau Crashes\n"
        "- Force String Extraction\n"
        "- Full Environment Mock\n"
        "- **Gokuoriginal Privilege:** Infinite Timeout",
        parse_mode="Markdown"
    )

@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    username = message.from_user.username
    file_name = message.document.file_name or "script.lua"
    unique_id = uuid.uuid4().hex[:8]
    
    # === ADMIN PRIVILEGE CHECK ===
    is_admin = (username == "Gokuoriginal")
    
    # Тайм-аут: Бесконечность для админа, 5 минут для смертных
    exec_timeout = 36000.0 if is_admin else 300.0 
    
    input_path = f"temp_{unique_id}.lua"
    output_path = f"Deobf_{unique_id}_{file_name}.txt"

    status_msg = await message.answer(
        f"⏳ **Анализ начат...**\n👤 User: {username}\n♾️ Timeout: {'INFINITE' if is_admin else '300s'}", 
        parse_mode="Markdown"
    )

    loop = asyncio.get_running_loop()
    
    # Функция обновления статуса
    last_status = [""]
    def sync_updater(text):
        if text == last_status[0]: return
        last_status[0] = text
        asyncio.run_coroutine_threadsafe(
            status_msg.edit_text(f"⚙️ **Status:** {text}", parse_mode="Markdown"),
            loop
        )

    try:
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "rb") as f: content = f.read()

        # Запуск движка в отдельном потоке
        # Используем wait_for с нашим динамическим тайм-аутом
        result = await asyncio.wait_for(
            loop.run_in_executor(None, engine.process, content, sync_updater),
            timeout=exec_timeout
        )

        with open(output_path, "wb") as f: f.write(result)
        
        caption = "✅ **Готово.**"
        if len(result) < 100: caption += "\n⚠️ Файл подозрительно маленький, проверь Hex Dump."
        
        await message.answer_document(FSInputFile(output_path), caption=caption)

    except asyncio.TimeoutError:
        await status_msg.edit_text("❌ **Timeout.** Скрипт слишком тяжелый.")
    except Exception as e:
        logger.error(f"Bot Error: {e}")
        await status_msg.edit_text(f"❌ **Error:** {str(e)}")
    finally:
        for p in [input_path, output_path]:
            if os.path.exists(p):
                try: os.remove(p)
                except: pass

async def main():
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
