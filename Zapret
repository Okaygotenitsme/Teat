logger = logging.getLogger("DeobfuscatorEngine")

class TimeoutException(Exception): pass

@contextmanager
def time_limit(seconds):
    """Защита от зависаний"""
    def signal_handler(signum, frame):
        raise TimeoutException("Execution timeout")
    signal.signal(signal.SIGALRM, signal_handler)
    signal.alarm(seconds)
    try:
        yield
    finally:
        signal.alarm(0)

class DeobfuscatorEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        logger.info(f"📁 Working Dir: {base_dir}")
        
        # Паттерны обфускаторов
        self.obfuscator_patterns = {
            'PSU': rb'PSU|Psu Obfuscator|wOwOwOwOwO',
            'MoonSec': rb'MoonSec|v3rm|moonsec',
            'IronBrew': rb'IronBrew|Ironbrew2',
            'Luraph': rb'Luraph|LPH_',
            'Prometheus': rb'Prometheus|PROMETHEUS'
        }

    def detect_obfuscator(self, content):
        """Определяет тип обфускатора"""
        if isinstance(content, str):
            content = content.encode('utf-8', errors='ignore')
        
        for name, pattern in self.obfuscator_patterns.items():
            if re.search(pattern, content, re.IGNORECASE):
                return name
        return "Unknown"

    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        if not self._check_java():
            return b"-- [FATAL] Java is missing. Install Java to use unluac."

        # Детект обфускатора
        obf_type = self.detect_obfuscator(content)
        update_status(f"🔍 Detected: {obf_type} Obfuscator")

        # Пре-процессинг
        content = self._preprocess_code(content)

        update_status("🧠 Initializing Roblox VM...")

        try:
            lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)
        except Exception as e:
            return f"-- [FATAL] Lua init error: {e}".encode('utf-8')

        # ==========================================
        # ПОЛНАЯ LUA СРЕДА (оптимизированная)
        # ==========================================
        full_setup = self._build_lua_environment()

        try:
            update_status("🌪️ Running script with hooks...")
            
            lua.execute(full_setup)
            
            # Безопасный раннер с таймаутом
            runner = lua.eval("""
                function(code)
                    _G.EXECUTION_STARTED = true
                    local status, err = pcall(function()
                        local f, load_err = load(code, "script", "t", _G)
                        if not f then error(load_err) end
                        f()
                    end)
                    
                    if not status then
                        table.insert(_G.ACTION_LOG, "⚠️ Script Error: " .. tostring(err))
                    end
                    
                    pcall(_G.dump_globals)
                    _G.EXECUTION_FINISHED = true
                    return status
                end
            """)
            
            # Запуск с таймаутом
            try:
                with time_limit(60):  # 60 секунд макс
                    runner(content)
            except TimeoutException:
                update_status("⏱️ Execution timeout (60s)")

            # Сбор данных
            strings_tbl = lua.globals().DETECTED_STRINGS
            detected_strings = list(strings_tbl) if strings_tbl else []
            
            global_dump = list(lua.globals().FINAL_GLOBALS) if lua.globals().FINAL_GLOBALS else []
            action_log = list(lua.globals().ACTION_LOG) if lua.globals().ACTION_LOG else []
            
            chunks = lua.globals().CAPTURED_CHUNKS
            remotes = lua.globals().REMOTE_CALLS
            
            # Поиск лучшего чанка
            best_chunk = self._find_best_chunk(chunks)
            target_code = best_chunk if best_chunk else content
            
            return self._finalize_output(
                target_code, detected_strings, global_dump, 
                action_log, list(remotes) if remotes else [], 
                obf_type, update_status
            )

        except Exception as e:
            logger.error(f"Engine Crash: {e}", exc_info=True)
            return f"-- [CRASH ERROR]: {str(e)}\n-- Obfuscator: {obf_type}".encode('utf-8')

