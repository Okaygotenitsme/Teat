        self.key = random.randint(100, 255)
        self.v_data = self._rand_name()
        self.v_func = self._rand_name()
        self.v_var = self._rand_name()

    def _rand_name(self):
        """Создает нечитаемые имена переменных"""
        # Используем символы, которые трудно различить визуально
        return "v" + "".join(random.choices("Il10O", k=random.randint(8, 12)))

