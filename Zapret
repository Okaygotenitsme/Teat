import asyncio
import os
import logging
import uuid
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command

# Импорт обновленного движка
from engine import DeobfuscatorEngine

# --- НАСТРОЙКИ ---
API_TOKEN = 'ТВОЙ_ТОКЕН_СЮДА'

logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(levelname)s - %(message)s")
logger = logging.getLogger("DeobfBot")

bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "🔮 **Roblox Ultimate Deobfuscator**\n\n"
        "Скинь `.lua` или `.txt`. Я проведу глубокий анализ.\n\n"
        "🛠 **Что я умею:**\n"
        "1. Эмуляция `game`, `workspace`, `Instance.new` (обход проверок среды).\n"
        "2. Эмуляция `getgenv`, `syn`, `debug` (обход проверок эксплойтов).\n"
        "3. Перехват HTTP запросов и файловой системы.\n"
        "4. Рекурсивный дамп глобальных переменных.\n"
        "5. Распаковка MoonSec/IronBrew слоев.\n\n"
        "⏳ Анализ может занять до 3-х минут для сложных скриптов.",
        parse_mode="Markdown"
    )

@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    unique_id = uuid.uuid4().hex[:8]
    file_name = message.document.file_name or "script.lua"
    
    input_path = f"temp_{user_id}_{unique_id}.lua"
    output_path = f"Deobf_{unique_id}_{file_name}.txt"

    # Создаем сообщение, которое будем обновлять
    status_msg = await message.answer("📥 **Скачивание файла...**", parse_mode="Markdown")
    
    loop = asyncio.get_running_loop()
    
    # Механизм обновления статуса в реальном времени
    last_status = [""]
    
    def sync_status_updater(text):
        if text == last_status[0]: return
        last_status[0] = text
        
        async def edit_coro():
            try:
                # Добавляем часики, чтобы телеграм не ругался на спам обновлений
                await status_msg.edit_text(f"⚙️ **Процесс:**\n`{text}`", parse_mode="Markdown")
            except Exception: pass 
        
        if not loop.is_closed():
            asyncio.run_coroutine_threadsafe(edit_coro(), loop)

    try:
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "rb") as f: content = f.read()

        # ЗАПУСК: Тайм-аут увеличен до 4 минут (240.0) для тяжелых скриптов
        result_data = await asyncio.wait_for(
            loop.run_in_executor(None, engine.process, content, sync_status_updater),
            timeout=240.0 
        )

        with open(output_path, "wb") as f: f.write(result_data)
        out_file = FSInputFile(output_path)
        
        # Интеллектуальное описание
        caption = "✅ **Анализ успешно завершен!**"
        
        # Проверяем размер результата
        res_size_kb = len(result_data) / 1024
        caption += f"\n📦 Размер отчета: {res_size_kb:.1f} KB"
        
        if b"SOURCE CODE" in result_data:
            caption += "\n📜 **Исходный код восстановлен!**"
        elif b"Found payload" in result_data:
            caption += "\n💣 **Найден скрытый пэйлоад!**"
        
        await message.answer_document(out_file, caption=caption)

    except asyncio.TimeoutError:
        await status_msg.edit_text("⏱ **Тайм-аут:** Скрипт слишком сложный или завис в вечном цикле.")
    except Exception as e:
        logger.error(f"Error: {e}")
        await status_msg.edit_text(f"❌ **Ошибка:** {str(e)}")
    finally:
        for p in [input_path, output_path]:
            if os.path.exists(p):
                try: os.remove(p)
                except: pass

async def main():
    logger.info("Бот запускается...")
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    try:
        if os.name == 'nt':
            asyncio.set_event_loop_policy(asyncio.WindowsSelectorEventLoopPolicy())
        asyncio.run(main())
    except KeyboardInterrupt:
        print("Bot stopped")
