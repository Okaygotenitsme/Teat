# Хранилище настроек пользователей (в памяти)
user_settings = {}

@dp.message(Command("setlayers"))
async def set_layers(message: types.Message, command: CommandObject):
    if not command.args:
        await message.answer("⚠️ Пример: `/setlayers 2`")
        return
    try:
        n = int(command.args)
        if 1 <= n <= 3:
            user_settings[message.from_user.id] = n
            await message.answer(f"✅ Установлено слоев защиты: **{n}**")
        else:
            await message.answer("⚠️ Можно установить от 1 до 3 слоев.")
    except:
        await message.answer("⚠️ Введите число.")

@dp.message(Command("loadstring"))
async def make_loadstring(message: types.Message, command: CommandObject):
    if not command.args:
        await message.answer("⚠️ Пример: `/loadstring https://raw.github...`")
        return
    url = command.args.strip()
    content = f'loadstring(game:HttpGet("{url}"))()'
    file_output = BufferedInputFile(content.encode('utf-8'), filename="loader.lua")
    await message.answer_document(file_output, caption=f"✅ **Loadstring готов**")

@dp.message(F.document)
async def handle_docs(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        return

    # Получаем настройки пользователя
    layers = user_settings.get(message.from_user.id, 1)

    status = await message.answer(f"🔒 **Защита V7 (Layers: {layers})...**\n_Исправлена ошибка синтаксиса..._", parse_mode="Markdown")
    try:
        file_info = await bot.get_file(message.document.file_id)
        file_content = await bot.download_file(file_info.file_path)
        source = file_content.read().decode('utf-8', errors='ignore')

        # Обфускация с указанным кол-вом слоев
        obf = MelotenObfuscatorV7(source, layers=layers)
        protected_code = obf.build()

        output = BufferedInputFile(
            protected_code.encode('utf-8'), 
            filename=f"Protected_{message.document.file_name}"
        )
        
        await message.answer_document(
            output, 
            caption=f"✅ **Успешно!**\n🛡 Слоев защиты: {layers}\n🐛 Syntax Error fix: Applied.",
        )
        await status.delete()
        del source, protected_code
        
    except Exception as e:
        logging.error(e)
        await message.answer(f"❌ Ошибка: {e}")

