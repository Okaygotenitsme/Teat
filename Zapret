import lupa
from lupa import LuaRuntime
import re

class DeobfuscatorEngine:
    def __init__(self):
        # Создаем runtime. Мы будем пересоздавать его или чистить для каждого запуска, 
        # чтобы избежать накопления мусора.
        pass

    def process_text(self, content):
        # Создаем новый инстанс Lua для каждого файла для изоляции
        self.lua = LuaRuntime(unpack_returned_tuples=True)
        # Ограничиваем количество инструкций (например, 10 миллионов), 
        # чтобы избежать бесконечных циклов.
        self.lua.set_instruction_count_limit(10_000_000)
        return self.run_nuclear_sandbox(content)

    def run_nuclear_sandbox(self, code):
        logs = ["-- [[ MoonSec V3: NUCLEAR DEOBFUSCATION ]] --\n"]
        
        # 1. Поиск переменной байт-кода
        var_match = re.search(r"\(function\(a\) (\w+) = a; end\)\)", code)
        bytecode_var = var_match.group(1) if var_match else None
        
        # 2. Поиск payload (строки с данными)
        payload = None
        payload_match = re.search(r"\(\[\[(.*?)\]\]\)", code, re.DOTALL)
        if payload_match:
            payload = payload_match.group(1)
        else:
            payload_match = re.search(r"gsub\(\s*['\"](.*?)['\"]\s*,\s*\(", code, re.DOTALL)
            if payload_match:
                payload = payload_match.group(1)

        if payload:
            logs.append(f"-- [SYSTEM]: Данные извлечены ({len(payload)} байт)")
        
        # Скрипт подготовки среды (улучшенный)
        setup_script = """
        _G.LOGS = {}
        _G.CAPTURED_RESULT = nil

        -- Полифилл для окружения
        local function find_env(f)
            local i = 1
            while true do
                local name, val = debug.getupvalue(f, i)
                if name == "_ENV" or name == nil then return i, val end
                i = i + 1
            end
        end

        _G.setfenv = function(f, t)
            local i = find_env(f)
            if i then debug.setupvalue(f, i, t) end
            return f
        end

        local function create_proxy(name)
            local proxy = {}
            setmetatable(proxy, {
                __index = function(t, k) return create_proxy(name .. "." .. tostring(k)) end,
                __call = function(t, ...) return create_proxy(name .. "()") end,
                __tostring = function() return name end,
                __len = function() return 0 end,
                __metatable = "Locked"
            })
            return proxy
        end

        local sandbox = {
            loadstring = function(c)
                _G.CAPTURED_RESULT = c
                return function() end 
            end,
            print = function(...) table.insert(_G.LOGS, "[PRINT]: " .. table.concat({...}, " ")) end,
            warn = function(...) table.insert(_G.LOGS, "[WARN]: " .. table.concat({...}, " ")) end,
            bit32 = bit32, string = string, math = math, table = table, debug = debug,
            pairs = pairs, ipairs = ipairs, next = next, type = type, 
            tostring = tostring, tonumber = tonumber, pcall = pcall, 
            xpcall = xpcall, select = select, unpack = unpack or table.unpack,
            game = create_proxy("game"),
            workspace = create_proxy("workspace"),
            script = create_proxy("script"),
            _G = {},
        }
        _G.sandbox_env = sandbox
        return sandbox
        """

        try:
            sandbox_env = self.lua.execute(setup_script)

            if bytecode_var and payload:
                sandbox_env[bytecode_var] = payload
                logs.append(f"-- [SYSTEM]: Переменная '{bytecode_var}' внедрена.")

            # Запуск с защитой
            runner = self.lua.eval("function(code, env) local f = load(code, 'src', 't', env) if f then return pcall(f) end return false, 'Load Error' end")
            
            success, error_msg = runner(code, sandbox_env)

            # Собираем логи Lua
            lua_logs = self.lua.globals().LOGS
            if lua_logs:
                for i in range(len(lua_logs)):
                    logs.append(str(lua_logs[i+1]))

            captured = self.lua.globals().CAPTURED_RESULT
            if captured:
                logs.append("\n" + "="*20 + " RESULT " + "="*20)
                logs.append(str(captured))
            elif not success:
                logs.append(f"\n[LUA ERROR]: {error_msg}")

        except Exception as e:
            logs.append(f"\n[ENGINE CRASH]: {e}")

        return "\n".join(logs)
