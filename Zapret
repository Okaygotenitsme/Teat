import lupa
from lupa import LuaRuntime
import logging
import subprocess
import os
import tempfile
import re
import binascii

# Логгер
logger = logging.getLogger("DeobfuscatorEngine")

class DeobfuscatorEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        logger.info(f"📁 Working Dir: {base_dir}")

    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        if not self._check_java():
            return b"-- [FATAL] Java is missing. Install Java to use unluac."

        update_status("🥷 Запуск стелс-режима (MoonSec Bypass V2)...")

        try:
            lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)
        except Exception as e:
            return f"-- [FATAL] Lua start error: {e}".encode('utf-8')

        # --- ХРАНИЛИЩА ДАННЫХ (В Python) ---
        captured_logs = []
        captured_strings = []
        captured_chunks = []
        
        # Python-функции, которые мы пробросим в Lua
        def py_log(msg):
            if len(captured_logs) < 500: captured_logs.append(str(msg))
        
        def py_capture_str(s):
            if isinstance(s, str) and len(s) > 4:
                captured_strings.append(s)
            return s

        def py_capture_chunk(chunk, name):
            if isinstance(chunk, (str, bytes)) and len(chunk) > 100:
                captured_chunks.append({"data": chunk, "name": name})
                py_log(f"💥 CAPTURED SCRIPT CHUNK ({len(chunk)} bytes)!")
            return chunk

        # --- LUA SETUP ---
        lua_globals = lua.globals()
        lua_globals.py_log = py_log
        lua_globals.py_capture_str = py_capture_str
        lua_globals.py_capture_chunk = py_capture_chunk

        setup_script = """
        -- [[ POLYFILLS FOR LUA 5.1 COMPATIBILITY ]] --
        -- Исправление ошибки 'getfenv is nil'
        if not getfenv then
            _G.getfenv = function(lvl) return _G end
            getfenv = _G.getfenv
        end
        if not setfenv then
            _G.setfenv = function(fn, env) return fn end
            setfenv = _G.setfenv
        end

        -- BIT32 (Критично для работы MoonSec)
        local bit = {}
        function bit.tobit(x) x = x % 4294967296; if x >= 2147483648 then x = x - 4294967296 end; return x end
        function bit.bnot(x) return 4294967295 - x % 4294967296 end
        local function bit_oper(a, b, oper)
            local r, m, s = 0, 2^31, nil
            repeat s,a,b = a+b+m, a%m, b%m; r,m = r + m*oper%(s-a-b), m/2 until m < 1
            return r
        end
        function bit.band(a, b) return bit_oper(a, b, 4) end
        function bit.bor(a, b)  return bit_oper(a, b, 1) end
        function bit.bxor(a, b) return bit_oper(a, b, 3) end
        function bit.lshift(a, b) return (a * 2^b) % 4294967296 end
        function bit.rshift(a, b) return math.floor(a / 2^b) % 4294967296 end
        
        local bit32 = {
            band = bit.band, bor = bit.bor, bxor = bit.bxor,
            lshift = bit.lshift, rshift = bit.rshift, bnot = bit.bnot
        }
        _G.bit = bit
        _G.bit32 = bit32
        package.loaded.bit = bit

        -- Hook load/loadstring
        local real_load = load
        local function hooked_load(chunk, name, ...)
            py_capture_chunk(chunk, tostring(name))
            -- Пытаемся загрузить чанк, чтобы он исполнился и распаковал следующий слой
            return real_load(chunk, name, ...)
        end
        _G.load = hooked_load
        _G.loadstring = hooked_load

        -- Hook string.char
        local real_char = string.char
        string.char = function(...)
            local res = real_char(...)
            if #res > 4 then py_capture_str(res) end
            return res
        end
        
        -- Hook table.concat
        local real_concat = table.concat
        table.concat = function(t, sep, i, j)
            local res = real_concat(t, sep, i, j)
            if #res > 50 then py_capture_str(res) end
            return res
        end

        -- Эмуляция Roblox
        _G.game = {
            GetService = function(s, n) 
                return {
                    LocalPlayer = {Name = "Player1", UserId = 123456},
                    HttpGet = function(s, u) py_log("HTTP GET: "..u); return "-- Lib" end
                } 
            end,
            HttpGet = function(s, u) py_log("HTTP GET: "..u); return "-- Lib" end
        }
        _G.workspace = {}
        _G.script = {Source = "..."}
        
        _G.getgenv = function() return _G end
        _G.getrenv = function() return _G end
        """

        try:
            update_status("🌪️ Исполнение байт-кода...")
            lua.execute(setup_script)
            
            runner = lua.eval("""
                function(code)
                    -- Безопасный вызов getfenv
                    local env = _G
                    if getfenv then env = getfenv() end
                    env.script = _G.script
                    
                    local f = load(code)
                    if not f then return "Load Error" end
                    
                    local success, err = pcall(f)
                    if not success then return "Runtime Error: " .. tostring(err) end
                    return "Completed"
                end
            """)
            
            status = runner(content)
            update_status(f"Статус VM: {status}")

            # --- АНАЛИЗ РЕЗУЛЬТАТОВ ---
            best_chunk = None
            max_size = 0
            
            for c in captured_chunks:
                if len(c['data']) > max_size:
                    max_size = len(c['data'])
                    best_chunk = c['data']
            
            if not best_chunk:
                for s in captured_strings:
                    if len(s) > max_size and ("local" in s or "function" in s or "return" in s):
                        max_size = len(s)
                        best_chunk = s

            target_code = best_chunk if best_chunk else content

            return self._finalize_output(target_code, captured_strings, captured_logs, update_status)

        except Exception as e:
            return f"-- [CRASH INTERNAL]: {str(e)}".encode('utf-8')

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _clean_string(self, s):
        if isinstance(s, bytes):
            try: return s.decode('utf-8')
            except: return str(s)
        return str(s)

    def _finalize_output(self, code_bytes, strings, logs, callback):
        if callback: callback("💅 Ренейминг переменных и форматирование...")
        
        decompiled = self._try_decompile(code_bytes)
        
        # --- HEADER (ВОТ ОН, ДОБАВЛЕН) ---
        final_text = "--[[Deobfuscated with using:\nhttp://t.me/Meloten_Deobfuscator_bot]]\n\n"
        
        final_text += "-- [[ REPORT ]] --\n"
        final_text += f"-- Captured Strings: {len(strings)}\n"
        final_text += f"-- Execution Logs: {len(logs)}\n\n"

        # --- CONSTANTS ---
        final_text += "-- [[ EXTRACTED CONSTANTS ]] --\n"
        unique_strings = sorted(list(set([self._clean_string(s).replace('\n', ' ') for s in strings])), key=len, reverse=True)
        for s in unique_strings[:50]:
            if len(s) > 3: final_text += f'-- "{s}"\n'
        
        final_text += "\n" + "="*50 + "\n\n"
        
        # --- SOURCE CODE ---
        src = ""
        if decompiled:
            try:
                src = decompiled.decode('utf-8', 'ignore')
            except:
                src = decompiled.decode('latin-1', 'ignore')
            final_text += "-- [[ DECOMPILED SOURCE (UNLUAC) ]] --\n\n"
        else:
            final_text += "-- [[ RAW DUMP (Decompilation Failed) ]] --\n\n"
            try:
                src = code_bytes.decode('utf-8')
            except:
                src = f"-- Binary Blob: {binascii.hexlify(code_bytes[:100])}..."
        
        # BEAUTIFIER & RENAMER
        if src and len(src) > 10:
            src = self._rename_variables(src)
            src = self._beautify_lua(src)
        
        final_text += src
        
        # --- LOGS ---
        final_text += "\n\n" + "="*50 + "\n-- [[ EXECUTION LOGS ]] --\n"
        for l in logs:
            final_text += f"-- {l}\n"

        return final_text.encode('utf-8')

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path): return None
        if isinstance(bytecode, bytes) and not bytecode.startswith(b'\x1bLua'):
            return None 

        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            res = subprocess.run(
                ["java", "-Xmx1G", "-jar", self.unluac_path, path], 
                capture_output=True, timeout=15
            )
            os.remove(path)
            if res.returncode == 0 and len(res.stdout) > 0: return res.stdout
            return None
        except: return None

    def _rename_variables(self, code):
        """Переименовывает мусорные переменные в var_1, func_2"""
        potential_vars = set(re.findall(r'\b[a-zA-Z_][a-zA-Z0-9_]{5,}\b', code))
        
        whitelist = {
            "string", "table", "math", "pairs", "ipairs", "tonumber", "tostring",
            "getmetatable", "setmetatable", "error", "pcall", "xpcall", "select",
            "unpack", "require", "game", "workspace", "script", "Instance", 
            "Vector3", "CFrame", "new", "Connect", "Wait", "Destroy", "Parent",
            "FindFirstChild", "WaitForChild", "GetService", "LocalPlayer",
            "loadstring", "getgenv", "getrenv", "bit32", "getfenv", "setfenv"
        }
        
        mapping = {}
        var_counter = 1
        func_counter = 1
        
        for var in potential_vars:
            if var in whitelist: continue
            
            if re.search(r'[a-z]', var) and re.search(r'[A-Z]', var):
                if re.search(rf'{re.escape(var)}\s*\(', code):
                    new_name = f"func_{func_counter}"
                    func_counter += 1
                else:
                    new_name = f"var_{var_counter}"
                    var_counter += 1
                
                mapping[var] = new_name

        sorted_vars = sorted(mapping.keys(), key=len, reverse=True)
        
        for old_name in sorted_vars:
            new_name = mapping[old_name]
            code = re.sub(rf'\b{re.escape(old_name)}\b', new_name, code)
            
        return code

    def _beautify_lua(self, source_code):
        source_code = re.sub(r'--\s*\[\[.*?\]\]', '', source_code, flags=re.DOTALL)
        source_code = re.sub(r'(\s)(local|return|if|for|while|repeat|function)(\s)', r'\n\2 ', source_code)
        
        replacements = {
            " then ": " then\n", " do ": " do\n", " end ": "\nend\n",
            " repeat ": "\nrepeat\n", " until ": "\nuntil ", ";": "\n"
        }
        for k, v in replacements.items():
            source_code = source_code.replace(k, v)
        
        lines = source_code.splitlines()
        formatted = []
        indent = 0
        for line in lines:
            line = line.strip()
            if not line: continue
            if line.startswith("--"): formatted.append(line); continue
            
            if line.startswith(("end", "until", "}", "]", ")", "else", "elseif")):
                indent = max(0, indent - 1)
            
            formatted.append("\t" * indent + line)
            
            if line.endswith(("then", "do", "repeat", "{", "(")) or \
               ("function" in line and not line.endswith("end")):
                indent += 1
            if line.startswith(("else", "elseif")):
                indent += 1
                
        return "\n".join(formatted)
