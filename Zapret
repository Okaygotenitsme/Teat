@bot.callback_query_handler(func=lambda call: True)
def callback_query(call):
    chat_id = call.message.chat.id
    if chat_id not in user_files:
        bot.answer_callback_query(call.id, "Ошибка: Файл утерян")
        return

    source_code = user_files[chat_id]
    
    # ШАГ 1: ПРОВЕРКА КОДА (LUA VALIDATOR)
    is_valid, error_msg = check_lua_syntax(source_code)
    
    if not is_valid:
        bot.edit_message_text(f"❌ **Скрипт не рабочий, перепишите!**\n\nПричина: {error_msg}", chat_id, call.message.message_id)
        del user_files[chat_id]
        return

    # ШАГ 2: ОБФУСКАЦИЯ
    try:
        protected = build_vm_v11(source_code, call.data)
        out_name = f"Meloten_v11_{call.data}.lua"
        with open(out_name, "w", encoding="utf-8") as f:
            f.write(protected)
        
        with open(out_name, "rb") as f:
            bot.send_document(chat_id, f, caption=f"✅ Защита V11 наложена.\nОшибок в синтаксисе не обнаружено.")
        
        os.remove(out_name)
    except Exception as e:
        bot.send_message(chat_id, f"Ошибка обфускации: {e}")
    
    del user_files[chat_id]

