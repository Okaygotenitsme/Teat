@dp.message(Command("start"))
async def start(message: types.Message):
    await message.answer(
        "✨ **Meloten Obfuscator V4 (MoonSec Style)**\n\n"
        "Я превращу твой код в защищенную VM-структуру с запутанным потоком управления.\n\n"
        "Отправь .lua или .txt файл.",
        parse_mode="Markdown"
    )

@dp.message(F.document)
async def handle_file(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        await message.answer("❌ Ошибка! Нужен файл .lua или .txt")
        return

    msg = await message.answer("⚙️ Генерация VM байткода и запутывание потоков...")
    
    try:
        file_info = await bot.get_file(message.document.file_id)
        file_content = await bot.download_file(file_info.file_path)
        source = file_content.read().decode('utf-8', errors='ignore')

        obf = MelotenObfuscator(source)
        final_code = obf.build()

        output = BufferedInputFile(
            final_code.encode('utf-8'), 
            filename=f"Protected_{message.document.file_name}"
        )
        
        await message.answer_document(output, caption="✅ Защита уровня 'MoonSec Style' применена.")
        await msg.delete()
        
    except Exception as e:
        await message.answer(f"❌ Ошибка: {e}")

