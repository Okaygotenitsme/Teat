# Обработчик команды /ASCII (должен быть ответом на видео)
@dp.message(Command("ASCII"))
async def ascii_convert(message: types.Message):
    # Проверяем, является ли сообщение ответом (reply)
    if not message.reply_to_message:
        await message.answer("❌ Эту команду нужно писать **в ответ** на видео!")
        return
    
    # Проверяем, есть ли видео в отвеченном сообщении
    video = message.reply_to_message.video or message.reply_to_message.animation
    if not video:
        await message.answer("❌ В сообщении, на которое ты ответил, нет видео.")
        return

    status_msg = await message.answer("⏳ Скачиваю видео и готовлю магию...")
    
    # Скачивание файла во временную папку
    file_id = video.file_id
    file = await bot.get_file(file_id)
    file_path = file.file_path
    
    temp_filename = f"temp_{video.file_id}.mp4"
    await bot.download_file(file_path, temp_filename)
    
    await status_msg.edit_text("🎬 Запускаю анимацию...")
    
    # Запуск процесса анимации
    await process_video_animation(temp_filename, status_msg)


# Обработчик файлов для обфускации
@dp.message(F.document)
async def handle_file_obfuscation(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        # Если это не луа и не команда ascii, просто игнорим или пишем ошибку
        return

    msg = await message.answer("🛡 Виртуализация...")
    
    try:
        file_info = await bot.get_file(message.document.file_id)
        file_content = await bot.download_file(file_info.file_path)
        source = file_content.read().decode('utf-8', errors='ignore')

        obf = MelotenObfuscator(source)
        final_code = obf.build()

        output = BufferedInputFile(
            final_code.encode('utf-8'), 
            filename=f"Meloten_{message.document.file_name}"
        )
        
        await message.answer_document(output, caption="✅ Готово!")
        await msg.delete()
        
    except Exception as e:
        await message.answer(f"❌ Ошибка: {e}")

