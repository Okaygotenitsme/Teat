@dp.message(Command("ban"))
async def ban_command(message: types.Message):
    # 1. Проверяем, что пишет владелец
    if message.from_user.username != ADMIN_USERNAME:
        return # Игнорируем обычных юзеров
    
    # 2. Проверяем, что это ответ на сообщение
    if not message.reply_to_message:
        await message.reply("⚠️ Эту команду нужно писать в ответ на сообщение нарушителя.")
        return

    # 3. Баним
    try:
        user_to_ban = message.reply_to_message.from_user
        await bot.ban_chat_member(chat_id=message.chat.id, user_id=user_to_ban.id)
        await message.answer(f"🚫 Пользователь {user_to_ban.full_name} был заблокирован.")
    except Exception as e:
        await message.answer(f"❌ Не удалось забанить: {e}")

