@dp.message(Command("loadstring"))
async def make_loadstring(message: types.Message, command: CommandObject):
    if not command.args:
        await message.answer("⚠️ Пример: `/loadstring https://raw.github...`")
        return

    url = command.args.strip()
    content = f'loadstring(game:HttpGet("{url}"))()'
    
    file_output = BufferedInputFile(
        content.encode('utf-8'), 
        filename="loader.lua"
    )
    
    await message.answer_document(
        file_output, 
        caption=f"✅ **Loadstring сгенерирован**", 
        parse_mode="Markdown"
    )

@dp.message(F.text)
async def meow_handler(message: types.Message):
    if message.text.startswith("/"): return
    
    text = message.text.lower()
    if "meow" in text or "мяу" in text:
        count = random.randint(1, 10)
        await message.answer(" ".join(["meow"] * count))

@dp.message(F.document)
async def handle_docs(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        return

    status = await message.answer("🔒 **Защита V6 (Rolling Key)...**", parse_mode="Markdown")
    try:
        file_info = await bot.get_file(message.document.file_id)
        file_content = await bot.download_file(file_info.file_path)
        source = file_content.read().decode('utf-8', errors='ignore')

        # Обфускация V6
        obf = MelotenObfuscatorV6(source)
        protected_code = obf.build()

        output = BufferedInputFile(
            protected_code.encode('utf-8'), 
            filename=f"Protected_{message.document.file_name}"
        )
        
        await message.answer_document(
            output, 
            caption="✅ **Скрипт защищен (V6)!**\nМетод: Rolling Key Encryption + Junk Code.\n\nКоманды: /help",
        )
        await status.delete()
        del source, protected_code
        
    except Exception as e:
        logging.error(e)
        await message.answer(f"❌ Ошибка: {e}")

