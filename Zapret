import re
import base64

class DeobfuscatorEngine:
    def process_text(self, content):
        """Основной метод обработки"""
        # Проверяем, какой перед нами обфускатор
        if "MoonSec V3" in content:
            return self.analyze_moonsec(content)
        elif "Luraph Obfuscator" in content:
            return self.analyze_luraph(content)
        else:
            return self.generic_analyze(content)

    def analyze_moonsec(self, content):
        """Специфичный разбор для MoonSec"""
        report = ["-- [[ MoonSec V3 Analysis Report ]] --\n"]
        
        # 1. Извлечение зашифрованного байт-кода из gsub
        # В MoonSec байт-код обычно в первой строке: (([[...]])):gsub(...)
        bytecode_match = re.search(r"\(\[\[(.*?)\]\]\)", content, re.DOTALL)
        if bytecode_match:
            bytecode = bytecode_match.group(1)
            report.append(f"-- [!] Обнаружен байт-код (Длина: {len(bytecode)})")
        
        # 2. Поиск констант
        report.append("\n-- [[ Extracted Constants ]]")
        report.append(self.extract_strings(content))
        
        # 3. Генерируем Hook-скрипт для Roblox
        report.append("\n" + self.generate_roblox_hook())
        
        return "\n".join(report)

    def analyze_luraph(self, content):
        """Специфичный разбор для Luraph (как в sunjingwoo.txt)"""
        report = ["-- [[ Luraph v14.3 Analysis Report ]] --\n"]
        
        # В Luraph данные часто лежат в переменных типа xp = ({...})
        # Ищем большие таблицы с числами
        tables = re.findall(r"\{(\d+(?:,\s*\d+){20,})\}", content)
        if tables:
            report.append(f"-- [!] Найдено таблиц с данными: {len(tables)}")
        
        report.append("\n-- [[ Extracted Constants ]]")
        report.append(self.extract_strings(content))
        report.append("\n" + self.generate_roblox_hook())
        
        return "\n".join(report)

    def extract_strings(self, content):
        """Поиск всех строковых литералов"""
        # Ищем строки в кавычках и Lua-эскейп последовательности (\123)
        strings = re.findall(r'"(.*?)"|\'(.*?)\'', content)
        found = []
        for s in strings:
            val = s[0] or s[1]
            if len(val) > 3 and not val.startswith("http"):
                found.append(f"const = \"{val}\"")
        return "\n".join(set(found[:50])) # Топ 50 уникальных строк

    def generate_roblox_hook(self):
        """Создает код, который нужно запустить в Roblox Executor"""
        return """
-- [[ ROBLOX DYNAMIC HOOK ]] --
-- Запусти этот код ПЕРЕД обфусцированным скриптом в своем исполнителе.

local function hookLog(name, ...)
    print("[HOOKED] " .. name .. " called with:", ...)
end

local old_getgenv = getgenv or function() return _G end
local env = old_getgenv()

-- Перехватываем стандартные функции, которые используют обфускаторы
local targets = {"loadstring", "print", "warn", "setclipboard", "http_request"}

for _, name in pairs(targets) do
    if env[name] then
        local old = env[name]
        env[name] = function(...)
            hookLog(name, ...)
            return old(...)
        end
    end
end
print("--- [!] Hooking Active. Now run the obfuscated script! ---")
"""

    def generic_analyze(self, content):
        return "-- [?] Тип не определен\n" + self.extract_strings(content)
