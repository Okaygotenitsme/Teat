        # Windows fix для event loop
        if os.name == 'nt':
            asyncio.set_event_loop_policy(asyncio.WindowsSelectorEventLoopPolicy())
        
        # Запуск
        asyncio.run(main())
        
    except KeyboardInterrupt:
