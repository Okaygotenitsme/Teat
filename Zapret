class MelotenObfuscator:
    def __init__(self, source):
        self.source = source
        self.var_table = {}  # Хранилище имен переменных

    def _get_var(self, key):
        """Генерирует или возвращает уже созданное имя переменной (lIl1l...)"""
        if key not in self.var_table:
            # Генерация имен в стиле MoonSec (l + рандомные lI1)
            length = random.randint(4, 10)
            name = "l" + "".join(random.choice("lI1") for _ in range(length))
            self.var_table[key] = name
        return self.var_table[key]

    def _generate_junk_math(self):
        """Генерирует бессмысленную математику, как в Source 2"""
        v_e = self._get_var('e')
        ops = ['+', '-', '*', '%']
        val = random.randint(100, 9999)
        mod = random.randint(1000, 99999)
        return f"{v_e}=({v_e}{random.choice(ops)}{val})%{mod};"

    def build(self):
        # 1. Сжатие и шифрование исходного кода
        # Мы разбиваем код на чанки и шифруем каждый байт
        key = random.randint(150, 255)
        bytecode = []
        for char in self.source:
            # Сложное преобразование байтов (XOR + смещение)
            val = (ord(char) ^ key) + 5
            bytecode.append(str(val))
        
        payload = "{" + ",".join(bytecode) + "}"

        # 2. Имена переменных для VM
        v_vm_func = self._get_var("vm_entry")
        v_str_char = self._get_var("str_char")
        v_str_byte = self._get_var("str_byte")
        v_table_concat = self._get_var("tbl_concat")
        v_bytecode = self._get_var("bytecode")
        v_idx = self._get_var("idx")
        v_decrypted = self._get_var("decrypted_table")
        v_key = self._get_var("key")
        v_char = self._get_var("char")
        v_state = self._get_var("state") # Переменная состояния для Control Flow
        v_e = self._get_var("e") # Мусорная переменная для математики

        # 3. Генерация заголовка (имитация MoonSec)
        lua_code = f"--[[This file was protected with Meloten V4 (MoonSec Style)]]\n"
        
        # 4. Основное тело обфускации (Control Flow Flattening)
        # Мы создаем цикл while, который прыгает по состояниям
        
        lua_code += (
            f"local {v_str_char} = string.char;"
            f"local {v_table_concat} = table.concat;"
            f"local {v_bytecode} = {payload};"
            f"local {v_key} = {key};"
            f"return (function(...)"
            f"local {v_state} = 1;" # Начальное состояние
            f"local {v_e} = {random.randint(10000, 99999)};" # Переменная для "мусорной" математики
            f"local {v_idx} = 1;"
            f"local {v_decrypted} = {{}};"
            f"while {v_state} ~= 0 do " # Главный цикл VM
        )

        # Блок 1: Мусорная математика (имитация Source 2)
        lua_code += f"if {v_state} == 1 then "
        for _ in range(random.randint(2, 5)):
            lua_code += self._generate_junk_math()
        lua_code += f"{v_state} = 2; end;"

        # Блок 2: Еще мусор + переход к дешифровке
        lua_code += f"if {v_state} == 2 then "
        lua_code += f"while {v_idx} <= #{v_bytecode} do "
        lua_code += self._generate_junk_math() # Шум внутри цикла
        
        # Логика дешифровки (обратная той, что в Python)
        lua_code += (
            f"local {v_char} = {v_bytecode}[{v_idx}];"
            f"{v_char} = ({v_char} - 5);"
            # Используем bit32 если есть, или эмуляцию XOR для совместимости 5.1+
            f"if bit32 then {v_char} = bit32.bxor({v_char}, {v_key}) "
            f"else {v_char} = ({v_char} ~ {v_key}) end;" # Lua 5.3+ использует ~ для XOR
            f"{v_decrypted}[{v_idx}] = {v_str_char}({v_char});"
            f"{v_idx} = {v_idx} + 1;"
        )
        lua_code += f"end; {v_state} = 3; end;"

        # Блок 3: Финализация и запуск
        lua_code += f"if {v_state} == 3 then "
        lua_code += f"local {v_vm_func} = loadstring({v_table_concat}({v_decrypted}));"
        lua_code += f"{v_state} = 0;" # Выход из цикла while
        lua_code += f"return {v_vm_func}(...); end;"
        
        # Закрытие цикла while и функции
        lua_code += "end end)(...)"

        return lua_code

