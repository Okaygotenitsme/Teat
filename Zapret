@dp.message(F.document)
async def handle_file_upload(message: types.Message):
    # принимаем только .lua и .txt
    if not message.document.file_name.endswith(('.lua', '.txt')):
        return

    # скачиваем файл
    file_info = await bot.get_file(message.document.file_id)
    downloaded = await bot.download_file(file_info.file_path)
    try:
        src = downloaded.read().decode('utf-8', errors='ignore')
    except:
        # fallback
        src = downloaded.read().decode(errors='ignore')

    token = str(uuid.uuid4())
    _pending_files[token] = {
        "source": src,
        "filename": message.document.file_name,
        "user_id": message.from_user.id,
        "uploaded_at": time.time()
    }

    kb = make_file_keyboard(token)
    await message.answer("Файл получен. Выберите действие:", reply_markup=kb)


@dp.callback_query(Text(startswith="filecb:"))
async def on_file_action(callback: types.CallbackQuery):
    await callback.answer()  # чтобы убрать "в ожидании"
    data = callback.data  # формат: filecb:{token}:{action}
    try:
        _, token, action = data.split(":", 2)
    except:
        await callback.message.answer("Ошибка: некорректные данные.")
        return

    if token not in _pending_files:
        await callback.message.answer("Время ожидания истекло или файл не найден. Пожалуйста, загрузите файл снова.")
        return

    record = _pending_files.pop(token)
    src = record["source"]
    filename = record["filename"]
    uid = record["user_id"]

    # Получаем слои пользователя
    layers = user_settings.get(uid, 1)
    # Если пользователь нажал Beautify
    if action == "beaut":
        await callback.message.answer("✨ Форматирую код...")
        try:
            beaut = LuaBeautifier(src)
            formatted_code = beaut.format()
            out = BufferedInputFile(formatted_code.encode(), filename=f"Beautified_{filename}")
            await callback.message.answer_document(out, caption="✨ Код отформатирован.")
        except Exception as e:
            await callback.message.answer(f"❌ Ошибка при форматировании: {e}")
        return

    # Если Obfuscate
    if action == "obf":
        await callback.message.answer(f"☢️ Начинаю обфускацию (уровни: {layers})...")
        try:
            obf = MelotenObfuscatorV12(src, layers=layers)
            protected_code = obf.build()
            out = BufferedInputFile(protected_code.encode(), filename=f"Protected_{filename}")
            # caption — НЕ содержит ссылок и не раскрывает бот-линк (он внутри файла)
            caption_text = f"✅ Готово: Protected_{filename}\n🛡 Layers: {layers}"
            await callback.message.answer_document(out, caption=caption_text)
        except Exception as e:
            logging.exception(e)
            await callback.message.answer(f"❌ Ошибка обфускации: {e}")
        return

    # unknown action
    await callback.message.answer("Неизвестное действие.")


# ------------------ периодическая чистка устаревших pending файлов ------------------
async def _cleanup_pending():
    while True:
        now = time.time()
        expired = [k for k, v in _pending_files.items() if now - v["uploaded_at"] > 600]  # 10 минут
        for k in expired:
            _pending_files.pop(k, None)
        await asyncio.sleep(60)


# ------------------ main ------------------
async def main():
    logging.info("Starting Meloten V12 Bot")
    # запустим таск очистки
    asyncio.create_task(_cleanup_pending())
    await dp.start_polling(bot)


if __name__ == "__main__":
    try:
