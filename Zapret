-- ServerScriptService/UnitAI (ModuleScript)
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UnitAI = {}

-- Функция для получения атрибута или значения по умолчанию
local function getStat(model, name, default)
	local attr = model:GetAttribute(name)
	if attr ~= nil then return attr end
	return default
end

local function findEnemies(selfModel, myOwner)
	local out = {}
	local spawned = Workspace:FindFirstChild("SpawnedUnits")
	if not spawned then return out end
	for _, m in ipairs(spawned:GetChildren()) do
		if m ~= selfModel and m:IsA("Model") and m.PrimaryPart then
			local o = m:FindFirstChild("Owner")
			if o and o.Value ~= myOwner then table.insert(out, m) end
		end
	end
	return out
end

local function findEnemyTowers(myOwner)
	local out = {}
	local towers = Workspace:FindFirstChild("Towers")
	if not towers then 
		warn("ПАПКА TOWERS НЕ НАЙДЕНА В WORKSPACE!")
		return out 
	end
	
	for _, t in ipairs(towers:GetChildren()) do
		if t:IsA("Model") and t.PrimaryPart then
			local o = t:FindFirstChild("Owner")
			if not o or o.Value ~= myOwner then
				table.insert(out, t)
			end
		end
	end
	return out
end

local function nearest(model, list)
	if not model.PrimaryPart then return nil, math.huge end
	local pos = model.PrimaryPart.Position
	local best, bestDist = nil, math.huge
	for _, m in ipairs(list) do
		local d = (m.PrimaryPart.Position - pos).Magnitude
		if d < bestDist then bestDist = d; best = m end
	end
	return best, bestDist
end

local function movePart(part, targetPos, speed, dt)
	local cur = part.Position
	local dir = (targetPos - cur) * Vector3.new(1, 0, 1) -- Движение только по X и Z
	if dir.Magnitude < 0.2 then return end
	
	local nextPos = cur + dir.Unit * speed * dt
	part.CFrame = CFrame.new(nextPos, nextPos + dir.Unit)
end

function UnitAI.Attach(unitModel)
	-- ЧИТАЕМ ТВОИ АТРИБУТЫ
	local Damage = getStat(unitModel, "Damage", 10)
	local Speed = getStat(unitModel, "Speed", 16) -- ДОБАВЬ ЭТОТ АТРИБУТ!
	local Range = getStat(unitModel, "Range", 8)
	local AttackSpeed = getStat(unitModel, "AttackSpeed", 1)
	local myOwner = ""
	local ownerObj = unitModel:WaitForChild("Owner", 5)
	if ownerObj then myOwner = ownerObj.Value end

	local primary = unitModel.PrimaryPart
	local lastAttackTime = 0
	local active = false
	
	-- Небольшая задержка перед активацией (SpawnSpeed)
	task.delay(getStat(unitModel, "SpawnSpeed", 0.5), function() active = true end)

	local conn
	conn = RunService.Heartbeat:Connect(function(dt)
		if not unitModel.Parent then conn:Disconnect(); return end
		
		-- Проверка здоровья (используем атрибут Health)
		local currentHealth = unitModel:GetAttribute("Health") or 0
		if currentHealth <= 0 then
			conn:Disconnect()
			unitModel:Destroy()
			return
		end

		if not active or not primary then return end

		-- Поиск цели
		local targets = findEnemies(unitModel, myOwner)
		local target, dist = nearest(unitModel, targets)

		if not target then
			local towers = findEnemyTowers(myOwner)
			target, dist = nearest(unitModel, towers)
		end

		-- Логика
		if target and target.PrimaryPart then
			if dist <= Range then
				-- АТАКА
				if tick() - lastAttackTime >= AttackSpeed then
					lastAttackTime = tick()
					-- Уменьшаем здоровье через атрибут цели
					local tHealth = target:GetAttribute("Health")
					if tHealth then
						target:SetAttribute("Health", tHealth - Damage)
					end
				end
			else
				-- ДВИЖЕНИЕ
				movePart(primary, target.PrimaryPart.Position, Speed, dt)
			end
		end
	end)
end

return UnitAI
