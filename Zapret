        # Переменные с запутанными именами
        var_pc = self._rand_str()
        var_key = self._rand_str()
        var_out = self._rand_str()
        var_op = self._rand_str()
        
        # Шаблон VM
        lua = f"""
        local {var_pc} = 1
        local {var_key} = {self.xor_key}
        local {var_out} = {{}}
        
        while true do
            local {var_op} = OP_TABLE[{var_pc}]
            {var_pc} = {var_pc} + 1
            
            if {var_op} == {self.OP_END} then
                break
            elseif {var_op} == {self.OP_ADD} then
                -- APPEND BYTE
                local len = OP_TABLE[{var_pc}]
                {var_pc} = {var_pc} + 1
                for i=1, len do
                    local val = OP_TABLE[{var_pc}]
                    {var_pc} = {var_pc} + 1
                    local dec = bit32.bxor(val, bit32.band({var_key}, 255))
                    table.insert({var_out}, string.char(dec))
                    -- Mutate key
                    {var_key} = bit32.bxor({var_key}, dec * 1664525 + 1013904223)
                end
            elseif {var_op} == {self.OP_XOR} then
                -- MUTATE KEY DIRECTLY
                local delta = OP_TABLE[{var_pc}]
                {var_pc} = {var_pc} + 1
                {var_key} = bit32.bxor({var_key}, delta)
            elseif {var_op} == {self.OP_JUNK} then
                -- JUNK CODE execution
                local cnt = OP_TABLE[{var_pc}]
                {var_pc} = {var_pc} + 1
                local _ = 0
                for j=1, cnt do _ = _ + j end
            end
        end
        return table.concat({var_out})
        """
        return lua

    def build(self) -> str:
        # 1. Превращаем исходный код в байты
        src_bytes = self.source.encode('utf-8')
        
        # 2. Генерируем поток опкодов (Bytecode Stream)
        ops = []
        
        # Разбиваем на чанки
        chunk_size = random.randint(5, 15)
        current_key = self.xor_key
        
        for i in range(0, len(src_bytes), chunk_size):
            chunk = src_bytes[i:i+chunk_size]
            
            # Вставляем мусорные инструкции случайно
            if random.random() > 0.7:
                ops.append(self.OP_JUNK)
                ops.append(random.randint(1, 10)) # loop count
            
            # Реальные данные
            ops.append(self.OP_ADD)
            ops.append(len(chunk))
            
            for byte in chunk:
                # XOR-им байт текущим ключом перед записью
                enc_byte = byte ^ (current_key & 0xFF)
                ops.append(enc_byte)
                # Симулируем мутацию ключа, чтобы Python знал правильный ключ для следующего байта
                current_key = (current_key ^ (byte * 1664525 + 1013904223)) & 0xFFFFFFFF

            # Иногда добавляем прямую мутацию ключа
            if random.random() > 0.8:
                delta = random.randint(1, 0xFFFFFF)
                ops.append(self.OP_XOR)
                ops.append(delta)
                current_key = (current_key ^ delta) & 0xFFFFFFFF

        ops.append(self.OP_END)

        # 3. Lua обертка
        ops_str = "{" + ",".join(map(str, ops)) + "}"
        vm_body = self._generate_vm_body(ops)
        
        load_func = self._encrypt_string("loadstring") # Прячем "loadstring"
        
        # Финальный шаблон
        final_lua = f"""
--[[ Meloten ULTRA Protection (v2.0) ]]
local bit32 = bit32 or require('bit') -- Fallback for LuaJIT
local OP_TABLE = {ops_str}
local function VM_ENTRY()
    {vm_body}
end

local function anti_tamper()
    if not ({load_func}) then return function() end end
    return ({load_func})(VM_ENTRY())
end

local s, r = pcall(anti_tamper)
if s and r then pcall(r) end
        """
        
        # Минификация (удаление лишних пробелов и энтеров)
        minified = "\n".join([line.strip() for line in final_lua.splitlines() if line.strip()])
        return minified

