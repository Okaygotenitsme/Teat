-- Путь к твоему RemoteEvent
local Remote = game.ReplicatedStorage:WaitForChild("AdminRemote")

Remote.OnServerEvent:Connect(function(player, code)
    print("Игрок " .. player.Name .. " запустил код!")
    
    -- Выполняем присланный текст как код
    local success, err = pcall(function()
        local func = loadstring(code)
        if func then
            func()
        else
            error("Синтаксическая ошибка в коде")
        end
    end)
    
    if not success then
        warn("Ошибка при выполнении: " .. tostring(err))
    end
end)
