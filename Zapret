import asyncio
import os
import logging
import uuid
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command
from engine import DeobfuscatorEngine

# --- НАСТРОЙКИ ---
API_TOKEN = 'ТВОЙ_ТОКЕН_ЗДЕСЬ' 

# Логгер
logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(levelname)s - %(message)s")
logger = logging.getLogger("BotCore")

bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "🔮 **Lua Deobfuscator V3 (Terminator)**\n\n"
        "Я умею вскрывать:\n"
        "🦠 MoonSec V2/V3\n"
        "🦠 IronBrew\n"
        "🦠 Luraph\n"
        "🦠 PSU Obfuscator\n\n"
        "📤 **Отправь мне .lua или .txt файл.**\n"
        "Я запущу его в эмуляторе и просканирую память на наличие ссылок, скриптов и ключей.",
        parse_mode="Markdown"
    )

@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    unique_id = uuid.uuid4().hex[:6]
    file_name = message.document.file_name or "script.lua"
    
    # Пути
    input_path = f"temp_{unique_id}.lua"
    output_path = f"Deobf_{unique_id}_{file_name}.txt"

    status_msg = await message.answer("📥 **Скачиваю файл...**", parse_mode="Markdown")
    
    try:
        # 1. Скачивание
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)
        
        with open(input_path, "rb") as f: content = f.read()

        # Получаем текущий цикл событий
        loop = asyncio.get_running_loop()
        last_text = [""] # Используем список для mutable замыкания
        
        # --- ИСПРАВЛЕННЫЙ КОЛБЭК ---
        def status_callback(text):
            # Эта функция выполняется в фоновом потоке
            if text == last_text[0]: return
            last_text[0] = text
            
            # Если цикл событий закрыт, выходим
            if loop.is_closed(): return
            
            # Создаем корутину-обертку. Это исправляет ошибку "coroutine object required"
            async def _updater():
                try:
                    # Игнорируем ошибки, если сообщение не изменилось
                    await status_msg.edit_text(f"⚙️ {text}")
                except Exception:
                    pass 

            # Безопасно передаем корутину в главный поток
            asyncio.run_coroutine_threadsafe(_updater(), loop)
        # -----------------------------

        # 2. ЗАПУСК ДВИЖКА
        await status_msg.edit_text("🌪️ **Запуск движка V3...**")
        
        # Запускаем синхронную функцию engine.process в пуле потоков
        # Тайм-аут 3 минуты (180 секунд)
        result_data = await asyncio.wait_for(
            loop.run_in_executor(None, engine.process, content, status_callback),
            timeout=180.0
        )

        # 3. Отправка результата
        with open(output_path, "wb") as f: f.write(result_data)
        out_file = FSInputFile(output_path)
        
        caption = "✅ **Готово!**\n"
        if b"INTERCEPTED URLS" in result_data: caption += "⚠️ Найдены HTTP ссылки!\n"
        if b"DECOMPILED SOURCE" in result_data: caption += "📜 Код декомпилирован.\n"
        else: caption += "🧱 Код в VM, строки извлечены."

        await message.answer_document(out_file, caption=caption)

    except asyncio.TimeoutError:
        await status_msg.edit_text("⏱ **Тайм-аут:** Скрипт выполнялся слишком долго.")
    except Exception as e:
        logger.error(f"Error handling file: {e}")
        try:
            await status_msg.edit_text(f"❌ Критическая ошибка: {str(e)[:50]}")
        except: pass
    finally:
        # Уборка мусора
        for p in [input_path, output_path]:
            if os.path.exists(p): 
                try: os.remove(p)
                except: pass

async def main():
    # Очистка вебхуков перед запуском
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    # Фикс для Windows
    if os.name == 'nt':
        asyncio.set_event_loop_policy(asyncio.WindowsSelectorEventLoopPolicy())
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("Бот выключен.")
