        for b in raw_bytes:
            # Шифруем: (Байт + Ключ) % 255
            encrypted_byte = (b + current_key) % 256
            enc_data.append(encrypted_byte)
            # Обновляем ключ для следующего байта (Rolling)
            current_key = (current_key * 1664525 + 1013904223) % 4294967296 # Линейный конгруэнтный метод
            current_key = int(current_key % 255)

        # Превращаем данные в строку таблицы Lua: {12, 55, 23...}
        table_str = "{" + ",".join(map(str, enc_data)) + "}"

        # 3. Создаем загрузчик (Loader)
        loader = f"""--[[ 
