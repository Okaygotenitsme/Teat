async def _process_file_callback(callback: types.CallbackQuery):
    data = callback.data
    try:
        _, token, action = data.split(":", 2)
    except Exception:
        await bot.send_message(callback.from_user.id, "Ошибка: некорректные данные.")
        return

    if token not in _pending_files:
        await bot.send_message(callback.from_user.id, "Время ожидания истекло или файл не найден. Пожалуйста, загрузите файл снова.")
        return

    record = _pending_files.pop(token)
    src = record["source"]
    filename = record["filename"]
    uid = record["user_id"]
    layers = user_settings.get(uid, 1)

    if action == "beaut":
        try:
            beaut = LuaBeautifier(src)
            formatted_code = beaut.format()
            out = BufferedInputFile(formatted_code.encode(), filename=f"Beautified_{filename}")
            await bot.send_document(uid, out, caption="✨ Код отформатирован.")
        except Exception as e:
            await bot.send_message(uid, f"❌ Ошибка при форматировании: {e}")
        return

    if action == "obf":
        try:
            await bot.send_message(uid, f"☢️ Начинаю обфускацию (уровни: {layers})...")
            obf = MelotenObfuscatorV13(src, layers=layers)
            protected_code = obf.build()
            out = BufferedInputFile(protected_code.encode(), filename=f"Protected_{filename}")
            caption_text = f"✅ Готово: Protected_{filename}\n🛡 Layers: {layers}"
            await bot.send_document(uid, out, caption=caption_text)
        except Exception as e:
            logging.exception(e)
            await bot.send_message(uid, f"❌ Ошибка обфускации: {e}")
        return

    await bot.send_message(uid, "Неизвестное действие.")


# cleanup pending
async def _cleanup_pending():
    while True:
        now = time.time()
        expired = [k for k, v in _pending_files.items() if now - v["uploaded_at"] > 600]
        for k in expired:
            _pending_files.pop(k, None)
        await asyncio.sleep(60)


async def main():
    logging.info("Starting Meloten V13 Bot (fixed)")
    asyncio.create_task(_cleanup_pending())
    await dp.start_polling(bot)


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except (KeyboardInterrupt, SystemExit):
