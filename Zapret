    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _clean_string(self, s):
        if isinstance(s, bytes):
            try: return s.decode('utf-8')
            except: return str(s)
        return str(s)

    def _finalize_output(self, code_bytes, strings, globals_dump, logs, callback):
        """Собирает финальный отчет"""
        
        # 1. Попытка декомпиляции (если это байткод)
        is_bytecode = code_bytes.strip().startswith(b'\x1bLua')
        decompiled = None
        
        if is_bytecode:
            if callback: callback("🧬 Обнаружен байткод, запускаю unluac...")
            decompiled = self._try_decompile(code_bytes)
        else:
            # Если это текст, считаем что это уже исходник
            if isinstance(code_bytes, str):
                decompiled = code_bytes.encode('utf-8')
            else:
                try: decompiled = code_bytes.decode('utf-8').encode('utf-8')
                except: pass # Binary trash
        
        final_text = ""
        
        # --- HEADER 1: INFO ---
        final_text += f"-- [[ ROBLOX DEOBFUSCATOR REPORT ]] --\n"
        final_text += f"-- Captured {len(strings)} strings, {len(logs)} events.\n\n"

        # --- HEADER 2: LOGS (Переместил вверх, это интереснее) ---
        final_text += "-- [[ EXECUTION LOG ]] --\n"
        final_text += "-- What the script tried to do (Network, FileSystem, API):\n"
        for l in logs: 
            final_text += f"-- {self._clean_string(l)}\n"
        final_text += "\n"

        # --- HEADER 3: STRINGS ---
        final_text += "-- [[ DECRYPTED STRINGS ]] --\n"
        sorted_strings = sorted(strings, key=lambda x: len(str(x)), reverse=True)
        seen = set()
        for s in sorted_strings:
            clean = self._clean_string(s).replace('\n', ' ').replace('\r', '')
            if clean not in seen and len(clean) > 2: # Фильтр мусора
                final_text += f'-- "{clean}"\n'
                seen.add(clean)
        final_text += "\n"

        # --- HEADER 4: GLOBALS ---
        if globals_dump:
            final_text += "-- [[ VARIABLE DUMP ]] --\n"
            # Сортируем
            globals_dump.sort()
            for g in globals_dump:
                final_text += f"-- {self._clean_string(g)}\n"
        final_text += "\n" + "="*50 + "\n\n"
        
        # --- BODY: CODE ---
        if decompiled:
            if callback: callback("💅 Форматирование результата...")
            try:
                src = decompiled.decode('utf-8', 'ignore')
            except:
                src = decompiled.decode('latin-1', 'ignore')
            
            src = self._beautify_lua(src)
            final_text += "-- [[ SOURCE CODE ]] --\n\n"
            final_text += src
        else:
            final_text += "-- [WARNING] Could not decompile or read source.\n"
            final_text += f"-- Raw Hex Preview: {str(binascii.hexlify(code_bytes[:64]))}..."

        return final_text.encode('utf-8')

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path): return None
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            # Увеличенный стек для unluac, так как обфусцированный код имеет глубокую вложенность
            res = subprocess.run(
                ["java", "-Xss50m", "-Xmx1G", "-jar", self.unluac_path, path], 
                capture_output=True,
                timeout=15 
            )
            os.remove(path)
            
            if res.returncode == 0 and len(res.stdout) > 0: 
                return res.stdout
            return None
        except: return None

    def _beautify_lua(self, source_code):
        # Чуть улучшенный бьютифаер
        source_code = re.sub(r'(\s)(local|return|if|for|while|repeat|function)(\s)', r'\n\2 ', source_code)
        replacements = {
            " then ": " then\n", " do ": " do\n", " end ": "\nend\n",
            " repeat ": "\nrepeat\n", " until ": "\nuntil ", ";": ";\n",
            " or ": " or ", " and ": " and "
        }
        for k, v in replacements.items():
            source_code = source_code.replace(k, v)

        lines = source_code.splitlines()
        formatted = []
        indent = 0
        
        for line in lines:
            line = line.strip()
            if not line: continue
            
            # Уменьшаем отступ ПЕРЕД записью строки
            if line.startswith(("end", "until", "}", "]", ")", "else", "elseif")):
                indent = max(0, indent - 1)
            
            formatted.append("\t" * indent + line)
            
            # Увеличиваем отступ ПОСЛЕ записи строки
            if line.endswith(("then", "do", "repeat", "{", "(")) or \
               ("function" in line and not line.endswith("end")):
                indent += 1
            if line.startswith(("else", "elseif")):
                indent += 1
                
        return "\n".join(formatted)
