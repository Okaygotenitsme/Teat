class MelotenUltraVM:
    def __init__(self, source: str):
        self.source = source
        # Генерируем случайные опкоды для каждой сессии
        self.OP_ADD = random.randint(10, 50)
        self.OP_XOR = random.randint(51, 100)
        self.OP_JUNK = random.randint(101, 150)
        self.OP_END = random.randint(151, 255)
        self.xor_key = random.getrandbits(32)

    def _rand_str(self, length=8):
        chars = "Il1O0" # Визуально запутанные имена переменных
        return "".join(random.choice(chars) for _ in range(length))

    def _encrypt_string(self, text: str) -> str:
        """Простое XOR шифрование для строк внутри Lua"""
        bytes_list = [ord(c) for c in text]
        key = random.randint(1, 255)
        res = [str(b ^ key) for b in bytes_list]
        # Lua-декриптор для этой строки
        return f"(function(k,t) local r='' for i=1,#t do r=r..string.char(bit32.bxor(t[i],k)) end return r end)({key}, {{{','.join(res)}}})"

    def _generate_vm_body(self, bytecode: List[int]) -> str:
