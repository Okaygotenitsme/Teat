        # Сортируем по длине (длинные строки обычно интереснее)
        sorted_strings = sorted(detected_strings, key=len, reverse=True)
        
        seen = set()
        count = 0
        for s in sorted_strings:
            if count >= 100:  # Ограничение для читаемости
                report.append(f"-- ... and {len(sorted_strings) - count} more strings")
                break
            
            clean_str = self._safe_string(s)
            if clean_str and clean_str not in seen and len(clean_str) > 3:
