use std::env;
use std::fs;
use std::io::{self, Write};
use rand::Rng;

// --- КОНФИГУРАЦИЯ ---
// Имя переменной для таблицы байтов (как W в твоем файле)
const BYTE_TABLE_NAME: &str = "GokuData"; 

fn main() {
    // 1. Получаем аргументы (файл ввода)
    let args: Vec<String> = env::args().collect();
    if args.len() < 2 {
        println!("Использование: vm_obfuscator <input.lua>");
        return;
    }

    let input_path = &args[1];
    let source_code = match fs::read_to_string(input_path) {
        Ok(code) => code,
        Err(_) => {
            println!("❌ Ошибка: Не удалось прочитать файл {}", input_path);
            return;
        }
    };

    println!("🔒 Начинаю VM-обфускацию для: {}", input_path);

    // 2. Генерация защиты
    let protected_lua = build_vm(&source_code);

    // 3. Сохранение
    let output_name = format!("Protected_{}", input_path);
    match fs::write(&output_name, protected_lua) {
        Ok(_) => println!("✅ Готово! Файл сохранен как: {}", output_name),
        Err(e) => println!("❌ Ошибка записи: {}", e),
    }
}

fn build_vm(source: &str) -> String {
    let mut rng = rand::thread_rng();

    // Генерация ключей шифрования
    let xor_key: u8 = rng.gen_range(100..255);
    let offset: u8 = rng.gen_range(10..50);

    // Превращаем исходный код в байты и шифруем
    let bytes = source.as_bytes();
    let mut encrypted_data = Vec::new();

    for (i, byte) in bytes.iter().enumerate() {
        // Сложная формула шифрования: (byte + offset) XOR key
        let mut b = byte.wrapping_add(offset);
        b = b ^ xor_key;
        // Добавляем "шум" (позиционную зависимость), как в WeAreDevs
        b = b.wrapping_add((i % 7) as u8); 
        encrypted_data.push(b);
    }

    // Формируем таблицу данных (как local W = { ... } в твоем примере)
    // Мы разбиваем данные на куски, чтобы Lua не подавился длинной строкой
    let mut table_content = String::new();
    for ch in encrypted_data {
        table_content.push_str(&format!("{},", ch));
    }

    // Генерируем случайные имена переменных для VM
    let var_table = BYTE_TABLE_NAME;
    let var_idx = random_var_name(4);
    let var_val = random_var_name(4);
    let var_res = random_var_name(5);
    let var_str = random_var_name(3);
    
    // --- LUA VM TEMPLATE ---
    // Это тот самый шаблон, который имитирует работу VM
    let vm_script = format!(r#"
--[[ 
    Goku V2 Secure (Rust Generated)
    Protected by Custom VM
]]

local {tbl} = {{{data}}}

local function {vm_name}()
    local {res} = {{}}
    local key = {key}
    local off = {off}
    
    -- Virtual Instruction Pointer Loop
    for {idx}, {val} in ipairs({tbl}) do
        -- Reverse Ops: (val - pos) XOR key - off
        local step1 = ({val} - (({idx} - 1) % 7)) % 256
        local step2 = bit32 and bit32.bxor(step1, key) or (function(a,b) 
            local p,c=1,0 
            while a>0 and b>0 do 
                local ra,rb=a%2,b%2 
                if ra~=rb then c=c+p end 
                a,b,p=(a-ra)/2,(b-rb)/2,p*2 
            end 
            if a<b then a=b end 
            while a>0 do 
                local ra=a%2 
                if ra>0 then c=c+p end 
                a,p=(a-ra)/2,p*2 
            end 
            return c 
        end)(step1, key)
        
        local final = (step2 - off) % 256
        table.insert({res}, string.char(final))
    end
    
    return table.concat({res})
end

local {final_str} = {vm_name}()
local exec = loadstring or load
exec({final_str})()
"#, 
        tbl = var_table,
        data = table_content,
        vm_name = random_var_name(6),
        res = var_res,
        key = xor_key,
        off = offset,
        idx = var_idx,
        val = var_val,
        final_str = var_str
    );

    // Удаляем лишние пробелы и переносы (минификация)
    minify_lua_script(vm_script)
}

fn random_var_name(len: usize) -> String {
    let mut rng = rand::thread_rng();
    let charset: &[u8] = b"Il1O0"; // Используем похожие символы как в твоем файле
    (0..len)
        .map(|_| {
            let idx = rng.gen_range(0..charset.len());
            charset[idx] as char
        })
        .collect()
}

fn minify_lua_script(code: String) -> String {
    // Простая минификация: удаляем комментарии и лишние пробелы
    let mut lines: Vec<&str> = code.lines().collect();
    lines.retain(|&x| !x.trim().starts_with("--") || x.contains("--[["));
    lines.join(" ")
}
