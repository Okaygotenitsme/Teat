import telebot
import random
import re

# ЗАМЕНИ ЭТО на свой токен, который дал @BotFather
TOKEN = 'ТВОЙ_ТОКЕН_ЗДЕСЬ' 

bot = telebot.TeleBot(TOKEN)

# Модуль защиты №1: Запутывание чисел
def mutate_number(n):
    num = int(n)
    offset = random.randint(100, 999)
    return f"(({num + offset} - {offset}) + (5 * 0))"

# Модуль защиты №2: Прячем строки в HEX
def hide_string(text):
    return "(\"" + "".join([f"\\{ord(c)}" for c in text]) + "\")"

def meloten_protect(code):
    # Прячем числа
    code = re.sub(r'\d+', lambda m: mutate_number(m.group()), code)
    # Прячем строки
    code = re.sub(r'"(.*?)"', lambda m: hide_string(m.group(1)), code)
    
    header = "-- [[ Meloten Obfuscator V1 ]]\n"
    return header + code

@bot.message_handler(commands=['start'])
def start(message):
    bot.reply_to(message, "Meloten System Online. Пришли Lua-код!")

@bot.message_handler(func=lambda message: True)
def handle_code(message):
    try:
        original = message.text
        result = meloten_protect(original)
        # Отправляем код в красивом блоке
        bot.send_message(message.chat.id, f"```lua\n{result}\n```", parse_mode="Markdown")
    except Exception as e:
        bot.reply_to(message, f"Ошибка: {e}")

print("Meloten Bot запущен! Проверь Telegram.")
bot.polling()
