local Workspace = game:GetService("Workspace")

local function createTowerUI(tower)
	local part = tower.PrimaryPart or tower:FindFirstChildWhichIsA("BasePart")
	if not part then return end

	local bgui = Instance.new("BillboardGui", part)
	bgui.Name = "HealthGui"
	bgui.Size = UDim2.new(5, 0, 1.5, 0)
	bgui.AlwaysOnTop = true
	bgui.ExtentsOffset = Vector3.new(0, 5, 0)

	local label = Instance.new("TextLabel", bgui)
	label.Size = UDim2.new(1, 0, 1, 0)
	label.BackgroundTransparency = 1
	label.TextColor3 = Color3.new(1, 1, 0)
	label.TextScaled = true
	label.Text = tostring(tower:GetAttribute("Health") or 1000)

	tower:GetAttributeChangedSignal("Health"):Connect(function()
		label.Text = tostring(math.floor(tower:GetAttribute("Health") or 0))
	end)
end

task.wait(1)
local towers = {"MainTower", "TowerLeft", "TowerRight"}

for _, name in ipairs(towers) do
	local t = Workspace:FindFirstChild(name)
	if t then
		if not t:GetAttribute("Health") then t:SetAttribute("Health", 1000) end
		createTowerUI(t)
	end
end
