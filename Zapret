import lupa
from lupa import LuaRuntime
import re
import logging

# Настройка логов движка
logger = logging.getLogger("Deobfuscator")

class DeobfuscatorEngine:
    def __init__(self):
        # Lua 5.1 - стандарт для Roblox скриптов
        self.lua = LuaRuntime(unpack_returned_tuples=True)

    def process(self, content):
        """Главный метод запуска"""
        logger.info("--- Начинаю деобфускацию ---")
        
        # 1. Этап динамического анализа (Lua)
        decrypted_code = self._run_lua_sandbox(content)
        
        if not decrypted_code or decrypted_code.startswith("ERROR"):
            return f"-- [FAIL] Не удалось расшифровать динамически.\n-- Лог: {decrypted_code}"

        # 2. Этап статической чистки (Python)
        logger.info("Lua отработала. Начинаю чистку кода...")
        clean_code = self._clean_code(decrypted_code)
        
        return clean_code

    def _run_lua_sandbox(self, code):
        """Запускает код в песочнице и перехватывает loadstring"""
        
        # Скрипт-перехватчик. Мы подменяем функции, которые используют обфускаторы.
        sandbox_script = """
        _G.RESULT = nil
        _G.LOGS = {}

        -- Фейковое окружение Roblox
        local env = {
            -- Самое важное: перехват результата
            loadstring = function(chunk)
                _G.RESULT = chunk
                table.insert(_G.LOGS, "[SUCCESS] loadstring перехвачен!")
                return function() end
            end,
            
            -- Заглушки для Roblox API
            game = { GetService = function(s, n) return { Name = n } end },
            workspace = {},
            script = {},
            
            -- Стандартные библиотеки
            string = string, math = math, table = table,
            bit = bit32 or require("bit"), -- Поддержка битовых операций
            bit32 = bit32,
            pairs = pairs, ipairs = ipairs, next = next, unpack = unpack or table.unpack,
            type = type, tostring = tostring, tonumber = tonumber,
            pcall = pcall, xpcall = xpcall, error = error,
            getfenv = function() return _G.sandbox_env end,
            setfenv = function() return end,
            
            -- Логирование
            print = function(...) 
                local args = {...}
                local s = ""
                for i, v in ipairs(args) do s = s .. tostring(v) .. " " end
                table.insert(_G.LOGS, "[LUA PRINT] " .. s)
            end
        }
        
        -- Ссылаемся сами на себя
        env._G = env
        env.getgenv = function() return env end
        _G.sandbox_env = env

        return env
        """

        try:
            # 1. Создаем среду
            env = self.lua.execute(sandbox_script)
            
            # 2. Пытаемся запустить вредоносный код внутри среды
            # Оборачиваем в pcall, чтобы не крашнуло весь Python
            runner = self.lua.eval("""
                function(code, env)
                    local func, err = load(code, "obfuscated", "t", env)
                    if not func then 
                        return false, "Syntax Error: " .. tostring(err) 
                    end
                    return pcall(func)
                end
            """)
            
            success, res = runner(code, env)
            
            # 3. Достаем результат
            captured = self.lua.globals().RESULT
            logs = list(self.lua.globals().LOGS)

            if captured:
                return str(captured)
            
            # Если не вышло перехватить loadstring, возвращаем логи
            error_log = "\n".join([str(l) for l in logs])
            return f"ERROR: Результат не был перехвачен.\nЛоги Lua:\n{error_log}\nОшибка выполнения: {res}"

        except Exception as e:
            return f"ERROR: Критическая ошибка Python-Lua: {e}"

    def _clean_code(self, code):
        """Чистит код от мусора после деобфускации"""
        
        # 1. Убираем лишние пробелы и табуляции в начале строк
        lines = code.split('\n')
        # code = "\n".join([line.strip() for line in lines]) # Слишком агрессивно, ломает отступы
        
        # 2. Переименование кракозябр (ll1l1l1 -> var_1)
        # Ищем переменные длиннее 10 символов, состоящие из l, 1, _, I
        ugly_vars = set(re.findall(r"\b[l1I_]{10,}\b", code))
        counter = 1
        for var in ugly_vars:
            code = code.replace(var, f"var_{counter}")
            counter += 1

        # 3. Удаление мертвого кода (if false then)
        code = re.sub(r"if\s+false\s+then[\s\S]*?end", "-- [Dead Code Removed]", code)
        
        # 4. Красивый заголовок
        header = f"-- [[ DEOBFUSCATED BY BOT ]]\n-- Renamed vars: {counter-1}\n\n"
        return header + code
