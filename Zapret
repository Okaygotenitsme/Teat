@dp.message(Command("bypass"))
async def bypass_handler(message: types.Message, command: CommandObject):
    if not command.args:
        await message.answer("⚠️ **Ошибка:** Вставь ссылку!\nПример: `/bypass https://linkvertise.com/123/xyz`")
        return

    url = command.args.strip()
    wait_msg = await message.answer("⏳ **Обхожу рекламу через новый API...**", parse_mode="Markdown")

    # Используем новый API (Adrinan)
    api_url = f"https://api.adrinan.com.br/bypass?url={url}"

    try:
        timeout = aiohttp.ClientTimeout(total=25)
        async with aiohttp.ClientSession(timeout=timeout) as session:
            async with session.get(api_url) as response:
                
                if response.status != 200:
                    await wait_msg.edit_text(f"❌ **Сервис перегружен.** Попробуйте позже.")
                    return

                data = await response.json()
                
                # У Adrinan API структура ответа может отличаться
                # Обычно результат лежит в поле 'bypassed' или 'result'
                result = data.get('bypassed') or data.get('result')

                if result:
                    await wait_msg.edit_text(
                        f"✅ **Готово!**\n\n🔗 **Результат:**\n`{result}`", 
                        parse_mode="Markdown"
                    )
                else:
                    await wait_msg.edit_text(f"❌ **Не удалось получить ссылку.** Возможно, этот сайт не поддерживается.")

    except Exception as e:
        logging.error(e)
        await wait_msg.edit_text(f"❌ **Ошибка подключения.**")
