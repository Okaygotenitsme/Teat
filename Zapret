import asyncio
import os
import logging
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command
from aiogram.exceptions import TelegramBadRequest

from engine import DeobfuscatorEngine

# --- НАСТРОЙКИ ---
API_TOKEN = 'ТВОЙ_ТОКЕН' 

logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(message)s")
logger = logging.getLogger("DeobfBot")

bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "🤖 **Roblox Lua Deobfuscator**\n"
        "Пришли файл `.lua`. Если это IronBrew/MoonSec, я достану код и декомпилирую его через unluac.\n\n"
        "⚠️ Убедись, что администратор добавил `unluac.jar` в папку бота.",
        parse_mode="Markdown"
    )

@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    file_name = message.document.file_name
    input_path = f"in_{user_id}_{file_name}"
    output_path = f"Deobfuscated_{file_name}"

    status_msg = await message.answer("⏳ **Загрузка и анализ...**", parse_mode="Markdown")
    last_status = [""]

    def sync_status_updater(text):
        if text == last_status[0]: return
        last_status[0] = text
        async def edit_coro():
            try:
                await status_msg.edit_text(f"⚙️ **Статус:** {text}", parse_mode="Markdown")
            except TelegramBadRequest: pass
        asyncio.run_coroutine_threadsafe(edit_coro(), bot.loop)

    try:
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "rb") as f: content = f.read()

        # Запуск с таймаутом
        try:
            result_data = await asyncio.wait_for(
                asyncio.to_thread(engine.process, content, sync_status_updater),
                timeout=180.0 # Даем чуть больше времени на декомпиляцию
            )
        except asyncio.TimeoutError:
            result_data = b"-- [TIMEOUT] Process took too long."
            await status_msg.edit_text("❌ **Ошибка:** Таймаут.")

        with open(output_path, "wb") as f: f.write(result_data)

        out_file = FSInputFile(output_path)
        caption = "✅ **Успех!**"
        if b"Decompiled with unluac" in result_data:
            caption += "\n📜 Код успешно декомпилирован!"
        else:
            caption += "\n🧩 Получен байткод (Java/Unluac не сработал или не найден)."

        await message.answer_document(out_file, caption=caption)

    except Exception as e:
        logger.error(e)
        await status_msg.edit_text("❌ Ошибка обработки.")
    finally:
        for p in [input_path, output_path]:
            if os.path.exists(p): os.remove(p)

async def main():
    bot.loop = asyncio.get_running_loop()
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
