import lupa
from lupa import LuaRuntime
import logging
import os
import re

logger = logging.getLogger("DeobfuscatorEngine")
logging.basicConfig(level=logging.INFO)

class DeobfuscatorEngine:
    def __init__(self):
        # Нам больше не нужен unluac для этого метода, мы генерируем код сами
        pass

    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        update_status("🧠 Запуск Реконструктора Кода (Trace Reconstruction)...")

        lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)

        # --- СКРИПТ-ШПИОН ---
        # Мы создаем среду, где КАЖДОЕ действие записывается в строку кода.
        setup_script = """
        _G.RECONSTRUCTED_LINES = {}
        local start_time = os.clock()
        
        -- Функция записи найденной строки кода
        local function emit(code_line)
            -- Игнорируем спам (опционально)
            if code_line:find("GetService") or code_line:find("http") or #code_line < 200 then
                 table.insert(_G.RECONSTRUCTED_LINES, code_line)
            end
        end

        -- Генератор имен переменных (v1, v2, v3...)
        local var_counter = 0
        local obj_cache = {} -- Чтобы помнить, что game.Workspace это тот же объект
        
        local function get_var_name(obj)
            if obj_cache[obj] then return obj_cache[obj] end
            var_counter = var_counter + 1
            local name = "v"..var_counter
            obj_cache[obj] = name
            return name
        end

        -- ГЛАВНЫЙ PROXY
        -- Это "фейковый" объект, который притворяется любой частью Roblox
        local function create_proxy(path_name, real_ref)
            local proxy = {}
            local meta = {}
            
            -- Сохраняем путь (например "game.Players")
            local my_path = path_name 

            meta.__index = function(t, k)
                local key_str = tostring(k)
                local next_path = my_path .. "." .. key_str
                
                -- Если скрипт просит сервис, запишем это красиво
                if key_str == "GetService" then
                    return function(self, service_name)
                        local call_str = 'game:GetService("' .. tostring(service_name) .. '")'
                        emit("-- Access Service: " .. service_name)
                        return create_proxy(call_str)
                    end
                end

                -- Если это просто чтение свойства
                -- emit(next_path) -- Можно раскомментировать для детального лога
                
                return create_proxy(next_path)
            end

            meta.__newindex = function(t, k, v)
                -- Скрипт пытается что-то изменить! Это 100% полезный код.
                local val_str = tostring(v)
                if type(v) == "string" then val_str = '"' .. val_str .. '"' end
                
                local line = my_path .. "." .. tostring(k) .. " = " .. val_str
                emit(line)
            end

            meta.__call = function(t, ...)
                local args = {...}
                local arg_strs = {}
                for i, arg in ipairs(args) do
                    if type(arg) == "string" then
                        table.insert(arg_strs, '"' .. arg .. '"')
                    elseif type(arg) == "table" then
                        table.insert(arg_strs, "tbl_" .. tostring(i)) -- Упрощение для таблиц
                    else
                        table.insert(arg_strs, tostring(arg))
                    end
                end
                
                -- Формируем строку вызова функции
                local line = my_path .. "(" .. table.concat(arg_strs, ", ") .. ")"
                emit(line)
                
                return create_proxy(line) -- Возвращаем результат как новый прокси
            end
            
            meta.__tostring = function() return my_path end
            
            setmetatable(proxy, meta)
            return proxy
        end

        -- --- ОКРУЖЕНИЕ ---
        local env = {
            -- Базовые Lua функции
            pairs = pairs, ipairs = ipairs, next = next, type = type, 
            tostring = tostring, tonumber = tonumber, pcall = pcall, xpcall = xpcall,
            error = error, select = select,
            
            -- Фейковая стандартная библиотека
            math = { random = function(...) emit("math.random(...)"); return 1 end, floor = math.floor, ceil = math.ceil },
            string = string,
            table = table,
            
            -- ГЛАВНЫЕ ТОЧКИ ВХОДА ROBLOX
            game = create_proxy("game"),
            workspace = create_proxy("workspace"),
            script = create_proxy("script"),
            
            -- EXPLOIT ФУНКЦИИ (Часто используются в скриптах)
            getgenv = function() return env end,
            checkcaller = function() return true end,
            
            -- Вывод в консоль тоже запишем как код
            print = function(...) 
                local args = {...}
                emit('print("' .. tostring(args[1]) .. '")') 
            end,
            warn = function(...)
                local args = {...}
                emit('warn("' .. tostring(args[1]) .. '")') 
            end
        }
        
        -- Битовые операции (нужны для запуска VM)
        local bit = {}
        function bit.band(a, b) return a end -- Заглушки, так как нам важен поток, а не математика
        function bit.rshift(a, b) return a end
        function bit.bxor(a, b) return a end
        env.bit = bit
        env.bit32 = bit

        env._G = env
        return env
        """

        try:
            env = lua.execute(setup_script)
            
            # Обертка для запуска с игнорированием ошибок
            runner = lua.eval("""
                function(code, env)
                    local f = load(code, "chunk", "bt", env)
                    if not f then return end
                    pcall(f) -- Запускаем и ловим все действия
                end
            """)
            
            update_status("🌪️ Трейсинг потока исполнения...")
            runner(content, env)
            
            # Забираем реконструированный код
            lines_table = list(lua.globals().RECONSTRUCTED_LINES)
            
            return self._finalize(lines_table, update_status)

        except Exception as e:
            return f"-- [CRASH]: {e}".encode('utf-8')

    def _finalize(self, lines, callback):
        if callback: callback("📝 Сборка чистого исходника...")
        
        final_code = "-- [[ RECONSTRUCTED SOURCE CODE ]] --\n"
        final_code += "-- Generated by Dynamic Tracing Engine\n"
        final_code += f"-- Total instructions captured: {len(lines)}\n\n"
        
        # Удаляем дубликаты подряд (часто бывают в циклах)
        unique_lines = []
        last_line = ""
        for line in lines:
            line = str(line)
            if line != last_line:
                unique_lines.append(line)
                last_line = line
        
        final_code += "\n".join(unique_lines)
        
        if len(unique_lines) == 0:
            final_code += "\n-- [WARNING] No actions captured.\n"
            final_code += "-- The script might have detected the sandbox or crashed early."
            
        return final_code.encode('utf-8')
