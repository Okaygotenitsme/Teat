import asyncio
import os
import logging
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command
from aiogram.exceptions import TelegramBadRequest

# Импортируем наш движок
from engine import DeobfuscatorEngine

# --- НАСТРОЙКИ ---
API_TOKEN = 'ТВОЙ_ТОКЕН_ЗДЕСЬ'  # <--- ВСТАВЬ ТОКЕН

# Настройка логирования
logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(message)s")
logger = logging.getLogger("DeobfBot")

# Инициализация бота и движка
bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    # Приветствие
    await message.answer(
        "🤖 **Roblox Lua Deobfuscator**\n\n"
        "Отправь мне файл `.lua` или `.txt`.\n"
        "Я запущу его в безопасной среде, перехвачу байткод и попробую декомпилировать через `unluac`.\n\n"
        "⚠️ Поддерживается: IronBrew, MoonSec, PSX Obfuscator и другие VM.",
        parse_mode="Markdown"
    )

@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    file_name = message.document.file_name
    
    # Пути для сохранения (используем временные файлы)
    input_path = f"temp_in_{user_id}_{file_name}"
    output_path = f"Deobfuscated_{file_name}"

    status_msg = await message.answer("⏳ **Скачиваю файл...**", parse_mode="Markdown")
    
    # Хак для обновления статуса из синхронного кода engine.py
    last_status = [""]
    def sync_status_updater(text):
        if text == last_status[0]: return
        last_status[0] = text
        # Создаем задачу в главном цикле событий
        async def edit_coro():
            try:
                await status_msg.edit_text(f"⚙️ **Статус:** {text}", parse_mode="Markdown")
            except TelegramBadRequest: pass # Игнорируем ошибки, если текст не изменился
        
        loop = asyncio.get_running_loop()
        if loop.is_running():
            asyncio.run_coroutine_threadsafe(edit_coro(), loop)

    try:
        # 1. Скачиваем файл
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "rb") as f: content = f.read()

        # 2. Запускаем движок в отдельном потоке, чтобы не блокировать бота
        # Таймаут 180 секунд (3 минуты) на обработку
        try:
            result_data = await asyncio.wait_for(
                asyncio.to_thread(engine.process, content, sync_status_updater),
                timeout=180.0
            )
        except asyncio.TimeoutError:
            result_data = b"-- [TIMEOUT] Process took too long ( > 3 mins)."
            await status_msg.edit_text("❌ **Ошибка:** Время обработки истекло.")

        # 3. Сохраняем результат
        with open(output_path, "wb") as f: f.write(result_data)

        # 4. Отправляем пользователю
        out_file = FSInputFile(output_path)
        caption = "✅ **Готово!**"
        
        if b"Decompiled with unluac" in result_data:
            caption += "\n📜 Байткод успешно декомпилирован в исходник."
        elif b"WARNING: Decompilation failed" in result_data:
            caption += "\n🧩 Байткод пойман, но декомпилятор (Java) вернул ошибку."
        elif b"[FAIL]" in result_data:
            caption = "❌ **Не удалось:** Скрипт не удалось распаковать (см. логи)."

        await message.answer_document(out_file, caption=caption)

    except Exception as e:
        logger.error(f"Global Error: {e}")
        await status_msg.edit_text(f"❌ Критическая ошибка бота: {e}")
    finally:
        # Удаляем временные файлы
        for p in [input_path, output_path]:
            if os.path.exists(p): 
                try: os.remove(p)
                except: pass

async def main():
    logger.info("Бот запущен!")
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        print("Бот остановлен.")
