import asyncio
import os
import logging
import sys
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command
from aiogram.exceptions import TelegramBadRequest

from engine import DeobfuscatorEngine

# --- CONFIG ---
API_TOKEN = 'ТВОЙ_ТОКЕН' 

# Логирование
logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(message)s")
logger = logging.getLogger("Bot")

bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer("🤖 **Roblox Deobfuscator V2**\n\nПришли скрипт, и я вскрою его защиту.")

@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    file_name = message.document.file_name
    input_path = f"in_{user_id}_{file_name}"
    output_path = f"out_{user_id}.lua"

    # Стартовое сообщение
    status_msg = await message.answer("⏳ **Инициализация...**")
    
    # Функция для обновления статуса в сообщении (вызывается из Engine)
    # Мы используем кеширование, чтобы не долбить API телеграма слишком часто
    last_status = [""]
    
    def sync_status_updater(text):
        """Эта функция вызывается из синхронного кода Engine"""
        if text == last_status[0]: return
        last_status[0] = text
        
        # Планируем асинхронное обновление сообщения
        async def edit_coro():
            try:
                # Добавляем часики для красоты
                await status_msg.edit_text(f"⚙️ **В работе...**\n\n🔹 {text}")
            except TelegramBadRequest:
                pass # Игнорируем ошибки (если сообщение не изменилось)
        
        # Безопасно передаем задачу в главный цикл событий бота
        asyncio.run_coroutine_threadsafe(edit_coro(), bot.loop)

    try:
        # 1. Скачивание
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "r", encoding="utf-8", errors="ignore") as f:
            content = f.read()

        # 2. ЗАПУСК (Передаем нашу функцию обновления статуса)
        # Ждем максимум 120 секунд
        try:
            result_code = await asyncio.wait_for(
                asyncio.to_thread(engine.process, content, sync_status_updater),
                timeout=120.0
            )
        except asyncio.TimeoutError:
            result_code = "-- [TIMEOUT] Скрипт слишком сложный (более 2 минут)."
            await status_msg.edit_text("❌ **Ошибка:** Время вышло.")

        # 3. Сохранение и отправка
        await status_msg.edit_text("✅ **Готово!** Загружаю файл...")
        
        with open(output_path, "w", encoding="utf-8") as f:
            f.write(result_code)

        output_file = FSInputFile(output_path, filename=f"Deobf_{file_name}")
        await message.answer_document(output_file, caption="✅ Успешная деобфускация.")

    except Exception as e:
        logger.error(f"Error: {e}")
        await status_msg.edit_text(f"❌ **Критическая ошибка:**\n{e}")

    finally:
        # Чистка
        for p in [input_path, output_path]:
            if os.path.exists(p):
                try: os.remove(p) 
                except: pass

async def main():
    # Важный хак: сохраняем loop в боте, чтобы вызывать его из потоков
    bot.loop = asyncio.get_running_loop()
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
