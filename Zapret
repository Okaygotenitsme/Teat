@dp.message(F.document)
async def handle_document(message: types.Message):
    doc = message.document
    fname = (doc.file_name or "script.lua").lower()

    if not fname.endswith(ALLOWED_EXTS):
        await message.answer("❌ Формат не поддерживается. Только .lua и .txt")
        return

    if doc.file_size > MAX_FILE_SIZE:
        await message.answer("❌ Файл слишком большой.")
        return

    status_msg = await message.answer("🛡 <b>Meloten Security:</b> Анализ и обфускация...", parse_mode="HTML")
    tmp_in_path = None
    tmp_out_path = None

    try:
        # --- Скачивание (AIOGRAM 3.X CORRECT WAY) ---
        bot_file = await bot.get_file(doc.file_id)
        
        # Используем BytesIO для обработки в памяти
        data_io = io.BytesIO()
        await bot.download(bot_file, destination=data_io)
        data_io.seek(0)
        
        source_code = data_io.read().decode("utf-8", errors="ignore")

        # --- Обфускация ---
        obfuscator = MelotenUltraVM(source_code)
        protected_code = obfuscator.build()

        # --- Сохранение во временный файл ---
        # Важно: закрываем файл перед отправкой, отправляем через FSInputFile
        with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode="w", encoding="utf-8") as tmp_out:
            tmp_out.write(protected_code)
            tmp_out_path = tmp_out.name

        # --- Отправка (AIOGRAM 3.X CORRECT WAY) ---
        output_file = FSInputFile(tmp_out_path, filename=f"Protected_{doc.file_name}")
        await message.answer_document(
            output_file, 
            caption=f"✅ <b>Успешно!</b>\nРазмер кода: {len(protected_code)} байт\nЗащита: Meloten ULTRA VM",
            parse_mode="HTML"
        )

    except Exception as e:
        logger.exception("Obfuscation error")
        await message.answer(f"⚠️ Произошла ошибка: {e}")
    finally:
        # Чистим статус и файлы
        try:
            await status_msg.delete()
        except:
            pass
            
        if tmp_out_path and os.path.exists(tmp_out_path):
            os.remove(tmp_out_path)

