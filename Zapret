        -- Exploit Environment (V0.44)
        local expl_env = {
            setclipboard = function(s) log("EXPL DETECT: setclipboard("..tostring(s)..")") end,
            setreadonly = function(t, v) end,
            hookfunction = function(old, new) log("EXPL DETECT: hookfunction called"); return old end,
            newcclosure = function(f) return f end,
            checkcaller = function() return true end,
            getgenv = function() return _G end,
            getrenv = function() return _G end,
