-- ServerScriptService/TowerInit
local Workspace = game:GetService("Workspace")

-- Создаем папку для башен, если её нет
local towersFolder = Workspace:FindFirstChild("Towers")
if not towersFolder then
	towersFolder = Instance.new("Folder")
	towersFolder.Name = "Towers"
	towersFolder.Parent = Workspace
end

-- Настройки здоровья
local HP_MAIN = 2000
local HP_SIDE = 1000

local function setupTower(name, healthValue)
	-- Ищем модель башни в Workspace
	local tower = Workspace:FindFirstChild(name)
	if tower and tower:IsA("Model") then
		tower.Parent = towersFolder -- Переносим в специальную папку
		
		-- Добавляем или обновляем значение здоровья
		local hp = tower:FindFirstChild("Health")
		if not hp then
			hp = Instance.new("IntValue")
			hp.Name = "Health"
			hp.Parent = tower
		end
		hp.Value = healthValue
		
		-- Убедимся, что у башни есть PrimaryPart, иначе юниты её не увидят
		if not tower.PrimaryPart then
			for _, part in ipairs(tower:GetDescendants()) do
				if part:IsA("BasePart") then
					tower.PrimaryPart = part
					break
				end
			end
		end
		print("[TowerInit] Башня " .. name .. " настроена. HP: " .. healthValue)
	else
		warn("[TowerInit] Башня " .. name .. " не найдена в Workspace!")
	end
end

-- Запускаем настройку для твоих башен
setupTower("MainTower", HP_MAIN)
setupTower("TowerLeft", HP_SIDE)
setupTower("TowerRight", HP_SIDE)
