import asyncio
import os
import logging
import uuid
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command

# Импортируем движок
from engine import DeobfuscatorEngine

# --- НАСТРОЙКИ ---
API_TOKEN = 'ТВОЙ_ТОКЕН_СЮДА' # <--- НЕ ЗАБУДЬ ВСТАВИТЬ ТОКЕН

# Настройка логгера
logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(message)s")
logger = logging.getLogger("DeobfBot")

# Инициализация бота и диспетчера
bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "🤖 **Roblox Deobfuscator V2 (Deep Trace)**\n\n"
        "Отправь мне `.lua` или `.txt` файл.\n"
        "Я прогоню его через эмулятор с глубоким перехватом строк.\n\n"
        "✨ **Особенности:**\n"
        "🔹 Формат `local mel_X` для строк\n"
        "🔹 Эмуляция `debug` библиотеки (для MoonSec)\n"
        "🔹 Перехват `gsub`, `sub`, `reverse`\n"
        "🔹 Декомпиляция вложенных скриптов",
        parse_mode="Markdown"
    )

@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    unique_id = uuid.uuid4().hex[:8]
    file_name = message.document.file_name or "script.lua"
    
    input_path = f"temp_{user_id}_{unique_id}.lua"
    output_path = f"Deobf_{unique_id}_{file_name}.txt"

    status_msg = await message.answer("⏳ **Анализ начат (Deep Trace)...**", parse_mode="Markdown")
    
    loop = asyncio.get_running_loop()
    last_status = [""]
    
    def sync_status_updater(text):
        if text == last_status[0]: return
        last_status[0] = text
        async def edit_coro():
            try:
                if text:
                    await status_msg.edit_text(f"⚙️ **Статус:** {text}", parse_mode="Markdown")
            except: pass 
        if not loop.is_closed():
            asyncio.run_coroutine_threadsafe(edit_coro(), loop)

    try:
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "rb") as f: content = f.read()

        # Увеличил тайм-аут до 180 секунд, так как анализ теперь глубже
        result_data = await asyncio.wait_for(
            loop.run_in_executor(None, engine.process, content, sync_status_updater),
            timeout=180.0 
        )

        with open(output_path, "wb") as f: f.write(result_data)
        out_file = FSInputFile(output_path)
        
        caption = "✅ **Готово!**\nПроверь файл, строки переименованы в `mel_X`."
        
        await message.answer_document(out_file, caption=caption)

    except asyncio.TimeoutError:
        await status_msg.edit_text("❌ **Ошибка:** Скрипт слишком сложный (тайм-аут).")
    except Exception as e:
        logger.error(f"Error: {e}")
        try: await status_msg.edit_text("❌ Внутренняя ошибка обработки.")
        except: pass
    finally:
        for p in [input_path, output_path]:
            if os.path.exists(p):
                try: os.remove(p)
                except: pass

async def main():
    logger.info("Бот запускается...")
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    try:
        if os.name == 'nt':
            asyncio.set_event_loop_policy(asyncio.WindowsSelectorEventLoopPolicy())
        asyncio.run(main())
    except KeyboardInterrupt:
        print("Стоп.")
