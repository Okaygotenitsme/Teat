// Определяем нашего персонажа
ACTOR CoolFriend 15000 // 15000 - это номер ID для редактора карт
{
  Health 5000          // Очень много здоровья
  Radius 20
  Height 56
  Speed 15             // Быстро бегает
  Monster
  +FLOORCLIP           // Чтобы не проваливался в пол
  SeeSound "friend/see"     // Можно добавить свои звуки
  PainSound "friend/pain"
  DeathSound "friend/death"
  Obituary "%o был уничтожен своим же другом."

  States
  {
  Spawn:
    FRND AB 10 A_Look  // Просто стоит и ждет
    Loop

  See:
    FRND AABBCCDD 3 A_Chase // Просто бегает за игроком, но не атакует
    Loop

  Pain:
    // Когда ударили, он переходит в режим ярости
    TNT1 A 0 A_Say("Сейчас ты получишь!") // (Опционально)
    ANGR A 105 A_Pain     // Замирает на 105 тиков (3 секунды) со злым фото
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", 32, 32, 0, 0, 0, 0, 0, SXF_SETMASTER) // Спавн 4 клонов вокруг
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", -32, 32, 0, 0, 0, 0, 0, SXF_SETMASTER)
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", 32, -32, 0, 0, 0, 0, 0, SXF_SETMASTER)
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", -32, -32, 0, 0, 0, 0, 0, SXF_SETMASTER)
    Goto AngrySee         // Переход в режим атаки

  AngrySee:
    ANGR AABBCCDD 3 A_Chase // Теперь бегает злой
    Loop

  Missile:
    // Шанс вызвать клонов снова (примерно 20%) или выстрелить огнем
    TNT1 A 0 A_Jump(50, "SummonClones") 
    ANGR E 8 A_FaceTarget
    ANGR F 8 BRIGHT A_CustomMissile("FatShot", 32, 0, 0) // Стреляет огнем (как Манкубус)
    Goto AngrySee

  SummonClones:
    ANGR A 20 A_SpawnItemEx("CoolFriendClone", 40, 0, 0, 0, 0, 0, 0, SXF_SETMASTER)
    Goto AngrySee

  Death:
    ANGR H 10 A_Scream
    ANGR I 10 A_NoBlocking
    ANGR JKLM 10
    Stop
  }
}

// Упрощенный клон (чтобы не нагружать игру)
ACTOR CoolFriendClone
{
  Health 100
  Speed 12
  Radius 20
  Height 56
  Monster
  +FLOORCLIP
  States
  {
  Spawn:
    FRND A 10 A_Look
    Loop
  See:
    FRND AABBCCDD 3 A_Chase
    Loop
  Missile:
    FRND E 8 A_FaceTarget
    FRND F 8 A_CustomMissile("DoomImpBall", 32, 0, 0) // Клоны стреляют как импы
    Goto See
  Death:
    FRND H 5 A_Scream
    FRND I 5 A_NoBlocking
    Stop
  }
}
