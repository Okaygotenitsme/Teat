        local enc = data[i]
        -- Обратная операция: (Enc - Key) % 256
        local dec = (enc - current_k) % 256
        if dec < 0 then dec = dec + 256 end
        
        table.insert({self.v['str_res']}, string.char(dec))
        
        -- Обновление ключа (точно такое же, как в Python)
        current_k = (current_k * 1664525 + 1013904223) % 4294967296
        current_k = current_k % 255
    end
    return table.concat({self.v['str_res']})
end

