@dp.message_handler(content_types=['document'])
async def handle_docs(message: types.Message):
    # Проверяем расширение
    if message.document.file_name.endswith(('.lua', '.txt')):
        await message.answer("🛠 Шифрую код и строю Виртуальную Машину...")
        
        try:
            # Скачиваем файл в память
            file_info = await bot.get_file(message.document.file_id)
            downloaded_file = await bot.download_file(file_info.file_path)
            source_code = downloaded_file.read().decode('utf-8')

            # Обфусцируем
            final_code = obfuscate_lua(source_code)

            # Отправляем файл обратно
            output_file = io.BytesIO(final_code.encode('utf-8'))
            output_file.name = f"protected_{message.document.file_name}"
            
            await message.reply_document(output_file, caption="✅ Готово! Код защищен VM-слоем.")
            
        except Exception as e:
            await message.reply(f"❌ Ошибка при обработке: {e}")
    else:
        await message.reply("⚠️ Пожалуйста, присылай только файлы .lua или .txt")

