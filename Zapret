def rnd_id(n=20):
    return "_" + "".join(random.choice(string.ascii_letters) for _ in range(n))

def encrypt_val(val, is_str=True):
    key = random.randint(50, 250)
    if is_str:
        encrypted = [ord(c) ^ key for c in val]
        v_name = rnd_id(15)
        return f"(function() local {v_name}={{ {','.join(map(str, encrypted))} }} local s='' for i=1,#{v_name} do s=s..string.char({v_name}[i] ~ {key}) end return s end)()"
    else:
        return f"({val + key} - {key})"

def build_vm(source):
    # 1. Очистка кода от лишних пробелов и комментариев (минимальная)
    source = re.sub(r'--\[\[.*?\]\]', '', source, flags=re.DOTALL)
    source = re.sub(r'--.*', '', source)
    
    # 2. Шифруем все строки
    source = re.sub(r'"(.*?)"', lambda m: encrypt_val(m.group(1)), source)
    source = re.sub(r"'(.*?)'", lambda m: encrypt_string(m.group(1)) if "encrypt_string" in globals() else encrypt_val(m.group(1)), source)

    # 3. Создаем структуру VM
    vm_table = rnd_id()
    pc_var = rnd_id()
    
    # Разбиваем код на "опкоды" (по строкам для простоты, но в структуре VM)
    lines = [line.strip() for line in source.split('\n') if line.strip()]
    opcodes = []
    for i, line in enumerate(lines):
        opcodes.append(f"[{i}] = function() {line} end")
    
    opcodes_str = ",\n        ".join(opcodes)
    
    # Финальная сборка VM
    vm_code = f"""
local {vm_table} = {{
        {opcodes_str}
}}

local {pc_var} = 0
local _running = true

--[[ MELOTEN VM CORE ]]
while _running do
    local _instr = {vm_table}[{pc_var}]
    if _instr then
        _instr()
        {pc_var} = {pc_var} + 1
    else
        _running = false
    end
end
"""
    
    # Добавляем "мусорный щит"
    header = f"--[[ PROTECTED BY MELOTEN SUPREME VM V6 ]]\n"
    for _ in range(10):
        header += f"local {rnd_id()} = {random.randint(1, 999999)}\n"
        
    return header + vm_code

