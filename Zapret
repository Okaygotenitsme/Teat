# --- СЕРДЦЕ ОБФУСКАТОРА (ГЕНЕРАЦИЯ VM) ---

class ObfuscatorVM:
    def __init__(self, source_code):
        self.source = source_code
        self.key = random.randint(50, 255)
        self.vm_name = "".join(random.choices(string.ascii_letters, k=8))
        
    def generate_junk(self):
        """Создает огромные блоки бесполезного кода"""
        junk = ""
        for _ in range(random.randint(5, 10)):
            var = "".join(random.choices(string.ascii_letters, k=6))
            val = random.randint(1000, 999999)
            op = random.choice(['+', '-', '*', '/'])
            junk += f"local {var} = ({val} {op} {random.randint(1, 100)}) + math.pi;\n"
        return junk

    def protect(self):
        """Главный процесс виртуализации"""
        # Превращаем код в байт-массив с XOR шифрованием
        encrypted_bytes = [ord(c) ^ self.key for c in self.source]
        payload = "{" + ",".join(map(str, encrypted_bytes)) + "}"
        
        # Генерация 'Сердца' Виртуальной Машины для Roblox
        vm_script = f"""--[[ 
    STRICT VIRTUAL MACHINE PROTECTION v4.0
    AUTHORIZED ACCESS ONLY
]]

{self.generate_junk()}

local _PAYLOAD = {payload}
local _K = {self.key}
local _S = ""

-- Виртуальный процессор (Интерпретатор)
local function {self.vm_name}(_d, _k)
    local _decoded = {{}}
    {self.generate_junk()}
    for _i = 1, #_d do
        local _byte = _d[_i]
        -- Динамическая дешифровка через побитовые операции Luau
        _decoded[_i] = string.char(bit32.bxor(_byte, _k))
        
        if _i % 100 == 0 then task.wait() end -- Anti-Lag для больших скриптов
    end
    
    local _res = table.concat(_decoded)
    {self.generate_junk()}
    
    local _exec, _err = loadstring(_res)
    if _exec then
        return _exec
    else
        warn("[VM CRITICAL ERROR]: " .. tostring(_err))
        return nil
    end
end

{self.generate_junk()}

local _ready_to_run = {self.vm_name}(_PAYLOAD, _K)
if _ready_to_run then
    task.spawn(_ready_to_run)
end

{self.generate_junk()}
"""
        return vm_script

