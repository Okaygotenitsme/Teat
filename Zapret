import lupa
from lupa import LuaRuntime
import logging
import subprocess
import os
import tempfile
import re

logger = logging.getLogger("DeobfuscatorEngine")
logging.basicConfig(level=logging.INFO)

class DeobfuscatorEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        logger.info(f"📁 Working Dir: {base_dir}")

    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        if not self._check_java():
            return b"-- [FATAL] Java is missing. Install Java to decompile."

        update_status("🧠 Инициализация среды эмуляции Roblox...")

        try:
            # unpack_returned_tuples=True важно для корректной работы lua
            lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)
        except Exception as e:
            return f"-- [FATAL] Lua start error: {e}".encode('utf-8')

        # --- 1. Продвинутые Полифиллы (Bitwise + Roblox Math) ---
        polyfill = """
        -- BITWISE --
        local bit = {}
        function bit.tobit(x) x = x % 4294967296; if x >= 2147483648 then x = x - 4294967296 end; return x end
        function bit.bnot(x) return 4294967295 - x % 4294967296 end
        local function bit_oper(a, b, oper)
            local r, m, s = 0, 2^31, nil
            repeat s,a,b = a+b+m, a%m, b%m; r,m = r + m*oper%(s-a-b), m/2 until m < 1
            return r
        end
        function bit.band(a, b) return bit_oper(a, b, 4) end
        function bit.bor(a, b)  return bit_oper(a, b, 1) end
        function bit.bxor(a, b) return bit_oper(a, b, 3) end
        function bit.lshift(a, b) return (a * 2^b) % 4294967296 end
        function bit.rshift(a, b) return math.floor(a / 2^b) % 4294967296 end
        
        -- ROBLOX TYPES MOCK (Минимальный набор) --
        local function create_struct(name, args) return {__type=name, args=args} end
        
        Vector3 = { new = function(...) return create_struct("Vector3", {...}) end, zero = create_struct("Vector3", {0,0,0}) }
        CFrame = { new = function(...) return create_struct("CFrame", {...}) end }
        UDim2 = { new = function(...) return create_struct("UDim2", {...}) end }
        Color3 = { new = function(...) return create_struct("Color3", {...}) end, fromRGB = function(...) return create_struct("Color3", {...}) end }
        Instance = { new = function(cls) return _G.create_proxy(cls) end }
        
        package.loaded.bit = bit; _G.bit = bit; _G.bit32 = bit 
        """

        # --- 2. Среда-шпион (Spyware Environment) ---
        sandbox_setup = polyfill + """
        _G.CAPTURED_CHUNKS = {}
        _G.DETECTED_STRINGS = {}
        _G.ACTION_LOG = {}
        
        -- Функция логирования
        local function log_action(msg) 
            if #_G.ACTION_LOG < 500 then -- Лимит логов, чтобы не забивать память
                table.insert(_G.ACTION_LOG, msg) 
            end
        end

        local function capture_str(s) 
            if type(s) == "string" and #s > 3 then 
                -- Фильтр мусора: игнорируем системные сообщения Lua
                if not s:find("stack begin") and not s:find("upvalue") then
                    _G.DETECTED_STRINGS[s] = true 
                end
            end 
            return s
        end

        -- Хук на string.char (основной источник строк в IronBrew)
        local real_char = string.char
        string.char = function(...)
            local res = real_char(...)
            capture_str(res)
            return res
        end
        
        -- Хук на table.concat
        local real_concat = table.concat
        table.concat = function(t, sep, i, j)
            local res = real_concat(t, sep, i, j)
            capture_str(res)
            return res
        end

        -- Хук на load/loadstring (перехват VM)
        local real_load = load
        local function hooked_load(chunk, name, mode, env)
            if type(chunk) == "string" and (#chunk > 100 or chunk:sub(1,4) == "\27Lua") then
                table.insert(_G.CAPTURED_CHUNKS, {data = chunk, size = #chunk})
            end
            -- Подменяем окружение на наше, чтобы вложенные скрипты тоже попались
            return real_load(chunk, name, mode, _G.sandbox_env) 
        end

        -- PROXY (Фейковый Roblox API)
        function _G.create_proxy(name)
            local proxy = {}
            local meta = {}
            
            meta.__index = function(t, k)
                local key = tostring(k)
                -- log_action("Read: " .. name .. "." .. key) -- Слишком много спама, отключаем
                
                -- Стандартные ответы, чтобы скрипт "верил", что он в игре
                if key == "PlaceId" then return 1818 end
                if key == "UserId" then return 12345 end
                if key == "Name" then return "Player1" end
                if key == "LocalPlayer" then return _G.create_proxy("game.Players.LocalPlayer") end
                if key == "Parent" then return _G.create_proxy(name .. ".Parent") end
                
                -- Возвращаем функцию, если скрипт пытается вызвать метод (например :FindFirstChild)
                return function(...) 
                    return _G.create_proxy(name .. ":" .. key) 
                end
            end
            
            meta.__newindex = function(t, k, v)
                -- Ловим установку значений (например, изменение GUI)
                log_action("SET: " .. name .. "." .. tostring(k) .. " = " .. tostring(v))
            end
            
            meta.__call = function(t, ...)
                return _G.create_proxy(name .. "()")
            end
            
            meta.__tostring = function() return name end
            setmetatable(proxy, meta)
            return proxy
        end

        local env = {
            loadstring = hooked_load, load = hooked_load,
            print = function(...) local args={...}; log_action("SCRIPT PRINT: "..tostring(args[1])); end,
            warn = function(...) local args={...}; log_action("SCRIPT WARN: "..tostring(args[1])); end,
            error = function(...) log_action("SCRIPT ERROR: "..tostring((...))); end,
            
            string = string, math = math, table = table, 
            bit = bit, bit32 = bit, pairs = pairs, ipairs = ipairs, next = next,
            type = type, tostring = tostring, tonumber = tonumber, pcall = pcall, xpcall = xpcall,
            select = select, unpack = unpack or table.unpack,
            setmetatable = setmetatable, getmetatable = getmetatable,
            
            -- Глобали Roblox
            game = _G.create_proxy("game"),
            workspace = _G.create_proxy("workspace"),
            script = _G.create_proxy("script"),
            
            -- Эксплойт окружение (часто проверяется скриптами)
            getgenv = function() return {} end,
            syn = { request = function() return {Body="OK"} end },
            request = function() return {Body="OK"} end,
            
            Vector3 = Vector3, CFrame = CFrame, UDim2 = UDim2, Color3 = Color3, Instance = Instance
        }
        env._G = env
        _G.sandbox_env = env
        return env
        """

        try:
            update_status("🌪️ Трейсинг (Исполнение)...")
            env = lua.execute(sandbox_setup)
            
            # Запускаем pcall
            runner = lua.eval("""
                function(code, env)
                    local f, err = load(code, "chunk", "bt", env)
                    if not f then return "LOAD ERR: "..tostring(err) end
                    
                    -- Изолируем выполнение
                    local status, res = pcall(f)
                    return status
                end
            """)
            runner(content, env)

            # --- СБОР ---
            strings_tbl = lua.globals().DETECTED_STRINGS
            detected_strings = list(strings_tbl)
            action_log = list(lua.globals().ACTION_LOG)
            chunks = lua.globals().CAPTURED_CHUNKS
            
            best_chunk = None
            max_size = 0
            if len(chunks) > 0:
                for i in range(1, len(chunks) + 1):
                    c = chunks[i]
                    if c.size > max_size:
                        max_size = c.size
                        best_chunk = c.data
            
            target_code = best_chunk if best_chunk else content
            return self._finalize_output(target_code, detected_strings, action_log, update_status)

        except Exception as e:
            return f"-- [CRASH]: {str(e)}".encode('utf-8')

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _finalize_output(self, code_bytes, strings, logs, callback):
        if callback: callback("📝 Анализ найденных данных...")
        
        final_text = ""
        
        # --- КАТЕГОРИЗАЦИЯ СТРОК (RegEx Magic) ---
        assets = []
        urls = []
        webhooks = []
        others = []
        
        for s in strings:
            s_str = str(s).replace('\n', ' ').replace('\r', '')
            if "rbxassetid" in s_str or re.search(r'\d{8,}', s_str): # ID обычно длинные
                assets.append(s_str)
            elif "http" in s_str:
                if "discord" in s_str: webhooks.append(s_str)
                else: urls.append(s_str)
            else:
                if len(s_str) > 4: others.append(s_str)

        final_text += "-- [[ 🕵️ DEOBFUSCATOR REPORT ]] --\n\n"
        
        if webhooks:
            final_text += "-- [🚨 WEBHOOKS FOUND] --\n"
            for w in webhooks: final_text += f"-- {w}\n"
            final_text += "\n"
            
        if assets:
            final_text += "-- [📦 ASSETS / IDs] --\n"
            for a in assets: final_text += f"-- {a}\n"
            final_text += "\n"

        final_text += "-- [📝 OTHER STRINGS] --\n"
        for o in others: final_text += f"-- {o}\n"
        final_text += "\n" + "="*50 + "\n\n"
        
        # --- DECOMPILATION ---
        if callback: callback("🧬 Декомпиляция...")
        decompiled = self._try_decompile(code_bytes)
        
        if decompiled:
            try:
                src = decompiled.decode('utf-8', 'ignore')
            except:
                src = decompiled.decode('latin-1', 'ignore')
            src = self._beautify_lua(src)
            final_text += src
        else:
            final_text += "-- [WARNING] Decompilation failed. Here is the raw dump.\n"
            final_text += str(code_bytes)

        # --- LOGS ---
        final_text += "\n\n" + "="*50 + "\n-- [[ EXECUTION LOGS ]] --\n"
        for l in logs[-50:]:
            final_text += f"-- {l}\n"

        return final_text.encode('utf-8')

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path): return None
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            # Увеличиваем Heap Memory Java, так как VM файлы огромные
            res = subprocess.run(["java", "-Xss5m", "-Xmx1024m", "-jar", self.unluac_path, path], capture_output=True)
            os.remove(path)
            
            if res.returncode == 0: return res.stdout
            return None # Если ошибка, возвращаем None
        except: return None

    def _beautify_lua(self, source_code):
        # Базовый бьютифайер
        source_code = re.sub(r'(\s)(local|return|if|for|while|repeat|function)(\s)', r'\n\2 ', source_code)
        replacements = { " then ": " then\n", " do ": " do\n", " end ": "\nend\n", ";": ";\n" }
        for k, v in replacements.items(): source_code = source_code.replace(k, v)
        
        lines = source_code.splitlines()
        formatted = []
        indent = 0
        for line in lines:
            line = line.strip()
            if not line: continue
            if line.startswith(("--")): formatted.append(line); continue
            
            if line.startswith(("end", "until", "}", ")", "else", "elseif")):
                indent = max(0, indent - 1)
            
            formatted.append("\t" * indent + line)
            
            if line.endswith(("then", "do", "repeat", "{", "(")) or ("function" in line and not line.endswith("end")):
                indent += 1
            if line.startswith(("else", "elseif")):
                indent += 1
                
        return "\n".join(formatted)
