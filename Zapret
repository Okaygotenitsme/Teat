        # Lupa упадет сразу. Мы должны это обнаружить.
        is_binary_luau = False
        if isinstance(content, bytes):
            if content.startswith(b"\x1BLua") or (len(content) > 0 and content[0] < 32):
                is_binary_luau = True
        
