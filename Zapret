import logging
import subprocess
import os
import tempfile
import re
import shutil

# Логгер
logger = logging.getLogger("DeobfuscatorEngine")

class DeobfuscatorEngine:
    def __init__(self):
        self.base_dir = os.path.dirname(os.path.abspath(__file__))
        
        # Luau для анализа
        self.luau_path = os.path.join(self.base_dir, "luau.exe" if os.name == 'nt' else "luau")
        if not os.path.exists(self.luau_path): self.luau_path = shutil.which("luau")

        # Unluac для байт-кода
        self.unluac_path = os.path.join(self.base_dir, "unluac.jar")

    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        # 1. ОПРЕДЕЛЯЕМ ТИП ФАЙЛА
        is_bytecode = content.startswith(b'\x1bLua')
        
        result_text = ""
        logs, strings, globs = [], [], []

        # 2. ЕСЛИ ЭТО БАЙТ-КОД (скомпилированный)
        if is_bytecode:
            update_status("⚙️ Обнаружен байт-код. Запуск Unluac...")
            decompiled = self._run_unluac(content)
            if decompiled:
                result_text = decompiled
            else:
                result_text = "-- [ERROR] Unluac failed to decompile binary."
        
        # 3. ЕСЛИ ЭТО ТЕКСТ (IronBrew, MoonSec, обычный скрипт)
        else:
            update_status("📜 Обнаружен исходный код. Форматирование...")
            try:
                # Пробуем декодировать текст
                source = content.decode('utf-8', 'ignore')
                result_text = self._beautify_lua(source)
            except:
                result_text = "-- [ERROR] Could not decode text file."

            # Запускаем шпиона Luau ТОЛЬКО для текстовых скриптов
            if self.luau_path:
                update_status("🕵️ Запуск динамического анализа (Luau)...")
                logs, strings, globs = self._run_luau_spy(content)

        # 4. ФИНАЛИЗАЦИЯ
        return self._finalize_output(result_text, strings, globs, logs)

    def _run_luau_spy(self, content):
        """Запускает скрипт в безопасной среде Luau"""
        logs, strings, globs = [], [], []
        try:
            # Декодируем для вставки в шаблон
            user_script = content.decode('utf-8', 'ignore')
        except: return [], [], []

        # Шаблон перехватчика
        emu_code = r"""
        -- :: BRIDGE ::
        local function send(t, d) print("||"..t.."||"..tostring(d)) end
        
        -- :: MOCKS ::
        _G.game = { 
            HttpGet = function(_, u) send("LOG", "🌍 GET: "..u) return "Proxy" end,
            HttpPost = function(_, u) send("LOG", "🌍 POST: "..u) return "Proxy" end
        }
        _G.warn = function(...) send("LOG", "Warn: "..table.concat({...}, " ")) end
        _G.print = function(...) send("LOG", "Print: "..table.concat({...}, " ")) end
        
        -- :: STRING SPY ::
        local old_char = string.char
        string.char = function(...)
            local r = old_char(...)
            if #r > 4 then send("STR", r) end
            return r
        end

        -- :: RUNNER ::
        local s, e = pcall(function() 
        """ + user_script + r""" 
        end)
        
        if not s then send("LOG", "❌ Error: " .. tostring(e)) end
        
        -- Dump globals
        for k,v in pairs(getfenv()) do 
            if type(v) == "string" and #v < 100 then send("GLB", k.."="..v) end 
        end
        """

        # Запись и запуск
        with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='w', encoding='utf-8') as tmp:
            tmp.write(emu_code)
            tmp_path = tmp.name

        try:
            proc = subprocess.run([self.luau_path, tmp_path], capture_output=True, text=True, encoding='utf-8', errors='replace', timeout=5)
            for line in proc.stdout.splitlines():
                if "||STR||" in line: strings.append(line.split("||STR||")[1])
                elif "||LOG||" in line: logs.append(line.split("||LOG||")[1])
                elif "||GLB||" in line: globs.append(line.split("||GLB||")[1])
        except: pass
        
        try: os.remove(tmp_path)
        except: pass
        
        return logs, strings, globs

    def _run_unluac(self, bytecode):
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            res = subprocess.run(["java", "-jar", self.unluac_path, path], capture_output=True, timeout=10)
            os.remove(path)
            if res.returncode == 0: return res.stdout.decode('utf-8', 'ignore')
        except: pass
        return None

    def _finalize_output(self, code_text, strings, globs, logs):
        out = []
        out.append("-- [[ ROBOT DEOBFUSCATOR REPORT ]] --")
        
        if strings:
            out.append("\n-- [ DECRYPTED STRINGS ] --")
            for s in list(set(strings))[:50]: out.append(f'-- "{s}"')
            
        if logs:
            out.append("\n-- [ EXECUTION LOGS ] --")
            for l in logs: out.append(f"-- {l}")

        out.append("\n" + "="*50 + "\n")
        out.append("-- [ SOURCE CODE ] --\n")
        out.append(code_text)
        
        return "\n".join(out).encode('utf-8')

    def _beautify_lua(self, source):
        """Простой алгоритм форматирования кода"""
        # Убираем лишние пробелы
        source = re.sub(r'\s+', ' ', source)
        
        # Вставляем переносы строк после ключевых слов
        replacements = {
            " local ": "\nlocal ",
            " function ": "\nfunction ",
            " if ": "\nif ",
            " then ": " then\n\t",
            " end ": "\nend\n",
            " return ": "\nreturn ",
            " do ": " do\n\t",
            " repeat ": "\nrepeat\n\t",
            " until ": "\nuntil ",
            ";": ";\n"
        }
        for k, v in replacements.items():
            source = source.replace(k, v)
            
        # Пытаемся восстановить отступы (примитивно)
        lines = source.split('\n')
        indent = 0
        formatted = []
        for line in lines:
            line = line.strip()
            if not line: continue
            
            # Уменьшаем отступ для закрывающих конструкций
            if line.startswith("end") or line.startswith("until") or line.startswith("}"):
                indent = max(0, indent - 1)
                
            formatted.append(("\t" * indent) + line)
            
            # Увеличиваем отступ для открывающих
            if (line.endswith("then") or line.endswith("do") or line.endswith("repeat") or 
                line.endswith("{") or line.endswith("(")):
                indent += 1
                
        return "\n".join(formatted)
