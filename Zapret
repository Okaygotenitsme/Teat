@dp.message(F.document)
async def handle_document(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        await message.answer("❌ Мне нужен файл .lua или .txt")
        return

    status = await message.answer("🛡 Применяю гипер-защиту Meloten...")
    
    try:
        file_in_memory = io.BytesIO()
        await bot.download(message.document, destination=file_in_memory)
        source_code = file_in_memory.getvalue().decode('utf-8', errors='ignore')

        obfuscator = MelotenHyperVM(source_code)
        protected_code = obfuscator.build()

        output = BufferedInputFile(protected_code.encode('utf-8'), filename=f"Protected_{message.document.file_name}")
        await message.answer_document(output, caption="✅ Код успешно обфусцирован для Roblox!")
        await status.delete()

    except Exception as e:
        await message.answer(f"⚠️ Ошибка: {str(e)}")

