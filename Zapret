local DataStoreService = game:GetService("DataStoreService")
local Players = game:GetService("Players")

-- Создаем "хранилище" с названием GameData
local gameDataStore = DataStoreService:GetDataStore("PlayerSave_v1")

local function onPlayerAdded(player)
	local ls = Instance.new("Folder")
	ls.Name = "leaderstats"
	ls.Parent = player

	local wins = Instance.new("IntValue")
	wins.Name = "Wins"
	wins.Parent = ls

	local cups = Instance.new("IntValue")
	cups.Name = "Cups"
	cups.Parent = ls

	-- Пытаемся загрузить данные
	local success, data = pcall(function()
		return gameDataStore:GetAsync(player.UserId)
	end)

	if success and data then
		wins.Value = data.Wins or 0
		cups.Value = data.Cups or 0
		print("Данные игрока " .. player.Name .. " загружены!")
	else
		print("Новый игрок или ошибка загрузки.")
	end
end

local function onPlayerRemoving(player)
	-- Сохраняем данные при выходе
	local dataToSave = {
		Wins = player.leaderstats.Wins.Value,
		Cups = player.leaderstats.Cups.Value
	}
	
	local success, err = pcall(function()
		gameDataStore:SetAsync(player.UserId, dataToSave)
	end)
	
	if success then
		print("Данные " .. player.Name .. " сохранены.")
	else
		warn("Ошибка сохранения: " .. err)
	end
end

Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoving:Connect(onPlayerRemoving)
