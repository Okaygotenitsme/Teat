# --- МОДУЛЬ BEAUTIFIER (Оставил Python-версию для кнопки Beautify) ---
class LuaBeautifier:
    def __init__(self, source):
        self.source = source

    def format(self):
        code = self.source
        lines = [line.strip() for line in code.splitlines() if line.strip()]
        formatted = []
        indent = 0
        indent_str = "    "
        
        up_keywords = ['function', 'do', 'then', 'repeat', '{', '(', 'if']
        down_keywords = ['end', 'until', '}', ')', 'elseif']
        
        for line in lines:
            curr = line.lower()
            if any(curr.startswith(k) for k in ['end', 'until', '}', ')', 'elseif', 'else']):
                indent = max(0, indent - 1)
            formatted.append((indent_str * indent) + line)
            open_count = sum(1 for k in up_keywords if k in curr)
            close_count = sum(1 for k in down_keywords if k in curr)
            if not ('function' in curr and 'end' in curr):
                if open_count > close_count: indent += 1
                elif 'else' == curr: indent += 1
        return "\n".join(formatted)

