    # Собираем всё в один текст
    final_text = '\n'.join(report)
    return final_text.encode('utf-8', errors='ignore')

def _safe_string(self, s: any) -> str:
    """Безопасное преобразование в строку"""
    if isinstance(s, bytes):
        try:
            return s.decode('utf-8', errors='ignore')
        except:
            return str(s)
    
    s_str = str(s)
    # Удаляем потенциально проблемные символы
    s_str = s_str.replace('\r', ' ').replace('\n', ' ').replace('\t', ' ')
    # Обрезаем длинные строки
    if len(s_str) > 200:
        s_str = s_str[:200] + "..."
    return s_str

def _beautify_lua(self, source_code: str) -> str:
    """Улучшенное форматирование Lua-кода"""
    
    # Добавляем переносы строк после ключевых слов
    keywords = [
        'then', 'do', 'repeat', 'function',
        'local function', 'end', 'until', 'else', 'elseif'
    ]
    
    for keyword in keywords:
        # Добавляем перенос после then/do
        if keyword in ['then', 'do']:
            source_code = re.sub(rf'\b{keyword}\b', f'{keyword}\n', source_code)
        # Добавляем перенос до end/until/else
        elif keyword in ['end', 'until', 'else', 'elseif']:
            source_code = re.sub(rf'\b{keyword}\b', f'\n{keyword}', source_code)
    
    # Добавляем переносы после точки с запятой
    source_code = source_code.replace(';', ';\n')
    
    # Убираем множественные пустые строки
    source_code = re.sub(r'\n{3,}', '\n\n', source_code)
    
    # Базовая индентация (упрощённая)
    lines = source_code.split('\n')
    indented = []
    indent_level = 0
    
    for line in lines:
        stripped = line.strip()
        if not stripped:
            indented.append('')
            continue
        
        # Уменьшаем отступ перед end/until/else
        if stripped.startswith(('end', 'until', 'else', 'elseif')):
            indent_level = max(0, indent_level - 1)
        
        indented.append('    ' * indent_level + stripped)
        
        # Увеличиваем отступ после then/do/repeat/function
        if stripped.endswith(('then', 'do', 'repeat')) or stripped.startswith('function'):
            indent_level += 1
    
    return '\n'.join(indented)
