        final_text += "-- Engine: Python + LuaJIT + Unluac\n\n"

        # --- SECTION 1: DECRYPTED STRINGS ---
        final_text += "-- [[ 🔎 FOUND STRINGS ]] --\n"
        sorted_strings = sorted(strings, key=lambda x: len(str(x)), reverse=True)
        seen = set()
        count = 0
        for s in sorted_strings:
            clean = self._clean_string(s).replace('\n', ' ').replace('\r', '')
            # Фильтр совсем мусора
            if clean not in seen and len(clean) > 3 and count < 200:
                # Убираем явный байт-код из вывода строк
                if not clean.startswith("\x1b"):
                    final_text += f'-- "{clean}"\n'
                    seen.add(clean)
                    count += 1
        
        final_text += f"\n-- Total strings found: {len(seen)}\n"
        final_text += "="*60 + "\n\n"

        # --- SECTION 2: REMOTE SPY / LOGS ---
