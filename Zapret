logger = logging.getLogger("DeobfuscatorEngine")

class DeobfuscatorEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        logger.info(f"📁 Working Dir: {base_dir}")
        
        # Статистика работы
        self.stats = {
            'strings_captured': 0,
            'chunks_intercepted': 0,
            'http_requests': 0,
            'bytecode_decoded': 0,
            'variables_dumped': 0
        }

    def process(self, content: bytes, status_callback: Optional[Callable] = None) -> bytes:
        """Главная функция обработки"""
        def update_status(msg: str):
            if status_callback: 
                status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        # === ЭТАП 1: ПРОВЕРКА JAVA ===
        if not self._check_java():
            return b"-- [FATAL] Java not found. Install Java 8+ to use unluac decompiler."

        update_status("🔍 Анализ структуры файла...")
        
        # === ЭТАП 2: ДЕТЕКТИРОВАНИЕ ТИПА ОБФУСКАЦИИ ===
        obf_type = self._detect_obfuscation_type(content)
        update_status(f"🧬 Обнаружен тип: {obf_type}")
        
        # === ЭТАП 3: ПРЕДОБРАБОТКА (ПАТЧИНГ) ===
        content = self._preprocess_script(content, obf_type)
        
        # === ЭТАП 4: ИНИЦИАЛИЗАЦИЯ LUA VM ===
        update_status("🧠 Инициализация виртуальной среды Roblox...")
        try:
            lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)
        except Exception as e:
            return f"-- [FATAL] Lua VM initialization failed: {e}".encode('utf-8')

        # === ЭТАП 5: НАСТРОЙКА ОКРУЖЕНИЯ ===
        # Битовые операции (критично для MoonSec/IronBrew)
        lua.execute(self._get_bit_polyfill())
        
        # Эмуляция Roblox API
        lua.execute(self._get_roblox_environment())
        
        # Система перехвата (спайвер)
        lua.execute(self._get_spyware_hooks())
        
        # Дополнительные хуки для конкретных обфускаторов
        if obf_type == "MoonSec":
            lua.execute(self._get_moonsec_hooks())
        elif obf_type == "IronBrew":
            lua.execute(self._get_ironbrew_hooks())
        elif obf_type == "Luraph":
            lua.execute(self._get_luraph_hooks())
        
        # === ЭТАП 6: ЗАПУСК СКРИПТА ===
        update_status("🌪️ Запуск скрипта с трассировкой...")
        
        try:
            # Создаём безопасный раннер
            runner = lua.eval("""
                function(code)
                    _G.EXECUTION_STARTED = true
                    local success, error_msg = pcall(function()
                        -- Загружаем код в изолированном окружении
                        local env = setmetatable({}, {__index = _G})
                        local func, load_err = load(code, "=deobf_script", "t", env)
                        
                        if not func then
                            table.insert(_G.ACTION_LOG, "❌ Load Error: " .. tostring(load_err))
                            error(load_err)
                        end
                        
                        -- Запускаем с тайм-лимитом (эмуляция)
                        func()
                    end)
                    
                    if not success then
                        table.insert(_G.ACTION_LOG, "⚠️ Runtime Error: " .. tostring(error_msg))
                    end
                    
                    _G.EXECUTION_FINISHED = true
                    
                    -- Финальный дамп окружения
                    pcall(_G.dump_globals)
                    pcall(_G.dump_locals)
                    
                    return success
                end
            """)
            
            # ЗАПУСК
            execution_result = runner(content.decode('utf-8', errors='ignore'))
            
        except Exception as e:
            logger.error(f"Execution error: {e}")
            return f"-- [CRASH] Execution failed: {str(e)}".encode('utf-8')
        
        # === ЭТАП 7: СБОР ДАННЫХ ===
        update_status("📊 Сбор результатов анализа...")
        
        # Строки (расшифрованные)
        strings_tbl = lua.globals().DETECTED_STRINGS or {}
        detected_strings = list(strings_tbl.keys()) if hasattr(strings_tbl, 'keys') else list(strings_tbl)
        self.stats['strings_captured'] = len(detected_strings)
        
        # Перехваченные чанки (распакованный код)
        chunks = lua.globals().CAPTURED_CHUNKS or []
        chunk_list = [chunks[i] for i in range(1, len(chunks) + 1)] if len(chunks) > 0 else []
        self.stats['chunks_intercepted'] = len(chunk_list)
        
        # HTTP-запросы
        http_log = list(lua.globals().HTTP_LOG or [])
        self.stats['http_requests'] = len(http_log)
        
        # Глобальные переменные
        global_dump = list(lua.globals().FINAL_GLOBALS or [])
        self.stats['variables_dumped'] = len(global_dump)
        
        # Локальные переменные
        local_dump = list(lua.globals().FINAL_LOCALS or [])
        
        # Логи действий
        action_log = list(lua.globals().ACTION_LOG or [])
        
        # Remote Events (RemoteSpy)
        remote_events = list(lua.globals().REMOTE_EVENTS or [])
        
        # === ЭТАП 8: ВЫБОР ЛУЧШЕГО ЧАНКА ===
        best_chunk = self._select_best_chunk(chunk_list, content)
        
        # === ЭТАП 9: ДЕКОМПИЛЯЦИЯ ===
        update_status("🔧 Декомпиляция байткода...")
        decompiled = self._try_decompile(best_chunk)
        
        # === ЭТАП 10: ФОРМИРОВАНИЕ ФИНАЛЬНОГО ФАЙЛА ===
        update_status("📝 Формирование отчёта...")
        
        return self._build_final_report(
            decompiled=decompiled,
            detected_strings=detected_strings,
            global_dump=global_dump,
            local_dump=local_dump,
            action_log=action_log,
            http_log=http_log,
            remote_events=remote_events,
            obf_type=obf_type,
            original_code=content
        )

    # ============================================================
    # ВСПОМОГАТЕЛЬНЫЕ МЕТОДЫ
    # ============================================================
    
    def _check_java(self) -> bool:
        """Проверка наличия Java"""
        try:
            result = subprocess.run(
                ["java", "-version"], 
                stdout=subprocess.DEVNULL, 
                stderr=subprocess.DEVNULL,
                timeout=5
            )
            return result.returncode == 0
        except:
            return False

    def _detect_obfuscation_type(self, content: bytes) -> str:
        """Определение типа обфускатора по сигнатурам"""
        try:
            text = content.decode('utf-8', errors='ignore').lower()
        except:
            text = str(content).lower()
        
        # Сигнатуры обфускаторов
        signatures = {
            'MoonSec': ['moonsec', 'bit.bxor', 'getfenv', 'setfenv', 'qjjjj'],
            'IronBrew': ['ironbrew', 'vmstack', 'vmenv', 'opcode'],
            'Luraph': ['luraph', 'lr_', '__lr_', 'luraph_decrypt'],
            'PSU': ['psu obfuscator', 'encrypted_code'],
            'Prometheus': ['prometheus', 'promethean'],
            'BytecodeVM': ['bytecode', 'vm_step', 'instruction']
        }
        
        for obf_name, keywords in signatures.items():
            if any(kw in text for kw in keywords):
                return obf_name
        
        # Эвристика: если есть длинные hex-строки — вероятно байткод
        if re.search(r'[0-9a-f]{100,}', text):
            self.stats['bytecode_decoded'] += 1
            return "Custom Bytecode"
        
        return "Unknown/Generic"

    def _preprocess_script(self, content: bytes, obf_type: str) -> bytes:
        """Предобработка: патчинг известных анти-дебаг трюков"""
        try:
            text = content.decode('utf-8', errors='ignore')
        except:
            return content
        
        # Удаляем анти-дебаг проверки
        anti_debug_patterns = [
            r'if\s+.*debug\s*\(.*\)\s+then.*end',
            r'while\s+true\s+do\s+end',  # Бесконечный цикл
            r'error\s*\(\s*["\'].*decompil.*["\']\s*\)',
            r'assert\s*\(\s*false.*\)',
        ]
        
        for pattern in anti_debug_patterns:
            text = re.sub(pattern, '-- [PATCHED ANTI-DEBUG]', text, flags=re.IGNORECASE)
        
        # Специфичные патчи
        if obf_type == "Luraph":
            # Luraph часто использует require() для анти-дампинга
            text = text.replace('require(', '-- require(')
        
        return text.encode('utf-8')

    def _select_best_chunk(self, chunks: List, original: bytes) -> bytes:
        """Выбор наилучшего перехваченного чанка"""
        if not chunks:
            return original
        
        # Сортируем по размеру (больше = вероятнее оригинал)
        sorted_chunks = sorted(chunks, key=lambda c: c.get('size', 0), reverse=True)
        
        for chunk in sorted_chunks:
            data = chunk.get('data', b'')
            if isinstance(data, str):
                data = data.encode('utf-8')
            
            # Проверяем, что это валидный Lua-код
            if self._is_valid_lua(data):
                return data
        
        # Если ничего не подошло — возвращаем самый большой
        return sorted_chunks[0].get('data', original)

    def _is_valid_lua(self, data: bytes) -> bool:
        """Проверка на валидность Lua-кода"""
        try:
            text = data.decode('utf-8', errors='ignore')
            # Простая эвристика: должны быть ключевые слова
            keywords = ['function', 'local', 'end', 'return']
            return any(kw in text for kw in keywords) and len(text) > 50
        except:
            return False

    # ============================================================
    # ДЕКОМПИЛЯЦИЯ
    # ============================================================
    
    def _try_decompile(self, bytecode: bytes) -> Optional[bytes]:
        """Попытка декомпиляции через unluac"""
        if not os.path.exists(self.unluac_path):
            logger.warning("unluac.jar not found — skipping decompilation")
            return None
        
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".luac", mode='wb') as tmp:
                tmp.write(bytecode)
                tmp_path = tmp.name
            
            result = subprocess.run(
                ["java", "-Xmx1G", "-jar", self.unluac_path, tmp_path],
                capture_output=True,
                timeout=30
            )
            
            os.remove(tmp_path)
            
            if result.returncode == 0 and len(result.stdout) > 0:
                return result.stdout
            else:
                logger.warning(f"Unluac failed: {result.stderr.decode('utf-8', errors='ignore')}")
                return None
                
        except subprocess.TimeoutExpired:
            logger.error("Unluac timeout")
            return None
        except Exception as e:
            logger.error(f"Decompilation error: {e}")
            return None

