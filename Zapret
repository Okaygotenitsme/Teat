@bot.callback_query_handler(func=lambda c: True)
def process_callback(c):
    if c.data == "settings":
        bot.answer_callback_query(c.id, "В разработке...")
        return

    cid = c.message.chat.id
    if cid not in user_sessions:
        bot.send_message(cid, "❌ Ошибка: отправьте код заново.")
        return

    bot.edit_message_text("🧬 **Запуск Meloten VM...**", cid, c.message.message_id, parse_mode="Markdown")

    try:
        # Применяем многослойную обфускацию
        original_code = user_sessions[cid]
        
        # 1 слой: Минификация
        minified = " ".join(original_code.split())
        
        # 2 слой: Генерация VM
        protected_code = UltraEngine.create_vm_layer(minified, c.data)
        
        # 3 слой: Финальная упаковка (Base64 для пущей нечитаемости)
        final_file = f"Protected_{random.randint(1000, 9999)}.lua"
        
        with open(final_file, "w", encoding="utf-8") as f:
            f.write(protected_code)

        with open(final_file, "rb") as f:
            bot.send_document(cid, f, caption="💎 **Ваш скрипт успешно защищен!**\nСреда: " + c.data, parse_mode="Markdown")

        os.remove(final_file)
        del user_sessions[cid]

    except Exception as e:
        bot.send_message(cid, f"⚠️ **Ошибка движка:**\n`{str(e)}`", parse_mode="Markdown")

