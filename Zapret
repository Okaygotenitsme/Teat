class MelotenHyperVM:
    def __init__(self, source):
        self.source = source
        self.key = random.randint(100, 255)
        self.seed = random.randint(1000, 9999)
        # Генерация нечитаемых переменных
        self.vars = {f"v{i}": self._rand_name() for i in range(10)}

    def _rand_name(self):
        return "Meloten_" + "".join(random.choices("lI1", k=12))

    def build(self):
        # 1. Заголовок
        header = "--[[Protected by Meloten Hyper-VM v5.0\nURL: http://t.me/Meloten_Obfuscator_bot]]\n"
        
        # 2. Двойное XOR шифрование
        bytes_data = [(ord(c) ^ self.key) ^ (self.seed % 255) for c in self.source]
        payload = "{" + ",".join(map(str, bytes_data)) + "}"
        
        # 3. Код VM с защитой от хуков (Anti-Hook)
        # Мы проверяем, не является ли функция loadstring "подделкой"
        vm_logic = (
            f"local {self.vars['v1']}={payload};"
            f"local {self.vars['v2']}={self.key};"
            f"local {self.vars['v3']}={self.seed};"
            f"local {self.vars['v4']}=getfenv();"
            f"local {self.vars['v5']}=string.char;"
            f"local {self.vars['v6']}=bit32.bxor;"
            f"local {self.vars['v7']}='';"
            f"if {self.vars['v4']}.loadstring~=loadstring then while true do end end;" # Anti-Hook check
            f"for i=1,#{self.vars['v1']} do "
            f"local b={self.vars['v6']}({self.vars['v1']}[i],{self.vars['v2']});"
            f"{self.vars['v7']}={self.vars['v7']}..{self.vars['v5']}({self.vars['v6']}(b,{self.vars['v3']}%255));"
            f"if i%400==0 then task.wait() end "
            f"end;"
            f"local {self.vars['v8']}, {self.vars['v9']} = loadstring({self.vars['v7']});"
            f"{self.vars['v7']}=nil;"
            f"if not {self.vars['v8']} then warn('Integrity Breach!') return end;"
            f"task.spawn({self.vars['v8']})"
        )
        
        # Минификация в одну строку
        one_liner = vm_logic.replace("  ", "").replace("\n", "")
        return header + one_liner

