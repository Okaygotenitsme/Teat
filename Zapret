version "4.10" // Версия GZDoom

// ФАЗА 1: Слабый монстр
class Phase1Zombie : Zombieman // Наследуем свойства обычного зомби
{
    Default
    {
        Health 50;
        Tag "Зараженный (Фаза 1)";
    }

    States
    {
    Death:
        // Когда здоровье падает до 0, проигрывается эта анимация
        POSS M 5;
        POSS N 5;
        // Ключевой момент: спавним Фазу 2 на месте смерти Фазы 1
        TNT1 A 0 A_SpawnItemEx("Phase2Zombie", 0, 0, 0, 0, 0, 0, 0, SXF_TRANSFERPOINTERS);
        Stop; // Исчезаем, уступая место второй фазе
    }
}

// ФАЗА 2: Сильный монстр
class Phase2Zombie : Zombieman
{
    Default
    {
        Health 200; // Намного больше здоровья
        Speed 15;   // Бегает быстрее
        Scale 1.2;  // Чуть больше в размерах
        Translation "112:127=176:191"; // Перекрасим его в красный цвет
        Tag "Кровавый зомби (Фаза 2)";
    }

    States
    {
    // Здесь он просто ведет себя как обычный зомби, но он сильнее
    Death:
        POSS H 5;
        POSS I 5;
        POSS J 5;
        POSS K 5;
        POSS L -1; // Просто падает и остается лежать
        Stop;
    }
}
