#!/usr/bin/env python3
# meloten_obfuscator_v6_bot.py
import asyncio
import logging
import random
import string
import io
import traceback

from aiogram import Bot, Dispatcher, types, F
from aiogram.filters import Command, CommandObject
from aiogram.types import BufferedInputFile

# --- КОНФИГУРАЦИЯ ---
API_TOKEN = "ВСТАВЬ_СЮДА_НОВЫЙ_ТОКЕН"  # <-- замените на ваш токен

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

bot = Bot(token=API_TOKEN)
dp = Dispatcher()

# --- MELOTEN OBFUSCATOR V6 (Rolling Key VM) ---
class MelotenObfuscatorV6:
    def __init__(self, source: str):
        self.source = source or ""
        # начальный ключ в диапазоне 150..250 (можно менять)
        self.key = random.randint(150, 250)
        # Генерируем "злые" имена переменных (I1l0O...)
        self.v = {
            "dec_func": self._n(),  # Функция дешифровки
            "byte_table": self._n(),  # Таблица данных
            "key_var": self._n(),  # Переменная ключа
            "idx": self._n(),  # Счетчик (unused but reserved)
            "str_res": self._n(),  # Итоговая строка
            "dummy": self._n(),  # Пустышка
        }

    def _n(self) -> str:
        """Генератор запутанных имен (Il1l0O)"""
        length = random.randint(12, 25)
        return "".join(random.choices("Il1O0", k=length))

    def _junk_code(self) -> str:
        """Генерирует мусор для сбивания с толку"""
        vars_ = [self._n() for _ in range(3)]
        ops = [
            f"local {vars_[0]} = function(a) return a*2 end",
            f"local {vars_[1]} = {{ 0x1, 0x2, 0x3 }}; -- Memory Check",
            f"if {random.randint(1,10)} > 20 then return end",
            f"local {vars_[2]} = {random.randint(0,9999)} -- filler",
        ]
        # Возвращаем случайные 2 строки из ops
        return "\n".join(random.sample(ops, min(2, len(ops))))

    def build(self) -> str:
        # 1. Очистка исходника: убираем комментарии типа --...
        lines = [
            line for line in self.source.splitlines()
            if not line.strip().startswith("--")
        ]
        clean_source = "\n".join(lines) if lines else self.source

        # 2. Rolling Key Encryption (Плавающий ключ)
        raw_bytes = clean_source.encode("utf-8", errors="ignore")
        enc_data = []
        current_key = int(self.key)

        for b in raw_bytes:
            # Шифруем: (Байт + Ключ) % 256
            encrypted_byte = (b + current_key) % 256
            enc_data.append(encrypted_byte)
            # Обновляем ключ для следующего байта (LCG)
            current_key = (current_key * 1664525 + 1013904223) % 4294967296
            current_key = int(current_key % 255)

        # Превращаем данные в строку таблицы Lua: {12,55,23...}
        table_str = "{" + ",".join(map(str, enc_data)) + "}"

        # 3. Создаем загрузчик (Loader) на Lua
        loader = (
            f"--[[\n\nMeloten Security V6\nProtected by Advanced Rolling Algorithm\n]]\n"
            f"local {self.v['byte_table']} = {table_str}\n"
            f"local {self.v['key_var']} = {self.key}\n\n"
            f"{self._junk_code()}\n\n"
            f"local function {self.v['dec_func']}(data, key)\n"
            f"    local {self.v['str_res']} = {{}}\n"
            f"    local current_k = key\n\n"
            f"    for i = 1, #data do\n"
            f"        local enc = data[i]\n"
            f"        -- Обратная операция: (enc - key) % 256\n"
            f"        local dec = (enc - current_k) % 256\n"
            f"        if dec < 0 then dec = dec + 256 end\n"
            f"        table.insert({self.v['str_res']}, string.char(dec))\n\n"
            f"        -- Обновление ключа (то же LCG)\n"
            f"        current_k = (current_k * 1664525 + 1013904223) % 4294967296\n"
            f"        current_k = current_k % 255\n"
            f"    end\n"
            f"    return table.concat({self.v['str_res']})\n"
            f"end\n\n"
            f"{self._junk_code()}\n\n"
            f"local _loader = loadstring or load\n"
            f"local _code = {self.v['dec_func']}({self.v['byte_table']}, {self.v['key_var']})\n"
            f"if getgenv then getgenv().Meloten_Secure = true end\n"
            f"pcall(_loader(_code))\n"
        )
        return loader


# --- ОБРАБОТЧИКИ ---
@dp.message(Command("start"))
async def start(message: types.Message):
    await message.answer(
        "🛡 Meloten Obfuscator V6\n\n"
        "Я обновился! Теперь защита ещё сложнее.\n"
        "Напиши /help чтобы увидеть список команд.",
        parse_mode="Markdown",
    )


@dp.message(Command("help"))
async def help_command(message: types.Message):
    await message.answer(
        "📜 Список команд:\n\n"
        "1️⃣ Отправь файл (.lua или .txt) — я зашифрую его методом V6.\n"
        "2️⃣ /loadstring <ссылка> — сгенерирую loadstring для скрипта.\n"
        "3️⃣ /start — перезапустить бота.\n\n"
        "🐱 Секрет: Попробуй написать мне 'meow'.",
        parse_mode="Markdown",
    )


@dp.message(Command("loadstring"))
async def make_loadstring(message: types.Message, command: CommandObject):
    if not command.args:
        await message.answer("⚠️ Пример: /loadstring https://raw.githubuser....")
        return

    url = command.args.strip()
    content = f'loadstring(game:HttpGet("{url}"))()'

    file_output = BufferedInputFile(
        content.encode("utf-8"),
        filename="loader.lua",
    )

    await message.answer_document(
        file_output,
        caption="✅ **Loadstring сгенерирован**",
        parse_mode="Markdown",
    )


@dp.message(F.text)
async def meow_handler(message: types.Message):
    # Игнорируем команды
    if message.text.startswith("/"):
        return

    text = message.text.lower()
    if "meow" in text or "мяу" in text:
        count = random.randint(1, 10)
        await message.answer(" ".join(["meow"] * count))


@dp.message(F.document)
async def handle_docs(message: types.Message):
    # Поддерживаем .lua и .txt
    name = (message.document.file_name or "").lower()
    if not name.endswith((".lua", ".txt")):
        await message.answer("❗ Поддерживаемые расширения: .lua, .txt")
        return

    status = await message.answer("🔒 **Защита V6 (Rolling Key)...**", parse_mode="Markdown")
    try:
        # Скачиваем файл в память (BytesIO)
        bio = io.BytesIO()
        await message.document.download(destination=bio)
        bio.seek(0)
        raw = bio.read()
        try:
            source = raw.decode("utf-8")
        except Exception:
            source = raw.decode("utf-8", errors="ignore")

        # Обфускация V6
        obf = MelotenObfuscatorV6(source)
        protected_code = obf.build()

        output = BufferedInputFile(
            protected_code.encode("utf-8"),
            filename=f"Protected_{message.document.file_name}",
        )

        await message.answer_document(
            output,
            caption="✅ **Скрипт защищен (V6)!**\nМетод: Rolling Key Encryption + Junk Code.\n\nКоманды: /help",
        )

        # удаляем статус (если возможно)
        try:
            await status.delete()
        except Exception:
            pass

        # очищаем память
        del source, protected_code, raw, bio

    except Exception as e:
        logger.error("Error in handle_docs: %s", traceback.format_exc())
        await message.answer(f"❌ Ошибка: {e}")


async def main():
    logger.info("--- MELOTEN V6 STARTED ---")
    try:
        # start polling
        await dp.start_polling(bot)
    finally:
        await bot.session.close()


if __name__ == "__main__":
    try:
        asyncio.run(main())
    except (KeyboardInterrupt, SystemExit):
        print("Bot off")
