-- ServerScriptService/InitServer
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local MAX_ENERGY = 10
local ENERGY_REGEN_INTERVAL = 2

local function ensureRemote(name)
	local e = ReplicatedStorage:FindFirstChild(name)
	if not e then
		e = Instance.new("RemoteEvent")
		e.Name = name
		e.Parent = ReplicatedStorage
	end
	return e
end

ensureRemote("SpawnEvent")
ensureRemote("SpawnResponse")

if not ReplicatedStorage:FindFirstChild("Units") then
	local f = Instance.new("Folder")
	f.Name = "Units"
	f.Parent = ReplicatedStorage
end

local function createStatsFor(player)
	if not player.Parent then return end

	if not player:FindFirstChild("leaderstats") then
		local ls = Instance.new("Folder")
		ls.Name = "leaderstats"
		ls.Parent = player

		local wins = Instance.new("IntValue")
		wins.Name = "Wins"
		wins.Value = 0
		wins.Parent = ls

		local cups = Instance.new("IntValue")
		cups.Name = "Cups"
		cups.Value = 0
		cups.Parent = ls
	end

	if not player:FindFirstChild("PrivateStats") then
		local private = Instance.new("Folder")
		private.Name = "PrivateStats"
		private.Parent = player

		local energy = Instance.new("IntValue")
		energy.Name = "Energy"
		energy.Value = MAX_ENERGY
		energy.Parent = private

		spawn(function()
			while player.Parent do
				wait(ENERGY_REGEN_INTERVAL)
				if energy.Value < MAX_ENERGY then
					energy.Value = math.clamp(energy.Value + 1, 0, MAX_ENERGY)
				end
			end
		end)
	end
end

Players.PlayerAdded:Connect(createStatsFor)

for _, pl in ipairs(Players:GetPlayers()) do
	createStatsFor(pl)
end
