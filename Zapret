logger = logging.getLogger("DeobfuscatorEngine")

class TimeoutException(Exception): 
    pass

@contextmanager
def time_limit(seconds):
    """Защита от зависаний (Windows-совместимая)"""
    timer = None
    is_timeout = [False]
    
    def timeout_handler():
        is_timeout[0] = True
    
    timer = threading.Timer(seconds, timeout_handler)
    timer.start()
    
    try:
        yield
        if is_timeout[0]:
            raise TimeoutException("Execution timeout")
    finally:
        timer.cancel()

class DeobfuscatorEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        logger.info(f"📁 Working Dir: {base_dir}")
        
        # Расширенные паттерны обфускаторов
        self.obfuscator_patterns = {
            'PSU': rb'PSU|Psu Obfuscator|wOwOwOwOwO|PSU_HEADER',
            'MoonSec': rb'MoonSec|v3rm\.moonsec|MOONSEC_|Rerubi',
            'IronBrew': rb'IronBrew|Ironbrew2|IRONBREW',
            'Luraph': rb'Luraph|LPH_|LURAPH_',
