        # Double encoding: first gzip-like, then base64
        import zlib
        compressed = zlib.compress(source_code.encode('utf-8'))
        b64_source = base64.b64encode(compressed).decode('utf-8')
        
        raw_bytes = b64_source.encode('utf-8')
        enc_bytes = []
        for i, b in enumerate(raw_bytes):
            mutator1 = (i * 7 + i % 3) % 255
            mutator2 = (i * 5 + (i // 3)) % 255
            dyn1 = (self.key1 + mutator1) % 255
            dyn2 = (self.key2 + mutator2) % 255
            val = b ^ dyn1 ^ dyn2
            enc_bytes.append(val)
        
        payload = "".join([f"\\{b}" for b in enc_bytes])

