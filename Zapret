# --- MELOTEN OBFUSCATOR V3 (POLYMORPHIC) ---
class MelotenObfuscatorV3:
    def __init__(self, source):
        self.source = source
        self.key_seed = random.randint(100, 255)
        # Генерируем "спагетти" имена (Ill1l) чтобы запутать чтение
        self.vars = {
            'str_var': self._gen_var(),
            'res_var': self._gen_var(),
            'idx_var': self._gen_var(),
            'byte_var': self._gen_var(),
            'func_dec': self._gen_var(),
            'xor_func': self._gen_var()
        }

    def _gen_var(self):
        """Генерирует имена типа Il1l1I"""
        length = random.randint(8, 15)
        return ''.join(random.choices("Il1", k=length))

    def _minify_lua_xor(self):
        """Возвращает Lua функцию для XOR (работает везде: Lua 5.1, Luau, LuaJIT)"""
        # Эта функция реализует XOR чисто математически для совместимости
        fn_name = self.vars['xor_func']
        return f"""
local function {fn_name}(a, b)
    local p, c = 1, 0
    while a > 0 and b > 0 do
        local ra, rb = a % 2, b % 2
        if ra ~= rb then c = c + p end
        a, b, p = (a - ra) / 2, (b - rb) / 2, p * 2
    end
    if a < b then a = b end
    while a > 0 do
        local ra = a % 2
        if ra > 0 then c = c + p end
        a, p = (a - ra) / 2, p * 2
    end
    return c
end
"""

    def build(self):
        # 1. Очистка
        lines = [line for line in self.source.splitlines() if not line.strip().startswith("--")]
        clean_source = "\n".join(lines)
        if not clean_source: clean_source = self.source

        # 2. Polymorphic Encryption
        # Ключ зависит от предыдущего зашифрованного байта. Это ломает простые XOR-декодеры.
        raw_bytes = clean_source.encode('utf-8')
        encrypted_bytes = []
        last_cipher = self.key_seed

        for byte in raw_bytes:
            # Шифруем: Byte XOR Key XOR Last_Cipher
            curr_cipher = byte ^ self.key_seed ^ (last_cipher % 255)
            encrypted_bytes.append(curr_cipher)
            last_cipher = curr_cipher # Обновляем ключ для следующего шага

        # Превращаем в строку Lua escapes
        payload = "".join([f"\\{b}" for b in encrypted_bytes])

        # 3. Генерация VM
        v = self.vars
        xor_logic = self._minify_lua_xor()
        
        vm_code = f"""--[[ Meloten Obfuscator V3 ]]
local bit = bit32 or require("bit") -- Fallback check
{xor_logic}
local function {v['func_dec']}(str, key)
    local {v['res_var']} = {{}}
    local last = key
    for {v['idx_var']} = 1, #str do
        local {v['byte_var']} = string.byte(str, {v['idx_var']})
        -- Decryption logic
        local decoded = {v['xor_func']}({v['xor_func']}({v['byte_var']}, key), last % 255)
        last = {v['byte_var']}
        table.insert({v['res_var']}, string.char(decoded))
    end
    return table.concat({v['res_var']})
end

local {v['str_var']} = "{payload}"
local run_func = loadstring or load
local final_code = {v['func_dec']}({v['str_var']}, {self.key_seed})
pcall(run_func(final_code))
"""
        return vm_code

