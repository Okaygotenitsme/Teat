            f"❌ **Ошибка**\nСкрипт нерабочий.\nПерепишите код.\n\n`{e}`",
            cid,
            c.message.message_id,
            parse_mode="Markdown"
        )
        return

    name = f"Meloten_Obfuscated_{env}.lua"
    with open(name, "w", encoding="utf-8") as f:
        f.write(out)

