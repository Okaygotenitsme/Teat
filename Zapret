-- ServerScriptService/UnitEditor
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local units = ReplicatedStorage:FindFirstChild("Units") or (function()
	local f = Instance.new("Folder")
	f.Name = "Units"
	f.Parent = ReplicatedStorage
	return f
end)()

local edit = ReplicatedStorage:FindFirstChild("UnitToEdit") or (function()
	local s = Instance.new("StringValue")
	s.Name = "UnitToEdit"
	s.Value = ""
	s.Parent = ReplicatedStorage
	return s
end)()

local defaults = {
	Health = 100,
	Damage = 10,
	Speed = 16,
	Cost = 1,
	AttackRadius = 8,
	AttackSpeed = 1,
	SpawnSpeed = 1,
	Task = "AttackEnemies"
}

local function ensure(parent, name, val)
	local existing = parent:FindFirstChild(name)
	if existing then
		local ok = (type(val) == "string" and existing:IsA("StringValue")) or
				   (type(val) == "number" and (existing:IsA("NumberValue") or existing:IsA("IntValue")))
		if ok then return existing else existing:Destroy() end
	end
	local v
	if type(val) == "string" then
		v = Instance.new("StringValue")
		v.Value = val
	elseif type(val) == "number" and math.floor(val) == val then
		v = Instance.new("IntValue")
		v.Value = val
	else
		v = Instance.new("NumberValue")
		v.Value = val
	end
	v.Name = name
	v.Parent = parent
	return v
end

local function setPrimary(model)
	if not model or not model:IsA("Model") then return end
	if model.PrimaryPart and model.PrimaryPart.Parent then return end
	for _, d in ipairs(model:GetDescendants()) do
		if d:IsA("BasePart") then
			model.PrimaryPart = d
			break
		end
	end
end

local function process(model)
	if not model or not model:IsA("Model") then return end
	setPrimary(model)
	for k, v in pairs(defaults) do ensure(model, k, v) end
	ensure(model, "Description", "")
	if not model:FindFirstChild("MelotenProcessed") then
		local b = Instance.new("BoolValue")
		b.Name = "MelotenProcessed"
		b.Value = true
		b.Parent = model
	end
end

if edit.Value ~= "" then
	local target = units:FindFirstChild(edit.Value)
	if target then process(target) end
end

edit.Changed:Connect(function()
	if edit.Value ~= "" then
		local t = units:FindFirstChild(edit.Value)
		if t then process(t) end
	end
end)
