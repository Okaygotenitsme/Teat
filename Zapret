# vm_detector.py
import re
import binascii

class VMDetector:
    """
    Небольшой модуль для детекции виртуализации (MoonSec / Luraph / IronBrew heuristics)
    и для извлечения строк / backslash-number sequences.
    Это не "полный" devirtualizer — но часто достаточно для извлечения плейнстрингов.
    """

    def analyze(self, text):
        """
        Возвращает словарь с ключами:
         - is_vm: bool
         - reasons: list
        """
        reasons = []
        lower = text.lower()
        # очевидные метки
        if "moonsec" in lower or "this file was protected" in lower:
            reasons.append("found 'moonsec' / 'protected' marker")
        # специфичные функции / странные имена
        if re.search(r'\ba\.[a-zA-Z0-9_]{6,}\b', text):
            reasons.append("found obfuscated table access patterns like a.something")
        if re.search(r'\\\\\d{1,3}\\\\\d{1,3}\\\\\d{1,3}', text):
            reasons.append("found repeated backslash-number escapes (\\4\\8\\116..)")
        if re.search(r'getfenv\s*\(', text):
            reasons.append("uses getfenv")
        if re.search(r'while\s+true\s+do\s+local\s+[a-zA-Z_0-9]+', text):
            reasons.append("large numeric loop detected")
        is_vm = len(reasons) > 0
        return {'is_vm': is_vm, 'reasons': reasons}

    def extract_strings(self, text, min_len=4):
        """Извлекает все строковые литералы длиннее min_len"""
        results = set()
        # двойные и одинарные кавычки
        for m in re.findall(r'"([^"\\]{%d,})"' % min_len, text):
            results.add(m)
        for m in re.findall(r"'([^'\\]{%d,})'" % min_len, text):
            results.add(m)
        # также ищем long sequences похожие на rbxassetid:// и http
        for m in re.findall(r'(rbxassetid://[0-9]+)', text):
            results.add(m)
        for m in re.findall(r'(https?://[^\s\'"]{8,})', text):
            results.add(m)
        return list(results)

    def extract_backslash_numbers(self, text):
        """
        Ищем последовательности вида "\\4\\8\\116\\111\\.." и превращаем их в строку.
        Возвращаем список распакованных строк.
        """
        out = []
        # ищем группы с большим количеством backslash-number
        for group in re.findall(r'(?:\\\d{1,3}){6,}', text):
            try:
                nums = re.findall(r'\\(\d{1,3})', group)
                b = bytes(int(n) for n in nums)
                try:
                    out.append(b.decode('utf-8'))
                except:
                    out.append(b.decode('latin-1', 'ignore'))
            except Exception:
                continue
        return out
