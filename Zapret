@dp.message(F.document)
async def handle_document(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        await message.answer("❌ Только .lua или .txt!")
        return

    wait_msg = await message.answer("🌀 Генерирую гипер-защиту...")
    
    try:
        file_info = await bot.get_file(message.document.file_id)
        file_content = await bot.download_file(file_info.file_path)
        source = file_content.read().decode('utf-8', errors='ignore')

        # Обфускация
        obfuscator = MelotenHyperVM(source)
        protected_code = obfuscator.build()

        # Отправка
        output_file = BufferedInputFile(
            protected_code.encode('utf-8'), 
            filename=f"Hyper_{message.document.file_name}"
        )
        
        await message.answer_document(output_file, caption="💎 Твой код теперь под защитой Hyper-VM!")
        await wait_msg.delete()
        
    except Exception as e:
        await message.answer(f"❌ Ошибка: {e}")

