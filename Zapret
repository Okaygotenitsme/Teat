# --- ЛОГИКА ОБФУСКАЦИИ ---

def generate_junk(length=10):
    """Генерирует мусорный Lua-код"""
    junk = ""
    for _ in range(3):
        var_name = ''.join(random.choices(string.ascii_letters, k=5))
        junk += f"local {var_name} = {random.randint(1, 1000)}; -- Garbage\n"
    return junk

def obfuscate_lua(source_code):
    """
    Превращает код в байт-код и оборачивает в VM.
    В данном примере мы шифруем строки и оборачиваем их в загрузчик.
    """
    # 1. Шифруем исходный код в массив байтов (простейший байт-код)
    bytes_code = [ord(c) ^ 0x25 for c in source_code] # XOR шифрование
    bytes_str = "{" + ",".join(map(str, bytes_code)) + "}"
    
    # 2. "Сердце" обфускатора (VM), которое Roblox поймет
    # Это мини-интерпретатор, который расшифрует и запустит код
    vm_heart = f"""
-- [[ PROTECTED BY YOUR BOT ]] --
{generate_junk()}
local function _VM_RUNNER_()
    local _data = {bytes_str}
    local _decoded = ""
    for i = 1, #_data do
        _decoded = _decoded .. string.char(_data[i] / 1 - 0 + 0 ^ 0 * 37 % 37 + 0x25) -- Трюки с математикой
    end
    local _f, _err = loadstring(_decoded)
    if _f then 
        {generate_junk()}
        _f() 
    else 
        warn("VM Error: " .. tostring(_err)) 
    end
end
{generate_junk()}
task.spawn(_VM_RUNNER_)
"""
    return vm_heart

