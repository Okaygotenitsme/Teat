                """
                runner = lua.eval(runner_script)
                
                update_status("🌪️ Исполнение кода (VM)...")
                runner(content)
                
                # Забираем результаты из VM
                lua_strings = list(lua.globals().CAPTURED)
                lua_logs = list(lua.globals().LOGS)
                
                for s in lua_strings: extracted_strings.add(self._clean_str(s))
                for l in lua_logs: execution_logs.append(self._clean_str(l))

            except Exception as e:
                execution_logs.append(f"⚠️ VM CRASHED: {str(e)}")
                update_status("⚠️ VM Error (switched to static mode)")

        else:
            execution_logs.append("ℹ️ Skipped VM (Luau Binary Detected)")

        # Финализация
        return self._finalize_output(content, extracted_strings, execution_logs, update_status)

    def _force_extract_strings(self, data):
        """Агрессивный поиск строк в любых данных"""
        found = set()
        try:
            # Превращаем в байты если строка
            if isinstance(data, str): data = data.encode('utf-8', 'ignore')
            
            # 1. ASCII строки (длина > 4)
            # Ищем последовательности печатных символов
            regex = rb'[\x20-\x7E]{4,}'
            for match in re.finditer(regex, data):
                try: found.add(match.group().decode('ascii'))
                except: pass
                
            # 2. Lua строковые паттерны (иногда они в UTF-8)
            # Пытаемся декодировать куски
            try:
                text_view = data.decode('utf-8', 'ignore')
                # Ищем URL
                urls = re.findall(r'https?://[^\s<>"]+|www\.[^\s<>"]+', text_view)
                for u in urls: found.add(u)
            except: pass
            
        except Exception as e:
            logger.error(f"Static scan error: {e}")
        return found

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _clean_str(self, s):
        if isinstance(s, bytes): return s.decode('utf-8', 'ignore')
        return str(s).strip()

    def _try_decompile(self, bytecode):
        # unluac хорош, но только для Lua 5.1. 
        # Если не выйдет, вернем None
        if not os.path.exists(self.unluac_path): return None
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                if isinstance(bytecode, str): tmp.write(bytecode.encode('utf-8'))
                else: tmp.write(bytecode)
                path = tmp.name
            
            res = subprocess.run(["java", "-jar", self.unluac_path, path], capture_output=True, timeout=15)
            os.remove(path)
            
            if res.returncode == 0 and len(res.stdout) > 10:
                return res.stdout.decode('utf-8', 'ignore')
        except: pass
        return None

    def _finalize_output(self, original_code, strings, logs, callback):
        callback("📝 Формирование отчета...")
        
        output = []
        output.append("-- [[ MEL DEOBFUSCATOR V4 - GOD MODE EDITION ]] --")
        output.append(f"-- Date: {time.strftime('%Y-%m-%d %H:%M:%S')}")
        output.append(f"-- Total Unique Strings: {len(strings)}")
        output.append("-- Note: 'mel_X' formatting is temporarily DISABLED (Mixed Mode).")
        output.append("-" * 50)
        
        # === STRINGS SECTION (MIXED) ===
        # Мы не будем делать local mel_1 =, но мы выведем их списком в комментариях
        # чтобы ты мог их копировать
        sorted_strs = sorted(list(strings), key=len, reverse=True)
        
        output.append("\n-- [ DETECTED STRINGS / KEYS / URLS ] --")
        for s in sorted_strs:
            clean = s.replace('\n', ' ').replace('\r', '')
            if len(clean) > 80: clean = clean[:77] + "..."
            output.append(f"-- {clean}")
        
        # === LOGS SECTION ===
        if logs:
            output.append("\n-- [ EXECUTION LOGS ] --")
            for l in logs:
                output.append(f"-- {l}")

        output.append("\n" + "="*50 + "\n")

        # === CODE SECTION ===
        decompiled = self._try_decompile(original_code)
        
        if decompiled:
            output.append("-- [ DECOMPILED SOURCE (UNLUAC) ] --\n")
            output.append(decompiled)
        else:
            output.append("-- [ RAW CONTENT VIEW (DECOMPILATION FAILED/UNSUPPORTED) ] --")
            output.append("-- This is likely Luau Bytecode or heavily virtualized code.")
            output.append("-- See extracted strings above for logic clues.\n")
            
            # Выводим как есть (текст или hex)
            if isinstance(original_code, bytes):
                try:
                    # Попытка вывести как текст (если это просто обфусцированный текст)
                    text = original_code.decode('utf-8')
                    output.append(text)
                except:
                    # Если бинарник - Hex Dump
                    hex_data = binascii.hexlify(original_code).decode('utf-8')
                    # Бьем на блоки по 100 символов
                    for i in range(0, len(hex_data), 100):
                        output.append(f"-- {hex_data[i:i+100]}")
            else:
                output.append(original_code)

        # Собираем все в байты
        return "\n".join(output).encode('utf-8')
