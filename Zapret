import re
import base64
import logging
from lupa import LuaRuntime

logger = logging.getLogger("MoonVeilDeobf")

class MoonVeilDeobfuscator:
    def __init__(self):
        self.lua = LuaRuntime(unpack_returned_tuples=True)
        self._setup_environment()
    
    def _setup_environment(self):
        """Минималистичная среда для перехвата"""
        setup = """
        -- Полифилл bit32
        bit32 = bit32 or {}
        bit32.bxor = function(a, b)
            local r, m, s = 0, 2^31
            repeat 
                s, a, b = a+b+m, a%m, b%m
                r, m = r + m*4%(s-a-b), m/2 
            until m < 1
            return r
        end
        
        -- Перехват getfenv/setfenv
        local old_getfenv = getfenv
        getfenv = function(level)
            return old_getfenv(level or 1)
        end
        
        -- Хранилище для декодированных строк
        _DECODED_STRINGS = {}
        _DECODED_FUNCS = {}
        
        -- Хук на string.char (главная цель!)
        local real_char = string.char
        string.char = function(...)
            local result = real_char(...)
            if #result > 5 then
                table.insert(_DECODED_STRINGS, result)
            end
            return result
        end
        
        -- Хук на loadstring/load
        local real_load = load or loadstring
        load = function(chunk, ...)
            if type(chunk) == "string" and #chunk > 100 then
                table.insert(_DECODED_FUNCS, chunk)
            end
            return real_load(chunk, ...)
        end
        loadstring = load
        """
        self.lua.execute(setup)
    
    def process(self, obfuscated_code):
        """Основной процесс деобфускации"""
        
        # ШАГ 1: Статический анализ
        static_data = self._static_analysis(obfuscated_code)
        
        # ШАГ 2: Динамическое исполнение с перехватом
        dynamic_data = self._dynamic_execution(obfuscated_code)
        
        # ШАГ 3: Восстановление кода
        restored_code = self._reconstruct(static_data, dynamic_data)
        
        return self._format_output(restored_code, static_data, dynamic_data)
    
    def _static_analysis(self, code):
        """Извлечение данных без исполнения"""
        data = {
            'base64_strings': [],
            'xor_keys': [],
            'bytecode_chunks': [],
            'constants': []
        }
        
        # 1. Поиск Base64 строк
        b64_pattern = r"ka\('([A-Za-z0-9+/=]{50,})'\)"
        for match in re.finditer(b64_pattern, code):
            try:
                decoded = base64.b64decode(match.group(1))
                data['base64_strings'].append(decoded)
            except:
                pass
        
        # 2. Поиск XOR ключей (паттерн Pb с числами)
        xor_pattern = r"J\((\w+),\s*(\d+)\)"
        data['xor_keys'] = list(set(re.findall(xor_pattern, code)))
        
        # 3. Извлечение числовых констант (могут быть индексы VM)
        num_pattern = r"\b(\d{4,})\b"  # Числа >= 4 цифр
        data['constants'] = list(set(re.findall(num_pattern, code)))[:50]
        
        logger.info(f"📊 Static: {len(data['base64_strings'])} b64, "
                   f"{len(data['xor_keys'])} XOR keys, "
                   f"{len(data['constants'])} constants")
        
        return data
    
    def _dynamic_execution(self, code):
        """БЕЗОПАСНОЕ исполнение с перехватом"""
        data = {
            'decoded_strings': [],
            'function_chunks': [],
            'errors': []
        }
        
        try:
            # Оборачиваем в защищённый контекст
            wrapper = f"""
            local function safe_exec()
                local status, err = pcall(function()
                    {code}
                end)
                if not status then
                    return false, tostring(err)
                end
                return true
            end
            
            local ok, err = safe_exec()
            
            return {{
                success = ok,
                strings = _DECODED_STRINGS,
                funcs = _DECODED_FUNCS,
                error = err or "none"
            }}
            """
            
            # TIMEOUT защита (важно!)
            import signal
            
            def timeout_handler(signum, frame):
                raise TimeoutError("Execution timeout")
            
            signal.signal(signal.SIGALRM, timeout_handler)
            signal.alarm(5)  # 5 секунд максимум
            
            try:
                result = self.lua.execute(wrapper)
                
                data['decoded_strings'] = list(result['strings'])
                data['function_chunks'] = list(result['funcs'])
                
                if not result['success']:
                    data['errors'].append(str(result['error']))
                    
            finally:
                signal.alarm(0)  # Отменяем таймер
                
        except TimeoutError:
            logger.warning("⏱️ Execution timeout - using partial results")
        except Exception as e:
            logger.error(f"Dynamic execution failed: {e}")
            data['errors'].append(str(e))
        
        logger.info(f"🔥 Dynamic: {len(data['decoded_strings'])} strings, "
                   f"{len(data['function_chunks'])} functions")
        
        return data
    
    def _reconstruct(self, static, dynamic):
        """Умная реконструкция кода"""
        
        # Приоритет: динамические данные > статические
        all_strings = dynamic['decoded_strings'] + [
            s.decode('utf-8', errors='ignore') 
            for s in static['base64_strings'] 
            if len(s) < 10000  # Фильтр больших данных
        ]
        
        # Удаляем дубликаты, сохраняя порядок
        seen = set()
        unique_strings = []
        for s in all_strings:
            if s not in seen and len(s) > 3:
                seen.add(s)
                unique_strings.append(s)
        
        # Пытаемся найти "главный" скрипт
        main_script = None
        for chunk in dynamic['function_chunks']:
            # Признаки основного кода:
            # - Содержит game/workspace
            # - Длина > 500 символов
            # - Нет VM инструкций (local a,b,c = ...)
            if ('game' in chunk or 'workspace' in chunk) and len(chunk) > 500:
                if not re.search(r'local [a-z],[a-z],[a-z]=', chunk):
                    main_script = chunk
                    break
        
        return {
            'strings': unique_strings,
            'main_script': main_script,
            'vm_chunks': [c for c in dynamic['function_chunks'] if c != main_script]
        }
    
    def _format_output(self, restored, static, dynamic):
        """Красивый вывод результата"""
        output = []
        
        output.append("-- " + "="*60)
        output.append("-- MoonVeil Deobfuscator Results")
        output.append("-- " + "="*60)
        output.append("")
        
        # 1. Найденные строки
        if restored['strings']:
            output.append("-- [DECODED STRINGS]")
            for i, s in enumerate(restored['strings'][:100], 1):  # Лимит 100
                clean = s.replace('\n', '\\n').replace('\r', '')
                if len(clean) > 100:
                    clean = clean[:100] + "..."
                output.append(f'-- [{i}] "{clean}"')
            output.append("")
        
        # 2. XOR ключи (может быть полезно)
        if static['xor_keys']:
            output.append("-- [XOR KEYS]")
            for var, key in static['xor_keys'][:20]:
                output.append(f"-- {var} XOR {key}")
            output.append("")
        
        # 3. Главный скрипт
        if restored['main_script']:
            output.append("-- " + "="*60)
            output.append("-- [RECOVERED SOURCE CODE]")
            output.append("-- " + "="*60)
            output.append("")
            output.append(self._beautify(restored['main_script']))
        else:
            output.append("-- [WARNING] Main script not found")
            output.append("-- This might be a pure VM obfuscation")
            output.append("")
            
            # Показываем VM чанки
            if restored['vm_chunks']:
                output.append("-- [VM BYTECODE CHUNKS]")
                for i, chunk in enumerate(restored['vm_chunks'][:3], 1):
                    output.append(f"-- Chunk {i} (size: {len(chunk)})")
                    preview = chunk[:200].replace('\n', ' ')
                    output.append(f"-- {preview}...")
                    output.append("")
        
        # 4. Ошибки
        if dynamic['errors']:
            output.append("-- [EXECUTION ERRORS]")
            for err in dynamic['errors'][:5]:
                output.append(f"-- {err}")
        
        return '\n'.join(output)
    
    def _beautify(self, code):
        """Простой форматтер Lua"""
        # Добавляем переводы строк после ключевых слов
        code = re.sub(r'\s+(local|function|if|for|while|repeat|return)\s+', 
                     r'\n\1 ', code)
        code = re.sub(r'\s+(then|do)\s+', r' \1\n', code)
        code = re.sub(r'\s+end\s+', r'\nend\n', code)
        
        # Убираем лишние пустые строки
        code = re.sub(r'\n{3,}', '\n\n', code)
        
        return code
