local player = game.Players.LocalPlayer
local mouse = player:GetMouse()
local RE = game.ReplicatedStorage:WaitForChild("SpawnEvent")

local gui = script.Parent
local energyLabel = gui:WaitForChild("EnergyLabel")
local spawnBtn = gui:WaitForChild("SpawnButton")

local isSelecting = false

local energyValue = player:WaitForChild("PrivateStats"):WaitForChild("Energy")

energyValue:GetPropertyChangedSignal("Value"):Connect(function()
	energyLabel.Text = "ENERGY: " .. energyValue.Value
end)
energyLabel.Text = "ENERGY: " .. energyValue.Value

spawnBtn.MouseButton1Click:Connect(function()
	isSelecting = true
end)

mouse.Button1Down:Connect(function()
	if isSelecting then
		RE:FireServer(mouse.Hit.Position)
		isSelecting = false
	end
end)
