# ================== UTILS ==================

def gen_var(n=12):
    return "_" + "".join(random.choice(string.ascii_letters) for _ in range(n))

def encrypt_string_to_bytes(code: str):
    key = random.randint(20, 240)
    out = ""
    for c in code:
        # Используем формат \ddd для надежности
        out += "\\" + str(ord(c) ^ key)
    return out, key

def junk():
    v = gen_var(6)
    # Добавили \n, чтобы мусор не склеивался с основным кодом
    return f"\nlocal {v} = {random.randint(1000,9999)}\n"

def basic_lua_check(code: str):
    """
    Более мягкая проверка. Считаем только полные слова, 
    исключая их нахождение внутри других слов.
    """
    # Удаляем комментарии перед проверкой (очень упрощенно)
    clean_code = re.sub(r'--.*', '', code)
    
    # Ищем отдельные слова
    opens = len(re.findall(r'\b(function|do|then|if)\b', clean_code))
    closes = len(re.findall(r'\bend\b', clean_code))
    
    # Если closes меньше opens, вероятно, забыт end
    return closes >= (opens * 0.5) # Смягчаем условие для вложенных структур

# ================== CORE ==================

def build_meloten_vm(source: str, env: str):
    # Если проверка слишком строгая, ее можно временно закомментировать
    # if not basic_lua_check(source):
    #     raise Exception("Возможная синтаксическая ошибка (проверьте end/function)")

    enc, key = encrypt_string_to_bytes(source)

    v_bytes = gen_var()
    v_out = gen_var()
    v_load = gen_var()
    v_xor = gen_var()

    # Настройка окружения
    if env == "roblox_exec":
        env_setup = "local _ENV = (getfenv and getfenv() or _G)"
    elif env == "studio":
        env_setup = "local _ENV = {}"
    else:
        env_setup = "local _ENV = _G"

    # Собираем финальный Lua скрипт
    lua = f'''--[[
    Protected with Meloten Obfuscator
]]
{junk()}
local {v_xor} = function(a, b)
    if bit32 then return bit32.bxor(a, b) end
    return a ~ b
end

return (function(...)
    {env_setup}
    local {v_bytes} = "{enc}"
    local {v_out} = ""

    for num in string.gmatch({v_bytes}, "\\\\(%d+)") do
        {v_out} = {v_out} .. string.char({v_xor}(tonumber(num), {key}))
    end

    local {v_load} = loadstring or load
    local f, err = {v_load}({v_out})

    if not f then
        error("Runtime Error: " .. tostring(err))
    end

    return f(...)
end)(...)
'''
    return lua

