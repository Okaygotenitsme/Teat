import math
from collections import Counter
from typing import Tuple, Dict, Any, List

# --- Твои утилиты из фреймворка ---
def entropy(s: str) -> float:
    if not s: return 0.0
    c = Counter(s)
    length = len(s)
    return -sum((freq / length) * math.log2(freq / length) for freq in c.values())

class DeobfuscatorEngine:
    def __init__(self):
        # Используем Lua 5.1 (чаще всего нужна для обфускаторов Roblox)
        # Если не работает, оставь просто LuaRuntime()
        try:
            self.lua = LuaRuntime(unpack_returned_tuples=True)
        except:
            self.lua = LuaRuntime()

    def clean_code(self, text):
        """Твоя логика очистки из фреймворка"""
        # 1. Простейшее переименование длинных имен
        ident_re = re.compile(r"\b[_A-Za-z]\w*\b")
        ids = ident_re.findall(text)
        mapping = {}
        counter = 0
        
        for ident in set(ids):
            if len(ident) > 12 and entropy(ident) > 3.0:
                counter += 1
                mapping[ident] = f"var_renamed_{counter}"
        
        def repl(match):
            return mapping.get(match.group(0), match.group(0))
        
        text = ident_re.sub(repl, text)
        
        # 2. Удаление мертвого кода (if false then)
        text = re.sub(r"if\s+false\s+then[\s\S]*?end", "-- [Removed Dead Code]", text)
        return text

    def run_nuclear_sandbox(self, code):
        logs = ["-- [[ MoonSec Hybrid Deobfuscator ]] --\n"]
        
        # Поиск данных MoonSec
        var_match = re.search(r"\(function\(a\) (\w+) = a; end\)\)", code)
        bytecode_var = var_match.group(1) if var_match else None
        
        payload = None
        payload_match = re.search(r"\(\[\[(.*?)\]\]\)", code, re.DOTALL)
        if payload_match:
            payload = payload_match.group(1)

        # Скрипт песочницы
        setup_script = """
        _G.CAPTURED_RESULT = nil
        local sandbox = {
            loadstring = function(c) _G.CAPTURED_RESULT = c return function() end end,
            print = function() end, warn = function() end,
            bit32 = bit32, string = string, math = math, table = table, 
            pairs = pairs, ipairs = ipairs, type = type, tostring = tostring,
            game = {}, workspace = {}, script = {}
        }
        return sandbox
        """

        try:
            sandbox_env = self.lua.execute(setup_script)
            if bytecode_var and payload:
                sandbox_env[bytecode_var] = payload

            # Запуск
            runner = self.lua.eval("function(code, env) local f = load(code, 'src', 't', env) if f then return pcall(f) end return false, 'Load Error' end")
            success, error_msg = runner(code, sandbox_env)

            captured = self.lua.globals().CAPTURED_RESULT
            if captured:
                logs.append("-- [SUCCESS]: Код извлечен. Начинаю очистку...\n")
                cleaned = self.clean_code(str(captured))
                logs.append(cleaned)
            else:
                logs.append(f"-- [FAILED]: Не удалось захватить loadstring. Ошибка: {error_msg}")

        except Exception as e:
            logs.append(f"-- [ERROR]: {str(e)}")

        return "\n".join(logs)
