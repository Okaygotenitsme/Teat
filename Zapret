@dp.message(Command("loadstring"))
async def make_loadstring(message: types.Message, command: CommandObject):
    if not command.args:
        await message.answer("⚠️ Пример: /loadstring https://raw.githubusercontent.com/.../script.lua")
        return
    url = command.args.strip()
    content = f'loadstring(game:HttpGet("{url}"))()'
    file_obj = make_file_bytes(content.encode("utf-8"), filename="loader.lua")
    await message.answer_document(file_obj, caption="✅ Loadstring сгенерирован")

@dp.message(F.text)
async def meow_handler(message: types.Message):
    if message.text.startswith("/"):
        return
    if "meow" in message.text.lower() or "мяу" in message.text.lower():
        await message.answer("meow " * random.randint(1, 6))

@dp.message(F.document)
async def handle_docs(message: types.Message):
    name = (message.document.file_name or "").lower()
    if not name.endswith((".lua", ".txt")):
        await message.answer("❗ Поддерживаемые расширения: .lua, .txt")
        return

    status = await message.answer("🔒 Обработка... (защита V6 v2)")
    try:
        bio = io.BytesIO()
        await message.document.download(destination=bio)
        bio.seek(0)
        content_bytes = bio.read()
        try:
            source = content_bytes.decode("utf-8")
        except Exception:
            source = content_bytes.decode("utf-8", errors="ignore")

        obf = MelotenObfuscatorV6(source)
        # self-check before sending:
        if not obf.verify_roundtrip():
            logger.warning("Roundtrip verification failed for the provided file. Proceeding anyway.")
        protected = obf.build()
        output = make_file_bytes(protected.encode("utf-8"), filename=f"Protected_{message.document.file_name}")
        await message.answer_document(output, caption="✅ Скрипт защищён (V6 v2).")
        try:
            await status.delete()
        except Exception:
            pass
    except Exception as e:
        logger.error("Error in handle_docs: %s", traceback.format_exc())
        await message.answer(f"❌ Ошибка при обработке: {e}")

