        -- ============================================
        -- TASK LIBRARY
        -- ============================================
        _G.task = {
            wait = function(duration)
                return duration or 0
            end,
            
            spawn = function(func, ...)
                local args = {...}
                pcall(function() func(unpack(args)) end)
            end,
            
            defer = function(func, ...)
                local args = {...}
                pcall(function() func(unpack(args)) end)
            end,
            
            delay = function(duration, func, ...)
                local args = {...}
                pcall(function() func(unpack(args)) end)
            end,
            
            desynchronize = function() end,
            synchronize = function() end,
            cancel = function() end
        }
        
        _G.wait = _G.task.wait
        _G.spawn = _G.task.spawn 
