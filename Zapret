def gen_mega_name():
    """Генерирует очень длинные имена переменных"""
    return "_" + "".join(random.choice(string.ascii_letters) for _ in range(25))

def encrypt_string(text):
    """Шифрование строк через XOR (как в элитных обфускаторах)"""
    key = random.randint(15, 95)
    chars = [ord(c) ^ key for c in text]
    v_t = gen_mega_name()
    # Создаем самовызывающуюся функцию (LVM-style)
    return f"(function() local {v_t}={{ {','.join(map(str, chars))} }} local r='' for i=1,#{v_t} do r=r..string.char({v_t}[i] ~ {key}) end return r end)()"

def meloten_core(source):
    """Главный движок обфускации"""
    # Заменяем все строки в коде на зашифрованные блоки
    source = re.sub(r'"(.*?)"', lambda m: encrypt_string(m.group(1)), source)
    source = re.sub(r"'(.*?)'", lambda m: encrypt_string(m.group(1)), source)
    
    # Добавляем слои мусора
    layers = [f"local {gen_mega_name()} = {random.randint(100, 9999)}" for _ in range(15)]
    junk = "\n".join(layers)
    
    entry_point = gen_mega_name()
    
    result = f"""--[[ 
    MELOTEN OBFUSCATOR SUPREME V4
    USER: {ADMIN_USERNAME}
]]
{junk}
local function {entry_point}()
    {source}
end
{entry_point}()
"""
    return result

