        vm_code = (
            f"--[[ Meloten Hyper-VM Roblox Edition ]]\n"
            f"local {self.vars['v1']} = {payload}; "
            f"{self._generate_complex_junk()} "
            f"local {self.vars['v2']} = {self._get_math_junk(self.key)}; "
            f"local {self.vars['v3']} = {self._get_math_junk(self.seed)}; "
            f"local {self.vars['v4']} = string.char; "
            f"local {self.vars['v5']} = bit32.bxor; "
            f"local {self.vars['v6']} = ''; "
            f"{self._generate_complex_junk()} "
            f"for {self.vars['v7']} = 1, #{self.vars['v1']} do "
            f"  local {self.vars['v8']} = {self.vars['v5']}({self.vars['v1']}[{self.vars['v7']}], {self.vars['v2']}); "
            f"  {self.vars['v6']} = {self.vars['v6']} .. {self.vars['v4']}({self.vars['v5']}({self.vars['v8']}, {self.vars['v3']} % 255)); "
            f"  if {self.vars['v7']} % 300 == 0 then task.wait() end " # Чтобы Roblox не лагал
            f"end; "
            f"{self._generate_complex_junk()} "
            f"local {self.vars['v9']}, {self.vars['v10']} = loadstring({self.vars['v6']}); "
            f"if not {self.vars['v9']} then "
            f"  warn('Critical Security Breach Detected!') "
            f"else "
            f"  local {self.vars['v11']} = task.spawn({self.vars['v9']}); "
            f"end; "
            f"{self.vars['v6']} = nil; " # Очистка памяти
        )
        
        # Финальная упаковка в одну строку для сложности чтения
        return " ".join(vm_code.split())

