# Реакция на Meow / Мяу
@dp.message(F.text)
async def meow_handler(message: types.Message):
    # Проверяем, есть ли слово meow или мяу в сообщении (игнорируя регистр)
    text = message.text.lower()
    if "meow" in text or "мяу" in text:
        # Генерируем случайное количество повторений от 1 до 10
        count = random.randint(1, 10)
        response = " ".join(["meow"] * count)
        await message.answer(response)
    
    # Если это просто текст и не содержит meow, бот ничего не делает (или можешь добавить свою логику)

# Обфускация документов
@dp.message(F.document)
async def handle_docs(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        return

    msg = await message.answer("🛡 Защищаю код...")
    try:
        file_info = await bot.get_file(message.document.file_id)
        file_content = await bot.download_file(file_info.file_path)
        source = file_content.read().decode('utf-8', errors='ignore')

        obf = MelotenObfuscator(source)
        output = BufferedInputFile(obf.build().encode('utf-8'), filename=f"Obf_{message.document.file_name}")
        
        await message.answer_document(output, caption="✅ Код защищен!")
        await msg.delete()
    except Exception as e:
        await message.answer(f"❌ Ошибка: {e}")

