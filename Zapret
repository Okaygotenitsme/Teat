def _rand_name(prefix="Meloten"):
    chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    return prefix + "_" + "".join(secrets.choice(chars) for _ in range(random.randint(10, 16)))

def _chunker(seq, min_size=4, max_size=16):
    i = 0
    while i < len(seq):
        size = random.randint(min_size, max_size)
        yield seq[i:i+size]
        i += size

# --- OBFUSCATOR CLASS ---
class MelotenMaxVM:
    def __init__(self, source: str):
        self.source = source
        self.var_names = {f"v{i}": _rand_name("m") for i in range(30)}
        # random generator seeds for reproducibility inside one build
        self._salt = random.randint(1, 1 << 30)

    def _generate_byte_map(self):
        arr = list(range(256))
        random.shuffle(arr)
        # produce inverse map too for use in encoded payload (we encode using arr mapping)
        return arr

    def _encode_with_map(self, bytes_seq, mapping):
        return [mapping[b] for b in bytes_seq]

    def _xor_bytes(self, bytes_seq, key):
        return [(b ^ (key >> ((i % 4) * 8) & 0xFF)) & 0xFF for i, b in enumerate(bytes_seq)]

    def _generate_opcode_stream(self, encoded_bytes):
        # Build a small custom opcode VM stream that describes how to reconstruct the original bytes:
        # Opcodes (numeric):
        # 1 <N> <data...>          -> append next N bytes from data stream
        # 2 <key>                 -> xor current key with key
        # 3 <derive_flag>         -> derive key from state (makes static analysis harder)
        # 4 <skip>                -> junk loops / changed pc
        # 5 0                     -> finalize and run (end)
        # We interleave data and junk heavily
        stream = []
        data_chunks = list(_chunker(encoded_bytes, 8, 30))
        for chunk in data_chunks:
            # sometimes insert random junk opcode(s)
            for _ in range(random.randint(0, 2)):
                op = random.choice([4, 3])
                if op == 4:
                    stream += [4, random.randint(1, 10)]
                else:
                    stream += [3, random.randint(0, 1)]
            # add real append
            stream.append(1)
            stream.append(len(chunk))
            stream += chunk
            # occasionally change key
            if random.random() < 0.35:
                stream.append(2)
                stream.append(random.randint(1, 255))
        # finalize
        stream += [5, 0]
        return stream

    def _make_lua_number_table(self, arr):
        # Return a Lua table literal with numbers; break into chunks to avoid super long lines
        parts = []
        line = []
        for i, v in enumerate(arr, start=1):
            line.append(str(v))
            if len(line) >= 16:
                parts.append(", ".join(line))
                line = []
        if line:
            parts.append(", ".join(line))
        return ", ".join(parts)

    def _random_junk_func(self):
        # small junk function that sometimes mutates an external value — used to make junk "necessary"
        name = _rand_name("junk")
        inner_var = _rand_name("x")
        body = f"""
local function {name}()
    local {inner_var} = 0
    for i=1,{random.randint(3,12)} do
        {inner_var} = ({inner_var} + i * {random.randint(2,8)}) % 256
    end
    return {inner_var}
end
"""
        return textwrap.dedent(body)

    def build(self) -> str:
        # 1) bytes of source
        src_bytes = [ord(c) for c in self.source]
        # 2) generate mapping table (table cipher)
        mapping = self._generate_byte_map()
        mapped = self._encode_with_map(src_bytes, mapping)
        # 3) apply XOR layer with random 32-bit key
        xor_key = random.getrandbits(32)
        xored = self._xor_bytes(mapped, xor_key)
        # 4) create opcode stream from xored bytes
        opcode_stream = self._generate_opcode_stream(xored)
        # 5) generate some decoy payload (fake simple string or fake decoded code)
        decoy_text = "--[[ Meloten Decoy ]] print('decoy_loaded')"
        decoy_bytes = [ord(c) for c in decoy_text]
        decoy_mapped = self._encode_with_map(decoy_bytes, mapping)
        decoy_xored = self._xor_bytes(decoy_mapped, xor_key ^ 0xA5A5A5A5)
        decoy_stream = self._generate_opcode_stream(decoy_xored)
        # 6) make Lua table literals
        mapping_table_lua = self._make_lua_number_table(mapping)
        opcode_table_lua = self._make_lua_number_table(opcode_stream)
        decoy_table_lua = self._make_lua_number_table(decoy_stream)
        # 7) random names for lua variables
        names = {k: _rand_name("l") for k in ["MAP", "OP", "DECOY", "K", "OUT", "PC", "TMP", "VMFUNC", "SRCLEN"]}
        junk_funcs = "".join(self._random_junk_func() for _ in range(2))

        # 8) prepare anti-hook checks and environment hardening (Roblox-compatible where possible)
        anti_hook = textwrap.dedent(f"""
        -- anti-hook checks
        local ok_load = type(loadstring) == "function" or type(load) == "function"
        local ok_debug = pcall(function() return debug and debug.getinfo end)
        if not ok_load or not ok_debug then
            -- make it expensive to analyze
            for i=1,500 do
                local _ = math.sin(i) * math.cos(i)
            end
        end
        -- try detect if loadstring was wrapped
        local _ls = loadstring or load
        local info_ok, info = pcall(function() return debug.getinfo(_ls) end)
        if info_ok and type(info) == "table" then
            if tostring(info.what) ~= "C" and tostring(info.what) ~= "main" then
                -- suspicious: try to break static dumps
                while #{} < 0 do end
            end
        end
        """)

        # 9) the VM runtime in Lua - multi-stage: interpret opcodes to reconstruct original bytes,
        #    then remap bytes via inverse mapping inside the Lua decoder, then xor with runtime-derived key,
        #    then build string and pcall(loadstring).
        lua_vm = f"""
--[[ Meloten MAX VM (auto-generated) ]]
{junk_funcs}

local {names['MAP']} = {{{mapping_table_lua}}}
local {names['OP']} = {{{opcode_table_lua}}}
local {names['DECOY']} = {{{decoy_table_lua}}}
local {names['K']} = {xor_key}
local {names['OUT']} = {{}}
local {names['PC']} = 1
local {names['TMP']} = 0

{anti_hook}

-- helper: inverse map (generated at runtime to avoid static signature)
local function build_inverse_map(tbl)
    local inv = {{}}
    for i=1, #tbl do
        inv[tbl[i]] = i - 1 -- lua index -> byte value original
    end
    return inv
end

local inv_map = build_inverse_map({names['MAP']})

local function derive_runtime_key(seed, env)
    local k = seed
    -- mix with small amounts from environment to avoid deterministic static key
    k = (k ~ (env or 0) ~ (#{names['OP']} + {random.randint(1,999)})) & 0xFFFFFFFF
    -- some tiny slow loops to force time for dynamic analysis
    local t = 0
    for i=1,5 do t = (t + math.floor(math.sin(i) * 1000)) & 0xFFFFFFFF end
    return k ~ t
end

-- VM: interprets opcode table to reconstruct a bytes buffer
local function run_vm(op_table, key_override)
    local out = {{}}
    local pc = 1
    local key = derive_runtime_key({names['K']}, key_override or 0)
    while pc <= #op_table do
        local op = op_table[pc]; pc = pc + 1
        if op == 1 then
            local n = op_table[pc]; pc = pc + 1
            for i=1,n do
                local b = op_table[pc]; pc = pc + 1
                -- reverse xor first, then inverse map
                local bx = (b ~ (key >> (((#out + 1) % 4) * 8) & 0xFF)) & 0xFF
                local orig = inv_map[bx] or bx
                table.insert(out, orig)
            end
        elseif op == 2 then
            local kdelta = op_table[pc]; pc = pc + 1
            key = (key ~ kdelta) & 0xFFFFFFFF
        elseif op == 3 then
            -- derive flag: mutate key slightly
            local f = op_table[pc]; pc = pc + 1
            if f == 1 then
                key = derive_runtime_key(key, (#op_table * 7) % 65536)
            else
                key = ((key << 3) | (key >> 29)) & 0xFFFFFFFF
            end
        elseif op == 4 then
            local skip = op_table[pc]; pc = pc + 1
            -- fake work to confuse static analysis; also may mutate key
            for i=1, skip do
                key = (key ~ i) & 0xFFFFFFFF
            end
        elseif op == 5 then
            -- finalize
            break
        else
            -- unknown opcode -> ignore or act as junk
        end
    end
    return out
end

-- run decoy first (to mislead analysis)
