            seen = set()
            for s, ctx in sorted_strs:
                clean_s = self._safe_str(s)
                if clean_s not in seen and len(clean_s) > 3:
                    out.append(f"-- [{ctx}] {clean_s}")
                    seen.add(clean_s)

        out.append("\n" + "="*60 + "\n")

        # 3. CODE SECTION
        if decompiled_src:
            out.append("-- [DECOMPILED SOURCE CODE]")
            out.append(self._beautify(decompiled_src))
        else:
            out.append("-- [WARNING] Unluac Failed (Custom VM Detected)")
            out.append("-- Dumping Raw Payload (Text Representation):")
            try:
                out.append(bytecode.decode('utf-8'))
            except:
                out.append(f"-- Binary Blob: {binascii.hexlify(bytecode[:64]).decode()}... (truncated)")

        # 4. EXECUTION LOG
        out.append("\n" + "="*60 + "\n")
        out.append("-- [EXECUTION TRACE]")
        for l in logs[-50:]:
            out.append(f"-- {l}")

        return "\n".join(out).encode('utf-8')

    def _try_decompile(self, data):
        if not os.path.exists(self.unluac_path): return None
        try:
            with tempfile.NamedTemporaryFile(delete=False, mode='wb') as f:
                f.write(data)
                fname = f.name
            
            # Запускаем unluac
            res = subprocess.run(
                ["java", "-jar", self.unluac_path, fname],
                capture_output=True, timeout=15
            )
            os.remove(fname)
            
            if res.returncode == 0 and res.stdout:
                return res.stdout.decode('utf-8', errors='ignore')
            return None
        except: return None

    def _safe_str(self, obj):
        """Очистка строк от непечатаемых символов"""
        s = str(obj)
        return s.replace('\n', ' ').replace('\r', '').replace('\0', '')

    def _beautify(self, src):
        """Простой форматтер Lua"""
        src = re.sub(r'(\s)(local|function|if|for|while|repeat)(\s)', r'\n\2 ', src)
        src = src.replace(';', ';\n').replace(' then ', ' then\n').replace(' do ', ' do\n').replace(' end ', '\nend\n')
        lines = src.splitlines()
        res = []
        indent = 0
        for line in lines:
            line = line.strip()
            if not line: continue
            if line.startswith(('end', 'until', '}', 'elseif', 'else')): indent = max(0, indent - 1)
            res.append('\t' * indent + line)
            if line.endswith(('then', 'do', 'repeat', '{', '(')) or ('function' in line and not line.endswith('end')):
                indent += 1
            if line.startswith(('if', 'elseif', 'else')):
                 pass # indent logic handled above mostly
        return "\n".join(res)
