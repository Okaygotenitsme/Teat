import lupa
from lupa import LuaRuntime
import logging
import subprocess
import os
import re

# Настройка логгера
logger = logging.getLogger("TerminatorV4")

class DeobfuscatorEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        logger.info(f"📁 Engine V4 initialized.")

    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        # Проверка Java
        if not self._check_java():
            update_status("⚠️ Java не найдена. Декомпиляция байт-кода пропущена.")

        update_status("🔥 Запуск Lupa (Lua 5.1) в режиме трассировки...")

        try:
            lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)
        except Exception as e:
            return f"-- [FATAL] Lua start error: {e}".encode('utf-8')

        # --- ХРАНИЛИЩА ДАННЫХ ---
        storage = {
            "logs": [],
            "strings": set(),
            "urls": set(),
            "chunks": [],
            "keys": []
        }

        # --- PYTHON-LUA МОСТ ---
        def py_log(msg):
            s = str(msg)
            if len(storage["logs"]) < 300: storage["logs"].append(s)
            if "http" in s: storage["urls"].add(s)

        def py_save_str(s):
            if isinstance(s, (str, bytes)):
                try:
                    res = s.decode('utf-8') if isinstance(s, bytes) else s
                    # Фильтр мусора: сохраняем только осмысленные строки
                    if len(res) > 3 and not re.match(r'^[\x00-\x1f]+$', res):
                        storage["strings"].add(res)
                        if "http" in res or "www." in res: storage["urls"].add(res)
                        if "key" in res.lower() or "auth" in res.lower(): storage["keys"].append(res)
                except: pass
            return s

        def py_save_chunk(chunk, name):
            if isinstance(chunk, (str, bytes)) and len(chunk) > 100:
                storage["chunks"].append({"data": chunk, "name": name})
                py_log(f"⚡ CAPTURED CHUNK: {name} ({len(chunk)} bytes)")
            return chunk

        lua_globals = lua.globals()
        lua_globals.py_log = py_log
        lua_globals.py_save_str = py_save_str
        lua_globals.py_save_chunk = py_save_chunk

        # --- СКРИПТ-ПЕРЕХВАТЧИК (LUA HOOKS) ---
        # Мы переписываем стандартные функции Lua, чтобы они "сливали" данные нам
        setup_script = r"""
        -- [[ TERMINATOR V4 ENVIRONMENT ]] --
        
        local seen_str = {}
        local function spy(val)
            if type(val) == "string" and #val > 3 and not seen_str[val] then
                seen_str[val] = true
                py_save_str(val)
            end
            return val
        end

        -- 1. String Library Hooks (Самое важное для MoonSec)
        local _str = string
        local old_char = string.char
        local old_byte = string.byte
        local old_sub = string.sub
        local old_gsub = string.gsub
        
        string.char = function(...)
            local args = {...}
            local res = old_char(unpack(args))
            spy(res) -- Ловим результат сборки строки
            return res
        end
        
        string.gsub = function(s, p, r, ...)
            if #s > 500 then py_save_chunk(s, "gsub_payload") end -- Ловим само тело скрипта
            spy(s)
            return old_gsub(s, p, r, ...)
        end

        -- 2. Table Hooks (Ловим сборку констант)
        local old_concat = table.concat
        table.concat = function(t, s, i, j)
            local res = old_concat(t, s, i, j)
            spy(res)
            return res
        end

        -- 3. Global Environment Mocking
        _G.print = function(...) 
            local t = {}
            for i,v in ipairs({...}) do table.insert(t, tostring(v)) end
            py_log("PRINT: "..table.concat(t, " ")) 
        end
        _G.warn = _G.print
        _G.error = _G.print
        _G.info = _G.print

        -- Roblox Mock
        local Dummy = newproxy(true)
        local mt = getmetatable(Dummy)
        mt.__index = function(t, k) return Dummy end
        mt.__call = function(...) return Dummy end
        mt.__tostring = function() return "Instance" end
        
        _G.game = {
            GetService = function(s, n) return Dummy end,
            HttpGet = function(s, u) spy(u); py_log("📡 HttpGet: "..tostring(u)); return "{}" end,
            PlaceId = 12345, JobId = "Terminator"
        }
        _G.workspace = Dummy
        _G.script = {Source = "LocalScript", Name = "MoonSecBypass"}
        
        -- Executor Functions
        _G.request = function(o) 
            if o.Url then spy(o.Url); py_log("📡 Request: "..o.Url) end
            return {Body="{}", StatusCode=200} 
        end
        _G.checkcaller = function() return true end
        _G.getgenv = function() return _G end

        -- 4. Bit32 Library (Если его нет в Lua 5.1)
        if not bit32 then
            local bit = {}
            function bit.bxor(a, b)
                local p, c = 1, 0
                while a > 0 and b > 0 do
                    local ra, rb = a%2, b%2
                    if ra ~= rb then c = c + p end
                    a, b, p = (a-ra)/2, (b-rb)/2, p*2
                end
                if a < b then a = b end
                while a > 0 do
                    local ra = a%2
                    if ra > 0 then c = c + p end
                    a, p = (a-ra)/2, p*2
                end
                return c
            end
            function bit.band(a,b) return ((a+b) - bit.bxor(a,b))/2 end
            function bit.rshift(n, bits) return math.floor(n / 2^bits) end
            _G.bit = bit
            _G.bit32 = bit
        end
        
        -- 5. Anti-Tamper Bypass (tostring spoof)
        local raw_tostring = tostring
        _G.tostring = function(v)
            if v == _G.string or v == _G.table or v == _G.math then
                return "table: 0x" .. string.format("%x", math.random(10000,99999))
            end
            return raw_tostring(v)
        end
        """

        try:
            update_status("💉 Внедрение хуков...")
            lua.execute(setup_script)
            
            # Запускаем скрипт через pcall чтобы не упасть при первой ошибке
            runner = lua.eval(r"""
                function(code)
                    local s, e = pcall(function()
                        local f, err = loadstring(code)
                        if not f then error(err) end
                        f()
                    end)
                    return tostring(e)
                end
            """)
            
            update_status("🌪️ Запуск обфусцированного кода...")
            res = runner(content)
            
            update_status("🧠 Анализ собранных данных...")
            
            # --- ФОРМИРОВАНИЕ РЕЗУЛЬТАТА ---
            
            # 1. Лучший чанк (если скрипт был распакован)
            best_code = None
            max_len = 0
            for c in storage["chunks"]:
                if len(c['data']) > max_len:
                    max_len = len(c['data'])
                    best_code = c['data']
            
            target_bytes = best_code if best_code else content
            
            return self._generate_report(target_bytes, storage, best_code is not None)

        except Exception as e:
            logger.error(f"Engine Crash: {e}")
            return f"-- [CRASH] Engine error: {str(e)}".encode('utf-8')

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _generate_report(self, code_bytes, storage, is_unpacked):
        report = "-- [[ TERMINATOR V4 REPORT (MoonSec Special) ]] --\n"
        report += f"-- Strings Decrypted: {len(storage['strings'])}\n"
        report += f"-- URLs Found: {len(storage['urls'])}\n"
        report += f"-- Payload Unpacked: {'YES' if is_unpacked else 'NO (VM Locked)'}\n\n"

        if storage['urls']:
            report += "-- [[ NETWORK CALLS ]] --\n"
            for u in sorted(list(storage['urls'])):
                report += f"'{u}'\n"
            report += "\n"

        if storage['keys']:
            report += "-- [[ POTENTIAL KEYS ]] --\n"
            for k in storage['keys']:
                report += f"-- {k}\n"
            report += "\n"

        # Пытаемся показать код
        report += "-- [[ CODE / BYTECODE DUMP ]] --\n"
        
        # Если удалось вытащить распакованный чанк
        decompiled = self._try_decompile(code_bytes)
        if decompiled:
            report += decompiled.decode('utf-8', 'ignore')
        else:
            report += "-- Декомпиляция не удалась (или код все еще в VM).\n"
            report += "-- Ниже представлен список расшифрованных строк:\n\n"
            try:
                # Если это текст (source), просто покажем его отформатированным
                src = code_bytes.decode('utf-8')
                if not is_unpacked: # Если это исходная VM
                     report += "-- (Raw Source)\n" + self._beautify_lua(src[:2000]) + "\n... (truncated)"
                else:
                     report += self._beautify_lua(src)
            except:
                report += f"-- Binary Blob Size: {len(code_bytes)} bytes\n"

        report += "\n\n" + "="*60 + "\n-- [[ DECRYPTED STRINGS (Dump) ]] --\n"
        # Сортируем строки по длине, чтобы сначала шло самое интересное
        clean_strings = sorted(list(storage['strings']), key=len, reverse=True)
        
        # Исключаем строки самого MoonSec
        blacklist = ["MoonSec", "char", "byte", "sub", "gsub", "bit", "concat", "insert"]
        
        count = 0
        for s in clean_strings:
            if count > 300: break
            if len(s) < 3: continue
            if any(b in s for b in blacklist): continue
            
            # Экранируем переносы строк для читаемости
            safe_s = s.replace('\n', '\\n').replace('\r', '')
            report += f'-- "{safe_s}"\n'
            count += 1

        return report.encode('utf-8', 'replace')

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path): return None
        # Проверка сигнатуры Lua 5.1 (ESC Lua)
        if isinstance(bytecode, bytes) and bytecode.startswith(b'\x1bLua'):
            try:
                with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                    tmp.write(bytecode)
                    path = tmp.name
                
                res = subprocess.run(["java", "-jar", self.unluac_path, path], capture_output=True, timeout=10)
                os.remove(path)
                if res.returncode == 0 and len(res.stdout) > 0: return res.stdout
            except: pass
        return None

    def _beautify_lua(self, code):
        code = code.replace(';', ';\n')
        code = code.replace(' then ', ' then\n\t')
        code = code.replace(' do ', ' do\n\t')
        code = code.replace(' end ', '\nend\n')
        return code
