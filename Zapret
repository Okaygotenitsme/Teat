# --- MELOTEN OBFUSCATOR V7 (MULTI-LAYER) ---
class MelotenObfuscatorV7:
    def __init__(self, source, layers=1):
        self.original_source = source
        self.layers = layers  # Количество слоев (проходов)
        
    def _generate_names(self):
        """Генерирует уникальный набор имен переменных для текущего слоя"""
        self.key = random.randint(50, 200)
        self.vars = {}
        # Используем нечитаемые имена (l, I, 1, 0, O)
        keys = ['vm', 'state', 'bytes', 'idx', 'xor', 'junk', 'magic', 'dec', 'len', 'byte_val', 'table', 'str_lib', 'bit_lib']
        for k in keys:
            length = random.randint(10, 20)
            suffix = ''.join(random.choices("Il1O0", k=length))
            self.vars[k] = f"_{suffix}"

    def _junk_code(self):
        """Генерирует безопасный мусорный код"""
        v1, v2 = self.vars['junk'], self.vars['magic']
        ops = [
            f"local {v1} = 0; for i=1, {random.randint(1,5)} do {v1}={v1}+i end",
            f"if ({random.randint(100,200)} < 50) then end -- Dead code",
            f"-- Stack: 0x{random.randint(1000, 9999):X}",
        ]
        return random.choice(ops)

    def _build_layer(self, source_code):
        """Создает один слой защиты (VM + Rolling XOR)"""
        self._generate_names() # Новые имена для каждого слоя
        
        # 1. Base64
        b64_source = base64.b64encode(source_code.encode('utf-8')).decode('utf-8')
        
        # 2. Rolling Key XOR
        raw_bytes = b64_source.encode('utf-8')
        enc_bytes = []
        for i, b in enumerate(raw_bytes):
            dynamic_key = (self.key + (i % 120)) % 255
            val = (b ^ dynamic_key)
            enc_bytes.append(val)
        
        payload = "".join([f"\\{b}" for b in enc_bytes])

        # 3. Virtual Machine (Исправленная версия без syntax error)
        vm_script = f"""--[[ Meloten Secure Layer ]]
local {self.vars['str_lib']} = string
local {self.vars['table']} = table
local {self.vars['bit_lib']} = bit32 or require('bit') -- Auto-detect bit library

-- Универсальная функция XOR (работает везде: Lua 5.1, JIT, Luau)
local function {self.vars['xor']}(a, b)
    if {self.vars['bit_lib']} then
        return {self.vars['bit_lib']}.bxor(a, b)
    else
        -- Math fallback for pure Lua 5.1 without libs
        local p,c=1,0
        while a>0 and b>0 do
            local ra,rb=a%2,b%2
            if ra~=rb then c=c+p end
            a,b,p=(a-ra)/2,(b-rb)/2,p*2
        end
        if a<b then a=b end
        while a>0 do
            local ra=a%2
            if ra>0 then c=c+p end
            a,p=(a-ra)/2,p*2
        end
        return c
    end
end

local function {self.vars['vm']}({self.vars['bytes']})
    local {self.vars['state']} = 500
    local {self.vars['dec']} = {{}}
    local {self.vars['idx']} = 1
    local {self.vars['len']} = #{self.vars['bytes']}
    local {self.vars['magic']} = {self.key}
    
    while {self.vars['state']} ~= 0 do
        {self._junk_code()}
        if {self.vars['state']} == 500 then
            {self.vars['idx']} = 1
            {self.vars['state']} = 200
        elseif {self.vars['state']} == 200 then
            if {self.vars['idx']} <= {self.vars['len']} then
                {self.vars['state']} = 300
            else
                {self.vars['state']} = 0
            end
        elseif {self.vars['state']} == 300 then
            local {self.vars['byte_val']} = {self.vars['str_lib']}.byte({self.vars['bytes']}, {self.vars['idx']})
            local dyn = ({self.vars['magic']} + (({self.vars['idx']} - 1) % 120)) % 255
            local clean = {self.vars['xor']}({self.vars['byte_val']}, dyn)
            {self.vars['table']}.insert({self.vars['dec']}, {self.vars['str_lib']}.char(clean))
            {self.vars['idx']} = {self.vars['idx']} + 1
            {self.vars['state']} = 200
        end
    end
    
    local res = {self.vars['table']}.concat({self.vars['dec']})
    return res
end

local _payload = "{payload}"
local _data = {self.vars['vm']}(_payload)

-- Embedded Base64 Decoder
local b='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
local function _dec(data)
    data = string.gsub(data, '[^'..b..'=]', '')
    return (data:gsub('.', function(x)
        if (x == '=') then return '' end
        local r,f='',(b:find(x)-1)
        for i=6,1,-1 do r=r..(f%2^i-f%2^(i-1)>0 and '1' or '0') end
        return r;
    end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
        if (#x ~= 8) then return '' end
        local c=0
        for i=1,8 do c=c+(x:sub(i,i)=='1' and 2^(8-i) or 0) end
        return string.char(c)
    end))
end

local _final = _dec(_data)
local _loader = loadstring or load
if getgenv then getgenv().SCRIPT_OWNER = "Meloten" end
_loader(_final)()
"""
        return vm_script

    def build(self):
        current_code = self.original_source
        
        # Цикл накладывания слоев
        for i in range(self.layers):
            # Если это не первый слой, мы убираем выполнение (_loader) из предыдущего кода,
            # чтобы VM внутри VM просто возвращала строку, а не исполняла её сразу.
            # Но для простоты: мы просто заворачиваем ВЕСЬ предыдущий скрипт как строку в новую VM.
            current_code = self._build_layer(current_code)
            
        return current_code

