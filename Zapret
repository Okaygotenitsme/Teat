    Protected with Meloten Obfuscator
    Author: Meloten
]]

{junk_block()}

return (function(...)
    {env_setup}

    local {v_tbl} = {{{lua_bytes}}}
    local {v_out} = ""

    for {v_i} = 1, #{v_tbl} do
        {v_out} = {v_out} .. string.char(bit32 and bit32.bxor({v_tbl}[{v_i}], {key}) or ({v_tbl}[{v_i}] ~ {key}))
    end

    local {v_load} = {loader}
    local f, err = {v_load}({v_out})

    if not f then
        return warn("Meloten Obfuscator: runtime error")
    end

    return f(...)
