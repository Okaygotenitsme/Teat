        function bit.rshift(a, b) return math.floor(a / 2^b) % 4294967296 end
        function bit.arshift(a, b) 
            local z = math.floor(a / 2^b) % 4294967296
            if a >= 2147483648 then z = z + 4294967296 - 2^(32-b) end
            return z
        end
        -- Bit32 Implementation (для новых скриптов)
        local bit32 = {}
        bit32.band = bit.band; bit32.bor = bit.bor; bit32.bxor = bit.bxor
        bit32.lshift = bit.lshift; bit32.rshift = bit.rshift; bit32.arshift = bit.arshift
