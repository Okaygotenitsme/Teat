        "Отправь мне файл `.lua` или `.txt`!"
    )
    await message.answer(welcome_text, parse_mode="Markdown")

@dp.message(F.document)
async def process_file(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        await message.answer("❌ Ошибка! Я принимаю только файлы .lua или .txt")
        return

    status_msg = await message.answer("🛠 Подготовка Виртуальной Машины...")
    
    try:
        # Скачивание
        file_info = await bot.get_file(message.document.file_id)
        file_content = await bot.download_file(file_info.file_path)
        source_code = file_content.read().decode('utf-8')

        # Обфускация
        obf = ObfuscatorVM(source_code)
        protected_code = obf.protect()

        # Отправка
        await status_msg.edit_text("🛰 Шифрование завершено. Отправляю...")
        
        output = BufferedInputFile(
            protected_code.encode('utf-8'), 
            filename=f"protected_{message.document.file_name}"
        )
        
        await message.answer_document(output, caption="✅ Код успешно виртуализирован!")
        
    except Exception as e:
        await message.answer(f"❌ Критическая ошибка: {e}")

