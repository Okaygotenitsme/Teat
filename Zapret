@dp.message_handler(content_types=['document'])
async def handle_docs(message: types.Message):
    if message.document.file_name.endswith(('.lua', '.txt')):
        # Скачиваем файл
        file_id = message.document.file_id
        file = await bot.get_file(file_id)
        file_path = file.file_path
        
        downloaded_file = await bot.download_file(file_path)
        source_code = downloaded_file.read().decode('utf-8')

        # Обфусцируем
        protected_code = obfuscate_lua(source_code)

        # Сохраняем и отправляем обратно
        output_name = "protected_" + message.document.file_name
        with open(output_name, "w", encoding="utf-8") as f:
            f.write(protected_code)

        with open(output_name, "rb") as f:
            await message.reply_document(f, caption="✅ Твой код защищен технологией VM!")
    else:
        await message.reply("Пожалуйста, отправь файл с расширением .lua или .txt")

