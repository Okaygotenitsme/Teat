def _rand_var_name():
    """Генерирует запутывающие имена переменных (Il1l, O0O0, v_AF2)"""
    mode = random.choice(['visual', 'random', 'normal'])
    if mode == 'visual':
        # Визуально похожие символы
        chars = "Il1"
        return "".join(random.choice(chars) for _ in range(random.randint(8, 12)))
    elif mode == 'random':
        # Абсолютный рандом
        chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
        return "".join(random.choice(chars) for _ in range(random.randint(6, 10)))
    else:
        # Похоже на обычные переменные
        prefix = random.choice(['val', 'data', 'temp', 'idx', 'ptr', 'mem'])
        suffix = "".join(random.choice("0123456789ABCDEF") for _ in range(4))
        return f"{prefix}_{suffix}"

def _chunker(seq, min_size=50, max_size=150):
    """
    Увеличенный размер чанка для больших файлов.
    Меньше оверхеда на VM = быстрее работа.
    """
    i = 0
    while i < len(seq):
        size = random.randint(min_size, max_size)
        yield seq[i:i+size]
        i += size

