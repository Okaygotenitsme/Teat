                function bit.bxor(a, b) local r=0; local m=1; while a+b>0 do local ra,rb=a%2,b%2; if ra+rb==1 then r=r+m end; a,b,m=(a-ra)/2,(b-rb)/2,m*2 end; return r end
                function bit.lshift(a, b) return (a * 2^b) % 4294967296 end
