    def _n(self):
        """Генератор запутанных имен (Il1l0O)"""
        length = random.randint(12, 25)
        return ''.join(random.choices("Il1O0", k=length))

    def _junk_code(self):
        """Генерирует мусор для сбивания с толку"""
        vars_ = [self._n() for _ in range(3)]
        ops = [
