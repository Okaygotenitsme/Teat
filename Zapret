ACTOR CoolFriend 15000
{
  Health 5000
  Radius 20
  Height 56
  Speed 10              // Сделал чуть медленнее, чтобы не пугал скоростью
  Scale 0.2             // <--- ЭТО УМЕНЬШИТ ЕГО (0.2 = 20% от размера фото)
  Monster
  +FLOORCLIP
  
  // Чтобы он не дергался лишний раз
  MinMissileChance 0    
  
  States
  {
  Spawn:
    FRND A 10 A_Look
    Loop

  See:
    // null, null означает: "Никогда не переходи в атаку" и "Никогда не переходи в ближний бой"
    FRND AABBCCDD 4 A_Chase(null, null) 
    Loop

  Pain:
    // Сюда код попадает ТОЛЬКО если ты в него выстрелил
    TNT1 A 0 A_ChangeFlag("MISSILEMORE", 1) // Включаем агрессию
    TNT1 A 0 A_ChangeFlag("MISSILEEVENMORE", 1)
    
    ANGR A 105 A_Pain   // Замирает на 3 секунды со злым лицом
    
    // Призыв клонов
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", 40, 40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", -40, 40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", 40, -40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", -40, -40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    
    Goto AngrySee       // Идем в злой режим

  AngrySee:
    // Теперь он ведет себя как обычный монстр и ищет момент для атаки (Missile)
    ANGR AABBCCDD 3 A_Chase
    Loop

  Missile:
    // Этот блок теперь работает ТОЛЬКО после того, как сработал Pain и мы перешли в AngrySee
    TNT1 A 0 A_Jump(60, "SummonMore") // Шанс призвать еще клонов
    
    ANGR E 8 A_FaceTarget
    ANGR F 8 BRIGHT A_CustomMissile("FatShot", 32, 0, 0) // Огонь
    ANGR E 8
    Goto AngrySee

  SummonMore:
    ANGR A 10 A_FaceTarget
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", 50, 0, 0, 0, 0, 0, 0, SXF_SETMASTER)
    Goto AngrySee

  Death:
    ANGR H 10 A_Scream
    ANGR I 10 A_NoBlocking
    ANGR JKLM 10
    Stop
  }
}

// Клон (тоже уменьшен)
ACTOR CoolFriendClone
{
  Health 100
  Speed 12
  Radius 20
  Height 56
  Scale 0.2             // <--- У клонов тоже уменьшаем размер
  Monster
  +FLOORCLIP
  States
  {
  Spawn:
    FRND A 10 A_Look
    Loop
  See:
    FRND AABBCCDD 3 A_Chase
    Loop
  Missile:
    FRND E 8 A_FaceTarget
    FRND F 8 BRIGHT A_CustomMissile("DoomImpBall", 32, 0, 0)
    Goto See
  Death:
    FRND H 5 A_Scream
    FRND I 5 A_NoBlocking
    Stop
  }
}
