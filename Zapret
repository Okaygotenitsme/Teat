@dp.message(F.document)
async def handle_document(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        await message.answer("❌ Нужен файл с расширением .lua или .txt")
        return

    status = await message.answer("🛡 Применяю Meloten MAX obfuscation — это займёт пару секунд...")
    try:
        file_in_memory = io.BytesIO()
        await bot.download(message.document, destination=file_in_memory)
        source_code = file_in_memory.getvalue().decode('utf-8', errors='ignore')

        obf = MelotenMaxVM(source_code)
        protected_code = obf.build()

        out_name = f"Protected_{message.document.file_name}"
        output = BufferedInputFile(protected_code.encode('utf-8'), filename=out_name)
        await message.answer_document(output, caption="✅ Код обфусцирован (Meloten MAX VM).")
        await status.delete()
    except Exception as e:
        await message.answer(f"⚠️ Ошибка: {str(e)}")

