    bot.reply_to(m, "🛡 **Meloten Obfuscator**\n\nПришли мне файл `.lua` или просто текст со скриптом.")

@bot.message_handler(content_types=["document", "text"])
def handle_input(m):
    if m.content_type == "document":
        if not m.document.file_name.endswith((".lua", ".txt")):
            bot.reply_to(m, "❌ Пожалуйста, отправь .lua файл.")
            return
        f = bot.get_file(m.document.file_id)
        code = bot.download_file(f.file_path).decode("utf-8", errors="ignore")
    else:
        code = m.text

    user_files[m.chat.id] = code

    kb = InlineKeyboardMarkup()
    kb.row(InlineKeyboardButton("⚡ Roblox Executor", callback_data="roblox_exec"))
    kb.row(InlineKeyboardButton("🛠 Roblox Studio", callback_data="studio"))
    kb.row(InlineKeyboardButton("🌙 Lua 5.1", callback_data="lua51"))

    bot.reply_to(m, "Выбери среду исполнения:", reply_markup=kb)

@bot.callback_query_handler(func=lambda c: True)
def callback(c):
    cid = c.message.chat.id
    if cid not in user_files:
        bot.answer_callback_query(c.id, "Ошибка: код не найден. Отправь файл снова.")
        return

    try:
        # Уведомляем пользователя, что процесс пошел
        bot.answer_callback_query(c.id, "Обфускация...")
        
        out = build_meloten_vm(user_files[cid], c.data)
        
        name = f"Meloten_{cid}.lua"
        with open(name, "w", encoding="utf-8") as f:
            f.write(out)

        with open(name, "rb") as f:
            bot.send_document(cid, f, caption="✅ Скрипт защищен!")
        
        os.remove(name)
        del user_files[cid]
        
    except Exception as e:
        bot.send_message(cid, f"❌ Ошибка при сборке:\n`{str(e)}`", parse_mode="Markdown")

