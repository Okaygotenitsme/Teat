import logging
import subprocess
import os
import tempfile
import re
import binascii

# Логгер
logger = logging.getLogger("DeobfuscatorEngine")

class DeobfuscatorEngine:
    def __init__(self):
        self.base_dir = os.path.dirname(os.path.abspath(__file__))
        self.luau_path = os.path.join(self.base_dir, "luau.exe")
        logger.info(f"📁 Working Dir: {self.base_dir}")
        if os.path.exists(self.luau_path):
            logger.info("✅ luau.exe обнаружен! Режим совместимости: ULTRA.")
        else:
            logger.warning("⚠️ luau.exe НЕ НАЙДЕН! Положите luau.exe в папку с ботом.")

    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        if not os.path.exists(self.luau_path):
            return b"-- [ERROR] luau.exe not found. Please place luau.exe in the bot folder."

        update_status("⚙️ Подготовка Luau Environment...")

        # ==========================================
        # ЭМУЛЯТОР ROBLOX (Написан на Lua)
        # ==========================================
        # Мы добавляем этот код ПЕРЕД скриптом пользователя.
        # Он создает фейковый game, script, перехватывает функции.
        env_script = r"""
        -- [[ SECURITY SANDBOX ]] --
        -- Отключаем опасные функции ОС, чтобы скрипт не навредил твоему ПК
        os.execute = nil; os.remove = nil; os.rename = nil; io.popen = nil
        
        -- [[ LOGGING SYSTEM ]] --
        local function send_log(type, msg)
            -- Формат для парсинга в Python: [TYPE] Message
            print(string.format("[%s] %s", type, msg))
        end

        -- [[ ROBLOX API EMULATION ]] --
        getgenv = function() return _G end
        getrenv = function() return _G end
        checkcaller = function() return true end
        
        -- Task Scheduler
        task = {
            wait = function() return 0 end,
            spawn = function(f) coroutine.wrap(f)() end,
            delay = function(t, f) coroutine.wrap(f)() end,
            defer = function(f) coroutine.wrap(f)() end
        }
        wait = task.wait
        spawn = task.spawn
        delay = task.delay

        -- Instance & Game
        local InstanceMock = {}
        InstanceMock.__index = function(t, k)
            if k == "Parent" then return nil end
            if k == "Name" then return "MockObject" end
            -- Возвращаем функцию-заглушку или новый объект
            return function(...) return InstanceMock.new() end
        end
        -- Магия: если обращаются к game.Players, возвращаем объект, а не nil
        InstanceMock.__newindex = function(t, k, v) end
        
        function InstanceMock.new(cls)
            local obj = {}
            setmetatable(obj, {
                __index = function(s, key)
                    if key == "Connect" then return function() end end -- Signal
                    if key == "Value" then return "MockValue" end
                    -- Рекурсивный возврат новых объектов
                    return setmetatable({}, InstanceMock) 
                end,
                __newindex = function() end,
                __tostring = function() return cls or "Instance" end
            })
            return obj
        end
        
        game = InstanceMock.new("DataModel")
        workspace = InstanceMock.new("Workspace")
        script = InstanceMock.new("Script")
        
        -- Services
        game.HttpGet = function(s, url)
            send_log("HTTP", "GET: " .. tostring(url))
            return "ProxyResponse"
        end
        game.HttpPost = function(s, url, data)
            send_log("HTTP", "POST: " .. tostring(url))
            return "ProxyResponse"
        end

        -- [[ HOOKS & SPY ]] --
        
        -- Hook loadstring to capture unpacked code
        local old_loadstring = loadstring
        getfenv().loadstring = function(chunk)
            if type(chunk) == "string" and #chunk > 50 then
                send_log("CHUNK", chunk) -- Отправляем код в Python
            end
            return old_loadstring(chunk)
        end

        -- Hook string.char (anti-obfuscation)
        local old_char = string.char
        string.char = function(...)
            local args = {...}
            local res = old_char(...)
            -- Если создается длинная строка, вероятно это скрипт
            if #res > 20 then
                send_log("STR", res)
            end
            return res
        end
        
        -- Hook bit32 (Roblox uses bit32)
        if not bit32 then bit32 = require("bit") end 

        -- [[ ERROR HANDLING ]] --
        -- Оборачиваем выполнение в pcall, чтобы бот не падал
        local function run_safe(func)
            local s, e = pcall(func)
            if not s then
                send_log("ERR", tostring(e))
            end
        end
        
        -- Заглушка для debug
        debug = {
            getinfo = function() return {} end,
            traceback = function() return "" end
        }

        print("--- START EXECUTION ---")
        """

        # Создаем временный файл
        # Мы склеиваем: Эмулятор + (pcall обертка) + Скрипт юзера
        
        # Очищаем скрипт пользователя от бинарных символов, которые могут сломать запись
        try:
            user_script = content.decode('utf-8')
        except:
            user_script = content.decode('latin-1', errors='ignore')

        # Оборачиваем скрипт пользователя в функцию, чтобы поймать ошибки
        full_source = env_script + "\n" + "run_safe(function()\n" + user_script + "\nend)"

        temp_script_path = os.path.join(self.base_dir, "temp_exec.lua")
        
        update_status("🚀 Запуск luau.exe...")

        try:
            with open(temp_script_path, "w", encoding="utf-8") as f:
                f.write(full_source)
            
            # Запускаем luau.exe через subprocess
            # timeout=10 секунд, чтобы не зависнуть на `while true do end`
            process = subprocess.run(
                [self.luau_path, temp_script_path],
                capture_output=True,
                text=True,
                encoding='utf-8',
                errors='replace',
                timeout=15
            )
            
            output = process.stdout
            
        except subprocess.TimeoutError:
            output = "[ERR] Script execution timed out (Infinite loop detected)."
        except Exception as e:
            output = f"[ERR] Execution failed: {e}"
        finally:
            if os.path.exists(temp_script_path):
                os.remove(temp_script_path)

        return self._parse_output(output, user_script, update_status)

    def _parse_output(self, raw_output, original_source, callback):
        callback("🧬 Анализ логов...")
        
        lines = raw_output.split('\n')
        
        captured_chunks = []
        captured_strings = set()
        http_logs = []
        errors = []
        
        for line in lines:
            # Парсим наши логи
            if line.startswith("[CHUNK] "):
                chunk = line[8:].strip()
                if len(chunk) > 20: captured_chunks.append(chunk)
            elif line.startswith("[STR] "):
                s = line[6:].strip()
                if len(s) > 4: captured_strings.add(s)
            elif line.startswith("[HTTP] "):
                http_logs.append(line[7:].strip())
            elif line.startswith("[ERR] "):
                errors.append(line[6:].strip())
        
        # Формируем итоговый файл
        final_text = "-- [[ DEOBFUSCATOR V2 (Luau Engine) ]] --\n\n"
        
        if http_logs:
            final_text += "-- [ HTTP REQUESTS ]\n"
            for log in http_logs:
                final_text += f"-- {log}\n"
            final_text += "\n"

        if captured_strings:
            final_text += "-- [ CAPTURED STRINGS ]\n"
            for s in captured_strings:
                # Убираем мусор
                clean_s = re.sub(r'[^a-zA-Z0-9\s_@\.\-\/:]', '', s)
                if len(clean_s) > 3:
                    final_text += f'-- "{clean_s}"\n'
            final_text += "\n"

        if captured_chunks:
            final_text += "-- [ !!! DECOMPILED / UNPACKED SCRIPTS !!! ]\n"
            final_text += "-- Found internal loadstring calls. This is likely the source code.\n\n"
            for i, chunk in enumerate(captured_chunks):
                final_text += f"-- CHUNK #{i+1}\n"
                final_text += self._beautify_lua(chunk) + "\n\n"
                final_text += "-" * 40 + "\n\n"
        else:
            final_text += "-- [ SOURCE ]\n"
            final_text += "-- No internal chunks captured. Showing original or partially cleaned source.\n"
            final_text += original_source

        if errors:
            final_text += "\n\n-- [ EXECUTION ERRORS ]\n"
            for err in errors:
                final_text += f"-- {err}\n"

        return final_text.encode('utf-8')

    def _beautify_lua(self, source_code):
        # Простой бьютифайер
        source_code = re.sub(r'(\s)(local|return|if|for|while|repeat|function)(\s)', r'\n\2 ', source_code)
        replacements = {
            " then ": " then\n", " do ": " do\n", " end ": "\nend\n",
            " repeat ": "\nrepeat\n", " until ": "\nuntil ", ";": ";\n"
        }
        for k, v in replacements.items():
            source_code = source_code.replace(k, v)
        return source_code
