@bot.message_handler(content_types=['document'])
def handle_docs(message):
    try:
        if message.document.file_name.endswith(('.lua', '.txt')):
            status = bot.reply_to(message, "⚙️ **Компиляция в байт-код...**")
            
            file_info = bot.get_file(message.document.file_id)
            downloaded = bot.download_file(file_info.file_path)
            src = downloaded.decode('utf-8')
            
            protected = meloten_vm_builder(src)
            
            out_name = "Protected_" + message.document.file_name
            with open(out_name, "w", encoding="utf-8") as f:
                f.write(protected)
            
            bot.send_document(message.chat.id, open(out_name, "rb"), caption="✅ **VM защита наложена.**\nКод внутри полностью виртуализирован.")
            os.remove(out_name)
            bot.delete_message(message.chat.id, status.message_id)
        else:
            bot.reply_to(message, "❌ Кидай только .lua или .txt")
    except Exception as e:
        bot.reply_to(message, f"Ошибка: {e}")

