import lupa
from lupa import LuaRuntime
import re
import logging
import asyncio

# Логгер
logger = logging.getLogger("DeobfuscatorEngine")

class DeobfuscatorEngine:
    def __init__(self):
        pass

    def process(self, content, status_callback=None):
        """
        status_callback: функция, которую движок будет дергать, чтобы сообщить боту о прогрессе.
        """
        def update_status(msg):
            if status_callback:
                status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        # --- ЭТАП 1: Подготовка ---
        update_status("🛠 Подготовка песочницы Lua (v5.4 + Polyfills)...")
        
        try:
            # Создаем Lua Runtime
            lua = LuaRuntime(unpack_returned_tuples=True)
        except Exception as e:
            return f"-- [FATAL ERROR]: Не удалось запустить Lua: {e}"

        # --- ЭТАП 2: Внедрение библиотек (FIX для ошибки 'module bit not found') ---
        update_status("💉 Внедрение патча для библиотеки 'bit'...")
        
        # Этот скрипт создает библиотеку bit на чистом Lua (работает везде)
        bit_polyfill = """
        local bit = {}
        function bit.tobit(x) x = x % 4294967296; if x >= 2147483648 then x = x - 4294967296 end; return x end
        function bit.bnot(x) return 4294967295 - x % 4294967296 end
        
        -- Простая реализация через деление (медленно, но надежно для эмуляции)
        local function bit_oper(a, b, oper)
            local r, m, s = 0, 2^31, nil
            repeat
                s,a,b = a+b+m, a%m, b%m
                r,m = r + m*oper%(s-a-b), m/2
            until m < 1
            return r
        end
        
        function bit.band(a, b) return bit_oper(a, b, 4) end
        function bit.bor(a, b)  return bit_oper(a, b, 1) end
        function bit.bxor(a, b) return bit_oper(a, b, 3) end
        function bit.lshift(a, b) return (a * 2^b) % 4294967296 end
        function bit.rshift(a, b) return math.floor(a / 2^b) % 4294967296 end
        
        -- Регистрируем библиотеку, чтобы require('bit') работало
        package.loaded.bit = bit
        _G.bit = bit
        _G.bit32 = bit -- Подмена bit32 тоже нужна
        """

        # --- ЭТАП 3: Настройка "Ядерной" среды ---
        update_status("🛡️ Создание неубиваемого окружения (Anti-Anti-Tamper)...")
        
        sandbox_setup = bit_polyfill + """
        _G.CAPTURED = nil
        _G.LOGS = {}

        local function log(msg) table.insert(_G.LOGS, msg) end

        -- 1. Мощный хук loadstring
        local raw_load = load
        local function hooked_loadstring(chunk, chunkname)
            if type(chunk) == "string" and #chunk > 100 then
                _G.CAPTURED = chunk
                log("[SUCCESS] Скрытый код перехвачен через loadstring!")
                return function() end -- Возвращаем пустышку, чтобы не выполнять вредоносный код
            end
            return raw_load(chunk, chunkname)
        end

        -- 2. Среда-приманка
        local env = {
            loadstring = hooked_loadstring,
            load = hooked_loadstring,
            
            -- Фейковые функции Roblox
            print = function(...) local arg={...} log("[SCRIPT PRINT]: " .. tostring(arg[1])) end,
            warn = function(...) end,
            error = function(...) log("[SCRIPT ERROR]: " .. tostring((...))) end,
            
            -- Обход проверок окружения
            getfenv = function() return _G.sandbox_env end,
            setfenv = function(f, t) return f end,
            
            -- Подмена debug (чтобы скрипт не понял, что его анализируют)
            debug = {
                getinfo = function() return { source = "=[C]", what = "C" } end, -- Прикидываемся движком игры
                getupvalue = function() return nil end,
                setupvalue = debug.setupvalue,
                traceback = debug.traceback
            },
            
            string = string, math = math, table = table, pairs = pairs, ipairs = ipairs,
            tonumber = tonumber, tostring = tostring, type = type, next = next,
            pcall = pcall, xpcall = xpcall, select = select,
            
            game = { GetService = function() return {} end },
            script = {}
        }
        
        -- Замыкаем окружение
        env._G = env
        env.getgenv = function() return env end
        _G.sandbox_env = env
        
        return env
        """

        # --- ЭТАП 4: Запуск ---
        update_status("🚀 Запуск обфусцированного кода в песочнице...")
        
        try:
            env = lua.execute(sandbox_setup)
            
            # Запускаем скрипт пользователя
            runner = lua.eval("""
                function(code, env)
                    -- Пытаемся загрузить код в защищенную среду
                    local f, err = load(code, "target", "t", env)
                    if not f then return false, "Syntax Error: " .. tostring(err) end
                    
                    -- Запускаем
                    return pcall(f)
                end
            """)
            
            success, res = runner(content, env)
            
            # Проверяем результат
            captured = lua.globals().CAPTURED
            logs = list(lua.globals().LOGS)
            
            if captured:
                update_status("✅ Код успешно перехвачен! Начинаю очистку...")
                return self._clean_code(str(captured))
            
            elif not success:
                log_str = "\n".join([str(l) for l in logs[-5:]]) # Последние 5 логов
                return f"-- [FAIL] Ошибка выполнения Lua: {res}\n-- Последние логи:\n-- {log_str}"
            
            else:
                return "-- [FAIL] Скрипт выполнился, но ничего не распаковал (возможно, используется другая техника)."

        except Exception as e:
            return f"-- [CRITICAL ERROR]: {str(e)}"

    def _clean_code(self, code):
        """Очистка мусора"""
        # 1. Красивый заголовок
        header = "-- [[ DEOBFUSCATED & CLEANED ]]\n\n"
        
        # 2. Убираем return в конце, который часто бывает в байткоде
        code = re.sub(r"\s*return\s*$", "", code)
        
        # 3. Базовая формат-чистка
        # Заменяем ; на новую строку для читаемости
        code = code.replace(";", "\n")
        
        return header + code
