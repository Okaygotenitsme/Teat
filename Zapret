import os
import logging
from telegram import Update
from telegram.ext import Application, CommandHandler, MessageHandler, filters, ContextTypes
from obfus import MelotenObfuscator

# Настройка логирования
logging.basicConfig(
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s',
    level=logging.INFO
)
logger = logging.getLogger(__name__)

# Токен бота (замените на свой)
BOT_TOKEN = "YOUR_BOT_TOKEN_HERE"

# Инициализация обфускатора
obfuscator = MelotenObfuscator()

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /start"""
    welcome_message = """
🔒 **Meloten Obfuscator v0.1**

Добро пожаловать в самый мощный обфускатор для Roblox Lua!

📝 **Как использовать:**
1. Отправьте .lua или .txt файл с вашим скриптом
2. Получите обфусцированный файл обратно
3. Скачанный файл автоматически удалится с сервера

⚡ **Возможности:**
• Многослойное шифрование
• Контроль потока выполнения
• Переименование переменных
• Удаление комментариев и форматирования
• Вставка мусорного кода
• Защита строк

Отправьте файл для начала работы!
    """
    await update.message.reply_text(welcome_message, parse_mode='Markdown')

async def handle_document(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик файлов"""
    try:
        document = update.message.document
        file_name = document.file_name
        
        # Проверка расширения файла
        if not (file_name.endswith('.lua') or file_name.endswith('.txt')):
            await update.message.reply_text(
                "❌ Пожалуйста, отправьте файл с расширением .lua или .txt"
            )
            return
        
        # Отправка статуса
        status_msg = await update.message.reply_text("⏳ Обработка файла...")
        
        # Скачивание файла
        file = await context.bot.get_file(document.file_id)
        input_path = f"temp_{update.effective_user.id}_{file_name}"
        await file.download_to_drive(input_path)
        
        # Чтение содержимого
        with open(input_path, 'r', encoding='utf-8') as f:
            lua_code = f.read()
        
        # Обфускация
        await status_msg.edit_text("🔒 Обфускация кода...")
        obfuscated_code = obfuscator.obfuscate(lua_code)
        
        # Создание выходного файла
        output_name = f"obfuscated_{file_name}"
        output_path = f"temp_out_{update.effective_user.id}_{output_name}"
        
        with open(output_path, 'w', encoding='utf-8') as f:
            f.write(obfuscated_code)
        
        # Отправка файла
        await status_msg.edit_text("📤 Отправка результата...")
        with open(output_path, 'rb') as f:
            await update.message.reply_document(
                document=f,
                filename=output_name,
                caption="✅ Обфускация завершена!\n🔒 Ваш код защищен Meloten v0.1"
            )
        
        # Удаление временных файлов
        if os.path.exists(input_path):
            os.remove(input_path)
        if os.path.exists(output_path):
            os.remove(output_path)
        
        await status_msg.delete()
        
        logger.info(f"Файл обфусцирован для пользователя {update.effective_user.id}")
        
    except Exception as e:
        logger.error(f"Ошибка при обработке файла: {e}")
        await update.message.reply_text(
            f"❌ Произошла ошибка при обработке файла:\n{str(e)}"
        )
        
        # Очистка в случае ошибки
        try:
            if os.path.exists(input_path):
                os.remove(input_path)
            if os.path.exists(output_path):
                os.remove(output_path)
        except:
            pass

async def help_command(update: Update, context: ContextTypes.DEFAULT_TYPE):
    """Обработчик команды /help"""
    help_text = """
🔒 **Meloten Obfuscator v0.1 - Помощь**

**Команды:**
/start - Начать работу
/help - Показать эту справку

**Поддерживаемые форматы:**
• .lua
• .txt

**Методы обфускации:**
1. Шифрование строк
2. Переименование переменных
3. Контроль потока
4. Мусорный код
5. Удаление пробелов
6. Скремблирование логики

**Примечание:** 
Обфусцированный код может быть медленнее оригинала из-за дополнительных слоев защиты.
    """
    await update.message.reply_text(help_text, parse_mode='Markdown')

def main():
    """Запуск бота"""
    # Создание приложения
    application = Application.builder().token(BOT_TOKEN).build()
    
    # Регистрация обработчиков
    application.add_handler(CommandHandler("start", start))
    application.add_handler(CommandHandler("help", help_command))
    application.add_handler(MessageHandler(filters.Document.ALL, handle_document))
    
    # Запуск бота
    logger.info("Бот Meloten запущен!")
    application.run_polling(allowed_updates=Update.ALL_TYPES)

if __name__ == '__main__':
    main()
