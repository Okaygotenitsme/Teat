import asyncio
import os
import logging
import uuid
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command

# Импортируем наш мощный движок
from engine import DeobfuscatorEngine

# --- CONFIG ---
API_TOKEN = 'ТВОЙ_ТОКЕН_ЗДЕСЬ' 

logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(message)s")
logger = logging.getLogger("Bot")

bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def start_handler(msg: types.Message):
    await msg.answer(
        "🗡️ **Ultimate Lua Deobfuscator**\n\n"
        "Поддерживает:\n"
        "📦 **MoonSec V3 / IronBrew** (Bit32 Emulation)\n"
        "💉 **Synapse/Krnl Checks** (Env Mocking)\n"
        "🕸️ **Stack Crawler** (Upvalue Stealing)\n\n"
        "Просто скинь файл `.lua`."
    )

@dp.message(F.document)
async def doc_handler(msg: types.Message):
    uid = uuid.uuid4().hex[:6]
    f_in = f"temp_{uid}.lua"
    f_out = f"Deobfuscated_{msg.document.file_name}_{uid}.txt"
    
    status = await msg.answer("🕵️ **Инициализация...**")
    
    # Получаем loop для threadsafe обновлений
    loop = asyncio.get_running_loop()
    
    def callback(text):
        if loop.is_closed(): return
        asyncio.run_coroutine_threadsafe(
            status.edit_text(f"⚙️ {text}"), loop
        )

    try:
        # Скачиваем
        file = await bot.get_file(msg.document.file_id)
        await bot.download_file(file.file_path, f_in)
        
        with open(f_in, "rb") as f: content = f.read()

        # Запускаем в отдельном потоке, чтобы не блочить бота
        # Увеличили таймаут до 3 минут, так как эмуляция тяжелая
        res_data = await asyncio.wait_for(
            asyncio.to_thread(engine.process, content, callback),
            timeout=180.0
        )
        
        # Пишем результат
        with open(f_out, "wb") as f: f.write(res_data)
        
        # Отправляем
        caption = "✅ **Успешно!**\nПроверь секцию `[CAPTURED UPVALUES]` и `[DECRYPTED STRINGS]`."
        if b"RUNTIME_ERR" in res_data:
            caption = "⚠️ **Частичный успех.** Скрипт упал во время эмуляции, но данные собраны."
            
        await msg.answer_document(FSInputFile(f_out), caption=caption)

    except asyncio.TimeoutError:
        await status.edit_text("💀 **Тайм-аут.** Скрипт слишком сложный или имеет защиту от зависания.")
    except Exception as e:
        await status.edit_text(f"❌ **Ошибка:** {e}")
    finally:
        # Уборка
        for f in [f_in, f_out]:
            if os.path.exists(f): os.remove(f)

async def main():
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
