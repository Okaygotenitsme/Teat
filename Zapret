import asyncio
import os
import logging
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command
from aiogram.exceptions import TelegramBadRequest

# Импортируем наш обновленный движок
from engine import DeobfuscatorEngine

# --- НАСТРОЙКИ ---
API_TOKEN = 'ВАШ_ТОКЕН_ОТ_BOTFATHER' 

# Настройка логирования для отслеживания работы
logging.basicConfig(
    level=logging.INFO, 
    format="%(asctime)s - [%(levelname)s] - %(message)s"
)
logger = logging.getLogger("DeobfBot")

bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    """Приветственное сообщение"""
    welcome_text = (
        "🤖 **Roblox Deobfuscator Bot V2.5**\n\n"
        "Я готов вскрывать Lua скрипты (IronBrew, MoonSec и др.).\n\n"
        "✨ **Как это работает:**\n"
        "1. Пришли мне файл `.lua` или `.txt` со скриптом.\n"
        "2. Я запущу его в безопасной 'песочнице'.\n"
        "3. Если скрипт попытается расшифровать себя, я перехвачу код!"
    )
    await message.answer(welcome_text, parse_mode="Markdown")

@dp.message(F.document)
async def handle_document(message: types.Message):
    """Обработка присланного файла"""
    user_id = message.from_user.id
    file_name = message.document.file_name
    
    # Создаем уникальные имена для временных файлов
    input_path = f"in_{user_id}_{file_name}"
    output_path = f"out_{user_id}.lua"

    status_msg = await message.answer("⏳ **Подготовка среды...**", parse_mode="Markdown")
    
    # Кэш для статуса, чтобы не спамить в Telegram API
    last_status = [""]

    def sync_status_updater(text):
        """Обновление текста статуса из синхронного кода Engine"""
        if text == last_status[0]: 
            return
        last_status[0] = text
        
        async def edit_coro():
            try:
                await status_msg.edit_text(f"⚙️ **Процесс:**\n\n🔹 {text}", parse_mode="Markdown")
            except TelegramBadRequest:
                pass # Если сообщение не изменилось или удалено
        
        # Передаем выполнение в основной поток asyncio
        asyncio.run_coroutine_threadsafe(edit_coro(), bot.loop)

    try:
        # 1. Скачиваем файл пользователя
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        # Читаем содержимое как байты (чтобы не было ошибок кодировки)
        with open(input_path, "rb") as f:
            content = f.read()

        # 2. ЗАПУСК ДЕОБФУСКАЦИИ
        # Запускаем в отдельном потоке, чтобы бот не "зависал"
        try:
            result_data = await asyncio.wait_for(
                asyncio.to_thread(engine.process, content, sync_status_updater),
                timeout=120.0
            )
        except asyncio.TimeoutError:
            result_data = b"-- [TIMEOUT] Script took more than 2 minutes to process."
            await status_msg.edit_text("❌ **Ошибка:** Превышено время ожидания.")

        # 3. Сохранение и отправка результата
        await status_msg.edit_text("✅ **Готово!** Формирую файл...")
        
        # Сохраняем результат как БАЙТЫ (wb)
        with open(output_path, "wb") as f:
            f.write(result_data)

        # Отправляем файл пользователю
        final_file = FSInputFile(output_path, filename=f"Fixed_{file_name}")
        await message.answer_document(
            final_file, 
            caption="✅ **Деобфускация завершена!**\n\n"
                    "💡 *Если внутри байткод, используй декомпилятор unluac.*"
        )

    except Exception as e:
        logger.error(f"Критическая ошибка: {e}")
        await status_msg.edit_text(f"❌ **Произошла ошибка:**\n`{str(e)}`", parse_mode="Markdown")

    finally:
        # Очистка: удаляем временные файлы
        for p in [input_path, output_path]:
            if os.path.exists(p):
                try:
                    os.remove(p)
                except Exception as cleanup_err:
                    logger.warning(f"Не удалось удалить файл {p}: {cleanup_err}")

async def main():
    # Важно: привязываем текущий цикл событий к объекту бота
    bot.loop = asyncio.get_running_loop()
    
    # Удаляем старые обновления и запускаем бота
    await bot.delete_webhook(drop_pending_updates=True)
    logger.info("Бот запущен и готов к работе!")
    await dp.start_polling(bot)

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except (KeyboardInterrupt, SystemExit):
        logger.info("Бот остановлен.")
