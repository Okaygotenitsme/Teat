  local {var} = 0
  for i=1,{random.randint(4,18)} do
    {var} = ({var} + (i * {random.randint(2,12)}) + (i % {random.randint(2,9)})) % 65536
  end
  return {var}
end
"""
        return textwrap.dedent(body)

    def build(self) -> str:
        # original bytes
        src_bytes = [ord(c) for c in self.source]
        mapping = self._generate_map()
        mapped = self._apply_map(src_bytes, mapping)
        xor_key = random.getrandbits(32)
        xored = self._xor_layer(mapped, xor_key)
        opcode_stream = self._build_opcode_stream(xored)

        # decoys (to confuse dumpers)
        decoy1_text = "--[[Meloten Decoy 1]] print('decoy1')"
        decoy2_text = "--[[Meloten Decoy 2]] for i=1,5 do end"
        dec1 = [ord(c) for c in decoy1_text]
        dec2 = [ord(c) for c in decoy2_text]
        dec1_m = self._apply_map(dec1, mapping)
        dec2_m = self._apply_map(dec2, mapping)
        dec1_x = self._xor_layer(dec1_m, xor_key ^ 0xA5A55A5A)
        dec2_x = self._xor_layer(dec2_m, xor_key ^ 0x5AA55AA5)
        dec1_ops = self._build_opcode_stream(dec1_x)
        dec2_ops = self._build_opcode_stream(dec2_x)

        checksum = sum(src_bytes) & 0xFFFFFFFF

