# --- СЕРДЦЕ ОБФУСКАТОРА ---

def generate_junk():
    """Создает случайный мусорный код для Roblox"""
    var_name = ''.join(random.choices(string.ascii_letters, k=8))
    return f"local {var_name} = {random.randint(100, 9999)}; -- Hidden layer\n"

def obfuscate_lua(source_code):
    """Шифрует код методом XOR и упаковывает в VM оболочку"""
    key = random.randint(10, 255)
    # Превращаем буквы в цифры и шифруем
    encrypted = [ord(c) ^ key for c in source_code]
    bytes_str = "{" + ",".join(map(str, encrypted)) + "}"
    
    # Это код, который получит пользователь. Он работает в Roblox Studio.
    protected_script = f"""--[[ 
    PROTECTED BY PROGRAMMER PARTNER VM
    Build: {random.randint(1000, 9999)}
]]
{generate_junk()}
local _D = {bytes_str}
local _K = {key}
local _R = ""

for i = 1, #_D do
    _R = _R .. string.char(bit32.bxor(_D[i], _K))
end

{generate_junk()}
local _F, _E = loadstring(_R)
if _F then
    task.spawn(_F)
else
    warn("Incompatibility or Integrity Error!")
end
{generate_junk()}
"""
    return protected_script

# --- ОБРАБОТЧИКИ СООБЩЕНИЙ ---

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer("🚀 Бот-обфускатор активен!\n\nПришли мне файл **.lua** или **.txt**, и я защищу его для Roblox.")

@dp.message(F.document)
async def handle_document(message: types.Message):
    # Проверяем, что файл подходит
    if message.document.file_name.endswith(('.lua', '.txt')):
        await message.answer("🛠 Обработка... Строю виртуальную машину...")
        
        try:
            # Загружаем файл в память
            file_info = await bot.get_file(message.document.file_id)
            file_content = await bot.download_file(file_info.file_path)
            source_text = file_content.read().decode('utf-8')

            # Обфусцируем
            obfuscated_text = obfuscate_lua(source_text)

            # Отправляем файл обратно пользователю
            input_file = BufferedInputFile(
                obfuscated_text.encode('utf-8'), 
                filename=f"protected_{message.document.file_name}"
            )
            await message.answer_document(input_file, caption="✅ Код защищен слоем VM!")
            
        except Exception as e:
            await message.answer(f"❌ Ошибка при чтении файла: {e}")
    else:
        await message.answer("⚠️ Отправь файл с расширением .lua или .txt")

