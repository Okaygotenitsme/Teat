        end
        _G.load = enhanced_load
        _G.loadstring = enhanced_load
        
        function _G.dump_globals()
            local ignore = {string=1, math=1, table=1, bit=1, bit32=1, pairs=1, ipairs=1, _G=1, package=1, load=1, loadstring=1, print=1, warn=1, tostring=1, tonumber=1, type=1, pcall=1}
            local count = 0
            for k, v in pairs(_G) do
                if not ignore[k] and count < 200 then
                    local t = type(v)
                    if t == "string" or t == "number" or t == "boolean" then
                        table.insert(_G.FINAL_GLOBALS, tostring(k) .. " = " .. tostring(v))
