import asyncio
import os
import logging
import sys
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command
from engine import DeobfuscatorEngine

# --- НАСТРОЙКА ЛОГОВ (ЧТОБЫ НЕ БЫЛО МОЛЧАНИЯ) ---
logging.basicConfig(
    level=logging.INFO,
    format="%(asctime)s - [%(levelname)s] - %(name)s - %(message)s",
    handlers=[logging.StreamHandler(sys.stdout)]
)
logger = logging.getLogger("BotWorker")

API_TOKEN = "ТВОЙ_ТОКЕН_СЮДА" 

# Проверка токена
if "ТВОЙ_ТОКЕН" in API_TOKEN:
    logger.critical("ТЫ ЗАБЫЛ ВСТАВИТЬ ТОКЕН В bot.py!")
    sys.exit()

# Инициализация
bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    logger.info(f"Пользователь {message.from_user.id} нажал /start")
    await message.answer(
        "👋 **Привет! Я Lua Deobfuscator.**\n\n"
        "Просто пришли мне `.lua` или `.txt` файл с обфусцированным кодом.\n"
        "Я попробую вытащить из него чистое содержимое."
    )

@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    file_name = message.document.file_name
    
    logger.info(f"Принят файл {file_name} от {user_id}")
    msg = await message.answer("📥 Скачиваю и запускаю анализ...")

    # Пути к файлам
    input_path = f"temp_{user_id}_in.lua"
    output_path = f"temp_{user_id}_out.lua"

    try:
        # 1. Скачивание
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        # 2. Чтение
        with open(input_path, "r", encoding="utf-8", errors="ignore") as f:
            content = f.read()

        await msg.edit_text("⚙️ Запущен движок деобфускации (это может занять время)...")

        # 3. ЗАПУСК ДВИЖКА (В ОТДЕЛЬНОМ ПОТОКЕ, ЧТОБЫ БОТ НЕ ЗАВИС)
        # Лимит времени - 60 секунд
        try:
            result_code = await asyncio.wait_for(
                asyncio.to_thread(engine.process, content),
                timeout=60.0
            )
        except asyncio.TimeoutError:
            result_code = "-- [ERROR] Скрипт выполняется слишком долго! Возможно, там бесконечный цикл."
            logger.warning(f"Timeout для {user_id}")

        # 4. Сохранение результата
        with open(output_path, "w", encoding="utf-8") as f:
            f.write(result_code)

        # 5. Отправка
        output_file = FSInputFile(output_path)
        await message.answer_document(
            output_file, 
            caption=f"✅ **Готово!**\nРазмер кода: {len(result_code)} символов."
        )
        logger.info(f"Файл отправлен {user_id}")

    except Exception as e:
        logger.error(f"Ошибка при обработке: {e}")
        await message.answer(f"❌ Произошла ошибка: {e}")
    
    finally:
        # Удаление мусора
        for p in [input_path, output_path]:
            if os.path.exists(p):
                try:
                    os.remove(p)
                except:
                    pass

async def main():
    logger.info("Бот запускается...")
    # Удаляем старые апдейты, чтобы бот не отвечал на старые сообщения пачкой
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    try:
        asyncio.run(main())
    except (KeyboardInterrupt, SystemExit):
        logger.info("Бот остановлен.")
