import lupa
from lupa import LuaRuntime
import logging
import subprocess
import os
import tempfile
import re
import binascii

logger = logging.getLogger("DeobfuscatorEngine")

class DeobfuscatorEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        logger.info(f"📁 Working Dir: {base_dir}")

    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        if not self._check_java():
            return b"-- [FATAL] Java is missing. Install Java to use unluac."

        update_status("🧠 Инициализация среды (MoonSec Bypass Mode)...")

        # Используем LuaJIT (lupa)
        try:
            lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)
        except Exception as e:
            return f"-- [FATAL] Lua start error: {e}".encode('utf-8')

        # ==========================================
        # 1. POLYFILLS & BITWISE
        # ==========================================
        base_env = """
        -- Стандартные полифиллы для совместимости
        local bit = require("bit") -- Lupa использует LuaJIT, там bit встроен
        _G.bit = bit
        _G.bit32 = bit -- MoonSec часто ищет bit32

        -- Вспомогательная функция для глубокого копирования (если понадобится)
        function table.clone(org)
            return {table.unpack(org)}
        end
        """

        # ==========================================
        # 2. ROBLOX API MOCK (Minimally viable)
        # ==========================================
        roblox_emu = """
        _G.game = {
            GetService = function(s, n)
                return {
                    ClassName = n,
                    GetChildren = function() return {} end,
                    FindFirstChild = function() return nil end
                }
            end,
            IsLoaded = function() return true end,
            PlaceId = 123456,
            JobId = "Job-Deobfuscator"
        }
        _G.workspace = {
            CurrentCamera = { CFrame = { Position = {X=0,Y=0,Z=0} } }
        }
        _G.script = { Source = "", Name = "LocalScript" }
        _G.Instance = { new = function() return {} end }
        _G.Vector3 = { new = function(x,y,z) return {X=x or 0, Y=y or 0, Z=z or 0} end }
        _G.CFrame = { new = function() return {} end }
        
        -- Важные константы среды
        _G.getgenv = function() return _G end
        _G.getrenv = function() return _G end
        _G.getreg = function() return {} end
        _G.checkcaller = function() return true end
        """

        # ==========================================
        # 3. ADVANCED SPYWARE (ANTI-DETECTION)
        # ==========================================
        # Здесь мы прячем хуки, чтобы MoonSec не заметил подмены
        spyware = """
        _G.CAPTURED_STRINGS = {}
        _G.CAPTURED_CHUNKS = {}
        _G.LOGS = {}

        -- [[ ANTI-TAMPER BYPASS ]] --
        -- Сохраняем оригиналы
        local real_tostring = tostring
        local real_getmetatable = getmetatable
        
        -- Функция для создания "невидимого" хука
        local function secure_hook(tbl, func_name, new_func)
            local old_func = tbl[func_name]
            tbl[func_name] = new_func
            
            -- Подделываем tostring, чтобы он возвращал то же, что и оригинал
            local old_str = real_tostring(old_func)
            local mt = {
                __tostring = function() return old_str end
            }
            -- Пытаемся защитить метатаблицу (хотя в Lupa это сложно)
            try_set_mt = pcall(function() 
                debug.setmetatable(new_func, mt) 
            end)
        end

        -- [[ HOOKING ]] --
        -- Перехват string.char (основной дешифратор)
        local real_char = string.char
        secure_hook(string, "char", function(...)
            local res = real_char(...)
            if #res > 3 then _G.CAPTURED_STRINGS[res] = true end
            return res
        end)

        -- Перехват load/loadstring
        local real_load = load
        local function hooked_load(chunk, name, ...)
            if type(chunk) == "string" and #chunk > 50 then
                table.insert(_G.CAPTURED_CHUNKS, chunk)
                table.insert(_G.LOGS, "🔥 Captured Bytecode/Source size: " .. #chunk)
            end
            return real_load(chunk, name, ...)
        end
        _G.load = hooked_load
        _G.loadstring = hooked_load

        -- [[ DEBUG LIB EMULATION ]] --
        -- MoonSec проверяет debug.getinfo, чтобы узнать, кто его вызвал
        if not debug then debug = {} end
        
        local real_getinfo = debug.getinfo
        debug.getinfo = function(...)
            local stat, res = pcall(real_getinfo, ...)
            if stat then 
                -- Очищаем следы LuaJIT/Lupa
                res.what = "Lua" 
                return res 
            end
            return {}
        end
        
        -- [[ CONSTANT SCANNER (UPVALUES) ]] --
        -- Это самое важное для MoonSec V3!
        -- Мы сканируем переменные внутри функций.
        function _G.scan_deep(func)
            if type(func) ~= "function" then return end
            
            local i = 1
            while true do
                local name, val = debug.getupvalue(func, i)
                if not name then break end
                
                -- Если нашли таблицу, сканируем её на строки
                if type(val) == "table" then
                    for k, v in pairs(val) do
                        if type(v) == "string" and #v > 3 then
                            _G.CAPTURED_STRINGS[v] = true
                        end
                    end
                elseif type(val) == "string" and #val > 3 then
                    _G.CAPTURED_STRINGS[val] = true
                end
                i = i + 1
            end
        end
        """

        full_script = base_env + "\n" + roblox_emu + "\n" + spyware

        try:
            update_status("🌪️ Запуск анализатора (Lupa JIT)...")
            lua.execute(full_script)

            # Раннер с защитой от ошибок
            runner = lua.eval("""
                function(code)
                    -- 1. Сначала пытаемся просто скомпилировать
                    local f, err = load(code)
                    if not f then return "Load Error: " .. tostring(err) end
                    
                    -- 2. СКАНИРУЕМ UPVALUES ДО ЗАПУСКА
                    -- MoonSec инициализирует таблицу строк в самом начале.
                    -- Если мы просканируем функцию 'f', мы можем найти эти таблицы.
                    pcall(_G.scan_deep, f)
                    
                    -- 3. Запускаем с ограничением (pcall)
                    -- Используем корутину, чтобы можно было убить (теоретически)
                    local co = coroutine.create(f)
                    local s, r = coroutine.resume(co)
                    
                    if not s then 
                        table.insert(_G.LOGS, "Execution Error: " .. tostring(r))
                    else
                        table.insert(_G.LOGS, "Script executed successfully")
                    end
                    
                    -- Повторное сканирование (на случай распаковки во время работы)
                    pcall(_G.scan_deep, f)
                    
                    return "Done"
                end
            """)
            
            runner(content)

            # Сбор данных
            captured_strings = list(lua.globals().CAPTURED_STRINGS)
            captured_chunks = list(lua.globals().CAPTURED_CHUNKS)
            logs = list(lua.globals().LOGS)

            # Попытка найти лучший чанк для декомпиляции
            target_bytecode = content
            if len(captured_chunks) > 0:
                # Берем самый большой кусок (обычно это распакованный скрипт)
                best_chunk = max(captured_chunks, key=len)
                if len(best_chunk) > len(content) * 0.5: # Эвристика
                     target_bytecode = best_chunk
                     logs.append(f"Выбран распакованный чанк размером {len(best_chunk)} байт")

            return self._finalize_output(target_bytecode, captured_strings, logs, update_status)

        except Exception as e:
            logger.error(f"Engine Exception: {e}")
            return f"-- [CRITICAL ERROR] {str(e)}".encode('utf-8')

    def _finalize_output(self, code_bytes, strings, logs, callback):
        callback("🧬 Попытка декомпиляции...")
        
        # Конвертация в байты, если это строка
        if isinstance(code_bytes, str):
            try: code_bytes = code_bytes.encode('latin-1') 
            except: code_bytes = code_bytes.encode('utf-8', 'ignore')

        decompiled = self._try_decompile(code_bytes)
        
        # Формирование отчета
        report = []
        report.append("-- [[ MOONSEC / IRONBREW DEOBFUSCATOR REPORT ]]")
        report.append(f"-- Found {len(strings)} interesting strings\n")
        
        report.append("-- [ LOGS ] --")
        for l in logs: report.append(f"-- {l}")
        report.append("")

        report.append("-- [ EXTRACTED STRINGS ] --")
        # Сортируем строки по длине (длинные обычно интереснее)
        unique_strings = sorted(list(set(strings)), key=len, reverse=True)
        for s in unique_strings:
            clean = str(s).replace('\n', ' ').replace('\r', '')
            if len(clean) < 1000: # Игнорируем огромные куски мусора
                report.append(f'-- "{clean}"')
        
        report.append("\n" + "="*50 + "\n")
        
        if decompiled:
            try:
                src = decompiled.decode('utf-8')
            except:
                src = decompiled.decode('latin-1', 'ignore')
            report.append(self._beautify_lua(src))
        else:
            report.append("-- [WARNING] Unluac failed or script is still protected.")
            report.append("-- Dumping raw bytecode representation (partial):")
            report.append(f"-- {str(binascii.hexlify(code_bytes[:100]))}...")

        return "\n".join(report).encode('utf-8', 'ignore')

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path): return None
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            # Запускаем unluac
            res = subprocess.run(
                ["java", "-jar", self.unluac_path, path], 
                capture_output=True, timeout=15
            )
            os.remove(path)
            
            if res.returncode == 0:
                return res.stdout
            return None
        except: return None

    def _beautify_lua(self, source_code):
        # Простой бьютификатор
        source_code = re.sub(r'(\s)(local|return|if|for|while|repeat|function)(\s)', r'\n\2 ', source_code)
        replacements = {
            " then ": " then\n", " do ": " do\n", " end ": "\nend\n",
            " repeat ": "\nrepeat\n", " until ": "\nuntil ", ";": ";\n"
        }
        for k, v in replacements.items():
            source_code = source_code.replace(k, v)
        return source_code
