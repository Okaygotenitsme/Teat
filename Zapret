    def detect_obfuscator(self, content):
        """Определяет тип обфускатора с улучшенной эвристикой"""
        if isinstance(content, str):
            content = content.encode('utf-8', errors='ignore')
        
        # Прямое совпадение по паттернам
        for name, pattern in self.obfuscator_patterns.items():
            if re.search(pattern, content, re.IGNORECASE):
                logger.info(f"🎯 Detected by pattern: {name}")
                return name
        
        # Эвристический анализ
        text = content[:5000].decode('utf-8', errors='ignore')
        
        # PSU признаки
        if 'local function(' in text and text.count('local') > 50:
            if re.search(r'\[\d+\]\s*=\s*\d+', text):
                return "PSU (heuristic)"
        
        # MoonSec признаки
        if 'bit.bxor' in text or 'bit32.bxor' in text:
            if text.count('local') > 30:
                return "MoonSec (heuristic)"
        
        # IronBrew признаки
        if 'Instruction' in text and 'Deserialize' in text:
            return "IronBrew (heuristic)"
        
        # Luraph признаки
        if re.search(r'____[A-Z]+____', text):
            return "Luraph (heuristic)"
        
        return "Unknown"

    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: 
                status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        if not self._check_java():
            return b"-- [FATAL] Java is missing. Install Java to use unluac."

        # Детект обфускатора
        obf_type = self.detect_obfuscator(content)
        update_status(f"🔍 Detected: {obf_type}")

        # Предобработка
        content = self._preprocess_code(content)

        update_status("🧠 Initializing Enhanced Roblox VM...")

        try:
            lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)
        except Exception as e:
            return f"-- [FATAL] Lua init error: {e}".encode('utf-8')

        # ==========================================
        # МАКСИМАЛЬНО ПОЛНАЯ ROBLOX СРЕДА
        # ==========================================
        full_setup = self._build_ultra_environment()

        try:
            update_status("🌪️ Running script with advanced hooks...")
            
            lua.execute(full_setup)
            
            # Безопасный раннер
            runner = lua.eval("""
                function(code)
                    _G.EXECUTION_STARTED = true
                    _G.EXEC_TIME_START = os.clock()
                    
                    local status, err = pcall(function()
                        -- Пытаемся разные режимы загрузки
                        local f, load_err
                        
                        -- Режим 1: Обычный load
                        f, load_err = load(code, "=script", "bt", _G)
                        
                        -- Режим 2: Если не удалось, пробуем через loadstring
                        if not f then
                            f, load_err = loadstring(code)
                        end
                        
                        -- Режим 3: Оборачиваем в функцию (для некоторых обфускаторов)
                        if not f then
                            local wrapped = "return function() " .. code .. " end"
                            f, load_err = load(wrapped, "=script", "bt", _G)
                            if f then f = f() end
                        end
                        
                        if not f then 
                            error("Load failed: " .. tostring(load_err)) 
                        end
                        
                        -- Выполняем
                        local result = f()
                        
                        -- Если вернула функцию, выполняем её тоже
                        if type(result) == "function" then
                            result()
                        end
                    end)
                    
                    _G.EXEC_TIME_END = os.clock()
                    _G.EXEC_TIME = _G.EXEC_TIME_END - _G.EXEC_TIME_START
                    
                    if not status then
                        table.insert(_G.ACTION_LOG, "⚠️ Script Error: " .. tostring(err))
                    else
                        table.insert(_G.ACTION_LOG, "✅ Execution completed in " .. string.format("%.2f", _G.EXEC_TIME) .. "s")
                    end
                    
                    pcall(_G.dump_globals)
                    _G.EXECUTION_FINISHED = true
                    return status
                end
            """)
            
            # Запуск с таймаутом (Windows-совместимый)
            execution_success = False
            try:
                # Используем threading вместо signal для Windows
                exec_thread = threading.Thread(target=lambda: runner(content))
                exec_thread.daemon = True
                exec_thread.start()
                exec_thread.join(timeout=90)  # 90 секунд макс
                
                if exec_thread.is_alive():
                    update_status("⏱️ Execution timeout (90s)")
                else:
                    execution_success = True
                    
            except Exception as e:
                logger.error(f"Execution error: {e}")

            # Сбор данных
            strings_tbl = lua.globals().DETECTED_STRINGS
            detected_strings = list(strings_tbl) if strings_tbl else []
            
            global_dump = list(lua.globals().FINAL_GLOBALS) if lua.globals().FINAL_GLOBALS else []
            action_log = list(lua.globals().ACTION_LOG) if lua.globals().ACTION_LOG else []
            
            chunks = lua.globals().CAPTURED_CHUNKS
            remotes = lua.globals().REMOTE_CALLS
            http_calls = lua.globals().HTTP_CALLS
            
            # Анализ переменных окружения
            env_vars = {}
            try:
                env_vars = dict(lua.globals().ENV_SNAPSHOT) if lua.globals().ENV_SNAPSHOT else {}
            except:
                pass
            
            # Поиск лучшего чанка
            best_chunk = self._find_best_chunk(chunks)
            target_code = best_chunk if best_chunk else content
            
            return self._finalize_output(
                target_code, 
                detected_strings, 
                global_dump, 
                action_log, 
                list(remotes) if remotes else [], 
                list(http_calls) if http_calls else [],
                env_vars,
                obf_type, 
                update_status
            )

        except Exception as e:
            logger.error(f"Engine Crash: {e}", exc_info=True)
            return f"-- [CRASH ERROR]: {str(e)}\n-- Obfuscator: {obf_type}".encode('utf-8')

