@dp.message(F.document)
async def handle_document(message: types.Message):
    """Главный обработчик файлов"""
    user_id = message.from_user.id
    user_name = message.from_user.username or f"user_{user_id}"
    
    # Проверка: один файл за раз
    if user_id in active_tasks:
        await message.answer(
            "⚠️ У вас уже есть активная задача.\n"
            "Используйте /cancel для отмены."
        )
        return
    
    # Валидация файла
    file_name = message.document.file_name or "script.lua"
    file_size_mb = message.document.file_size / (1024 * 1024)
    
    if file_size_mb > MAX_FILE_SIZE_MB:
        await message.answer(
            f"❌ Файл слишком большой ({file_size_mb:.1f} МБ)\n"
            f"Максимум: {MAX_FILE_SIZE_MB} МБ"
        )
        return
    
    if not file_name.endswith(('.lua', '.txt')):
        await message.answer(
            "⚠️ Поддерживаются только `.lua` и `.txt` файлы.\n"
            "Переименуйте файл и попробуйте снова."
        )
        return
    
    # Генерация уникальных имён
    unique_id = uuid.uuid4().hex[:8]
    input_path = f"temp_{user_id}_{unique_id}.lua"
    output_path = f"Deobf_{unique_id}_{file_name}.txt"
    
    # Статус-сообщение
    status_msg = await message.answer(
        f"⏳ **Обработка `{file_name}`...**\n"
        f"📦 Размер: {file_size_mb:.2f} МБ",
        parse_mode="Markdown"
    )
    
    # Получаем текущий event loop
    loop = asyncio.get_running_loop()
    
    # Хранилище для статуса (для синхронизации)
    status_data = {"last": "", "counter": 0}
    
    def update_status(text):
        """Callback из движка для обновления статуса"""
        if text == status_data["last"]:
            return
        
        status_data["last"] = text
        status_data["counter"] += 1
        
        # Обновляем не чаще раза в секунду
        if status_data["counter"] % 3 != 0:
            return
        
        async def edit_task():
            try:
                await status_msg.edit_text(
                    f"⚙️ **Статус:** {text}",
                    parse_mode="Markdown"
                )
            except:
                pass  # Игнорируем ошибки редактирования
        
        if not loop.is_closed():
            asyncio.run_coroutine_threadsafe(edit_task(), loop)
    
    # Создаём задачу
    task = asyncio.create_task(
        process_file(
            message, 
            status_msg, 
            input_path, 
            output_path, 
            update_status
        )
    )
    
    active_tasks[user_id] = task
    
    try:
        await task
    finally:
        # Удаляем из активных
        if user_id in active_tasks:
            del active_tasks[user_id]


async def process_file(message, status_msg, input_path, output_path, callback):
    """Асинхронная обработка файла"""
    loop = asyncio.get_running_loop()
    
    try:
        # ШАГ 1: Скачивание
        callback("📥 Скачивание файла...")
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)
        
        # ШАГ 2: Чтение
        callback("📖 Чтение содержимого...")
        try:
            with open(input_path, "r", encoding="utf-8") as f:
                code = f.read()
        except UnicodeDecodeError:
            # Пробуем латиницу, если UTF-8 не сработал
            with open(input_path, "r", encoding="latin-1") as f:
                code = f.read()
        
        if len(code) < 50:
            await status_msg.edit_text("❌ Файл слишком маленький или пустой.")
            return
        
        # ШАГ 3: Деобфускация
        callback("🔓 Деобфускация кода...")
        
        try:
            # Запускаем движок с таймаутом
            result = await asyncio.wait_for(
                loop.run_in_executor(None, engine.process, code),
                timeout=PROCESSING_TIMEOUT
            )
        except asyncio.TimeoutError:
            await status_msg.edit_text(
                "⏱️ **Превышен лимит времени**\n"
                "Скрипт слишком сложный или зациклился.\n"
                "Попробуйте упростить код.",
                parse_mode="Markdown"
            )
            return
        
        # ШАГ 4: Сохранение
        callback("💾 Сохранение результата...")
        with open(output_path, "w", encoding="utf-8") as f:
            f.write(result)
        
        # ШАГ 5: Отправка
        callback("📤 Отправка файла...")
        
        # Определяем успешность
        success_indicators = [
            "RECOVERED SOURCE CODE",
            "DECODED STRINGS",
            "MAIN SCRIPT"
        ]
        
        success = any(indicator in result for indicator in success_indicators)
        
        if success:
            caption = "✅ **Деобфускация завершена!**\n"
            if "RECOVERED SOURCE CODE" in result:
                caption += "📜 Исходный код восстановлен\n"
            if "DECODED STRINGS" in result:
                caption += "🔎 Извлечены скрытые строки\n"
            if "XOR KEYS" in result:
                caption += "🔐 Найдены ключи шифрования\n"
        else:
            caption = (
                "⚠️ **Частичный результат**\n"
                "Полная деобфускация не удалась,\n"
                "но извлечены доступные данные."
            )
        
        await message.answer_document(
            FSInputFile(output_path),
            caption=caption,
            parse_mode="Markdown"
        )
        
        # Удаляем статус-сообщение
        try:
            await status_msg.delete()
        except:
            pass
        
    except asyncio.CancelledError:
        await status_msg.edit_text("❌ Обработка отменена пользователем.")
        raise
    
    except Exception as e:
        logger.error(f"Processing error: {e}", exc_info=True)
        
        try:
            await status_msg.edit_text(
                f"❌ **Ошибка обработки**\n"
                f"```\n{str(e)[:200]}\n```",
                parse_mode="Markdown"
            )
        except:
            await message.answer("❌ Произошла внутренняя ошибка.")
    
    finally:
        # Очистка файлов
        for path in [input_path, output_path]:
            if os.path.exists(path):
                try:
                    os.remove(path)
                    logger.debug(f"Deleted: {path}")
                except Exception as e:
                    logger.warning(f"Failed to delete {path}: {e}")


