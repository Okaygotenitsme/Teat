ACTOR CoolFriend 15000
{
  Health 5000
  Radius 20
  Height 56
  Speed 12
  
  // РАЗМЕР: Я поставил 0.05 (это в 20 раз меньше оригинала). 
  // Если будет СЛИШКОМ маленький, поменяй на 0.1
  Scale 0.05 
  
  Monster
  +FLOORCLIP
  +LOOKALLAROUND // Чтобы он сразу тебя видел
  
  // Создаем переменную-переключатель (0 - добрый, 1 - злой)
  var int user_angry;

  States
  {
  Spawn:
    FRND A 10 A_Look
    Loop

  See:
    TNT1 A 0 A_JumpIf(user_angry == 1, "AngrySee") // Если злой - идем воевать
    FRND AABBCCDD 3 A_Chase(0, 0) // Если нет - просто бегаем
    Loop

  Pain:
    TNT1 A 0 { user_angry = 1; } // ВКЛЮЧАЕМ РЕЖИМ ЗЛОСТИ
    ANGR A 105 A_Pain // Замирает на 3 секунды со злым фото
    
    // Призыв клонов
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", 40, 40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", -40, 40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", 40, -40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", -40, -40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    Goto AngrySee

  AngrySee:
    ANGR AABBCCDD 3 A_Chase // Теперь бегает и атакует по-настоящему
    Loop

  Missile:
    // Шанс призвать еще клонов во время боя
    TNT1 A 0 A_Jump(64, "SummonMore") 
    
    ANGR E 8 A_FaceTarget
    ANGR F 8 BRIGHT A_CustomMissile("FatShot", 32, 0, 0)
    ANGR E 8
    Goto AngrySee

  SummonMore:
    ANGR A 10 A_FaceTarget
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", 50, 0, 0, 0, 0, 0, 0, SXF_SETMASTER)
    Goto AngrySee

  Death:
    ANGR H 10 A_Scream
    ANGR I 10 A_NoBlocking
    ANGR JKLM 10
    Stop
  }
}

// Клон (тоже очень маленький)
ACTOR CoolFriendClone
{
  Health 100
  Speed 12
  Radius 20
  Height 56
  Scale 0.05 
  Monster
  +FLOORCLIP
  States
  {
  Spawn:
    FRND A 10 A_Look
    Loop
  See:
    FRND AABBCCDD 3 A_Chase
    Loop
  Missile:
    FRND E 8 A_FaceTarget
    FRND F 8 BRIGHT A_CustomMissile("DoomImpBall", 32, 0, 0)
    Goto See
  Death:
    FRND H 5 A_Scream
    FRND I 5 A_NoBlocking
    Stop
  }
}
