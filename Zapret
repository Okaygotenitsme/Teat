-- ServerScriptService/UnitAI (ModuleScript)
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local UnitAI = {}

local function getVal(model, name)
	local v = model:FindFirstChild(name)
	if not v then return nil end
	return v.Value
end

-- Ищем только ВРАЖЕСКИЕ цели (юнитов)
local function findEnemies(selfModel, myOwner)
	local out = {}
	local spawned = Workspace:FindFirstChild("SpawnedUnits")
	if not spawned then return out end
	for _, m in ipairs(spawned:GetChildren()) do
		if m ~= selfModel and m:IsA("Model") and m.PrimaryPart then
			local o = m:FindFirstChild("Owner")
			if o and o.Value ~= myOwner then table.insert(out, m) end
		end
	end
	return out
end

-- Ищем только ВРАЖЕСКИЕ башни
local function findEnemyTowers(myOwner)
	local out = {}
	local towers = Workspace:FindFirstChild("Towers")
	if not towers then return out end
	for _, t in ipairs(towers:GetChildren()) do
		if t:IsA("Model") and t.PrimaryPart then
			local o = t:FindFirstChild("Owner")
			-- Если у башни нет владельца или владелец другой - это враг
			if not o or o.Value ~= myOwner then
				table.insert(out, t)
			end
		end
	end
	return out
end

local function nearest(model, list)
	if not model.PrimaryPart then return nil, math.huge end
	local pos = model.PrimaryPart.Position
	local best, bestDist = nil, math.huge
	for _, m in ipairs(list) do
		local d = (m.PrimaryPart.Position - pos).Magnitude
		if d < bestDist then bestDist = d; best = m end
	end
	return best, bestDist
end

local function movePart(part, targetPos, speed, dt)
	local cur = part.Position
	local dir = (targetPos - cur) * Vector3.new(1, 0, 1) -- Игнорируем высоту (Y)
	if dir.Magnitude < 0.1 then return end
	
	local nextPos = cur + dir.Unit * speed * dt
	part.CFrame = CFrame.new(nextPos, nextPos + dir.Unit)
end

function UnitAI.Attach(unitModel)
	local Damage = getVal(unitModel, "Damage") or 10
	local Speed = getVal(unitModel, "Speed") or 16
	local AttackRadius = getVal(unitModel, "AttackRadius") or 8
	local AttackSpeed = getVal(unitModel, "AttackSpeed") or 1
	local myOwner = getVal(unitModel, "Owner") or ""

	local hp = unitModel:FindFirstChild("Health")
	local primary = unitModel.PrimaryPart
	
	local lastAttackTime = 0
	local active = false
	task.delay(getVal(unitModel, "SpawnSpeed") or 1, function() active = true end)

	local conn
	conn = RunService.Heartbeat:Connect(function(dt)
		if not unitModel.Parent or hp.Value <= 0 then 
			conn:Disconnect()
			unitModel:Destroy()
			return 
		end
		if not active or not primary then return end

		-- 1. Сначала ищем ближайшего вражеского юнита
		local targets = findEnemies(unitModel, myOwner)
		local target, dist = nearest(unitModel, targets)

		-- 2. Если вражеских юнитов нет, ищем башни
		if not target then
			local towers = findEnemyTowers(myOwner)
			target, dist = nearest(unitModel, towers)
		end

		-- 3. Логика действия
		if target and target.PrimaryPart then
			if dist <= AttackRadius then
				-- АТАКА (вместо wait используем время)
				if tick() - lastAttackTime >= AttackSpeed then
					lastAttackTime = tick()
					local targetHP = target:FindFirstChild("Health")
					if targetHP then
						targetHP.Value = targetHP.Value - Damage
						-- Если цель умерла, она сама себя удалит через свой скрипт
					end
				end
			else
				-- ДВИЖЕНИЕ
				movePart(primary, target.PrimaryPart.Position, Speed, dt)
			end
		end
	end)
end

return UnitAI
