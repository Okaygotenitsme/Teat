-- ServerScriptService/UnitEditor
-- Пробегает ReplicatedStorage.Units и гарантирует:
-- 1) Model.PrimaryPart установлен (первая BasePart)
-- 2) В шаблон добавлены значения: Health, Damage, Speed, Cost, AttackRadius, AttackSpeed, SpawnSpeed, Task

local ReplicatedStorage = game:GetService("ReplicatedStorage")

local unitsFolder = ReplicatedStorage:FindFirstChild("Units")
if not unitsFolder then
    unitsFolder = Instance.new("Folder")
    unitsFolder.Name = "Units"
    unitsFolder.Parent = ReplicatedStorage
end

local DEFAULTS = {
    Health = 100,
    Damage = 10,
    Speed = 16,            -- studs/sec
    Cost = 1,
    AttackRadius = 8,      -- studs
    AttackSpeed = 1,       -- seconds between attacks
    SpawnSpeed = 1,        -- seconds to stand before active
    Task = "AttackEnemies" -- "AttackEnemies" or "ChargeTower"
}

local function ensureValue(parent, name, value)
    local existing = parent:FindFirstChild(name)
    if existing then
        -- если значение другого типа — заменим
        if existing:IsA("IntValue") or existing:IsA("NumberValue") or existing:IsA("StringValue") then
            return existing
        else
            existing:Destroy()
        end
    end

    local val
    if type(value) == "string" then
        val = Instance.new("StringValue")
        val.Value = value
    elseif math.type(value) == "integer" then
        val = Instance.new("IntValue")
        val.Value = value
    else
        -- float -> NumberValue
        val = Instance.new("NumberValue")
        val.Value = value
    end
    val.Name = name
    val.Parent = parent
    return val
end

local function setPrimaryPartIfMissing(model)
    if not model:IsA("Model") then return end
    if model.PrimaryPart and model.PrimaryPart.Parent then return end
    for _,desc in ipairs(model:GetDescendants()) do
        if desc:IsA("BasePart") then
            model.PrimaryPart = desc
            break
        end
    end
end

local function sanitizeParts(model)
    for _, part in ipairs(model:GetDescendants()) do
        if part:IsA("BasePart") then
            -- превью/шаблон: не менять физику шаблона, но убедимся, что нет странных velocities
            part.CanCollide = true
            part.Anchored = false
            part.Massless = false
        end
    end
end

local function processTemplate(model)
    if not model or not model:IsA("Model") then return end
    setPrimaryPartIfMissing(model)
    sanitizeParts(model)
    -- values
    for name,def in pairs(DEFAULTS) do
        ensureValue(model, name, def)
    end
    -- optional: метаданные
    ensureValue(model, "Description", "") -- string
    -- пометим, что шаблон обработан
    if not model:FindFirstChild("MelotenProcessed") then
        local tag = Instance.new("BoolValue")
        tag.Name = "MelotenProcessed"
        tag.Value = true
        tag.Parent = model
    end
end

-- Обработать существующие шаблоны
for _, model in ipairs(unitsFolder:GetChildren()) do
    processTemplate(model)
end

-- Следим за новыми шаблонами, которые добавят в будущем
unitsFolder.ChildAdded:Connect(function(child)
    -- небольшая задержка на случай, если модель ещё клонируется в память
    wait(0.1)
    pcall(function() processTemplate(child) end)
end)

print("[UnitEditor] Done — templates processed")
