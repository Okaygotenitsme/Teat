# Символы от темного к светлому
ASCII_CHARS = ["@", "#", "S", "%", "?", "*", "+", ";", ":", ",", "."]

def image_to_ascii(image, new_width=25):
    """Преобразует один кадр (картинку) в текст"""
    width, height = image.size
    aspect_ratio = height / width
    # Корректировка высоты шрифта (символы в консоли обычно вытянуты)
    new_height = int(new_width * aspect_ratio * 0.55)
    
    # Ресайз для уменьшения и перевод в оттенки серого (L)
    img = image.resize((new_width, new_height)).convert("L")
    pixels = img.getdata()
    
    # Заменяем пиксели на символы
    ascii_str = ""
    for pixel in pixels:
        ascii_str += ASCII_CHARS[pixel // 25] # 255 / 11 символов ~= 25
        
    # Разбиваем строку на линии
    ascii_img = ""
    for i in range(0, len(ascii_str), new_width):
        ascii_img += ascii_str[i:i+new_width] + "\n"
        
    return ascii_img

async def animate_media(file_path, message_to_edit):
    """Читает файл и анимирует сообщение"""
    try:
        # Открываем файл через Pillow
        with Image.open(file_path) as im:
            
            # Проверка: Pillow может анимировать GIF и некоторые форматы.
            # Обычные MP4 могут не открыться как последовательность кадров без плагинов.
            
            frame_number = 0
            # ImageSequence.Iterator проходит по кадрам (если это GIF)
            for frame in ImageSequence.Iterator(im):
                frame_number += 1
                
                # Пропускаем кадры, чтобы не спамить (берем каждый 3-й кадр)
                if frame_number % 3 != 0:
                    continue
                
                # Ограничение длины (максимум 20 обновлений, чтобы не зависло)
                if frame_number > 60: 
                    break

                # Конвертация
                ascii_art = image_to_ascii(frame)
                text_block = f"```\n{ascii_art}\n```"
                
                try:
                    # Редактируем сообщение (Эффект анимации)
                    await message_to_edit.edit_text(text_block, parse_mode="MarkdownV2")
                    # ВАЖНО: Задержка 1.5 сек, иначе Телеграм забанит за флуд
                    await asyncio.sleep(1.5)
                except Exception:
                    # Если текст не изменился или ошибка сети - идем дальше
                    pass

    except OSError:
        await message_to_edit.edit_text("❌ Ошибка: Pillow не может прочитать этот видео-формат. Попробуй отправить **GIF** файл.")
    except Exception as e:
        logging.error(f"Error in animation: {e}")
        await message_to_edit.edit_text(f"❌ Ошибка обработки: {e}")
    finally:
        # Удаляем временный файл
        if os.path.exists(file_path):
            os.remove(file_path)
        await message_to_edit.edit_text("🏁 Анимация завершена!")


