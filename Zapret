@bot.callback_query_handler(func=lambda c: True)
def callback(c):
    cid = c.message.chat.id

    if cid not in user_files:
        bot.answer_callback_query(c.id, "Код не найден")
        return

    try:
        out = build_meloten_vm(user_files[cid], c.data)
    except Exception as e:
        bot.edit_message_text(
            f"❌ Скрипт нерабочий.\nПерепишите код.\n\n{e}",
            cid,
            c.message.message_id
        )
        return

    name = f"Meloten_Obfuscated_{c.data}.lua"
    with open(name, "w", encoding="utf-8") as f:
        f.write(out)

    with open(name, "rb") as f:
        bot.send_document(cid, f, caption="✅ Meloten Obfuscator")

    os.remove(name)
    del user_files[cid]

