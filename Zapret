import lupa
from lupa import LuaRuntime
import logging
import subprocess
import os
import tempfile
import re
import binascii

# Настройка логгера
logger = logging.getLogger("DeobfuscatorEngine")

class DeobfuscatorEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        logger.info(f"📁 Engine initialized. Root: {base_dir}")

    def process(self, content, status_callback=None):
        """
        Главный метод обработки.
        content: байты скрипта
        status_callback: функция для отправки статусов боту
        """
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        # Проверка Java
        if not self._check_java():
            return b"-- [FATAL ERROR] Java not installed. Unluac requires Java."

        update_status("🔥 Инициализация Lupa (Lua 5.1)...")

        try:
            # Создаем Lua Runtime
            lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)
        except Exception as e:
            return f"-- [FATAL] Lua start error: {e}".encode('utf-8')

        # --- ХРАНИЛИЩА (Bridge Python <-> Lua) ---
        captured_logs = []
        captured_strings = []
        captured_chunks = []
        captured_urls = []

        # Python-функции, доступные внутри Lua
        def py_log(msg):
            msg_str = str(msg)
            if len(captured_logs) < 200: captured_logs.append(msg_str)
            # Ловим ссылки
            if "http" in msg_str: captured_urls.append(msg_str)

        def py_capture_str(s):
            if isinstance(s, (str, bytes)):
                try:
                    s_decoded = s.decode('utf-8') if isinstance(s, bytes) else s
                    if len(s_decoded) > 4: # Игнорируем мусор короче 4 символов
                        captured_strings.append(s_decoded)
                        if "http" in s_decoded: captured_urls.append(s_decoded)
                except: pass
            return s

        def py_capture_chunk(chunk, name):
            if isinstance(chunk, (str, bytes)) and len(chunk) > 50:
                captured_chunks.append({"data": chunk, "name": name})
                py_log(f"⚡ CAPTURED SCRIPT CHUNK ({len(chunk)} bytes) form '{name}'")
            return chunk

        # Прокидываем функции в глобальную область Lua
        lua_globals = lua.globals()
        lua_globals.py_log = py_log
        lua_globals.py_capture_str = py_capture_str
        lua_globals.py_capture_chunk = py_capture_chunk

        # --- LUA SETUP SCRIPT (САМОЕ ВАЖНОЕ) ---
        setup_script = """
        -- [[ LUA ENVIRONMENT EMULATION V3 ]] --
        
        -- 1. Bit32 Library (Critical for MoonSec/IronBrew)
        local bit = {}
        function bit.tobit(x) x = x % 4294967296; if x >= 2147483648 then x = x - 4294967296 end; return x end
        function bit.bnot(x) return 4294967295 - x % 4294967296 end
        local function bit_oper(a, b, oper)
            local r, m, s = 0, 2^31, nil
            repeat s,a,b = a+b+m, a%m, b%m; r,m = r + m*oper%(s-a-b), m/2 until m < 1
            return r
        end
        function bit.band(a, b) return bit_oper(a, b, 4) end
        function bit.bor(a, b)  return bit_oper(a, b, 1) end
        function bit.bxor(a, b) return bit_oper(a, b, 3) end
        function bit.lshift(a, b) return (a * 2^b) % 4294967296 end
        function bit.rshift(a, b) return math.floor(a / 2^b) % 4294967296 end
        
        _G.bit = bit
        _G.bit32 = {
            band = bit.band, bor = bit.bor, bxor = bit.bxor,
            lshift = bit.lshift, rshift = bit.rshift, bnot = bit.bnot,
            arshift = bit.rshift -- упрощение
        }

        -- 2. Mock Roblox Globals (Чтобы скрипт не падал)
        local Dummy = {}
        local mt_dummy = {
            __index = function(t, k) return function(...) return t end end,
            __newindex = function(t, k, v) end,
            __call = function(...) return Dummy end,
            __tostring = function() return "Instance" end
        }
        setmetatable(Dummy, mt_dummy)

        _G.game = {
            GetService = function(s, n) return Dummy end,
            HttpGet = function(s, u) py_log("📡 HttpGet: "..tostring(u)); return "-- Fetched Lib" end,
            PlaceId = 123456,
            JobId = "DeadBeef"
        }
        _G.workspace = Dummy
        _G.script = {Source = "", Name = "LocalScript", Parent = nil}
        _G.warn = py_log
        _G.print = py_log
        _G.error = py_log
        
        -- Executor Environment
        _G.getgenv = function() return _G end
        _G.getrenv = function() return _G end
        _G.getreg = function() return {} end
        _G.checkcaller = function() return true end
        
        local function fake_req(opts)
            if type(opts) == "table" and opts.Url then py_log("📡 Request: "..tostring(opts.Url)) end
            if type(opts) == "string" then py_log("📡 Request: "..tostring(opts)) end
            return {Body = "{}", StatusCode = 200}
        end
        _G.request = fake_req
        _G.http_request = fake_req
        _G.syn = { request = fake_req, protect_gui = function() end }

        -- 3. HOOKS (Шпионы)
        
        -- Hook load/loadstring
        local old_load = load
        local function hooked_load(chunk, name)
            if type(chunk) == "string" then
                if #chunk > 100 then 
                     py_capture_chunk(chunk, tostring(name or "chunk"))
                end
            end
            return old_load(chunk, name)
        end
        _G.load = hooked_load
        _G.loadstring = hooked_load

        -- Hook string.char (Сборщик строк)
        local old_char = string.char
        string.char = function(...)
            local res = old_char(...)
            if #res > 4 then py_capture_str(res) end
            return res
        end
        
        -- Hook table.concat
        local old_concat = table.concat
        table.concat = function(t, s, i, j)
            local res = old_concat(t, s, i, j)
            if type(res) == "string" and #res > 4 then py_capture_str(res) end
            return res
        end

        -- 4. MEMORY SCANNER (Upvalue Explorer)
        -- Рекурсивно сканирует функции, чтобы найти строки
        
        local seen_tables = {}
        
        local function scan_val(val, depth)
            if depth > 4 then return end
            
            if type(val) == "string" and #val > 4 then
                py_capture_str(val)
            elseif type(val) == "function" and debug and debug.getupvalue then
                local i = 1
                while true do
                    local n, v = debug.getupvalue(val, i)
                    if not n then break end
                    scan_val(v, depth + 1)
                    i = i + 1
                end
            elseif type(val) == "table" and not seen_tables[val] then
                seen_tables[val] = true
                for k, v in pairs(val) do
                    scan_val(k, depth + 1)
                    scan_val(v, depth + 1)
                end
            end
        end

        _G.GLOBAL_SCAN = function()
            seen_tables = {} -- сброс кэша
            -- Сканируем глобальную среду
            for k, v in pairs(_G) do
                if k ~= "_G" and k ~= "package" then
                     scan_val(v, 1)
                end
            end
        end
        """

        try:
            update_status("🌪️ Запуск эмулятора и скрипта...")
            lua.execute(setup_script)
            
            # Обертка для безопасного запуска пользовательского кода
            runner = lua.eval("""
                function(code)
                    if not getfenv then _G.getfenv = function() return _G end end
                    
                    local f, err = load(code)
                    if not f then return "LoadError: "..tostring(err) end
                    
                    local s, e = pcall(f)
                    if not s then return "RuntimeError: "..tostring(e) end
                    return "Success"
                end
            """)
            
            status = runner(content)
            update_status(f"Скрипт выполнен: {status}")

            # ЗАПУСК СКАНЕРА ПОСЛЕ ВЫПОЛНЕНИЯ
            update_status("🧠 Сканирование памяти (Upvalues & Tables)...")
            try:
                lua.execute("_G.GLOBAL_SCAN()")
            except Exception as e:
                logger.error(f"Scan warning: {e}")

            # --- ФИНАЛИЗАЦИЯ ---
            
            # Выбираем лучший чанк кода (если скрипт распаковал себя)
            best_chunk = None
            max_len = 0
            for c in captured_chunks:
                if len(c['data']) > max_len:
                    max_len = len(c['data'])
                    best_chunk = c['data']
            
            # Если ничего не перехватили, возвращаем исходный
            final_code_bytes = best_chunk if best_chunk else content

            return self._generate_report(final_code_bytes, captured_strings, captured_logs, captured_urls, update_status)

        except Exception as e:
            logger.error(f"Engine Crash: {e}")
            return f"-- [CRASH] Engine error: {str(e)}".encode('utf-8')

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _generate_report(self, code_bytes, strings, logs, urls, callback):
        if callback: callback("💅 Формирование отчета...")
        
        # Попытка декомпиляции через unluac
        decompiled = self._try_decompile(code_bytes)
        
        report = "-- [[ TERMINATOR V3 REPORT ]] --\n"
        report += f"-- Scan Time: Done\n"
        report += f"-- Strings Captured: {len(strings)}\n"
        report += f"-- HTTP Requests: {len(urls)}\n\n"

        if urls:
            report += "-- [[ INTERCEPTED URLS ]] --\n"
            for u in sorted(list(set(urls))):
                report += f"-- {u}\n"
            report += "\n"

        report += "-- [[ DUMPED STRINGS ]] --\n"
        # Очистка и сортировка уникальных строк
        clean_strings = sorted(list(set([s.replace('\n', ' ') for s in strings])), key=len, reverse=True)
        for s in clean_strings[:100]: # Топ 100 длинных строк
            report += f'-- "{s}"\n'
        
        report += "\n" + "="*60 + "\n\n"
        
        if decompiled:
            report += "-- [[ DECOMPILED SOURCE (UNLUAC) ]] --\n\n"
            try:
                src = decompiled.decode('utf-8', 'ignore')
            except:
                src = decompiled.decode('latin-1', 'ignore')
            
            # Бьютифайер (упрощенный)
            src = self._simple_beautify(src)
            report += src
        else:
            report += "-- [[ RAW BYTECODE DUMP ]] --\n"
            report += "-- Декомпиляция не удалась (возможно, нестандартный байт-код).\n\n"
            try:
                report += code_bytes.decode('utf-8', 'ignore')
            except:
                report += f"-- Binary Blob Size: {len(code_bytes)} bytes"

        report += "\n\n" + "="*60 + "\n-- [[ DEBUG LOGS ]] --\n"
        for l in logs[-50:]: # Последние 50 логов
            report += f"-- {l}\n"
            
        return report.encode('utf-8', 'replace')

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path): return None
        # Быстрая проверка хедера Lua 5.1
        if isinstance(bytecode, bytes) and not bytecode.startswith(b'\x1bLua'):
            # Если это текст, возвращаем его как есть (возможно, распакованный скрипт)
            if all(32 <= b < 127 or b in [9, 10, 13] for b in bytecode[:100]):
                return bytecode
            return None

        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            res = subprocess.run(
                ["java", "-jar", self.unluac_path, path], 
                capture_output=True, timeout=10
            )
            os.remove(path)
            if res.returncode == 0 and len(res.stdout) > 0: return res.stdout
            return None
        except: return None

    def _simple_beautify(self, code):
        """Простая очистка кода от мусорных имен"""
        # Замена длинных hex чисел
        code = re.sub(r'0x[0-9a-fA-F]+', lambda m: str(int(m.group(0), 16)), code)
        return code
