def gen_mega_name():
    return "_" + "".join(random.choice(string.ascii_letters) for _ in range(25))

def encrypt_string(text):
    key = random.randint(15, 95)
    chars = [ord(c) ^ key for c in text]
    v_t = gen_mega_name()
    return f"(function() local {v_t}={{ {','.join(map(str, chars))} }} local r='' for i=1,#{v_t} do r=r..string.char({v_t}[i] ~ {key}) end return r end)()"

def meloten_core(source):
    # Защита строк
    source = re.sub(r'"(.*?)"', lambda m: encrypt_string(m.group(1)), source)
    source = re.sub(r"'(.*?)'", lambda m: encrypt_string(m.group(1)), source)
    
    junk = "\n".join([f"local {gen_mega_name()} = {random.randint(100, 9999)}" for _ in range(10)])
    entry_point = gen_mega_name()
    
    result = f"--[[ MELOTEN SUPREME V5 ]]\n{junk}\nlocal function {entry_point}()\n{source}\nend\n{entry_point}()"
    return result

# --- ОБРАБОТКА ФАЙЛОВ ---

@bot.message_handler(content_types=['document'])
def handle_docs(message):
    try:
        # Проверяем расширение файла
        file_name = message.document.file_name
        if file_name.endswith('.lua') or file_name.endswith('.txt'):
            status = bot.reply_to(message, f"📥 Получен файл: `{file_name}`. Начинаю магию...")
            
            # Скачиваем файл
            file_info = bot.get_file(message.document.file_id)
            downloaded_file = bot.download_file(file_info.file_path)
            
            # Декодируем содержимое
            source_code = downloaded_file.decode('utf-8')
            
            # Обфусцируем
            protected_code = meloten_core(source_code)
            
            # Сохраняем и отправляем результат
            out_name = f"Meloten_{file_name}"
            with open(out_name, "w", encoding="utf-8") as f:
                f.write(protected_code)
            
            bot.send_document(message.chat.id, open(out_name, "rb"), caption="✅ Готово! Файл защищен.")
            os.remove(out_name) # Удаляем временный файл с ПК
        else:
            bot.reply_to(message, "❌ Я принимаю только файлы с расширением .lua или .txt")
    except Exception as e:
        bot.send_message(message.chat.id, f"⚠️ Ошибка при обработке файла: {e}")

