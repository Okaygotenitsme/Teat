# bot.py
import os
import uuid
import asyncio
import logging
import tempfile

from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command

from engine import DeobfuscatorEngine

API_TOKEN = os.environ.get("DEOBF_BOT_TOKEN", "REPLACE_WITH_TOKEN")

logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(message)s")
logger = logging.getLogger("DeobfBot")

bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()


@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "🤖 **Roblox Deobfuscator V2**\n\n"
        "Скинь `.lua` или `.txt` файл.\n"
        "Я запущу его в безопасной среде и вытащу:\n"
        "🔹 RemoteSpy (сетевые запросы)\n"
        "🔹 Спрятанные строки\n"
        "🔹 Глобальные переменные\n"
        "🔹 Исходный код (если повезет)\n\n"
        "🚀 Поддерживает MoonSec, IronBrew, Luraph (best-effort).",
        parse_mode="Markdown"
    )


@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    unique_id = uuid.uuid4().hex[:8]
    file_name = message.document.file_name or "script.lua"

    input_path = f"temp_{user_id}_{unique_id}.lua"
    output_path = f"Deobf_{unique_id}_{file_name}.txt"

    status_msg = await message.answer("⏳ **Загрузка и анализ...**", parse_mode="Markdown")

    loop = asyncio.get_running_loop()
    last_status = [""]

    def sync_status_updater(text):
        if text == last_status[0]:
            return
        last_status[0] = text

        async def edit_coro():
            try:
                if text:
                    await status_msg.edit_text(f"⚙️ **Статус:** {text}", parse_mode="Markdown")
            except Exception:
                pass

        if not loop.is_closed():
            asyncio.run_coroutine_threadsafe(edit_coro(), loop)

    try:
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "rb") as f:
            content = f.read()

        # Run engine in executor to avoid blocking
        result_data = await asyncio.wait_for(
            loop.run_in_executor(None, engine.process, content, sync_status_updater),
            timeout=180.0
        )

        # Save main output
        with open(output_path, "wb") as f:
            if isinstance(result_data, (bytes, bytearray)):
                f.write(result_data)
            else:
                f.write(str(result_data).encode("utf-8"))

        # Prepare files to send
        main_file = FSInputFile(output_path)
        caption = "✅ **Анализ завершен!**"
        if b"DECOMPILED SOURCE" in (result_data if isinstance(result_data, (bytes, bytearray)) else str(result_data).encode()):
            caption += "\n📜 Код частично декомпилирован."
        elif b"DUMPED STRINGS" in (result_data if isinstance(result_data, (bytes, bytearray)) else str(result_data).encode()):
            caption += "\n🔎 Строки и данные извлечены."

        await message.answer_document(main_file, caption=caption)

        # Send extracted mel file if present
        extra = engine.get_last_extracted_path()
        if extra and os.path.exists(extra):
            try:
                await message.answer_document(FSInputFile(extra), caption="📦 Extracted blocks (local mel_N variables)")
            except Exception:
                pass

    except asyncio.TimeoutError:
        try:
            await status_msg.edit_text("❌ **Ошибка:** Скрипт выполнялся слишком долго (более 3 минут).")
        except:
            pass
    except Exception as e:
        logger.exception("Error processing file: %s", e)
        try:
            await status_msg.edit_text("❌ Произошла внутренняя ошибка при обработке.")
        except:
            pass
    finally:
        # Cleanup
        for p in [input_path, output_path]:
            if os.path.exists(p):
                try:
                    os.remove(p)
                except:
                    pass
        # cleanup engine's extracted file
        engine.clear_last_extracted_path()


async def main():
    logger.info("Бот запускается...")
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)


if __name__ == "__main__":
    try:
        if os.name == 'nt':
            try:
                asyncio.set_event_loop_policy(asyncio.WindowsSelectorEventLoopPolicy())
            except Exception:
                pass
        asyncio.run(main())
    except KeyboardInterrupt:
        print("Бот остановлен пользователем.")
