    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _clean_string(self, s):
        if isinstance(s, bytes):
            try: return s.decode('utf-8')
            except: return str(s)
        return str(s)

    def _finalize_output(self, code_bytes, strings, links, logs, callback):
        if callback: callback("🧬 Декомпиляция и Smart Formatting...")
        decompiled = self._try_decompile(code_bytes)
        
        final_text = ""
        
        # 1. SECURITY REPORT
        final_text += "-- [[ SECURITY REPORT ]] --\n"
        if len(links) > 0:
            final_text += "-- ⚠️ DETECTED LINKS / WEBHOOKS:\n"
            for l in links: final_text += f"-- {self._clean_string(l)}\n"
        else:
            final_text += "-- No malicious links detected.\n"
        
        final_text += "\n" + "="*50 + "\n"
        
        # 2. CONSTANT COLLECTION (Strings)
        final_text += "-- [[ CONSTANT COLLECTION ]] --\n"
        seen = set()
        # Сортируем по длине, чтобы важные строки были вверху
        sorted_strings = sorted(strings, key=lambda x: len(str(x)), reverse=True)
        for s in sorted_strings:
            cln = self._clean_string(s).replace('\n', ' ')
            if cln not in seen and len(cln) > 3 and cln not in links:
                final_text += f'-- "{cln}"\n'
                seen.add(cln)
        
        final_text += "\n" + "="*50 + "\n\n"
        
        # 3. CODE
        if decompiled:
            try:
                src = decompiled.decode('utf-8', 'ignore')
            except:
                src = decompiled.decode('latin-1', 'ignore')
            
            # Smart Reconstruction (V0.22.95 Feature)
            src = self._smart_reconstruction(src)
            src = self._beautify_lua(src)
            
            final_text += "-- [[ DECOMPILED & RECONSTRUCTED SOURCE ]] --\n\n"
            final_text += src
        else:
            final_text += "-- [WARNING] Unluac failed. Dumping raw bytes/text.\n\n"
            try:
                final_text += code_bytes.decode('utf-8')
            except:
                final_text += f"-- Binary Data ({len(code_bytes)} bytes)"

        # 4. LOGS
        final_text += "\n\n" + "="*50 + "\n-- [[ EXECUTION LOG ]] --\n"
        for l in logs[-100:]: # Последние 100 действий
            final_text += f"-- {self._clean_string(l)}\n"

        return final_text.encode('utf-8')

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path): return None
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            res = subprocess.run(
                ["java", "-Xmx1G", "-jar", self.unluac_path, path], 
                capture_output=True, timeout=15
            )
            os.remove(path)
            if res.returncode == 0 and len(res.stdout) > 0: return res.stdout
            return None
        except: return None

    def _smart_reconstruction(self, code):
        """
        V0.22.95: Smart Pattern & Name Reconstruction
        Заменяет уродливые вызовы на красивые имена.
        """
        # Замена game:GetService("Players").LocalPlayer -> LocalPlayer
        code = re.sub(r'game:GetService\("Players"\)\.LocalPlayer', 'LocalPlayer', code)
        code = re.sub(r'game:GetService\("(\w+)"\)', r'game.\1', code)
        
        # Замена game:HttpGet(...) на loadstring(...)
        code = re.sub(r'loadstring\(game:HttpGet\((.*?)\)\)\(\)', r'-- Loaded Library from \1', code)
        
        # Очистка мусора от MoonSec (ASCII артефакты)
        code = re.sub(r'\\(\d{1,3})', lambda m: chr(int(m.group(1))) if int(m.group(1)) > 31 and int(m.group(1)) < 127 else m.group(0), code)
        
        return code

    def _beautify_lua(self, source_code):
        # Базовое форматирование
        source_code = re.sub(r'(\s)(local|return|if|for|while|repeat|function)(\s)', r'\n\2 ', source_code)
        replacements = {
            " then ": " then\n", " do ": " do\n", " end ": "\nend\n",
            " repeat ": "\nrepeat\n", " until ": "\nuntil ", ";": "\n"
        }
        for k, v in replacements.items():
            source_code = source_code.replace(k, v)
        
        lines = source_code.splitlines()
        formatted = []
        indent = 0
        for line in lines:
            line = line.strip()
            if not line: continue
            if line.startswith("--"): formatted.append(line); continue
            
            if line.startswith(("end", "until", "}", "]", ")", "else", "elseif")):
                indent = max(0, indent - 1)
            
            formatted.append("\t" * indent + line)
            
            if line.endswith(("then", "do", "repeat", "{", "(")) or ("function" in line and not line.endswith("end")):
                indent += 1
            if line.startswith(("else", "elseif")):
                indent += 1
                
        return "\n".join(formatted)
