@dp.message(F.document)
async def handle_document(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        await message.answer("❌ Формат не поддерживается.")
        return

    # Если файл больше 2 МБ, предупреждаем
    if message.document.file_size > 2 * 1024 * 1024:
         await message.answer("❌ Файл слишком большой (лимит 2 МБ).")
         return

    status_msg = await message.answer("🔄 Анализ и шифрование (v2)...")

    try:
        mem = io.BytesIO()
        await bot.download(message.document, destination=mem)
        src_code = mem.getvalue().decode('utf-8', errors='ignore')

        # === ВЫПОЛНЕНИЕ В ПОТОКЕ (ЧТОБЫ НЕ ЗАВИСЛО) ===
        def process():
            obf = MelotenUltraVM(src_code)
            return obf.build()
        
        protected_code = await asyncio.to_thread(process)
        # ==============================================

        out_name = f"Protected_{message.document.file_name}"
        output = BufferedInputFile(protected_code.encode('utf-8'), filename=out_name)
        
        await message.answer_document(
            output, 
            caption=f"✅ **Успешно!**\nРазмер: {len(protected_code)} байт\nЗащита: Ultra VM + StringPacking",
            request_timeout=120 # Увеличенный таймаут для отправки
        )
        await status_msg.delete()

    except Exception as e:
        await message.answer(f"⚠️ Ошибка при обработке: {e}")
        logging.error(f"Error: {e}")

