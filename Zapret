        local bit = {}
        function bit.tobit(x) x = x % 4294967296; if x >= 2147483648 then x = x - 4294967296 end; return x end
        function bit.bnot(x) return 4294967295 - x % 4294967296 end
        local function bit_oper(a, b, oper) local r, m, s = 0, 2^31; repeat s, a, b = a + b + m, a % m, b % m; r, m = r + m * oper % (s - a - b), m / 2 until m < 1; return r end
        function bit.band(a, b) return bit_oper(a, b, 4) end
        function bit.bor(a, b) return bit_oper(a, b, 1) end
        function bit.bxor(a, b) return bit_oper(a, b, 3) end
        function bit.lshift(a, b) b = b % 32; return (a * 2^b) % 4294967296 end
        function bit.rshift(a, b) b = b % 32; return math.floor(a / 2^b) % 4294967296 end
        function bit.arshift(a, b) b = b % 32; local z = math.floor(a / 2^b) % 4294967296; if a >= 2147483648 then z = z + 4294967296 - 2^(32-b) end; return z end
        _G.bit = bit; _G.bit32 = bit; package.loaded.bit = bit; package.loaded.bit32 = bit
        
        _G.CAPTURED_CHUNKS = {}; _G.DETECTED_STRINGS = {}; _G.ACTION_LOG = {}; _G.FINAL_GLOBALS = {}; _G.REMOTE_CALLS = {}; _G.HTTP_CALLS = {}; _G.ENV_SNAPSHOT = {}
        
        local function log(msg) if #_G.ACTION_LOG < 2000 then table.insert(_G.ACTION_LOG, tostring(msg)) end end
        local function capture_string(s) if type(s) == "string" and #s > 2 and #s < 50000 then if not s:match("^%s*$") and not s:match("stack") and not s:match("upvalue") then _G.DETECTED_STRINGS[s] = true end end; return s end
        
        local real_char = string.char
        string.char = function(...) local result = real_char(...); capture_string(result); return result end
        
        local real_concat = table.concat
        table.concat = function(t, sep, i, j) local result = real_concat(t, sep, i, j); capture_string(result); return result end
        
        local real_load = load
        local load_call_count = 0
        local function enhanced_load(chunk, chunkname, mode, env)
            load_call_count = load_call_count + 1
