@dp.callback_query(F.data.startswith("act_"))
async def process_file_action(callback: CallbackQuery):
    action = callback.data.split("_")[1]
    user_id = callback.from_user.id
    file_id = user_current_file.get(user_id)
    
    if not file_id:
        await callback.answer("❌ Файл устарел")
        return

    await callback.message.edit_text("⏳ **Working...**", parse_mode="Markdown")
    
    try:
        file_info = await bot.get_file(file_id)
        downloaded = await bot.download_file(file_info.file_path)
        source_code = downloaded.read().decode('utf-8', errors='ignore')
        
        if action == "obfuscate":
            layers = user_settings.get(user_id, 1)
            obf = MelotenObfuscatorV11(source_code, layers=layers)
            res = obf.build()
            name = "Protected_V11.lua"
            cap = f"🛡 **Protected V11 (Stable)**\nLayers: {layers}"
            
        elif action == "beautify":
            beauty = LuaBeautifier(source_code)
            res = beauty.format()
            name = "Clean.lua"
            cap = "✨ **Beautified**"

        out = BufferedInputFile(res.encode(), filename=name)
        await callback.message.answer_document(out, caption=cap, parse_mode="Markdown")
        await callback.message.delete()
        
    except Exception as e:
        await callback.message.answer(f"Err: {e}")
    
    if user_id in user_current_file: del user_current_file[user_id]
    await callback.answer()

