# --- Utility to create a file object safe for different aiogram versions ---
def make_file_bytes(data: bytes, filename: str):
    """
    Returns an object suitable for aiogram .answer_document/upload.
    Prefer BufferedInputFile if available; otherwise use types.InputFile with BytesIO.
    """
    if _HAS_BUFFERED and BufferedInputFile is not None:
        return BufferedInputFile(data, filename=filename)
    # Fallback: use InputFile with BytesIO (works in many aiogram versions)
    return types.InputFile(io.BytesIO(data), filename=filename)


# --- MelotenObfuscatorV6 (improved) ---
class MelotenObfuscatorV6:
    """
    Rolling Key VM obfuscator:
    - Uses uint32 LCG to produce evolving key.
    - Uses (byte + key) % 256 encryption.
    - Emits Lua loader which reproduces same LCG and decodes the bytes.
    """

    LCG_A = 1664525
    LCG_C = 1013904223
    LCG_MOD = 0x100000000  # 2**32

    def __init__(self, source: str, seed_key: Optional[int] = None):
        self.source = source or ""
        # choose seed in 1..254 to avoid trivial 0 always (but 0 is allowed if desired)
        self.key = int(seed_key) if seed_key is not None else random.randint(1, 254)
        # guard range
        self.key = max(0, min(255, self.key))
        self.v = {
            "dec_func": self._n(),
            "byte_table": self._n(),
            "key_var": self._n(),
            "idx": self._n(),
            "str_res": self._n(),
            "dummy": self._n(),
        }

    def _n(self) -> str:
        length = random.randint(12, 25)
        return "".join(random.choices("Il1O0", k=length))

    def _junk_code(self) -> str:
        vars_ = [self._n() for _ in range(3)]
        ops = [
            f"local {vars_[0]} = function(a) return a*2 end",
            f"local {vars_[1]} = {{ 0x1, 0x2, 0x3 }}; -- Memory Check",
            f"if {random.randint(100,999)} == 12345 then return end",
            f"local {vars_[2]} = {random.randint(0,9999)} -- filler",
        ]
        return "\n".join(random.sample(ops, 2))

    @staticmethod
    def _lcg_next(curr: int) -> int:
        return ( (curr * MelotenObfuscatorV6.LCG_A + MelotenObfuscatorV6.LCG_C) & 0xFFFFFFFF )

    def build(self) -> str:
        # Remove single-line comments starting with -- (preserve other content)
        lines = [ln for ln in self.source.splitlines() if not ln.strip().startswith("--")]
        clean_source = "\n".join(lines) if lines else self.source

        raw = clean_source.encode("utf-8", errors="ignore")
        enc_data = []
        curr = int(self.key) & 0xFFFFFFFF

        for b in raw:
            key_byte = curr % 256
            enc = (b + key_byte) % 256
            enc_data.append(enc)
            curr = self._lcg_next(curr)

        # produce Lua-style table
        table_str = "{" + ",".join(map(str, enc_data)) + "}"

        # Lua loader: uses same LCG arithmetic (with modulo 2^32 and then %256)
        # additional safety: check that load/loadstring returns a function
        loader = (
            f"--[[\nMeloten Security V6 (v2)\n]]\n"
            f"local {self.v['byte_table']} = {table_str}\n"
            f"local {self.v['key_var']} = {self.key}\n\n"
            f"{self._junk_code()}\n\n"
            f"local function {self.v['dec_func']}(data, key)\n"
            f"    local out = {{}}\n"
            f"    local current_k = key % 4294967296\n"
            f"    for i = 1, #data do\n"
            f"        local enc = data[i]\n"
            f"        local dec = (enc - (current_k % 256)) % 256\n"
            f"        table.insert(out, string.char(dec))\n"
            f"        current_k = (current_k * {self.LCG_A} + {self.LCG_C}) % 4294967296\n"
            f"    end\n"
            f"    return table.concat(out)\n"
            f"end\n\n"
            f"{self._junk_code()}\n\n"
            f"local _loader = loadstring or load\n"
            f"local _code_src = {self.v['dec_func']}({self.v['byte_table']}, {self.v['key_var']})\n"
            f"local _fn, _err = _loader(_code_src)\n"
            f"if _fn then pcall(_fn) else if print then print('Loader error:', _err) end end\n"
        )
        return loader

    def verify_roundtrip(self) -> bool:
        """
        Optional local test: encrypt->decrypt using same algorithm (Python side)
        to check that encryption is reversible. This does NOT execute Lua;
        it uses the same arithmetic to compute original back.
        """
        raw = self.source.encode("utf-8", errors="ignore")
        # encrypt
        enc = []
        curr = int(self.key) & 0xFFFFFFFF
        for b in raw:
            enc_byte = (b + (curr % 256)) % 256
            enc.append(enc_byte)
            curr = self._lcg_next(curr)
        # decrypt
        curr = int(self.key) & 0xFFFFFFFF
        out_bytes = bytearray()
        for e in enc:
            orig = (e - (curr % 256)) % 256
            out_bytes.append(orig)
            curr = self._lcg_next(curr)
        try:
            decoded = out_bytes.decode("utf-8", errors="ignore")
        except Exception:
            decoded = out_bytes.decode("utf-8", errors="replace")
        return decoded == self.source

