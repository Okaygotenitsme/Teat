    def _extract_strings_heuristic(self, content):
        """Извлекает строки из байткода"""
        strings = []
        if isinstance(content, bytes):
            pattern = rb'[\x20-\x7E]{4,}'
            matches = re.findall(pattern, content)
            for match in matches:
                try:
                    s = match.decode('ascii')
                    if len(s) > 3 and not s.isdigit():
                        strings.append(s)
                except:
                    pass
        return strings

    def _preprocess_code(self, content):
        """Предобработка: декодирование Base64/Hex"""
        if isinstance(content, bytes):
            try:
                text = content.decode('utf-8')
            except:
                return content
        else:
            text = content

        # Base64
        if re.match(r'^[A-Za-z0-9+/=\s]+$', text) and len(text) > 100:
            try:
                decoded = base64.b64decode(text)
                if b'local' in decoded or b'function' in decoded:
                    logger.info("✅ Decoded Base64")
                    return decoded
            except:
                pass

        return content.encode('utf-8') if isinstance(content, str) else content

    def _find_best_chunk(self, chunks):
        """Ищет лучший чанк"""
        if not chunks or len(chunks) == 0:
            return None
        
        best = None
        max_score = 0
        
        for i in range(1, len(chunks) + 1):
            c = chunks[i]
            score = c.size
            
            if isinstance(c.data, bytes):
                if b'function' in c.data: score += 1000
                if b'local' in c.data: score += 500
                if b'return' in c.data: score += 300
            
            if score > max_score:
                max_score = score
                best = c.data
        
        return best

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], 
                         stdout=subprocess.DEVNULL, 
                         stderr=subprocess.DEVNULL,
                         timeout=5)
            return True
        except:
            return False

    def _clean_string(self, s):
        if isinstance(s, bytes):
            try:
                return s.decode('utf-8', errors='ignore')
            except:
                return str(s)
        return str(s)

    def _finalize_output(self, code_bytes, strings, globals_dump, logs, remotes, http_calls, env_vars, obf_type, callback):
        if callback:
            callback("🧬 Decompiling bytecode...")
        
        decompiled = self._try_decompile(code_bytes)
        heuristic_strings = self._extract_strings_heuristic(code_bytes)
        
        final = f"""-- ============================================
-- DEOBFUSCATION REPORT
-- Obfuscator: {obf_type}
-- ============================================

"""
        
        # REMOTE SPY
        if remotes:
            final += "-- [[ 📡 REMOTE SPY ]] --\n"
            for r in remotes[:100]:
                final += f"-- {self._clean_string(r)}\n"
            final += "\n"

        # HTTP CALLS
        if http_calls:
            final += "-- [[ 🌍 HTTP CALLS ]] --\n"
            for h in http_calls[:50]:
                final += f"-- {self._clean_string(h)}\n"
            final += "\n"

        # STRINGS
        all_strings = set()
        for s in strings:
            clean = self._clean_string(s)
            if len(clean) > 3 and len(clean) < 1000:
                all_strings.add(clean)
        
        for s in heuristic_strings[:200]:
            if len(s) > 3:
                all_strings.add(s)
        
        if all_strings:
            final += f"-- [[ 🔤 EXTRACTED STRINGS ({len(all_strings)} total) ]] --\n"
            for s in sorted(all_strings, key=len, reverse=True)[:100]:
                s_display = s.replace('\n', '\\n').replace('\r', '\\r')[:200]
                final += f'--   "{s_display}"\n'
            final += "\n"

        # GLOBALS
        if globals_dump:
            final += f"-- [[ 🌍 GLOBAL VARIABLES ({len(globals_dump)} found) ]] --\n"
            for g in globals_dump[:50]:
                final += f"-- {self._clean_string(g)}\n"
            final += "\n"

        # LOGS
        if logs:
            final += "-- [[ 📋 EXECUTION LOG ]] --\n"
            for l in logs[-40:]:
                final += f"-- {self._clean_string(l)[:300]}\n"
            final += "\n"

        final += "="*70 + "\n"
        final += "-- [[ 📜 DECOMPILED SOURCE CODE ]] --\n"
        final += "="*70 + "\n\n"
        
        if decompiled:
            try:
                src = decompiled.decode('utf-8', 'ignore')
            except:
                src = decompiled.decode('latin-1', 'ignore')
            final += self._beautify_lua(src)
        else:
            final += "-- [!] Decompilation failed.\n\n"
            try:
                raw_text = code_bytes.decode('utf-8', 'ignore')
                if len(raw_text) > 100:
                    final += raw_text
                else:
                    final += f"-- Binary data: {len(code_bytes)} bytes\n"
            except:
                final += f"-- Binary data: {len(code_bytes)} bytes\n"

        final += "\n\n" + "="*70 + "\n-- End of Report\n" + "="*70
        return final.encode('utf-8')

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path):
            return None
        
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".luac", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            res = subprocess.run(
                ["java", "-Xmx2G", "-jar", self.unluac_path, path],
                capture_output=True,
                timeout=30
            )
            
            os.remove(path)
            
            if res.returncode == 0 and len(res.stdout) > 0:
                return res.stdout
            
            return None
        except Exception as e:
            logger.error(f"Decompile error: {e}")
            return None

    def _beautify_lua(self, source):
        """Улучшенное форматирование"""
        try:
            source = re.sub(r'--\[\[.*?--\]\]', '', source, flags=re.DOTALL)
            source = re.sub(r'local\s+_+[a-zA-Z0-9_]*\s*=\s*(?:nil|{});?', '', source)
            source = re.sub(r';', ';\n', source)
            source = re.sub(r'\n{4,}', '\n\n', source)
            source = re.sub(r'[ \t]+$', '', source, flags=re.MULTILINE)
            
            return source
        except Exception as e:
            logger.error(f"Beautify error: {e}")
            return source 
