ACTOR CoolFriend 15000
{
  Health 5000
  Radius 20
  Height 56
  Speed 12
  Scale 0.05 
  Monster
  +FLOORCLIP
  +NOTARGET        // Другие монстры его не трогают, пока он добрый
  
  States
  {
  Spawn:
    FRNDA 10 A_Look
    Loop

  See:
    // Он просто ходит за тобой. A_Chase без параметров позволяет ему 
    // ходить, но мы не дадим ему стрелять, пока не будет команды.
    FRND A 3 A_Chase
    Loop

  Pain:
    // Когда ты попал в него:
    TNT1 A 0 A_ChangeFlag("NOTARGET", 0) // Теперь он цель для всех
    ANGR B 105 A_Pain                   // Показываем злую фотку 3 секунды
    
    // Вызываем клонов
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", 40, 40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", -40, 40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", 40, -40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", -40, -40, 0, 0, 0, 0, 0, SXF_SETMASTER)
    Goto AngrySee

  AngrySee:
    // Постоянно бегает со злой фоткой
    ANGR B 3 A_Chase
    Loop

  Missile:
    // Если он в этом состоянии — он уже злой.
    // Раз в несколько секунд может снова вызвать клона
    TNT1 A 0 A_Jump(64, "SummonMore") 
    ANGR B 8 A_FaceTarget
    ANGR B 8 BRIGHT A_CustomMissile("FatShot", 32, 0, 0)
    Goto AngrySee

  SummonMore:
    ANGR B 10 A_FaceTarget
    TNT1 A 0 A_SpawnItemEx("CoolFriendClone", 50, 0, 0, 0, 0, 0, 0, SXF_SETMASTER)
    Goto AngrySee

  Death:
    // При смерти просто исчезает
    TNT1 A 0 A_NoBlocking
    Stop
  }
}

ACTOR CoolFriendClone
{
  Health 100
  Speed 12
  Radius 20
  Height 56
  Scale 0.05 
  Monster
  +FLOORCLIP
  States
  {
  Spawn:
    FRND A 10 A_Look
    Loop
  See:
    FRND A 3 A_Chase
    Loop
  Missile:
    FRND A 8 A_FaceTarget
    FRND A 8 BRIGHT A_CustomMissile("DoomImpBall", 32, 0, 0)
    Goto See
  Death:
    TNT1 A 0 A_NoBlocking
    Stop
  }
}
