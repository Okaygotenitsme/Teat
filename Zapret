# ================== UTILS ==================

def gen_var(n=12):
    return "_" + "".join(random.choice(string.ascii_letters) for _ in range(n))

def encrypt_string_to_bytes(code: str):
    key = random.randint(20, 240)
    out = ""
    for c in code:
        out += "\\" + str(ord(c) ^ key)
    return out, key

def junk():
    v = gen_var(6)
    return f"""
local {v} = {random.randint(1000,9999)}
for i = 1, {random.randint(5,20)} do
    {v} = ({v} * {random.randint(2,9)}) % {random.randint(2000,9000)}
end
"""

def basic_lua_check(code: str):
    opens = code.count("function") + code.count("do") + code.count("then")
    closes = code.count("end")
    return opens == closes

# ================== CORE ==================

def build_meloten_vm(source: str, env: str):
    if not basic_lua_check(source):
        raise Exception("Lua syntax error")

    enc, key = encrypt_string_to_bytes(source)

    v_bytes = gen_var()
    v_out = gen_var()
    v_load = gen_var()
    v_env = gen_var()
    v_xor = gen_var()

    if env == "roblox_exec":
        env_setup = "local _ENV = getfenv and getfenv() or _G"
    elif env == "studio":
        env_setup = "local _ENV = {}"
    else:
        env_setup = "local _ENV = _G"

    lua = f'''
--[[
    Protected with Meloten Obfuscator
]]

{junk()}

return (function(...)
    {env_setup}

    local {v_bytes} = "{enc}"
    local {v_out} = ""

    local function {v_xor}(a, b)
        if bit32 then
            return bit32.bxor(a, b)
        else
            return a ~ b
        end
    end

    -- ROBLOX SAFE BYTE STRING READER
    for num in string.gmatch({v_bytes}, "\\\\(%d+)") do
        local b = tonumber(num)
        {v_out} = {v_out} .. string.char({v_xor}(b, {key}))
    end

    local {v_load} = loadstring or load
    local f, err = {v_load}({v_out})

    if not f then
        warn("Meloten Obfuscator runtime error:", err)
        return
    end

    return f(...)
end)(...)
'''
    return lua

