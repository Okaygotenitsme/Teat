# === ОБРАБОТКА ФАЙЛОВ ===

@dp.message(F.document)
async def handle_document(message: types.Message):
    """Главная обработка файлов"""
    user_id = message.from_user.id
    username = message.from_user.username or "unknown"
    unique_id = uuid.uuid4().hex[:8]
    file_name = message.document.file_name or "script.lua"
    
    # Проверка расширения
    if not file_name.lower().endswith(('.lua', '.txt', '.luac')):
        await message.answer(
            "⚠️ Неподдерживаемый формат.\n"
            "Принимаются только: `.lua`, `.txt`, `.luac`"
        )
        return

    # Проверка размера (20 МБ)
    if message.document.file_size > 20 * 1024 * 1024:
        await message.answer("⚠️ Файл слишком большой! Макс: 20 МБ")
        return

    input_path = f"temp_{user_id}_{unique_id}.lua"
    output_path = f"Deobf_{unique_id}_{file_name}.txt"

    # Логирование
    logger.info(f"Processing file from @{username} (ID:{user_id}): {file_name}")

    status_msg = await message.answer(
        "⏳ **Загрузка файла...**",
        parse_mode="Markdown"
    )
    
    loop = asyncio.get_running_loop()
    last_status = [""]
    
    def sync_status_updater(text):
        """Обновление статуса из синхронного кода"""
        if text == last_status[0]:
            return
        last_status[0] = text
        
        async def edit_coro():
            try:
                await status_msg.edit_text(
                    f"⚙️ **{text}**",
                    parse_mode="Markdown"
                )
            except Exception as e:
                logger.debug(f"Status update error: {e}")
        
        if not loop.is_closed():
            asyncio.run_coroutine_threadsafe(edit_coro(), loop)

    try:
        # 1. Скачивание
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "rb") as f:
            content = f.read()

        # 2. Обработка (с таймаутом)
        result_data = await asyncio.wait_for(
            loop.run_in_executor(None, engine.process, content, sync_status_updater),
            timeout=120.0
        )

        # 3. Сохранение
        with open(output_path, "wb") as f:
            f.write(result_data)

        # 4. Анализ результата
        result_text = result_data.decode('utf-8', errors='ignore')
        
        caption = "✅ **Анализ завершен!**\n\n"
        
        # Определяем обфускатор
        if "Obfuscator: " in result_text:
            obf_match = result_text.split("Obfuscator: ")[1].split("\n")[0]
            caption += f"🔍 Обфускатор: `{obf_match}`\n"
        
        # Проверяем наличие данных
        if "REMOTE SPY" in result_text:
            caption += "📡 RemoteSpy: найдены вызовы\n"
        if "EXTRACTED STRINGS" in result_text:
            caption += "🔤 Строки: извлечены\n"
        if "DECOMPILED SOURCE" in result_text:
            caption += "📜 Код: декомпилирован\n"
        
        caption += f"\n📊 Размер отчета: {len(result_data) // 1024} КБ"

        out_file = FSInputFile(output_path)
        await message.answer_document(
            out_file,
            caption=caption,
            parse_mode="Markdown"
        )
        
        # Удаляем статусное сообщение
        try:
            await status_msg.delete()
        except:
            pass

        logger.info(f"✅ Successfully processed: {file_name}")

    except asyncio.TimeoutError:
        await status_msg.edit_text(
            "❌ **Ошибка:** Таймаут (>120 сек)\n\n"
            "Скрипт слишком сложный или зациклился.",
            parse_mode="Markdown"
        )
        logger.warning(f"Timeout for {file_name}")

    except Exception as e:
        logger.error(f"Error processing {file_name}: {e}", exc_info=True)
        try:
            await status_msg.edit_text(
                "❌ **Внутренняя ошибка**\n\n"
                "Попробуйте другой файл или обратитесь к администратору.",
                parse_mode="Markdown"
            )
        except:
            pass

    finally:
        # Очистка
        for p in [input_path, output_path]:
            if os.path.exists(p):
                try:
                    os.remove(p)
                except Exception as e:
                    logger.warning(f"Failed to delete {p}: {e}")

