import lupa
from lupa import LuaRuntime
import re

class DeobfuscatorEngine:
    def __init__(self):
        # Инициализация Lua
        self.lua = LuaRuntime(unpack_returned_tuples=True)

    def process_text(self, content):
        return self.run_maximum_deobfuscation(content)

    def run_maximum_deobfuscation(self, code):
        logs = ["-- [[ MoonSec V3 Maximum Deobfuscation ]] --\n"]
        
        # Скрипт подготовки среды (Полифил для setfenv + Прокси)
        setup_script = """
        -- 1. Эмуляция setfenv/getfenv для Lua 5.2+ (через debug)
        if not setfenv then
            local function find_env(f)
                local i = 1
                while true do
                    local name, val = debug.getupvalue(f, i)
                    if name == "_ENV" or name == nil then return i, val end
                    i = i + 1
                end
            end
            
            setfenv = function(f, t)
                local i = find_env(f)
                if i then debug.setupvalue(f, i, t) end
                return f
            end
            
            getfenv = function(f)
                local _, val = find_env(f)
                return val
            end
        end

        -- 2. Функция-шпион (Proxy) для обхода проверок
        local function create_proxy(name)
            local proxy = {}
            setmetatable(proxy, {
                __index = function(t, k)
                    return create_proxy(name .. "." .. tostring(k))
                end,
                __call = function(t, ...)
                    return create_proxy(name .. "()")
                end,
                __tostring = function() return name end
            })
            return proxy
        end

        -- 3. Настройка перехватов
        _G.LOGS = {}
        _G.CAPTURED_RESULT = nil

        local sandbox = {
            print = function(...) table.insert(_G.LOGS, "[PRINT]: " .. table.concat({...}, " ")) end,
            loadstring = function(c)
                _G.CAPTURED_RESULT = c
                table.insert(_G.LOGS, "[!] ВЗЛОМ: Код захвачен через loadstring!")
                return function() end -- Останавливаем выполнение после захвата
            end,
            -- Базовые библиотеки
            bit32 = bit32,
            string = string,
            math = math,
            table = table,
            debug = debug,
            pairs = pairs,
            ipairs = ipairs,
            next = next,
            type = type,
            unpack = unpack or table.unpack,
            -- Roblox эмуляция
            game = create_proxy("game"),
            workspace = create_proxy("workspace"),
            script = create_proxy("script"),
            getgenv = function() return _G.sandbox_env end,
        }

        -- Делаем sandbox "всеядным"
        setmetatable(sandbox, {
            __index = function(t, k) return create_proxy(tostring(k)) end
        })

        _G.sandbox_env = sandbox
        return sandbox
        """

        try:
            # Подготовка среды
            sandbox_env = self.lua.execute(setup_script)
            
            # Функция запуска
            # Мы используем loadstring на самом коде MoonSec
            lua_code_runner = self.lua.eval("""
                function(code, env)
                    local f, err = load(code, "obfuscated_script", "t", env)
                    if not f then return false, "Ошибка загрузки: " .. tostring(err) end
                    return pcall(f)
                end
            """)

            success, error_msg = lua_code_runner(code, sandbox_env)

            # Извлечение логов
            lua_logs = self.lua.globals().LOGS
            for i in range(len(lua_logs)):
                logs.append(lua_logs[i+1])

            # Извлечение захваченного кода
            captured = self.lua.globals().CAPTURED_RESULT
            if captured:
                logs.append("\n" + "="*20 + " ДЕОБФУСЦИРОВАННЫЙ КОД " + "="*20)
                logs.append(str(captured))
            elif not success:
                logs.append(f"\n[ОШИБКА ВЫПОЛНЕНИЯ]: {error_msg}")

        except Exception as e:
            logs.append(f"\n[CRITICAL PYTHON ERROR]: {e}")

        return "\n".join(logs)
