# ================== LUA VALIDATOR ==================

def check_lua_syntax(code):
    """Простейшая проверка синтаксиса на уровне баланса ключевых слов"""
    open_tags = len(re.findall(r'\b(then|do|function|repeat)\b', code))
    close_tags = len(re.findall(r'\b(end|until)\b', code))
    
    # Проверка на базовые ошибки
    if open_tags != close_tags:
        return False, f"Ошибка баланса блоков (end)! Найдено начал: {open_tags}, концов: {close_tags}"
    
    # Проверка на пустой код
    if len(code.strip()) < 2:
        return False, "Скрипт слишком пустой."
    
    return True, "OK"

# ================== VM BUILDER V11 ==================

import re

def gen_moon_var(length=10):
    return "_" + "".join(random.choice(string.ascii_letters) for _ in range(length))

def build_vm_v11(source_code, env_type):
    # Шифрование в MoonSec Style
    key = random.randint(30, 150)
    encrypted_bytes = [ord(c) ^ key for c in source_code]
    
    # Формируем строку байтов
    byte_str = "".join([f"\\{b}" for b in encrypted_bytes])
    
    v_entry = gen_moon_var()
    v_key = gen_moon_var()
    v_data = gen_moon_var()
    v_env = gen_moon_var()
    
    # Выбор загрузчика в зависимости от среды
    loader = "loadstring" if env_type == "roblox_exec" else "load"

    vm_template = f"""
--[[ Meloten V11 Anti-Crash ]]
local {v_key} = {key}
local {v_data} = "{byte_str}"

local function {v_entry}()
    local decoded = ""
    for i = 1, #{v_data} do
        local b = string.byte({v_data}, i)
        decoded = decoded .. string.char(b ~ {v_key})
    end
    
    local success, result = pcall(function()
        local _L = {loader} or load
        local _exec = _L(decoded)
        if _exec then 
            return _exec()
        else
            error("VM Error: Failed to load chunk")
        end
    end)
    
    if not success then
        warn("Meloten Guard: " .. tostring(result))
    end
end

{v_entry}()
"""
    return vm_template

