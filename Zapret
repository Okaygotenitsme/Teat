class MoonSecReplica:
    def __init__(self, source_code):
        self.source = source_code
        self.var_cache = {}
        # Настройки генерации мусора
        self.junk_vars = []
        
    def _rnd_name(self, length=None):
        """Генерирует переменные в стиле llIll1l"""
        if not length:
            length = random.randint(6, 15)
        return random.choice(['l', 'I']) + ''.join(random.choice(['l', 'I', '1']) for _ in range(length))

    def _get_var(self, key):
        """Возвращает консистентное имя переменной"""
        if key not in self.var_cache:
            self.var_cache[key] = self._rnd_name()
        return self.var_cache[key]

    def _generate_junk_math(self, v_math):
        """Генерирует математический шум как в MoonSec V3 (Source 2)"""
        ops = ['+', '-', '*', '%']
        block = ""
        # Создаем цепочку бессмысленных вычислений
        for _ in range(random.randint(2, 5)):
            val = random.randint(0x100, 0xFFFF)
            mod = random.randint(0x1000, 0xFFFF)
            op = random.choice(ops)
            block += f"{v_math}=({v_math}{op}{val})%{mod};"
            
            # Вложенный мусорный if
            if random.random() > 0.7:
                v_check = random.randint(100, 5000)
                block += f"if({v_math}%{random.randint(100, 900)})>{v_check} then {v_math}=({v_math}-{random.randint(10,99)})%0x{random.randint(1000,9999):x} end;"
        return block

    def obfuscate(self):
        # 1. Сжимаем и шифруем исходник
        compressed = zlib.compress(self.source.encode('utf-8'))
        # Превращаем в массив байт с диким смещением
        key = random.randint(10000, 99999)
        bytecode = []
        for b in compressed:
            # Шифрование: (Byte XOR Key) + Index
            enc = (b ^ (key % 255))
            bytecode.append(str(enc))
        
        # Переменные для VM
        v_func_wrapper = self._get_var('wrapper')
        v_env = self._get_var('env')
        v_byte_table = self._get_var('byte_table')
        v_pointer = self._get_var('pointer')
        v_math_val = self._get_var('math_val')
        v_str_buffer = self._get_var('str_buffer')
        v_xor_key = self._get_var('xor_key')
        v_final_code = self._get_var('final_code')
        v_bit = self._get_var('bit')
        
        # Заголовок как в MoonSec
        header = f"([[This file was protected with MoonSec V3]]):gsub('.+', (function(a) _ngWOHRHfEJeL = a; end)); return(function(l,...)"
        
        # Переменные VM
        vars_decl = f"local {v_env};local {v_byte_table};local {v_pointer};local {v_math_val}={random.randint(20000, 50000)};local {v_xor_key}={key};local {v_str_buffer}={{}};"
        
        # Загрузка байткода (разбиваем на части, чтобы Lua не крашнулся от длины строки)
        payload_str = ",".join(bytecode)
        table_loader = f"{v_byte_table}={{ {payload_str} }};"
        
        # Основной цикл VM
        vm_loop = f"while {v_math_val} < {random.randint(900000, 999999)} do "
        
        # Генерируем "Control Flow Flattening"
        # Реальная логика прячется среди мусора
        vm_loop += self._generate_junk_math(v_math_val)
        
        # Блок дешифровки
        # Мы используем условие с % 2 ~= 0 чтобы запутать
        vm_loop += f"if {v_math_val}%2~=0 then "
        vm_loop += self._generate_junk_math(v_math_val)
        vm_loop += f"else "
        
        # Реальная логика цикла
        vm_loop += (
            f"local {self._rnd_name()} = 0;"
            f"for {self._rnd_name()} = 1, #{v_byte_table} do "
            f"local b = {v_byte_table}[{self._rnd_name()}];"
            f"table.insert({v_str_buffer}, string.char(bit32 and bit32.bxor(b, {v_xor_key}%255) or (b ~ ({v_xor_key}%255)) ));"
            f"end; break;" # Прерываем while после расшифровки
        )
        
        vm_loop += "end end " # Закрываем if/else и while
        
        # Финализация: распаковка zlib (эмуляция через loadstring, так как на чистом Lua zlib нет, 
        # но мы используем трюк: мы просто защищаем строку, а не сжимаем в коде, чтобы работало везде)
        
        # ВАЖНО: Так как в чистом Lua нет zlib декомпрессии из коробки, 
        # для совместимости мы уберем zlib сжатие из кода выше и оставим только XOR шифрование,
        # но добавим визуального шума, чтобы код выглядел "сжатым".
        
        # --- ПЕРЕГЕНЕРАЦИЯ БЕЗ ZLIB (ДЛЯ СОВМЕСТИМОСТИ) ---
        # MoonSec часто использует кастомные алгоритмы, но чтобы работало везде (SAMP, Roblox),
        # лучше использовать чистый XOR + Table.
        
        bytecode = []
        for char in self.source:
            byte = ord(char)
            # Сложная формула шифрования
            enc = (byte + key) % 255
            bytecode.append(str(enc))
        payload_str = ",".join(bytecode)
        
        # Собираем финальный скрипт заново
        
        final_lua = (
            f"{header} "
            f"local {self._rnd_name()}; local {self._rnd_name()}; "
            f"{vars_decl} "
            f"{v_byte_table}={{ {payload_str} }}; "
            f"{v_pointer}=1; "
            
            # Начало цикла обфускации
            f"while {v_pointer} <= #{v_byte_table} do "
            f"{v_math_val} = {v_math_val} + 1; "
            
            # Вставляем много мусорного кода
            + self._generate_junk_math(v_math_val) +
            
            # Условие-обманка
            f"if ({v_math_val}%0x30b4)>0x185a then "
            + self._generate_junk_math(v_math_val) +
            f" else "
            
            # Реальное действие (расшифровка одного байта)
            f"local e = {v_byte_table}[{v_pointer}]; "
            f"e = (e - {v_xor_key}) % 255; "
            f"table.insert({v_str_buffer}, string.char(e)); "
            f"{v_pointer} = {v_pointer} + 1; "
            f"end; "
            
            # Еще мусор
            f"if {v_math_val}%2 ~= 0 then " + self._generate_junk_math(v_math_val) + " end; "
            f"end; " # Конец цикла while
            
            # Запуск кода
            f"local {v_final_code} = table.concat({v_str_buffer}); "
            f"local {v_env} = (loadstring or load)({v_final_code}); "
            f"if {v_env} then return {v_env}(...) else return nil end; "
            f"end)(...) "
        )
        
        return final_lua

