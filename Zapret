    def _preprocess_code(self, content):
        """Предобработка: декодирование Base64/Hex"""
        if isinstance(content, bytes):
            try:
                text = content.decode('utf-8')
            except:
                return content
        else:
            text = content

        # Попытка декодировать Base64
        if re.match(r'^[A-Za-z0-9+/=\s]+$', text) and len(text) > 100:
            try:
                decoded = base64.b64decode(text)
                if b'local' in decoded or b'function' in decoded:
                    logger.info("✅ Decoded Base64")
                    return decoded
            except:
                pass

        return content.encode('utf-8') if isinstance(content, str) else content

    def _find_best_chunk(self, chunks):
        """Ищет самый большой и осмысленный чанк"""
        if not chunks or len(chunks) == 0:
            return None
        
        best = None
        max_score = 0
        
        for i in range(1, len(chunks) + 1):
            c = chunks[i]
            score = c.size
            
            # Бонус за наличие ключевых слов
            if isinstance(c.data, bytes):
                if b'function' in c.data: score += 1000
                if b'local' in c.data: score += 500
                if b'return' in c.data: score += 300
            
            if score > max_score:
                max_score = score
                best = c.data
        
        return best

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], 
                         stdout=subprocess.DEVNULL, 
                         stderr=subprocess.DEVNULL,
                         timeout=5)
            return True
        except:
            return False

    def _clean_string(self, s):
        if isinstance(s, bytes):
            try:
                return s.decode('utf-8', errors='ignore')
            except:
                return str(s)
        return str(s)

    def _finalize_output(self, code_bytes, strings, globals_dump, logs, remotes, obf_type, callback):
        if callback:
            callback("🧬 Decompiling bytecode...")
        
        decompiled = self._try_decompile(code_bytes)
        
        # HEADER
        final = f"""-- ============================================
-- DEOBFUSCATION REPORT
-- Obfuscator: {obf_type}
-- ============================================

"""
        
        # REMOTE CALLS
        if remotes:
            final += "-- [[ 📡 REMOTE SPY ]] --\n"
            for r in remotes[:50]:
                final += f"-- {self._clean_string(r)}\n"
            final += "\n"

        # STRINGS
        if strings:
            final += "-- [[ 🔤 EXTRACTED STRINGS ]] --\n"
            sorted_strings = sorted(strings, key=lambda x: len(str(x)), reverse=True)
            seen = set()
            count = 0
            for s in sorted_strings:
                if count >= 100:
                    break
                clean = self._clean_string(s).replace('\n', '\\n').replace('\r', '')
                if clean not in seen and len(clean) > 3:
                    final += f'-- "{clean}"\n'
                    seen.add(clean)
                    count += 1
            final += "\n"

        # GLOBALS
        if globals_dump:
            final += "-- [[ 🌍 GLOBAL VARIABLES ]] --\n"
            for g in globals_dump[:30]:
                final += f"-- {self._clean_string(g)}\n"
            final += "\n"

        # LOGS
        if logs:
            final += "-- [[ 📋 EXECUTION LOG ]] --\n"
            for l in logs[-30:]:
                final += f"-- {self._clean_string(l)}\n"
            final += "\n"

        final += "="*60 + "\n"
        final += "-- [[ 📜 DECOMPILED SOURCE ]] --\n"
        final += "="*60 + "\n\n"
        
        if decompiled:
            try:
                src = decompiled.decode('utf-8', 'ignore')
            except:
                src = decompiled.decode('latin-1', 'ignore')
            final += self._beautify_lua(src)
        else:
            final += "-- [!] Decompilation failed. Raw data:\n"
            try:
                final += code_bytes.decode('utf-8', 'ignore')
            except:
                final += f"-- Binary data: {len(code_bytes)} bytes\n"

        return final.encode('utf-8')

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path):
            return None
        
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".luac", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            res = subprocess.run(
                ["java", "-Xmx2G", "-jar", self.unluac_path, path],
                capture_output=True,
                timeout=30
            )
            
            os.remove(path)
            
            if res.returncode == 0 and len(res.stdout) > 0:
                return res.stdout
            
            return None
        except Exception as e:
            logger.error(f"Decompile error: {e}")
            return None

    def _beautify_lua(self, source):
        """Улучшенное форматирование кода"""
        # Удаление мусора
        source = re.sub(r'--\[\[.*?--\]\]', '', source, flags=re.DOTALL)  # Блочные комменты
        source = re.sub(r'local _+[a-zA-Z0-9]+ *= *nil;?', '', source)  # Мусорные локали
        
        # Форматирование
        source = re.sub(r';', ';\n', source)
        source = re.sub(r'(\s+)(local|return|if|for|while|repeat|function|end)(\s+)', r'\n\2\3', source)
        source = re.sub(r' then ', ' then\n\t', source)
        source = re.sub(r' do ', ' do\n\t', source)
        source = re.sub(r'\n{3,}', '\n\n', source)  # Убрать лишние пустые строки
        
        return source
