import cv2
import mediapipe as mp
import numpy as np

# --- Инициализация ---

# Инициализация модулей MediaPipe для рисования и определения рук
mp_drawing = mp.solutions.drawing_utils
mp_hands = mp.solutions.hands

# Настройка параметров детектора рук
# min_detection_confidence: минимальная уверенность для признания руки обнаруженной
# min_tracking_confidence: минимальная уверенность для продолжения отслеживания
hands = mp_hands.Hands(
    max_num_hands=1, # Нам нужна только одна рука для рисования
    min_detection_confidence=0.7,
    min_tracking_confidence=0.7
)

# Подключение к веб-камере (обычно 0 — это встроенная камера)
cap = cv2.VideoCapture(0)

# Переменные для рисования
prev_x, prev_y = 0, 0 # Предыдущие координаты кончика пальца
# Создаем "холст" — черное изображение того же размера, что и видео (пока заглушка)
canvas_img = None

# Цвет линии (белый в формате BGR) и толщина
DRAW_COLOR = (255, 255, 255)
BRUSH_THICKNESS = 5


# --- Основной цикл программы ---

print("Камера запускается. Рисуйте указательным пальцем. Покажите открытую ладонь ✋, чтобы очистить.")

while cap.isOpened():
    # Чтение кадра с камеры
    success, frame = cap.read()
    if not success:
        print("Не удалось получить кадр с камеры.")
        break

    # Зеркальное отражение кадра по горизонтали для удобства
    frame = cv2.flip(frame, 1)

    # Если холст еще не создан, создаем его с размерами текущего кадра
    if canvas_img is None:
        canvas_img = np.zeros_like(frame)

    # Получаем высоту и ширину кадра
    h, w, c = frame.shape

    # Конвертируем изображение из BGR (формат OpenCV) в RGB (формат для MediaPipe)
    frame_rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)

    # Обрабатываем кадр с помощью MediaPipe Hands
    results = hands.process(frame_rgb)

    # Флаг для определения жеста "открытая ладонь"
    fingers_up = [False, False, False, False, False] # Большой, Указат., Средний, Безым., Мизинец

    # Если руки обнаружены
    if results.multi_hand_landmarks:
        for hand_landmarks in results.multi_hand_landmarks:
            # Опционально: рисуем скелет руки на кадре для наглядности
            # mp_drawing.draw_landmarks(frame, hand_landmarks, mp_hands.HAND_CONNECTIONS)

            # Получаем список всех ключевых точек руки
            lmList = []
            for id, lm in enumerate(hand_landmarks.landmark):
                # Конвертируем нормализованные координаты (0.0-1.0) в пиксели
                cx, cy = int(lm.x * w), int(lm.y * h)
                lmList.append([id, cx, cy])

            # --- Логика определения жестов ---
            if len(lmList) != 0:
                # Координаты кончиков пальцев (IDs: 4, 8, 12, 16, 20)
                # Координаты средних суставов (IDs: 2, 6, 10, 14, 18)

                # Проверка большого пальца (он работает немного иначе, проверяем по оси X)
                # Если кончик (4) правее сустава (3) для правой руки (при зеркалировании)
                if lmList[4][1] > lmList[3][1]: fingers_up[0] = True

                # Проверка остальных 4 пальцев (если кончик выше среднего сустава по оси Y)
                # Ось Y идет сверху вниз, поэтому "выше" значит меньше координата Y
                if lmList[8][2] < lmList[6][2]: fingers_up[1] = True  # Указательный
                if lmList[12][2] < lmList[10][2]: fingers_up[2] = True # Средний
                if lmList[16][2] < lmList[14][2]: fingers_up[3] = True # Безымянный
                if lmList[20][2] < lmList[18][2]: fingers_up[4] = True # Мизинец

                # --- Режим ОЧИСТКИ (Жест ✋: все пальцы кроме, возможно, большого, подняты) ---
                # Проверяем, подняты ли указательный, средний, безымянный и мизинец
                if fingers_up[1] and fingers_up[2] and fingers_up[3] and fingers_up[4]:
                   # Очищаем холст (заливаем черным)
                   canvas_img = np.zeros_like(frame)
                   # Сбрасываем предыдущую позицию, чтобы не было линии после очистки
                   prev_x, prev_y = 0, 0
                   cv2.putText(frame, "CLEARED!", (50, 50), cv2.FONT_HERSHEY_SIMPLEX, 1, (0, 0, 255), 2)

                # --- Режим РИСОВАНИЯ (Иначе, если видна рука) ---
                else:
                    # Получаем координаты кончика указательного пальца (ID 8)
                    curr_x, curr_y = lmList[8][1], lmList[8][2]

                    # Если это первая точка после потери руки или старта
                    if prev_x == 0 and prev_y == 0:
                        prev_x, prev_y = curr_x, curr_y

                    # Рисуем линию на холсте от предыдущей точки к текущей
                    cv2.line(canvas_img, (prev_x, prev_y), (curr_x, curr_y), DRAW_COLOR, BRUSH_THICKNESS)

                    # Обновляем предыдущую точку
                    prev_x, prev_y = curr_x, curr_y

                    # Рисуем кружок на кончике пальца в реальном видео для визуализации
                    cv2.circle(frame, (curr_x, curr_y), 10, DRAW_COLOR, cv2.FILLED)

    else:
        # Если рука потеряна из виду, сбрасываем предыдущие координаты
        prev_x, prev_y = 0, 0

    # --- Объединение и отображение ---

    # Накладываем холст с рисунком на оригинальный кадр с камеры
    # Сложение изображений: черный цвет (0,0,0) не меняет оригинальный кадр,
    # а белые линии добавляются.
    combined_image = cv2.add(frame, canvas_img)

    # Показываем результат
    cv2.imshow('Air Canvas', combined_image)

    # Выход при нажатии клавиши 'q'
    if cv2.waitKey(1) & 0xFF == ord('q'):
        break

# --- Завершение работы ---
cap.release()
cv2.destroyAllWindows()
print("Программа завершена.")
