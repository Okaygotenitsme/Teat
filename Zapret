@dp.message(F.document)
async def handle_file(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        await message.answer("❌ Кидай только .lua или .txt")
        return

    wait_msg = await message.answer("🔄 **Анализ структуры и генерация OpCode...**")

    try:
        file_info = await bot.get_file(message.document.file_id)
        file_content = await bot.download_file(file_info.file_path)
        source = file_content.read().decode('utf-8', errors='ignore')

        # Запускаем обфускацию в отдельном потоке, чтобы не блочить бота
        loop = asyncio.get_running_loop()
        
        # Функция-обертка для запуска
        def process():
            obfuscator = MoonSecReplica(source)
            return obfuscator.obfuscate()

        # Выполняем
        final_code = await loop.run_in_executor(None, process)

        output = BufferedInputFile(
            final_code.encode('utf-8'), 
            filename=f"Protected_{message.document.file_name}"
        )
        
        await message.answer_document(output, caption="✅ **Защищено методом MoonSec V3 Style**")
        await wait_msg.delete()
        
    except Exception as e:
        logging.error(e)
        await message.answer(f"❌ Ошибка бота: {e}")

