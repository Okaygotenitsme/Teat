logger = logging.getLogger("DeobfuscatorEngine")
logger.addHandler(logging.NullHandler())


class DeobfuscatorEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        self.vm_detector = VMDetector()
        self._last_extracted_path = None
        logger.info(f"📁 Working Dir: {base_dir}")

    # ---------------- public API ----------------
    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback:
                try:
                    status_callback(msg)
                except Exception:
                    pass
            logger.info(f"[STATUS] {msg}")

        # Normalize sample text
        raw_bytes = content if isinstance(content, (bytes, bytearray)) else None
        if raw_bytes is not None:
            try:
                sample = raw_bytes[:20000].decode('latin-1', 'ignore')
            except Exception:
                sample = str(raw_bytes)
        else:
            sample = str(content)

        update_status("🔎 Static heuristics...")
        try:
            vm_info = self.vm_detector.analyze(sample)
            if vm_info.get('is_vm'):
                update_status("⚠️ Virtualization/Protection detected — static extraction only.")
                extracted_strings = self.vm_detector.extract_strings(sample)
                backslash_decoded = self.vm_detector.extract_backslash_numbers(sample)
                strings = extracted_strings + backslash_decoded
                return self._finalize_output(content, strings, vm_info.get('reasons', []), vm_info.get('action_log', []), update_status)
            else:
                update_status("🧠 Attempt runtime tracing (sandbox) — cautious.")
        except Exception as e:
            logger.exception("VM detection error: %s", e)

        # If no Lua runtime available — bail with static hints
        if LuaRuntime is None:
            return b"-- [FATAL] lupa (LuaRuntime) not installed. Install lupa to enable runtime tracing."

        # Runtime tracing
        try:
            lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)
        except Exception as e:
            return f"-- [FATAL] Lua start error: {e}".encode('utf-8')

        try:
            env = lua.execute(self._get_sandbox_setup())
            runner = lua.eval("""
                function(code, env)
                    local f, err = load(code, "chunk", "bt", env)
                    if not f then return false, err end
                    local ok, res = pcall(f)
                    pcall(_G.dump_globals)
                    return ok, res
                end
            """)
            update_status("🌪️ Running sandboxed trace (capture loads/strings)...")
            ok, res = runner(content, env)

            # Collect results robustly (lua tables <-> python)
            strings_tbl = lua.globals().DETECTED_STRINGS
            detected_strings = list(strings_tbl) if strings_tbl else []
            global_dump = list(lua.globals().FINAL_GLOBALS) if lua.globals().FINAL_GLOBALS else []
            action_log = list(lua.globals().ACTION_LOG) if lua.globals().ACTION_LOG else []
            chunks = lua.globals().CAPTURED_CHUNKS if lua.globals().CAPTURED_CHUNKS else []

            best_chunk = None
            max_size = 0
            try:
                # try table-like iteration
                for i in range(1, len(chunks) + 1):
                    c = chunks[i]
                    if getattr(c, 'size', 0) > max_size:
                        max_size = c.size
                        best_chunk = c.data
            except Exception:
                try:
                    for c in chunks:
                        s = getattr(c, 'size', 0)
                        if s > max_size:
                            max_size = s
                            best_chunk = getattr(c, 'data', None)
                except Exception:
                    pass

            target_code = best_chunk if best_chunk else content
            return self._finalize_output(target_code, detected_strings, global_dump, action_log, update_status)
        except Exception as e:
            logger.exception("Runtime tracing failed: %s", e)
            return f"-- [CRASH] {e}".encode('utf-8')

    # ---------------- sandbox ----------------
    def _get_sandbox_setup(self):
        # bit and bit32 polyfill (improved)
        bit_polyfill = """
        local bit = {}
        function bit.tobit(x) x = x % 4294967296; if x >= 2147483648 then x = x - 4294967296 end; return x end
        function bit.bnot(x) return 4294967295 - x % 4294967296 end
        function bit.band(a,b) local r=0;m=1; while a>0 or b>0 do local aa=a%2; local bb=b%2; if aa==1 and bb==1 then r=r+m end; a=(a-aa)/2; b=(b-bb)/2; m=m*2; end; return r end
        function bit.bor(a,b) local r=0;m=1; while a>0 or b>0 do local aa=a%2; local bb=b%2; if aa==1 or bb==1 then r=r+m end; a=(a-aa)/2; b=(b-bb)/2; m=m*2; end; return r end
        function bit.bxor(a,b) local r=0;m=1; while a>0 or b>0 do local aa=a%2; local bb=b%2; if aa~=bb then r=r+m end; a=(a-aa)/2; b=(b-bb)/2; m=m*2; end; return r end
        function bit.lshift(a,b) return (a * 2^b) % 4294967296 end
        function bit.rshift(a,b) return math.floor(a / 2^b) % 4294967296 end
        function bit.arshift(a,b)
            local z = math.floor(a / 2^b) % 4294967296
            if a >= 2147483648 then z = z + 4294967296 - 2^(32-b) end
            return z
        end
        package.loaded.bit = bit; _G.bit = bit; _G.bit32 = bit
        """

        sandbox = bit_polyfill + """
        _G.CAPTURED_CHUNKS = {}
        _G.DETECTED_STRINGS = {}
        _G.ACTION_LOG = {}
        _G.FINAL_GLOBALS = {}

        local function log_action(msg)
            if #_G.ACTION_LOG < 1000 then
                table.insert(_G.ACTION_LOG, tostring(msg))
            end
        end

        local function capture_str(s)
            if type(s) == "string" and #s > 3 then
                if not s:find("stack begin") and not s:find("upvalue") then
                    _G.DETECTED_STRINGS[s] = true
                end
            end
            return s
        end

        -- hook common string builders
        local real_char = string.char
        string.char = function(...)
            local ok, res = pcall(real_char, ...)
            if ok then capture_str(res) end
            return res
        end

        local real_concat = table.concat
        table.concat = function(t, sep, i, j)
            local ok, res = pcall(real_concat, t, sep, i, j)
            if ok then capture_str(res) end
            return res
        end

        local real_load = load
        local function hooked_load(chunk, name, mode, env)
            if type(chunk) == "string" and #chunk > 50 then
                table.insert(_G.CAPTURED_CHUNKS, {data = chunk, size = #chunk, type = "string"})
            end
            return real_load(chunk, name, mode, env)
        end

        function _G.dump_globals()
            local ignore = {string=1, math=1, table=1, bit=1, bit32=1, pairs=1, ipairs=1, next=1, _G=1, sandbox_env=1, package=1}
            local g = getfenv and getfenv() or _G
            for k, v in pairs(g) do
                if not ignore[k] then
                    if type(v) == "string" or type(v) == "number" or type(v) == "boolean" then
                        table.insert(_G.FINAL_GLOBALS, tostring(k) .. " = " .. tostring(v))
                    end
                end
            end
        end

        local function create_proxy(name)
            local proxy = {}
            local meta = {}
            meta.__index = function(t, k)
                local key = tostring(k)
                if key == "PlaceId" then return 123456 end
                if key == "UserId" then return 1001 end
                if key == "HttpGet" or key == "HttpGetAsync" then
                    return function(u) log_action("HTTP GET: "..tostring(u)); return "ProxyResponse" end
                end
                return create_proxy(name .. "." .. key)
            end
            meta.__newindex = function(t, k, v)
                log_action("Write: " .. name .. "." .. tostring(k) .. " = " .. tostring(v))
            end
            meta.__call = function(t, ...) return create_proxy(name) end
            meta.__tostring = function() return name end
            setmetatable(proxy, meta)
            return proxy
        end

        local env = {
            loadstring = hooked_load, load = hooked_load,
            print = function(...) local a={...}; log_action("Print: "..tostring(a[1])); end,
            warn = function(...) local a={...}; log_action("Warn: "..tostring(a[1])); end,
            error = function(...) log_action("Error suppressed"); end,
            string = string, math = math, table = table,
            bit = bit, bit32 = bit, pairs = pairs, ipairs = ipairs, next = next,
            type = type, tostring = tostring, tonumber = tonumber, pcall = pcall, xpcall = xpcall,
            select = select, unpack = unpack or table.unpack,
            setmetatable = setmetatable, getmetatable = getmetatable,

            game = create_proxy("game"),
            workspace = create_proxy("workspace"),
            script = create_proxy("script"),
            getgenv = function() return {} end,
        }
        env._G = env
        _G.sandbox_env = env
        return env
        """
        return sandbox

    # --------------- finalization (multi-pass) ----------------
    def _finalize_output(self, code_bytes, strings, globals_dump, logs, callback):
        """
        Multi-pass finalizer:
         - static decodings on collected strings
         - generate extracted_blocks.lua (mel_N)
         - collect bytecode candidates (raw bytes, \ddd groups, captured chunks)
         - run unluac LAST on all candidates
        """
        if callback:
            callback("🔧 Postprocessing and multi-pass decoding...")

        # prepare workspace
        composed = []
        composed.append("-- [[ DUMPED STRINGS (DECRYPTED / STATIC) ]] --\n")
        composed.append("-- Assets, Keys, and Messages found during analysis:\n\n")

        strings = strings or []
        # try to expand decodings for strings
        decoded_map = OrderedDict()
        for s in sorted(set(strings), key=lambda x: len(str(x)), reverse=True):
            s_clean = self._clean_string(s)
            if len(s_clean) < 4:
                continue
            composed.append(f'-- "{s_clean}"\n')
            # try common decodings and append as comments
            decs = self._try_common_decodings(s_clean)
            for t, r in decs[:3]:
                if t == 'xor_single':
                    composed.append(f'--   [xor_single key={r[0]}] {r[1][:200]}\n')
                else:
                    composed.append(f'--   [{t}] {str(r)[:200]}\n')
            decoded_map[s_clean] = decs

        # globals dump
        if globals_dump:
            composed.append("\n" + "=" * 50 + "\n")
            composed.append("-- [[ GLOBAL VARIABLES DUMP ]] --\n")
            composed.append("-- Variables left in environment after run:\n\n")
            for g in globals_dump:
                composed.append(f"-- {self._clean_string(g)}\n")

        composed.append("\n" + "=" * 50 + "\n\n")

        # Generate extracted mel file (from code_bytes or captured strings)
        try:
            code_text = None
            if isinstance(code_bytes, (bytes, bytearray)):
                code_text = code_bytes.decode('latin-1', 'ignore')
            else:
                code_text = str(code_bytes)
            mel_text = self._generate_mel_wrappers(code_text)
            # write mel file
            mel_path = os.path.join(tempfile.gettempdir(), f"extracted_blocks_{uuid.uuid4().hex[:8]}.lua")
            with open(mel_path, 'w', encoding='utf-8') as mf:
                mf.write(mel_text)
            self._last_extracted_path = mel_path
            composed.append("-- [[ extracted_blocks.lua generated and saved ]]\n")
            composed.append(f"-- Path: {mel_path}\n")
        except Exception:
            self._last_extracted_path = None

        # At this point: attempt to find bytecode candidates to pass to unluac *last*
        candidates = []

        # 1) if code_bytes already bytes -> candidate
        if isinstance(code_bytes, (bytes, bytearray)):
            candidates.append(bytes(code_bytes))

        # 2) find long backslash-number groups inside code_text and decode to bytes
        try:
            bs = self._extract_backslash_byte_blobs(code_text)
            for b in bs:
                if b and len(b) > 64:
                    candidates.append(b)
                    composed.append(f"-- Found backslash-byte blob candidate (len {len(b)})\n")
        except Exception:
            pass

        # 3) try to find base64-like long literals in decoded_map results
        try:
            for s, decs in decoded_map.items():
                for t, r in decs:
                    if t in ('base64', 'base64_raw'):
                        if isinstance(r, str):
                            # base64 decoded text (r may be readable)
                            try:
                                candidates.append(r.encode('latin-1', 'ignore'))
                                composed.append(f"-- base64 decode candidate from string: {s[:80]}\n")
                            except:
                                pass
        except Exception:
            pass

        # 4) try to extract raw-looking lua chunks inside captured big strings (mel file already contains them)
        # We will attempt unluac on each candidate, but only at the very end.

        # Before unluac, append any raw script-preview (we'll later try to decompile)
        composed.append("\n-- [[ RAW / CAPTURED SCRIPT PREVIEW ]] --\n\n")
        # if code_text is textual, attach truncated preview
        try:
            if code_text:
                preview = code_text[:2000]
                composed.append(preview + ("\n-- ...(truncated preview)\n" if len(code_text) > 2000 else "\n"))
        except Exception:
            pass

        # === NOW: the LAST STEP: try unluac on candidates (unluac runs last) ===
        composed.append("\n-- [[ Attempting unluac on candidates (last) ]] --\n")
        unluac_success = False
        unluac_results = []
        for idx, cand in enumerate(candidates):
            if not cand:
                continue
            if callback:
                callback(f"🧪 unluac attempt #{idx+1} (last step)...")
            try:
                res = self._try_decompile(cand)
                if res:
                    unluac_success = True
                    try:
                        src = res.decode('utf-8', 'ignore')
                    except:
                        src = res.decode('latin-1', 'ignore')
                    # beautify and rename obfuscated local identifiers
                    src = self._beautify_lua(src)
                    renamed_src, mapping = self._rename_obfuscated_identifiers(src)
                    unluac_results.append((cand, renamed_src, mapping))
                    # we stop after first successful decompile (but still keep other candidates as fallback)
                    break
            except Exception:
                continue

        # If unluac succeeded, append decompiled source, otherwise leave warning and include raw preview
        if unluac_success and unluac_results:
            cand, renamed_src, mapping = unluac_results[0]
            composed.append("\n" + "=" * 50 + "\n")
            composed.append("-- [[ DECOMPILED SOURCE (unluac result) ]] --\n\n")
            composed.append(renamed_src)
            composed.append("\n\n-- [[ Identifier mapping (sample) ]] --\n")
            for k, v in list(mapping.items())[:200]:
                composed.append(f"-- {k} -> {v}\n")
        else:
            composed.append("\n-- [WARNING] unluac failed on all candidates (file may be VM-protected / nonstandard bytecode).\n")
            composed.append("-- Keep extracted_blocks.lua and captured previews for manual inspection.\n")

        # Action log
        composed.append("\n" + "=" * 50 + "\n")
        composed.append("-- [[ ACTION LOG ]] --\n\n")
        for l in (logs or [])[-1000:]:
            composed.append(f"-- {self._clean_string(l)}\n")

        return ''.join(composed).encode('utf-8')

    # ---------------- decompiler wrapper (runs unluac) ----------------
    def _try_decompile(self, byteblob):
        """
        Runs unluac.jar on byteblob. Returns stdout bytes or None.
        """
        if not os.path.exists(self.unluac_path):
            logger.debug("unluac.jar not found at %s", self.unluac_path)
            return None
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                if isinstance(byteblob, (bytes, bytearray)):
                    tmp.write(byteblob)
                else:
                    tmp.write(str(byteblob).encode('latin-1', 'ignore'))
                path = tmp.name

            res = subprocess.run(
                ["java", "-Xmx2G", "-jar", self.unluac_path, path],
                capture_output=True,
                timeout=30
            )
            try:
                os.remove(path)
            except:
                pass

            if res.returncode == 0 and res.stdout:
                return res.stdout
            return None
        except Exception as e:
            logger.exception("unluac execution failed: %s", e)
            return None

    # -------------- helpers: extract backslash-byte blobs -------------
    def _extract_backslash_byte_blobs(self, text):
        """
        Finds long sequences of \ddd\ddd... in text and converts them to raw bytes.
        Returns list of bytes objects.
        """
        if not text:
            return []
        out = []
        # find long groups of \ddd (at least 8 numbers consecutively)
        for group in re.findall(r'(?:\\\d{1,3}){8,}', text):
            try:
                nums = re.findall(r'\\(\d{1,3})', group)
                b = bytes(int(n) for n in nums)
                out.append(b)
            except Exception:
                continue
        return out

    # ---------------- other utils ----------------
    def _clean_string(self, s):
        if isinstance(s, (bytes, bytearray)):
            try:
                return s.decode('utf-8')
            except:
                try:
                    return s.decode('latin-1')
                except:
                    return str(s)
        return str(s)

    def _beautify_lua(self, source_code):
        source_code = re.sub(r'(\s)(local|return|if|for|while|repeat|function)(\s)', r'\n\2 ', source_code)
        replacements = {
            " then ": " then\n", " do ": " do\n", " end ": "\nend\n",
            " repeat ": "\nrepeat\n", " until ": "\nuntil ", ";": ";\n"
        }
        for k, v in replacements.items():
            source_code = source_code.replace(k, v)

        lines = source_code.splitlines()
        formatted = []
        indent = 0

        for line in lines:
            line = line.rstrip()
            if not line.strip():
                continue
            stripped = line.strip()
            if stripped.startswith("--"):
                formatted.append("\t" * indent + stripped)
                continue

            if stripped.startswith(("end", "until")):
                indent = max(0, indent - 1)

            formatted.append("\t" * indent + stripped)

            if stripped.endswith(("then", "do", "repeat")) or (stripped.startswith("function") and not stripped.endswith("end")):
                indent += 1
            if stripped.startswith(("else", "elseif")):
                pass

        return "\n".join(formatted)

    # --------------- mel wrappers (extracted_blocks.lua) --------------
    def _generate_mel_wrappers(self, text_blob, min_string_len=60):
        fragments = []
        qpat = re.compile(r'("(?:(?:\\\\\d{1,3})|[^"\\\\]){'+str(min_string_len)+r',}"|\'(?:(?:\\\\\d{1,3})|[^\'\\\\]){'+str(min_string_len)+r',}\')', re.S)
        for m in qpat.finditer(text_blob):
            fragments.append(m.group(0))
        fpat = re.compile(r'(function[\s\S]{200,}?end)', re.I)
        for m in fpat.finditer(text_blob):
            fragments.append(m.group(0))
        if not fragments:
            for i in range(0, len(text_blob or ""), 10000):
                frag = (text_blob or "")[i:i+10000]
                if len(frag) > 200:
                    fragments.append(frag)
        uniq = []
        seen = set()
        for f in fragments:
            key = f[:200]
            if key in seen: continue
            seen.add(key)
            uniq.append(f)

        out = []
        out.append('-- extracted_blocks.lua  (auto-generated)\n\n')
        for i, b in enumerate(uniq, start=1):
            raw = b
            if (raw.startswith('"') and raw.endswith('"')) or (raw.startswith("'") and raw.endswith("'")):
                inner = raw[1:-1]
                decoded = self._decode_backslash_numbers(inner)
                lua_literal = self._to_lua_long_bracket(decoded)
                preview = decoded[:500].replace('\n', '\\n')
                out.append(f'-- fragment #{i} (decoded preview): {preview}\n')
                out.append(f'local mel_{i} = {lua_literal}\n\n')
            else:
                preview = raw[:200].replace('\n', '\\n')
                out.append(f'-- fragment #{i} (raw blob length {len(raw)}): {preview}\n')
                lua_literal = self._to_lua_long_bracket(raw)
                out.append(f'local mel_{i} = {lua_literal}\n\n')
        if not uniq:
            out.append('-- No significant fragments detected.\n')
        return ''.join(out)

    def _to_lua_long_bracket(self, s: str):
        if s is None:
            s = ""
        for n in range(0, 8):
            eq = '=' * n
            close = ']' + eq + ']'
            if close not in s:
                return f'[{eq}[\n{s}\n]{eq}]'
        esc = s.replace('\\', '\\\\').replace('"', '\\"')
        return '"' + esc + '"'

    def _decode_backslash_numbers(self, s: str):
        nums = re.findall(r'\\(\d{1,3})', s)
        if not nums:
            return s
        try:
            b = bytes(int(n) for n in nums)
            try:
                return b.decode('utf-8')
            except:
                return b.decode('latin-1', 'ignore')
        except Exception:
            return s

    # --------------- identifier renamer (local short -> mel_N) --------------
    def _rename_obfuscated_identifiers(self, src: str, max_len=8):
        keywords = set("""and break do else elseif end false for function if in local nil not or repeat return then true until while
                        string table math pairs ipairs next coroutine package io os debug load loadfile require pcall xpcall""".split())
        common_globals = set(["game","workspace","script","Instance","Vector3","CFrame","wait","warn","print","require","tick","DateTime"])
        protected = keywords.union(common_globals)

        ident_pattern = re.compile(r'\b([A-Za-z_][A-Za-z0-9_]*)\b')
        counts = {}
        for m in ident_pattern.finditer(src):
            name = m.group(1)
            if name in protected: continue
            if len(name) <= max_len:
                counts[name] = counts.get(name, 0) + 1

        candidates = [n for n,c in counts.items() if c >= 1]
        candidates = sorted(candidates, key=lambda x:(len(x), x))[:800]

        mapping = {}
        i = 1
        for name in candidates:
            mapping[name] = f"mel_{i}"
            i += 1

        def repl(m):
            n = m.group(1)
            return mapping.get(n, n)

        new_src = ident_pattern.sub(repl, src)
        return new_src, mapping

    # --------------- decoders (common) ----------------
    def _try_common_decodings(self, s: str):
        results = []
        ds = self._decode_backslash_numbers(s)
        if ds != s:
            results.append(('backslash', ds))

        # base64
        try:
            b = base64.b64decode(s, validate=True)
            printable = sum(32 <= c < 127 for c in b)
            ratio = printable / max(1, len(b))
            if ratio > 0.6 and len(b) > 4:
                results.append(('base64', b.decode('utf-8', 'ignore')))
            else:
                results.append(('base64_raw', binascii.hexlify(b).decode()[:200]))
        except Exception:
            pass

        # hex-like
        hexcand = re.sub(r'[^0-9a-fA-F]', '', s)
        if len(hexcand) >= 8 and len(hexcand) % 2 == 0:
            try:
                b = binascii.unhexlify(hexcand)
                printable = sum(32 <= c < 127 for c in b)
                ratio = printable / max(1, len(b))
                if ratio > 0.6:
                    results.append(('hex', b.decode('utf-8', 'ignore')))
                else:
                    results.append(('hex_raw', binascii.hexlify(b).decode()[:200]))
            except:
                pass

        # single-byte XOR brute
        best = None
        try:
            raw = s.encode('latin-1', 'ignore')
            for key in range(1, 256):
                b = bytes([c ^ key for c in raw])
                printable = sum(32 <= c < 127 for c in b)
                ratio = printable / max(1, len(b))
                if ratio > 0.85:
                    best = (key, b.decode('utf-8', 'ignore'))
                    break
        except Exception:
            pass
        if best:
            results.append(('xor_single', best))
        return results

    # --------------- utilities for bot ----------------
    def get_last_extracted_path(self):
        return getattr(self, "_last_extracted_path", None)

    def clear_last_extracted_path(self):
        p = getattr(self, "_last_extracted_path", None)
        if p and os.path.exists(p):
            try:
                os.remove(p)
            except:
                pass
        self._last_extracted_path = None 
