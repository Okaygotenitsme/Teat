import asyncio
import os
import logging
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command
from engine import DeobfuscatorEngine

API_TOKEN = 'ТВОЙ_ТОКЕН'

logging.basicConfig(level=logging.INFO)
bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer("Привет! Я деобфускатор. Пришли файл, и я попробую вытащить из него исходный код.")

@dp.message(F.document)
async def handle_document(message: types.Message):
    file_id = message.document.file_id
    file_name = message.document.file_name
    input_path = f"in_{message.from_user.id}_{file_name}"
    output_path = f"out_{message.from_user.id}_{file_name}"

    try:
        sent_msg = await message.answer("📥 Файл получен. Начинаю анализ (лимит 30 сек)...")
        
        # Скачиваем файл
        file = await bot.get_file(file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "r", encoding="utf-8", errors="ignore") as f:
            content = f.read()

        # ЗАПУСК В ОТДЕЛЬНОМ ПОТОКЕ С ТАЙМАУТОМ
        try:
            # asyncio.to_thread запускает функцию в другом потоке (Python 3.9+)
            # asyncio.wait_for ограничивает время выполнения
            result_code = await asyncio.wait_for(
                asyncio.to_thread(engine.process_text, content), 
                timeout=30.0
            )
        except asyncio.TimeoutError:
            result_code = "❌ Ошибка: Время ожидания истекло (Timeout). Скрипт слишком сложный или зациклен."

        # Сохраняем результат
        with open(output_path, "w", encoding="utf-8") as f:
            f.write(result_code)

        await message.answer_document(FSInputFile(output_path), caption="✅ Готово!")

    except Exception as e:
        logging.error(f"Ошибка: {e}")
        await message.answer(f"❌ Произошла ошибка: {e}")
    
    finally:
        # Чистка временных файлов
        for path in [input_path, output_path]:
            if os.path.exists(path):
                os.remove(path)

async def main():
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
