# --- МОДУЛЬ BEAUTIFIER ---
class LuaBeautifier:
    def __init__(self, source):
        self.source = source

    def format(self):
        """Простое выравнивание отступов"""
        code = self.source
        lines = [line.strip() for line in code.splitlines() if line.strip()]
        formatted = []
        indent = 0
        indent_str = "    "
        
        up_keywords = ['function', 'do', 'then', 'repeat', '{', '(', 'if']
        down_keywords = ['end', 'until', '}', ')', 'elseif']
        
        for line in lines:
            curr_line_lower = line.lower()
            if any(curr_line_lower.startswith(k) for k in ['end', 'until', '}', ')', 'elseif', 'else']):
                indent = max(0, indent - 1)
            formatted.append((indent_str * indent) + line)
            open_count = sum(1 for k in up_keywords if k in curr_line_lower)
            close_count = sum(1 for k in down_keywords if k in curr_line_lower)
            if not ('function' in curr_line_lower and 'end' in curr_line_lower):
                if open_count > close_count: indent += 1
                elif 'else' == curr_line_lower: indent += 1

        return "\n".join(formatted)

# --- MELOTEN OBFUSCATOR V11 (STABLE) ---
class MelotenObfuscatorV11:
    def __init__(self, source, layers=1):
        self.original_source = source
        self.layers = layers
        # Просто ссылка, без угроз
        self.watermark = (
            "--[[ Protected by Meloten Obfuscator ]]\n"
            "--[[ http://t.me/Meloten_Obfuscator_bot ]]\n\n"
        )
        
    def _n(self):
        """Безопасные имена переменных (всегда с _ в начале)"""
        length = random.randint(10, 20)
        suffix = ''.join(random.choices("Il1O0", k=length))
        return f"_{suffix}"

    def _generate_names(self):
        self.key = random.randint(100, 255)
        self.vars = {k: self._n() for k in [
            'vm', 'state', 'bytes', 'idx', 'xor', 'junk', 
            'magic', 'dec', 'len', 'byte_val', 'table', 
            'str_lib', 'bit_lib', 'char', 'concat', 'res'
        ]}

    def _junk_code(self):
        """
        Безопасный мусорный код. 
        Убраны бесконечные циклы, которые вешали игру.
        """
        v1 = self._n()
        ops = [
            f"local {v1} = math.floor(12.5 + 0.5);",
            f"if (1 == 2) then return end;",
            f"-- Opcode: {random.randint(100,999)}",
            f"local {v1} = string.char({random.randint(65, 90)});",
        ]
        return random.choice(ops)

    def _build_layer(self, source_code):
        self._generate_names()
        
        # 1. Base64
        b64_source = base64.b64encode(source_code.encode('utf-8')).decode('utf-8')
        
        # 2. Stable XOR Encryption
        # Используем простую, но надежную арифметику, чтобы Lua точно это переварил
        raw_bytes = b64_source.encode('utf-8')
        enc_bytes = []
        
        # Генерируем динамический ключ для каждого байта
        for i, b in enumerate(raw_bytes):
            key_mod = (self.key + i) % 255
            # XOR операция
            val = b ^ key_mod
            enc_bytes.append(val)
        
        payload = "".join([f"\\{b}" for b in enc_bytes])

        # 3. VM Logic (Исправленная и стабильная)
        vm_script = f"""{self.watermark}local {self.vars['str_lib']} = string
local {self.vars['table']} = table
local {self.vars['char']} = {self.vars['str_lib']}.char
local {self.vars['concat']} = {self.vars['table']}.concat

local function {self.vars['xor']}(a, b)
    local p,c=1,0
    while a>0 and b>0 do
        local ra,rb=a%2,b%2; if ra~=rb then c=c+p end
        a,b,p=(a-ra)/2,(b-rb)/2,p*2
    end
    if a<b then a=b end
    while a>0 do local ra=a%2; if ra>0 then c=c+p end a,p=(a-ra)/2,p*2 end
    return c
end

local function {self.vars['vm']}({self.vars['bytes']})
    local {self.vars['dec']} = {{}}
    local {self.vars['len']} = #{self.vars['bytes']}
    local {self.vars['magic']} = {self.key}
    
    -- Цикл расшифровки
    for {self.vars['idx']} = 1, {self.vars['len']} do
        {self._junk_code()}
        
        local {self.vars['byte_val']} = {self.vars['str_lib']}.byte({self.vars['bytes']}, {self.vars['idx']})
        local key_mod = ({self.vars['magic']} + ({self.vars['idx']} - 1)) % 255
        local clean = {self.vars['xor']}({self.vars['byte_val']}, key_mod)
        
        {self.vars['table']}.insert({self.vars['dec']}, {self.vars['char']}(clean))
    end
    
    return {self.vars['concat']}({self.vars['dec']})
end

local _payload = "{payload}"
local {self.vars['res']} = {self.vars['vm']}(_payload)

-- Base64 Decode
local b='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/'
local function _d(d)
    d = string.gsub(d, '[^'..b..'=]', '')
    return (d:gsub('.', function(x)
        if (x == '=') then return '' end
        local r,f='',(b:find(x)-1)
        for i=6,1,-1 do r=r..(f%2^i-f%2^(i-1)>0 and '1' or '0') end
        return r;
    end):gsub('%d%d%d?%d?%d?%d?%d?%d?', function(x)
        if (#x ~= 8) then return '' end
        local c=0
        for i=1,8 do c=c+(x:sub(i,i)=='1' and 2^(8-i) or 0) end
        return string.char(c)
    end))
end

local _final = _d({self.vars['res']})
local _run = loadstring or load
pcall(_run(_final))
"""
        return vm_script

    def build(self):
        code = self.original_source
        for _ in range(self.layers):
            code = self._build_layer(code)
        return code

