            out.append("\n-- [CAPTURED UPVALUES / KEYS]")
            out.append("-- Переменные, найденные внутри функций (замыкания):")
            for k, v in upvalues.items():
                clean_v = self._safe_str(v)
                out.append(f"-- {k} = {clean_v}")

        # 2. DECRYPTED STRINGS
