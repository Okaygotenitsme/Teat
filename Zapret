# ================== UTILS ==================

def gen_var(n=12):
    return "_" + "".join(random.choice(string.ascii_letters) for _ in range(n))

def lua_syntax_check(code: str):
    """
    Минимальная проверка Lua:
    - баланс скобок
    - end / function / if / do
    """
    stack = 0
    for token in code.split():
        if token in ("function", "then", "do", "repeat"):
            stack += 1
        elif token in ("end", "until"):
            stack -= 1
    return stack == 0

def encrypt_to_byte_table(code: str, key: int):
    return [(ord(c) ^ key) for c in code]

def junk_block():
    v = gen_var(6)
    return f"""
local {v} = {random.randint(1000,9999)}
for i = 1, {random.randint(10,40)} do
    {v} = ({v} * {random.randint(2,9)}) % {random.randint(2000,9000)}
end
"""

# ================== OBFUSCATOR CORE ==================

