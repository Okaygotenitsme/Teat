@dp.message(Command("bypass"))
async def bypass_handler(message: types.Message, command: CommandObject):
    if not command.args:
        await message.answer("⚠️ **Ошибка:** Вставь ссылку!\nПример: `/bypass https://linkvertise.com/123/xyz`")
        return

    url = command.args.strip()
    wait_msg = await message.answer("⏳ **Обхожу рекламу...**\n_Это может занять 5-10 секунд._", parse_mode="Markdown")

    api_url = f"https://api.bypass.vip/bypass?url={url}"

    try:
        timeout = aiohttp.ClientTimeout(total=20)
        async with aiohttp.ClientSession(timeout=timeout) as session:
            async with session.get(api_url) as response:
                
                if response.status != 200:
                    await wait_msg.edit_text(f"❌ **API недоступен.** Код: {response.status}")
                    return

                data = await response.json()
                
                status = data.get('status', '')
                result = data.get('result', '')

                if status == 'success' or result:
                    final_link = result if result else "Ссылка получена, но пуста"
                    await wait_msg.edit_text(
                        f"✅ **Успешно!**\n\n"
                        f"🔗 **Результат:**\n`{final_link}`", 
                        parse_mode="Markdown"
                    )
                else:
                    error_msg = data.get('message', 'Неизвестная ошибка API')
                    await wait_msg.edit_text(f"❌ **Не удалось обойти:**\n_{error_msg}_", parse_mode="Markdown")

    except asyncio.TimeoutError:
        await wait_msg.edit_text("❌ **Ошибка:** Превышено время ожидания API.")
    except Exception as e:
        logging.error(e)
        await wait_msg.edit_text(f"❌ **Критическая ошибка:**\n`{e}`", parse_mode="Markdown")


@dp.message(F.document)
async def handle_files(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        return

    file_id = message.document.file_id
    file_info = await bot.get_file(file_id)
    downloaded = await bot.download_file(file_info.file_path)
    source_code = downloaded.read().decode('utf-8', errors='ignore')

    user_id = message.from_user.id
    user_data[user_id] = {
        'source': source_code,
        'filename': message.document.file_name
    }

    keyboard = InlineKeyboardMarkup(inline_keyboard=[
        [InlineKeyboardButton(text="Obfuscate", callback_data="obfuscate")],
        [InlineKeyboardButton(text="Beautify", callback_data="beautify")]
    ])

    await message.answer("🔧 **Выберите действие для файла:**", reply_markup=keyboard)

@dp.callback_query(F.data.in_({"obfuscate", "beautify"}))
async def callback_handler(query: types.CallbackQuery):
    user_id = query.from_user.id
    if user_id not in user_data:
        await query.answer("❌ Сессия истекла. Отправьте файл заново.")
        return

    data = user_data[user_id]
    source = data['source']
    fname = data['filename']

    status = await query.message.edit_text("⏳ **Обработка...**", reply_markup=None)

    try:
        if query.data == 'obfuscate':
            layers = user_settings.get(user_id, 1)
            obf = MelotenObfuscatorV2(source, layers=layers)
            protected_code = obf.build()
            
            out = BufferedInputFile(protected_code.encode(), filename=f"Protected_{fname}")
            await query.message.answer_document(out, caption=f"✅ **Готово (V2 Eclipse)**\n🛡 Layers: {layers}")
        
        elif query.data == 'beautify':
            beauty = LuaBeautifier(source)
            formatted_code = beauty.format()
            
            out = BufferedInputFile(formatted_code.encode(), filename=f"Clean_{fname}")
            await query.message.answer_document(out, caption="✨ **Код отформатирован!**")

        del user_data[user_id]
        await status.delete()
        await query.answer("✅ Успешно!")

    except Exception as e:
        logging.error(e)
        await query.message.answer(f"❌ Ошибка: {e}")
        await status.delete()
        await query.answer("❌ Ошибка обработки.")

