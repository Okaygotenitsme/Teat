local Workspace = game:GetService("Workspace")

local towersFolder = Workspace:FindFirstChild("Towers") or Instance.new("Folder", Workspace)
towersFolder.Name = "Towers"

local function createTowerUI(obj)
    -- Пытаемся найти деталь, к которой прикрепим полоску (PrimaryPart или сама деталь)
    local adornee = (obj:IsA("Model") and obj.PrimaryPart) or (obj:IsA("BasePart") and obj)
    
    if not adornee then 
        warn("Не удалось найти деталь для UI у башни: " .. obj.Name)
        return 
    end
    
    -- Создаем интерфейс
    local bgui = Instance.new("BillboardGui")
    bgui.Name = "HealthGui"
    bgui.Size = UDim2.new(8, 0, 2, 0) -- Немного увеличим размер
    bgui.AlwaysOnTop = true
    bgui.ExtentsOffset = Vector3.new(0, 8, 0) -- Поднимаем выше над башней
    bgui.Adornee = adornee
    bgui.Parent = adornee
    
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(255, 215, 0) -- Золотой
    label.TextStrokeTransparency = 0
    label.TextScaled = true
    label.Text = tostring(obj:GetAttribute("Health") or "???")
    label.Parent = bgui
    
    -- Обновление текста при изменении здоровья
    obj:GetAttributeChangedSignal("Health"):Connect(function()
        local currentHealth = obj:GetAttribute("Health") or 0
        label.Text = tostring(math.ceil(currentHealth))
    end)
end

local function setupTower(name, health)
    local tower = Workspace:FindFirstChild(name)
    if tower then
        tower.Parent = towersFolder
        
        -- Сначала ставим PrimaryPart, если это модель
        if tower:IsA("Model") and not tower.PrimaryPart then
            tower.PrimaryPart = tower:FindFirstChildWhichIsA("BasePart")
        end
        
        -- Устанавливаем атрибут здоровья ДО создания UI
        tower:SetAttribute("Health", health)
        createTowerUI(tower)
        print("Башня успешно настроена: " .. name)
    else
        warn("Внимание: Башня '" .. name .. "' не найдена в Workspace!")
    end
end

-- Настройка башен
setupTower("MainTower", 2000)
setupTower("TowerLeft", 1000)
setupTower("TowerRight", 1000)
