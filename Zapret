            }
        end
        _debug.getupvalue = function(f, i) return nil, nil end
        _debug.setupvalue = function(f, i, v) end
        _debug.getmetatable = function(o) return nil end -- Скрываем метатаблицы
        _G.debug = _debug

        -- 3. Bit32 Polyfill (Roblox Standard)
        local bit = {}
        function bit.bnot(x) return 4294967295 - x % 4294967296 end
        function bit.band(a, b) 
            local p, c = 1, 0
            while a > 0 and b > 0 do
                local ra, rb = a%2, b%2
                if ra + rb > 1 then c = c + p end
                a, b, p = (a-ra)/2, (b-rb)/2, p*2
            end
            return c
        end
        function bit.bor(a, b) 
            local p, c = 1, 0
            while a > 0 or b > 0 do
                local ra, rb = a%2, b%2
                if ra + rb > 0 then c = c + p end
                a, b, p = (a-ra)/2, (b-rb)/2, p*2
            end
            return c
        end
        function bit.bxor(a, b) 
            local p, c = 1, 0
            while a > 0 or b > 0 do
                local ra, rb = a%2, b%2
                if ra + rb == 1 then c = c + p end
                a, b, p = (a-ra)/2, (b-rb)/2, p*2
            end
            return c
        end
        function bit.lshift(a, b) return (a * 2^b) % 4294967296 end
        function bit.rshift(a, b) return math.floor(a / 2^b) % 4294967296 end
        _G.bit = bit
        _G.bit32 = bit

        -- 4. Roblox Environment Mock
        _G.game = {
