import lupa
from lupa import LuaRuntime
import logging
import subprocess
import os
import tempfile
import re
import binascii

logger = logging.getLogger("DeobfuscatorEngine")

class DeobfuscatorEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        
    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        # Проверка Java для unluac
        has_java = self._check_java()
        if not has_java:
            update_status("⚠️ Java не найдена. Декомпиляция байткода будет пропущена.")

        update_status("🧠 Запуск LuaJIT (IronBrew/MoonSec Mode)...")

        try:
            # Создаем Lua Runtime (используем Lua 5.1 совместимый режим)
            lua = LuaRuntime(unpack_returned_tuples=True)
        except Exception as e:
            return f"-- [FATAL] Ошибка запуска Lua: {e}".encode('utf-8')

        # ==========================================
        # 1. ПОЛИФИЛЛЫ BIT32 (Обязательно для IB2)
        # ==========================================
        bit_polyfill = """
        local bit = {}
        function bit.bnot(a) return 4294967295 - a % 4294967296 end
        function bit.band(a, b) local r = 0; local m = 0; for i = 0, 31 do m = 2^i; if (a % (m*2) >= m) and (b % (m*2) >= m) then r = r + m end end return r end
        function bit.bor(a, b) local r = 0; local m = 0; for i = 0, 31 do m = 2^i; if (a % (m*2) >= m) or (b % (m*2) >= m) then r = r + m end end return r end
        function bit.bxor(a, b) local r = 0; local m = 0; for i = 0, 31 do m = 2^i; if (a % (m*2) >= m) ~= (b % (m*2) >= m) then r = r + m end end return r end
        function bit.lshift(a, b) return (a * 2^b) % 4294967296 end
        function bit.rshift(a, b) return math.floor(a / 2^b) % 4294967296 end
        
        _G.bit = bit
        _G.bit32 = bit -- IronBrew часто использует bit32
        """

        # ==========================================
        # 2. МОЩНАЯ СИСТЕМА ПЕРЕХВАТА (HOOKS)
        # ==========================================
        spyware = """
        _G.DEOBF_RESULT = {
            strings = {},
            logs = {},
            captured_scripts = {}
        }
        
        local function safe_log(msg)
            table.insert(_G.DEOBF_RESULT.logs, tostring(msg))
        end

        -- :: ANTI-DETECTION (Spoofing debug) ::
        -- IronBrew проверяет debug.getinfo, чтобы узнать, хукнута ли функция.
        -- Мы сохраняем оригиналы, чтобы использовать их для подделки.
        local real_debug = debug.getinfo
        local real_string_char = string.char
        local real_loadstring = loadstring
        
        -- Функция-пустышка для 'безопасных' вызовов
        local function blank_func() end

        -- Перехват string.char (дешифровка строк)
        -- ВАЖНО: Мы не меняем логику, просто подглядываем.
        -- IB2 часто генерирует строки посимвольно.
        string.char = function(...)
            local args = {...}
            local res = real_string_char(unpack(args))
            -- Логируем только длинные строки, чтобы не спамить
            if #res > 3 then 
                -- Удаляем мусорные символы
                local clean = res:gsub("[%c]", "")
                if #clean > 3 then
                    _G.DEOBF_RESULT.strings[res] = true 
                end
            end
            return res
        end

        -- Перехват table.concat (Сборка массивов в строки)
        local real_concat = table.concat
        table.concat = function(t, sep, i, j)
            local res = real_concat(t, sep, i, j)
            if type(res) == "string" and #res > 4 then
                _G.DEOBF_RESULT.strings[res] = true
            end
            return res
        end

        -- Перехват loadstring (Загрузка VM)
        -- Это позволяет поймать 'распакованный' скрипт.
        getfenv().loadstring = function(chunk, name)
            safe_log("🔥 LOADSTRING CAUGHT! Size: " .. #chunk)
            table.insert(_G.DEOBF_RESULT.captured_scripts, chunk)
            return real_loadstring(chunk, name)
        end
        
        -- Алиас для load
        getfenv().load = getfenv().loadstring

        -- :: ROBLOX MOCKS ::
        _G.game = {
            GetService = function(s, n)
                return {
                    HttpGet = function(self, url) 
                        safe_log("🌍 HttpGet: " .. tostring(url))
                        return "<html>Mock</html>" 
                    end,
                    HttpPost = function(self, url, d)
                        safe_log("🌍 HttpPost: " .. tostring(url))
                        return "{}" 
                    end
                }
            end,
            PlaceId = 123456
        }
        _G.script = { Parent = _G.game }
        _G.workspace = {}
        
        -- Важные функции среды
        _G.getgenv = function() return _G end
        _G.getrenv = function() return _G end
        _G.syn = { request = function() end } -- Synapse mock
        _G.http_request = function() end
        _G.is_synapse_function = function() return true end

        -- :: CONSTANT HARVESTER (Сборщик констант) ::
        -- Эта функция пытается найти большие таблицы строк в памяти
        function _G.harvest_constants()
            local found_count = 0
            
            -- Рекурсивный поиск в таблицах (ограниченная глубина)
            local function scan_table(t, depth)
                if depth > 2 then return end
                for k, v in pairs(t) do
                    if type(v) == "string" and #v > 4 then
                        _G.DEOBF_RESULT.strings[v] = true
                        found_count = found_count + 1
                    elseif type(v) == "table" then
                        scan_table(v, depth + 1)
                    end
                end
            end
            
            -- Сканируем реестр (сложно в чистом Lua, сканируем _G и package)
            scan_table(_G, 0)
            scan_table(package.loaded, 0)
            
            return found_count
        end
        """

        setup_code = bit_polyfill + "\n" + spyware

        try:
            update_status("🌪️ Запуск эмуляции скрипта...")
            
            # 1. Загружаем окружение
            lua.execute(setup_code)
            
            # 2. Оборачиваем скрипт пользователя, чтобы он не положил весь процесс
            wrapper = """
            local user_script = function() 
                %s 
            end
            
            local status, err = pcall(user_script)
            if not status then
                table.insert(_G.DEOBF_RESULT.logs, "❌ Script Crash: " .. tostring(err))
            else
                table.insert(_G.DEOBF_RESULT.logs, "✅ Script Finished Executing")
            end
            
            -- Пытаемся собрать константы после выполнения
            pcall(_G.harvest_constants)
            
            return _G.DEOBF_RESULT
            """
            
            # В LuaJIT/Lupa иногда нужно передавать код аккуратно
            # Мы используем python-level конкатенацию для вставки скрипта,
            # но делаем это через присвоение переменной внутри Lua для безопасности
            
            lua.globals().USER_CODE_STRING = content
            
            # Выполняем скрипт, загружая его из переменной
            res_table = lua.eval("""
            (function()
                local status, err = pcall(function()
                    local func = loadstring(USER_CODE_STRING)
                    if not func then error("Syntax Error in script") end
                    func()
                end)
                
                if not status then
                    table.insert(_G.DEOBF_RESULT.logs, "❌ Runtime Error: " .. tostring(err))
                end
                
                pcall(_G.harvest_constants)
                return _G.DEOBF_RESULT
            end)()
            """)

            # --- ИЗВЛЕЧЕНИЕ ДАННЫХ ---
            # Конвертируем Lua Table в Python Dict
            detected_strings = []
            if res_table['strings']:
                for k, v in res_table['strings'].items():
                    if isinstance(k, (bytes, str)):
                        detected_strings.append(k)
            
            logs = []
            if res_table['logs']:
                for l in res_table['logs'].values():
                    logs.append(l)

            # Проверяем, поймали ли мы "внутренний скрипт" через loadstring
            captured_scripts = []
            if res_table['captured_scripts']:
                for k, v in res_table['captured_scripts'].items():
                    captured_scripts.append(v)

            # Выбираем лучший код для сохранения
            # Если есть перехваченный loadstring - это скорее всего и есть деобфусцированный скрипт
            target_code = content
            is_captured = False
            
            if len(captured_scripts) > 0:
                # Берем самый большой кусок кода
                target_code = max(captured_scripts, key=len)
                is_captured = True
                update_status(f"🔓 Перехвачен скрытый скрипт ({len(target_code)} байт)!")

            return self._finalize_output(target_code, detected_strings, logs, update_status, is_captured)

        except Exception as e:
            logger.error(f"Engine Exception: {e}")
            return f"-- [CRASH]: {e}".encode('utf-8')

    def _finalize_output(self, code_bytes, strings, logs, callback, is_decompiled_chunk):
        if callback: callback("🧬 Формирование отчета...")
        
        # Попытка декомпиляции через Unluac (если это байткод Lua 5.1)
        # LuaJIT байткод Unluac НЕ возьмет, но стандартный Lua 5.1 возьмет.
        decompiled_src = None
        if self._check_java():
            decompiled_src = self._try_decompile(code_bytes)

        final_text = ""
        
        # 1. LOGS
        final_text += "-- [[ EXECUTION LOGS ]] --\n"
        for l in logs:
            final_text += f"-- {self._clean(l)}\n"
            
        # 2. STRINGS (Самое важное для IB)
        final_text += "\n" + "="*40 + "\n-- [[ DECRYPTED STRINGS ]] --\n"
        final_text += "-- Look here for Webhooks, APIs, and Keys\n\n"
        
        # Фильтруем и сортируем строки
        seen = set()
        sorted_strings = sorted(strings, key=lambda x: len(str(x)), reverse=True)
        
        for s in sorted_strings:
            s_clean = self._clean(s).strip()
            if s_clean not in seen and len(s_clean) > 4:
                # Убираем явный мусор
                if not all(c in ' \t\n\r' for c in s_clean):
                    final_text += f'-- "{s_clean}"\n'
                    seen.add(s_clean)

        final_text += "\n" + "="*40 + "\n\n"
        
        # 3. CODE
        if decompiled_src:
            final_text += "-- [[ DECOMPILED SOURCE (Unluac) ]] --\n\n"
            final_text += self._beautify_lua(decompiled_src.decode('utf-8', 'ignore'))
        else:
            final_text += "-- [[ SOURCE / BYTECODE ]] --\n"
            if is_decompiled_chunk:
                final_text += "-- Warning: This is likely raw bytecode or a packed script.\n"
            
            try:
                final_text += code_bytes.decode('utf-8')
            except:
                final_text += f"-- Binary data (Displaying hex of first 512 bytes):\n"
                final_text += str(binascii.hexlify(code_bytes[:512]))

        return final_text.encode('utf-8')

    def _try_decompile(self, bytecode):
        # Если байткод начинается не с ESC Lua (0x1B4C7561), unluac не поможет
        if isinstance(bytecode, bytes) and not bytecode.startswith(b'\x1bLua'):
            # Если это просто текст, возвращаем его как есть (для форматирования)
            if all(32 <= b < 127 or b in [9, 10, 13] for b in bytecode[:100]):
                return None # Это исходник, не байткод
            return None

        if not os.path.exists(self.unluac_path): return None
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            res = subprocess.run(
                ["java", "-jar", self.unluac_path, path], 
                capture_output=True, timeout=15
            )
            os.remove(path)
            if res.returncode == 0 and len(res.stdout) > 0: 
                return res.stdout
            return None
        except: return None

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _clean(self, s):
        if isinstance(s, bytes):
            try: return s.decode('utf-8', 'ignore')
            except: return str(s)
        return str(s).replace('\n', ' ').replace('\r', '')

    def _beautify_lua(self, source_code):
        # Простой beautifier
        source_code = re.sub(r'(\s)(local|return|if|for|while|repeat|function)(\s)', r'\n\2 ', source_code)
        replacements = {
            " then ": " then\n", " do ": " do\n", " end ": "\nend\n",
            " repeat ": "\nrepeat\n", " until ": "\nuntil ", ";": ";\n"
        }
        for k, v in replacements.items():
            source_code = source_code.replace(k, v)
        return source_code
