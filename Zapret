# --- Обработчик команды /ASCII ---
@dp.message(Command("ASCII"))
async def ascii_handler(message: types.Message):
    # Проверка: команда должна быть ответом (reply)
    if not message.reply_to_message:
        await message.answer("⚠️ Используй эту команду **в ответ** на GIF или видео!")
        return
    
    # Ищем анимацию или видео в сообщении
    media = message.reply_to_message.animation or message.reply_to_message.video
    
    if not media:
        await message.answer("❌ В сообщении нет видео или GIF.")
        return

    # Ответ пользователю
    status_msg = await message.answer("📥 Скачиваю файл...")
    
    # Скачивание
    file = await bot.get_file(media.file_id)
    file_path = file.file_path
    
    # Сохраняем с правильным расширением (GIF надежнее для Pillow)
    ext = file_path.split('.')[-1]
    temp_name = f"temp_{media.file_id}.{ext}"
    
    await bot.download_file(file_path, temp_name)
    
    await status_msg.edit_text("🎨 Рисую символами...")
    
    # Запуск магии
    await animate_media(temp_name, status_msg)


# --- Обработчик файлов для обфускации ---
@dp.message(F.document)
async def obfuscate_file(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        return # Игнорируем не скрипты

    msg = await message.answer("🛡 Защищаю код...")
    
    try:
        file_info = await bot.get_file(message.document.file_id)
        downloaded_file = await bot.download_file(file_info.file_path)
        
        # Читаем исходник
        source_code = downloaded_file.read().decode('utf-8', errors='ignore')

        # Обфусцируем
        obfuscator = MelotenObfuscator(source_code)
        protected_code = obfuscator.build()

        # Отправляем обратно
        result_file = BufferedInputFile(
            protected_code.encode('utf-8'), 
            filename=f"Protected_{message.document.file_name}"
        )
        
        await message.answer_document(result_file, caption="✅ Готово! Код защищен.")
        await msg.delete()
        
    except Exception as e:
        await message.answer(f"❌ Ошибка: {e}")


