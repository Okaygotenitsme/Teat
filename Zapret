# Обработчик команды /loadstring
@dp.message(Command("loadstring"))
async def make_loadstring(message: types.Message, command: CommandObject):
    if not command.args:
        await message.answer("⚠️ Ошибка! Введи ссылку после команды.\nПример: `/loadstring https://raw.github.com/...`", parse_mode="Markdown")
        return

    url = command.args
    content = f'loadstring(game:HttpGet("{url}"))()'
    
    file_output = BufferedInputFile(
        content.encode('utf-8'), 
        filename="loader.lua"
    )
    
    await message.answer_document(
        file_output, 
        caption=f"✅ **Loadstring готов!**\n\n📢 @MelotenBot", 
        parse_mode="Markdown"
    )

