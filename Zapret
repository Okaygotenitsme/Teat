@dp.message(F.document)
async def handle_file_upload(message: types.Message):
    if not message.document.file_name.endswith(('.lua', '.txt')):
        return
    file_info = await bot.get_file(message.document.file_id)
    downloaded = await bot.download_file(file_info.file_path)
    try:
        src = downloaded.read().decode('utf-8', errors='ignore')
    except:
        src = downloaded.read().decode(errors='ignore')

    token = str(uuid.uuid4())
    _pending_files[token] = {
        "source": src,
        "filename": message.document.file_name,
        "user_id": message.from_user.id,
        "uploaded_at": time.time()
    }
    kb = make_file_keyboard(token)
    await message.answer("Файл получен. Выберите действие:", reply_markup=kb)


