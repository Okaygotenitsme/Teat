    def _is_luac_bytecode(self, data):
        """Проверяет, является ли файл скомпилированным байткодом Lua"""
        if len(data) < 4:
            return False
        # Lua 5.1/5.2/5.3 signature
        return data[:4] in [b'\x1bLua', b'\x1bLuQ', b'\x1bLuR']

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], 
                         stdout=subprocess.DEVNULL, 
                         stderr=subprocess.DEVNULL,
                         timeout=5)
            return True
        except:
            return False

    def _clean_string(self, s):
        if isinstance(s, bytes):
            try:
                return s.decode('utf-8')
            except:
                return s.decode('latin-1', errors='ignore')
        return str(s)

    def _finalize_output(self, code, strings, globals_dump, logs, network_calls, callback):
        if callback:
            callback("🧬 Финальная декомпиляция...")
        
        # Пробуем декомпилировать
        decompiled = None
        if isinstance(code, str):
            code_bytes = code.encode('utf-8')
        else:
            code_bytes = code
        
        decompiled = self._try_decompile(code_bytes)
        
        return self._wrap_output(
            decompiled or code_bytes,
            strings,
            globals_dump,
            logs,
            network_calls
        )

    def _wrap_output(self, code, strings, globals_dump, logs, network_calls=None):
        """Формирует финальный вывод"""
        final_text = "-- ╔═══════════════════════════════════════╗\n"
        final_text += "-- ║   ROBLOX DEOBFUSCATOR V4 REPORT     ║\n"
        final_text += "-- ╚═══════════════════════════════════════╝\n\n"
        
        # NETWORK CALLS
        if network_calls and len(network_calls) > 0:
            final_text += "-- [[ 📡 NETWORK CALLS (RemoteSpy) ]]\n"
            for call in network_calls[:50]:
                final_text += f"-- {self._clean_string(call)}\n"
            final_text += "\n"

        # STRINGS
        if strings:
            final_text += "-- [[ 🔎 EXTRACTED STRINGS ]]\n"
            # Дедупликация и сортировка
            unique_strings = list(set(strings))
            unique_strings.sort(key=lambda x: len(str(x)), reverse=True)
            
            for s in unique_strings[:100]:  # топ 100
                clean = self._clean_string(s).replace('\n', '\\n').replace('\r', '')
                if len(clean) > 3 and len(clean) < 500:
                    final_text += f'-- "{clean}"\n'
            final_text += "\n"

        # GLOBALS
        if globals_dump:
            final_text += "-- [[ 🌐 GLOBAL VARIABLES ]]\n"
            for g in globals_dump[:50]:
                final_text += f"-- {self._clean_string(g)}\n"
            final_text += "\n"

        # LOGS
        if logs:
            final_text += "-- [[ 📋 EXECUTION LOG ]]\n"
            for log in logs[-30:]:
                final_text += f"-- {self._clean_string(log)}\n"
            final_text += "\n"

        final_text += "-- " + "="*50 + "\n"
        final_text += "-- [[ 📜 DECOMPILED SOURCE CODE ]]\n"
        final_text += "-- " + "="*50 + "\n\n"
        
        # КОД
        if isinstance(code, bytes):
            try:
                source = code.decode('utf-8', errors='ignore')
            except:
                source = code.decode('latin-1', errors='ignore')
        else:
            source = str(code)
        
        final_text += self._beautify_lua(source)
        
        return final_text.encode('utf-8')

    def _try_decompile(self, bytecode):
        """Декомпиляция через unluac.jar"""
        if not os.path.exists(self.unluac_path):
            logger.warning("unluac.jar not found")
            return None
        
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".luac", mode='wb') as tmp:
                tmp.write(bytecode)
                tmp_path = tmp.name
            
            result = subprocess.run(
                ["java", "-Xmx1G", "-jar", self.unluac_path, tmp_path],
                capture_output=True,
                timeout=15
            )
            
            os.remove(tmp_path)
            
            if result.returncode == 0 and len(result.stdout) > 0:
                return result.stdout
            
            return None
        except Exception as e:
            logger.error(f"Decompile failed: {e}")
            return None

    def _beautify_lua(self, code):
        """Базовое форматирование Lua"""
        # Убираем лишние пробелы
        code = re.sub(r'\s+', ' ', code)
        
        # Переносы строк после ключевых слов
        keywords = ['local ', 'function ', 'return ', 'if ', 'then ', 
                   'else ', 'elseif ', 'end ', 'for ', 'while ', 'repeat ', 'until ']
        
        for kw in keywords:
            code = code.replace(' ' + kw, '\n' + kw)
        
        code = code.replace(' do ', ' do\n')
        code = code.replace(';', ';\n')
        code = code.replace('{', '{\n')
        code = code.replace('}', '\n}')
        
        # Убираем пустые строки
        lines = [l for l in code.split('\n') if l.strip()]
        return '\n'.join(lines)
