# bot.py
import asyncio
import os
import logging
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command

# Импортируем наш "Мозг" из соседнего файла
from engine import DeobfuscatorEngine

# 1. НАСТРОЙКИ
API_TOKEN = 'ТВОЙ_ТОКЕН_ОТ_BOTFATHER'

# Включаем логирование, чтобы видеть ошибки в консоли
logging.basicConfig(level=logging.INFO)

# Инициализация бота
bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

# 2. ОБРАБОТЧИКИ (HANDLERS)

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "Привет! Я — Lua Deobfuscator Bot. 🤖\n\n"
        "Отправь мне файл `.txt` или `.lua` с обфусцированным кодом (Luraph/MoonSec),\n"
        "и я попробую его расшифровать."
    )

@dp.message(F.document)
async def handle_document(message: types.Message):
    file_id = message.document.file_id
    file_name = message.document.file_name
    
    # Проверка расширения (по желанию)
    if not (file_name.endswith('.txt') or file_name.endswith('.lua')):
        await message.answer("⚠️ Пожалуйста, отправь файл с расширением .txt или .lua")
        return

    await message.answer("📥 Файл получен. Начинаю анализ...")

    # Скачиваем файл
    file = await bot.get_file(file_id)
    file_path = file.file_path
    
    local_filename = f"temp_{file_name}"
    await bot.download_file(file_path, local_filename)

    try:
        # --- ЗАПУСК ДЕОБФУСКАЦИИ ---
        # Читаем скачанный файл
        with open(local_filename, "r", encoding="utf-8", errors="ignore") as f:
            content = f.read()
        
        # Обрабатываем через наш движок
        deobfuscated_code = engine.process_text(content)
        
        # Сохраняем результат в новый файл
        result_filename = f"deobf_{file_name}"
        with open(result_filename, "w", encoding="utf-8") as f:
            f.write(deobfuscated_code)
            
        # Отправляем результат пользователю
        output_file = FSInputFile(result_filename)
        await message.answer_document(output_file, caption="✅ Готово! Вот твой код.")
        
        # Уборка мусора (удаляем временные файлы)
        os.remove(result_filename)

    except Exception as e:
        await message.answer(f"❌ Произошла ошибка при обработке: {e}")
    
    finally:
        # Всегда удаляем исходный скачанный файл
        if os.path.exists(local_filename):
            os.remove(local_filename)

# 3. ЗАПУСК
async def main():
    print("Бот запущен...")
    await dp.start_polling(bot)

if __name__ == "__main__":
    asyncio.run(main())
