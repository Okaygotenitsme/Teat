import telebot
import os
from obfuscator import obfuscate_script # Импортируем нашу логику из части 1

# Вставь сюда свой токен от BotFather
API_TOKEN = 'ВАШ_ТОКЕН_ЗДЕСЬ'

bot = telebot.TeleBot(API_TOKEN)

@bot.message_handler(commands=['start', 'help'])
def send_welcome(message):
    bot.reply_to(message, "Привет! Отправь мне .lua или .txt файл с Lua кодом, и я зашифрую его (Hex Obfuscation).")

@bot.message_handler(content_types=['document'])
def handle_docs(message):
    try:
        # 1. Получаем информацию о файле
        file_info = bot.get_file(message.document.file_id)
        file_name = message.document.file_name
        
        # Проверка расширения (необязательно, но полезно)
        if not (file_name.endswith('.lua') or file_name.endswith('.txt')):
            bot.reply_to(message, "Пожалуйста, отправь файл с расширением .lua или .txt")
            return

        bot.reply_to(message, "Файл получен. Начинаю обфускацию...")

        # 2. Скачиваем файл
        downloaded_file = bot.download_file(file_info.file_path)

        # 3. Обфусицируем (вызываем функцию из модуля obfuscator.py)
        # downloaded_file уже в байтах, передаем как есть
        protected_code = obfuscate_script(downloaded_file)

        # 4. Создаем имя для нового файла
        new_file_name = "Protected_" + file_name
        
        # 5. Отправляем результат обратно пользователю
        # Отправляем как документ (файл)
        bot.send_document(
            message.chat.id, 
            document=(new_file_name, protected_code), # Передаем имя и содержимое
            caption="Вот твой защищенный скрипт!"
        )

    except Exception as e:
        bot.reply_to(message, f"Произошла ошибка: {e}")
        print(f"Error: {e}")

# Запуск бота (Polling)
if __name__ == '__main__':
    print("Бот запущен...")
    bot.infinity_polling()
