@dp.message(F.text & ~F.text.startswith('/'))
async def handle_text(message: types.Message):
    """Обработка прямого кода"""
    if len(message.text) < 100:
        await message.answer(
            "💡 Отправьте файл `.lua` или `.txt` для анализа.\n"
            "Используйте /start для помощи."
        )
        return
    
    # Создаем временный файл
    unique_id = uuid.uuid4().hex[:8]
    temp_file = f"temp_text_{unique_id}.lua"
    
    with open(temp_file, "w", encoding="utf-8") as f:
        f.write(message.text)
    
    # Отправляем как документ для обработки
    doc = FSInputFile(temp_file, filename="code.lua")
    await message.answer_document(doc)
    
    os.remove(temp_file)

