import cv2
import mediapipe as mp
import numpy as np
import time

# Настройки
CAM_ID = 0                # индекс камеры
DRAW_COLOR = (255, 255, 255)  # белая линия (BGR)
THICKNESS = 6
SMOOTHING = 0.2           # для сглаживания движения (0..1, меньше = сильнее сглаживание)
CLEAR_HOLD_TIME = 0.6     # сек, сколько держать жест "открытая ладонь", чтобы очистить

mp_hands = mp.solutions.hands
mp_draw = mp.solutions.drawing_utils

def fingers_up(hand_landmarks, hand_label):
    """
    Возвращает список булевских значений для [thumb, index, middle, ring, pinky]
    hand_label: "Left" или "Right" (от MediaPipe)
    """
    lm = hand_landmarks.landmark
    fingers = []

    # Thumb: сравниваем x координаты (для правой/левой руки нужно по-разному)
    # tip = 4, ip = 3, mcp = 2
    if hand_label == "Right":
        fingers.append(lm[4].x < lm[3].x)  # для правой руки палец "вправо" -> x меньше
    else:
        fingers.append(lm[4].x > lm[3].x)

    # Для остальных пальцев сравниваем y: tip выше pip значит палец поднят
    tips_ids = [8, 12, 16, 20]
    pip_ids  = [6, 10, 14, 18]
    for t, p in zip(tips_ids, pip_ids):
        fingers.append(lm[t].y < lm[p].y)

    return fingers  # [thumb, index, middle, ring, pinky]

def norm_to_pixel(norm_x, norm_y, frame_w, frame_h):
    x = int(norm_x * frame_w)
    y = int(norm_y * frame_h)
    return x, y

def main():
    cap = cv2.VideoCapture(CAM_ID)
    if not cap.isOpened():
        print("Не удалось открыть камеру.")
        return

    with mp_hands.Hands(
        model_complexity=1,
        max_num_hands=1,
        min_detection_confidence=0.6,
        min_tracking_confidence=0.6
    ) as hands:

        # Получим размеры кадра (будут известны после первого кадра)
        ret, frame = cap.read()
        if not ret:
            print("Нет кадра с камеры.")
            return
        frame_h, frame_w = frame.shape[:2]
        canvas = np.zeros_like(frame)  # холст для рисования

        prev_x, prev_y = None, None
        smoothed_x, smoothed_y = None, None

        clear_start_time = None

        while True:
            ret, frame = cap.read()
            if not ret:
                break

            # Отзеркалим изображение, чтобы поведение было "зеркальным"
            frame = cv2.flip(frame, 1)
            rgb = cv2.cvtColor(frame, cv2.COLOR_BGR2RGB)
            results = hands.process(rgb)

            draw_now = False
            clear_now = False

            if results.multi_hand_landmarks and results.multi_handedness:
                hand_landmarks = results.multi_hand_landmarks[0]
                hand_label = results.multi_handedness[0].classification[0].label  # "Left" / "Right"

                # Где кончик указательного пальца?
                index_tip = hand_landmarks.landmark[8]  # normalized coords

                ix, iy = norm_to_pixel(index_tip.x, index_tip.y, frame_w, frame_h)

                # Сглаживание позиции
                if smoothed_x is None:
                    smoothed_x, smoothed_y = ix, iy
                else:
                    smoothed_x = int(smoothed_x * (1 - SMOOTHING) + ix * SMOOTHING)
                    smoothed_y = int(smoothed_y * (1 - SMOOTHING) + iy * SMOOTHING)

                # Решаем рисовать или нет: есть ли поднятый указательный палец и НЕ подняты другие?
                fingers = fingers_up(hand_landmarks, hand_label)
                # fingers = [thumb, index, middle, ring, pinky]
                index_is_up = fingers[1]
                others = fingers[0] or fingers[2] or fingers[3] or fingers[4]

                # Вариант: рисовать, когда индекс поднят (независимо от других):
                # draw_now = index_is_up
                # Но чтобы не рисовать при "открытой ладони" (очистка), проверим жест ✋:
                all_up = all(fingers)

                if all_up:
                    # Начинаем/продолжаем отсчет для очистки
                    if clear_start_time is None:
                        clear_start_time = time.time()
                    else:
                        if time.time() - clear_start_time >= CLEAR_HOLD_TIME:
                            clear_now = True
                else:
                    clear_start_time = None
                    # Рисуем если индекс поднят (и не открытая ладонь)
                    if index_is_up:
                        draw_now = True
                    else:
                        prev_x, prev_y = None, None  # сброс точки при поднятии пальца нет

                # Рисуем контур/точку указателя на экране (для удобства пользователю)
                cv2.circle(frame, (smoothed_x, smoothed_y), 8, (0, 255, 255), -1)

                # (опционально) отрисуем landmarks для отладки
                # mp_draw.draw_landmarks(frame, hand_landmarks, mp_hands.HAND_CONNECTIONS)

            else:
                clear_start_time = None
                prev_x, prev_y = None, None

            # Выполняем рисование на холсте
            if draw_now:
                if prev_x is None:
                    prev_x, prev_y = smoothed_x, smoothed_y
                # рисуем линию между предыдущей и текущей позициями
                cv2.line(canvas, (prev_x, prev_y), (smoothed_x, smoothed_y), DRAW_COLOR, THICKNESS, cv2.LINE_AA)
                prev_x, prev_y = smoothed_x, smoothed_y

            if clear_now:
                canvas[:] = 0  # очистка холста
                clear_start_time = None
                prev_x, prev_y = None, None
                # краткий визуальный индикатор очистки
                cv2.putText(frame, "CLEARED", (10, 40), cv2.FONT_HERSHEY_SIMPLEX, 1.0, (0, 0, 255), 2)

            # Наложим холст поверх кадра
            img = cv2.add(frame, canvas)

            # UI подсказки
            cv2.putText(img, "Index finger to draw. Open palm (hold) to clear. Esc to exit.", (10, frame_h - 10),
                        cv2.FONT_HERSHEY_SIMPLEX, 0.5, (200, 200, 200), 1)

            cv2.imshow("Draw by Finger", img)

            key = cv2.waitKey(1) & 0xFF
            if key == 27:  # ESC
                break

    cap.release()
    cv2.destroyAllWindows()

if __name__ == "__main__":
    main()
