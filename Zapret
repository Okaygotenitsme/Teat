class MelotenUltraVM:
    def __init__(self, source: str):
        self.source = source
        self.key_seed = random.randint(1000000, 9999999)
    
    def _d32(self, val):
        return val & 0xFFFFFFFF

    def _build_bytecode_string(self, payload_bytes, start_key):
        """
        Генерирует байткод и упаковывает его в строку (String Packing).
        Это решает проблему больших файлов.
        """
        ops = bytearray()
        current_key = start_key
        
        # Разбиваем на большие куски, чтобы не перегружать Lua
        chunks = list(_chunker(payload_bytes))
        
        outlen = 0
        
        for chunk in chunks:
            # 1. Иногда вставляем "смену ключа" (Opcode 2)
            if random.random() < 0.3:
                delta = random.randint(1, 255)
                ops.append(2) # Opcode
                ops.append(delta)
                current_key = self._d32(current_key ^ delta)

            # 2. Вставляем мусорные операции для сбивания декомпиляторов (Opcode 4)
            if random.random() < 0.2:
                loops = random.randint(1, 5)
                ops.append(4)
                ops.append(loops)
                # Симуляция изменения ключа
                for i in range(1, loops + 1):
                    current_key = self._d32(current_key ^ self._d32(i * 1664525))

            # 3. Данные (Opcode 1)
            # Заголовок: OP(1) + LEN(1 byte if <255, else logic handles blocks)
            # Для упрощения чанки < 250 байт
            chunk_len = len(chunk)
            ops.append(1)
            ops.append(chunk_len)
            
            for b in chunk:
                # Шифрование на лету
                shift = (outlen % 4) * 8
                kbyte = (current_key >> shift) & 0xFF
                enc_byte = b ^ kbyte
                ops.append(enc_byte)
                
                outlen += 1
                # Легкая мутация ключа каждые 37 байт
                if outlen % 37 == 0:
                    current_key = self._d32(current_key ^ outlen)

        ops.append(5) # EOF
        return ops

    def _lua_string_literal(self, byte_arr):
        """
        Превращает bytearray в строку Lua: "\10\255\0..."
        Это занимает меньше памяти при парсинге, чем таблица.
        """
        # Используем chunks для склейки, чтобы не забить память Python
        res = []
        for b in byte_arr:
            res.append(f"\\{b}")
        return "".join(res)

    def _generate_junk_func(self):
        """Создает безобидную, но запутанную функцию с рандомным именем."""
