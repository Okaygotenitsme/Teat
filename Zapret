        if len(local_dump) > 30:
            report.append(f"-- ... and {len(local_dump) - 30} more locals")
        
        report.append("")
    
    # === СЕКЦИЯ 6: ACTION LOG ===
    if action_log:
        report.append("-- [[ SECTION 6: EXECUTION LOG ]] --")
        report.append("-- Last 50 actions during script execution")
        report.append("--")
        
        for log in action_log[-50:]:
            report.append(f"-- {self._safe_string(log)}")
        
        report.append("")
    
    # === СЕКЦИЯ 7: DECOMPILED SOURCE ===
    report.append("-- " + "=" * 70)
    report.append("-- [[ SECTION 7: DECOMPILED SOURCE CODE ]] --")
    report.append("-- " + "=" * 70)
    report.append("")
    
    if decompiled:
        try:
            source = decompiled.decode('utf-8', errors='ignore')
            beautified = self._beautify_lua(source)
