class UltraEngine:
    @staticmethod
    def random_string(length):
        """Создает максимально нечитаемые имена"""
        return "___" + "".join(random.choice("lI1") for _ in range(length))

    @staticmethod
    def heavy_encrypt(text, key):
        """Сложный XOR с ротацией ключа"""
        res = []
        for i, char in enumerate(text):
            k = ord(key[i % len(key)])
            res.append(str(ord(char) ^ k))
        return "\\".join(res)

