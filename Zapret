        return f"_{suffix}"

    def _generate_names(self):
        self.key1 = random.randint(100, 300)
        self.key2 = random.randint(50, 200)
        self.vars = {k: self._n() for k in [
            'vm', 'state', 'bytes', 'idx', 'xor', 'junk', 
            'magic1', 'magic2', 'dec', 'len', 'byte_val', 'table', 
            'str_lib', 'bit_lib', 'cache', 'fake', 'env_check',
            'bogus', 'integrity', 'hash', 'decrypt', 'mutate'
        ]}

    def _junk_code(self):
