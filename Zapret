end
"""
        return code.strip()

    def build(self) -> str:
        # 1. Подготовка исходника
        src_bytes = self.source.encode('utf-8')
        
        # 2. Основной ключ
        master_key = random.getrandbits(32)
        
        # 3. Генерация защищенного потока (Bytecode)
        # Мы НЕ используем маппинг массивов для больших данных, так как это медленно.
        # Мы используем полиморфный XOR поток.
        vm_bytecode = self._build_bytecode_string(src_bytes, master_key)
        
        # 4. Lua-генерация
        payload_str = self._lua_string_literal(vm_bytecode)
        
        # 5. Имена переменных VM (чтобы не палиться)
        v_data = _rand_var_name()
        v_key = _rand_var_name()
        v_pc = _rand_var_name()
        v_out = _rand_var_name()
        v_run = _rand_var_name()
        
        junk1 = self._generate_junk_func()
        junk2 = self._generate_junk_func()
        
        # 6. Anti-Tamper Checksum (на длину байткода)
        check_val = len(vm_bytecode)

        lua_template = f'''
--[[ Meloten ULTRA Protection // No-Junk Mode ]]
{junk1}

local {v_data} = "{payload_str}"
local {v_key} = {master_key}

-- Bitwise operations compatibility
local bxor = bit32 and bit32.bxor or function(a,b)
    local p,c=1,0
    while a>0 and b>0 do
        local ra,rb=a%2,b%2
        if ra~=rb then c=c+p end
        a,b,p=(a-ra)/2,(b-rb)/2,p*2
    end
    if a<b then a=b end
    while a>0 do
        local ra=a%2
        if ra>0 then c=c+p end
        a,p=(a-ra)/2,p*2
    end
    return c
end

{junk2}

local function {v_run}()
    local ptr = 1
    local k = {v_key}
    local out = {{}}
    local out_idx = 0
    local datalen = #{v_data}
    
    -- Anti-Tamper: Length check
    if datalen ~= {check_val} then return end

    while ptr <= datalen do
        local op = string.byte({v_data}, ptr); ptr = ptr + 1
        
        if op == 1 then -- DATA BLOCK
            local len = string.byte({v_data}, ptr); ptr = ptr + 1
            for i=1, len do
                local enc = string.byte({v_data}, ptr); ptr = ptr + 1
                
                -- Decrypt
                local shift = (out_idx % 4) * 8
                local kbyte = math.floor(k / (2 ^ shift)) % 256
                local dec = bxor(enc, kbyte)
                
                table.insert(out, string.char(dec))
                out_idx = out_idx + 1
                
                if (out_idx % 37) == 0 then
                    k = bxor(k, out_idx) % 4294967296
                end
            end
            
        elseif op == 2 then -- KEY MUTATION
            local delta = string.byte({v_data}, ptr); ptr = ptr + 1
            k = bxor(k, delta) % 4294967296
            
        elseif op == 4 then -- JUNK LOOP
            local loops = string.byte({v_data}, ptr); ptr = ptr + 1
            for i=1, loops do
                k = bxor(k, (i * 1664525) % 4294967296)
