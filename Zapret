    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _clean_string(self, s):
        if isinstance(s, bytes):
            try: return s.decode('utf-8')
            except: return str(s)
        return str(s)

    def _finalize_output(self, code_bytes, strings, globals_dump, logs, callback):
        # Декодирование байткода если нужно
        is_bytecode = code_bytes.strip().startswith(b'\x1bLua')
        decompiled = None
        
        if is_bytecode:
            if callback: callback("🧬 Декомпиляция байткода...")
            decompiled = self._try_decompile(code_bytes)
        else:
            if isinstance(code_bytes, str): decompiled = code_bytes.encode('utf-8')
            else: decompiled = code_bytes

        final_text = ""
        final_text += f"-- [[ DEOBFUSCATOR REPORT ]] --\n"
        final_text += f"-- Captured {len(strings)} strings, {len(logs)} logs.\n\n"
        
        final_text += "-- [[ LOGS ]] --\n"
        for l in logs[-200:]: final_text += f"-- {self._clean_string(l)}\n" # Последние 200 логов
        final_text += "\n"

        final_text += "-- [[ STRINGS ]] --\n"
        seen = set()
        for s in sorted(strings, key=lambda x: len(str(x)), reverse=True):
            clean = self._clean_string(s).replace('\n', ' ')
            if clean not in seen and len(clean) > 3:
                final_text += f'-- "{clean}"\n'
                seen.add(clean)
        final_text += "\n"

        if globals_dump:
            final_text += "-- [[ GLOBALS ]] --\n"
            for g in sorted(globals_dump): final_text += f"-- {self._clean_string(g)}\n"
            
        final_text += "\n" + "="*50 + "\n-- [[ SOURCE CODE ]] --\n\n"
        
        if decompiled:
            try: src = decompiled.decode('utf-8', 'ignore')
            except: src = decompiled.decode('latin-1', 'ignore')
            final_text += self._beautify_lua(src)
        else:
            final_text += "-- [FAIL] Could not decompile.\n"
            final_text += f"-- Blob: {str(binascii.hexlify(code_bytes[:100]))}..."

        return final_text.encode('utf-8')

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path): return None
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            # Увеличенный стек для Java чтобы избежать StackOverflow при декомпиляции
            res = subprocess.run(
                ["java", "-Xss100m", "-Xmx2G", "-jar", self.unluac_path, path], 
                capture_output=True, timeout=20
            )
            os.remove(path)
            if res.returncode == 0 and len(res.stdout) > 0: return res.stdout
            return None
        except: return None

    def _beautify_lua(self, source_code):
        source_code = re.sub(r'(\s)(local|return|if|for|while|repeat|function)(\s)', r'\n\2 ', source_code)
        replacements = {" then ": " then\n", " do ": " do\n", " end ": "\nend\n", " repeat ": "\nrepeat\n", " until ": "\nuntil ", ";": ";\n"}
        for k, v in replacements.items(): source_code = source_code.replace(k, v)
        lines = source_code.splitlines()
        formatted = []
        indent = 0
        for line in lines:
            line = line.strip()
            if not line: continue
            if line.startswith(("end", "until", "}", "]", ")", "else", "elseif")): indent = max(0, indent - 1)
            formatted.append("\t" * indent + line)
            if line.endswith(("then", "do", "repeat", "{", "(")) or ("function" in line and not line.endswith("end")): indent += 1
            if line.startswith(("else", "elseif")): indent += 1
        return "\n".join(formatted)
