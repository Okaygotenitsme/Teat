    t_name = random_name()
    lua_block = f"(function() local {t_name}={{ {','.join(map(str, encrypted))} }} "
    lua_block += f"local res='' for i=1,#{t_name} do res=res..string.char(bit32.bxor({t_name}[i], {key})) end return res end)()"
    return lua_block

