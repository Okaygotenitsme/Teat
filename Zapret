logger = logging.getLogger("DeobfuscatorEngine")

class DeobfuscatorEngine:
    def __init__(self):
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        logger.info(f"📁 Working Dir: {base_dir}")

    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        if not self._check_java():
            return b"-- [FATAL] Java is missing. Install Java to use unluac."

        update_status("🧠 Запуск Lua VM с эмуляцией Exploits API...")

        # --- НАСТРОЙКА LUA VM ---
        try:
            # Включаем unpack_returned_tuples, чтобы функции возвращали кортежи Python
            lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)
        except Exception as e:
            return f"-- [FATAL] Lua start error: {e}".encode('utf-8')

        # 1. Библиотека Bit (необходима для дешифровки MoonSec)
        bit_polyfill = """
        local bit = {}
        function bit.tobit(x) x = x % 4294967296; if x >= 2147483648 then x = x - 4294967296 end; return x end
        function bit.bnot(x) return 4294967295 - x % 4294967296 end
        function bit.band(a, b) local r, m, s = 0, 2^31, nil; repeat s,a,b = a+b+m, a%m, b%m; r,m = r + m*4%(s-a-b), m/2 until m < 1; return r end
        function bit.bor(a, b) local r, m, s = 0, 2^31, nil; repeat s,a,b = a+b+m, a%m, b%m; r,m = r + m*1%(s-a-b), m/2 until m < 1; return r end
        function bit.bxor(a, b) local r, m, s = 0, 2^31, nil; repeat s,a,b = a+b+m, a%m, b%m; r,m = r + m*3%(s-a-b), m/2 until m < 1; return r end
        function bit.lshift(a, b) return (a * 2^b) % 4294967296 end
        function bit.rshift(a, b) return math.floor(a / 2^b) % 4294967296 end
        package.loaded.bit = bit; _G.bit = bit; _G.bit32 = bit 
        """

        # 2. Улучшенная среда-шпион (Spyware V3)
        sandbox_setup = bit_polyfill + """
        _G.CAPTURED_DATA = {strings={}, remotes={}, chunks={}}
        _G.ACTION_LOG = {}
        _G.FINAL_GLOBALS = {}
        
        local function log_action(msg) 
            if #_G.ACTION_LOG < 500 then table.insert(_G.ACTION_LOG, msg) end
        end

        -- === STRING SNIFFER ===
        local function capture_str(s) 
            if type(s) == "string" and #s > 3 then 
                -- Игнорируем мусорные строки
                if not s:match("^stack ") and not s:match("^upvalue") then
                    _G.CAPTURED_DATA.strings[s] = true 
                end
            end 
            return s
        end

        local real_char = string.char
        string.char = function(...)
            local res = real_char(...)
            capture_str(res)
            return res
        end
        
        local real_concat = table.concat
        table.concat = function(t, sep, i, j)
            local res = real_concat(t, sep, i, j)
            capture_str(res)
            return res
        end

        -- === REMOTE SPY (ГЛАВНАЯ ФИШКА) ===
        -- Эмулируем FireServer чтобы видеть аргументы
        local function mock_remote(name, method, args)
            local arg_str = ""
            for i,v in pairs(args) do 
                arg_str = arg_str .. tostring(v) .. ", "
                if type(v) == "string" then capture_str(v) end
            end
            local log_entry = "REMOTE: " .. name .. ":" .. method .. "(" .. arg_str .. ")"
            log_action(log_entry)
            table.insert(_G.CAPTURED_DATA.remotes, log_entry)
        end

        -- === ROBLOX INSTANCE MOCK ===
        local InstanceMock = {}
        InstanceMock.__index = InstanceMock
        
        function InstanceMock.new(cls, parent)
            local self = setmetatable({}, {
                __index = function(t, k)
                    if k == "FireServer" or k == "InvokeServer" then
                        return function(inst, ...) mock_remote(tostring(t), k, {...}) end
                    end
                    if k == "Name" then return "MockInstance" end
                    if k == "Parent" then return parent end
                    return function(...) return InstanceMock.new("Part") end -- Возвращаем пустышку
                end,
                __newindex = function(t, k, v) end, -- Игнорируем запись
                __tostring = function() return cls end
            })
            return self
        end

        -- === EXPLOIT ENVIRONMENT ===
        -- Многие обфускаторы проверяют наличие этих функций
        _G.getgenv = function() return _G end
        _G.getrenv = function() return _G end
        _G.hookfunction = function(orig, hook) log_action("HOOK ATTEMPT detected"); return orig end
        _G.checkcaller = function() return true end
        _G.islclosure = function() return true end
        
        -- Proxy для game/workspace
        local function create_proxy(name)
            return setmetatable({}, {
                __index = function(t, k)
                    if k == "HttpGet" then 
                        return function(u) 
                            log_action("HTTP: " .. tostring(u)) 
                            capture_str(tostring(u))
                            return "print('Honeypot')" 
                        end
                    end
                    if k == "GetService" then return function(self, s) return create_proxy(s) end end
                    return create_proxy(name .. "." .. k)
                end,
                __newindex = function(t, k, v) end,
                __tostring = function() return name end,
                __call = function(...) return create_proxy(name) end
            })
        end

        -- === LOAD HOOK ===
        local real_load = load
        local function hooked_load(chunk, name, mode, env)
            if type(chunk) == "string" and #chunk > 50 then
                 -- Сохраняем байткод, если MoonSec пытается загрузить распакованный скрипт
                 table.insert(_G.CAPTURED_DATA.chunks, {data = chunk, size = #chunk})
            end
            return real_load(chunk, name, mode, env)
        end

        -- Среда исполнения
        local env = {
            loadstring = hooked_load, load = hooked_load,
            print = function(...) local a={...}; log_action("PRINT: "..tostring(a[1])); end,
            warn = function(...) local a={...}; log_action("WARN: "..tostring(a[1])); end,
            error = function(...) end, 
            string = string, math = math, table = table, 
            bit = bit, bit32 = bit, pairs = pairs, ipairs = ipairs, next = next,
            type = type, tostring = tostring, tonumber = tonumber, pcall = pcall, xpcall = xpcall,
            select = select, unpack = unpack or table.unpack,
            setmetatable = setmetatable, getmetatable = getmetatable,
            rawget = rawget, rawset = rawset, rawequal = rawequal,
            
            Instance = { new = InstanceMock.new },
            game = create_proxy("game"),
            workspace = create_proxy("workspace"),
            script = create_proxy("script"),
            getgenv = _G.getgenv,
            hookfunction = _G.hookfunction,
            checkcaller = _G.checkcaller,
            wait = function() end,
            task = { wait = function() end, spawn = function(f) pcall(f) end }
        }
        env._G = env
        _G.sandbox_env = env
        return env
        """

        try:
            update_status("🌪️ Трассировка выполнения скрипта...")
            env = lua.execute(sandbox_setup)
            
            # Раннер с защитой от ошибок
            runner = lua.eval("""
                function(code, env)
                    local f, err = load(code, "chunk", "bt", env)
                    if not f then return false end
                    
                    -- Запускаем скрипт
                    local status, res = pcall(f)
                    
                    -- DUMP GLOBALS
                    for k, v in pairs(env) do
                        if type(v) ~= "function" and type(v) ~= "table" and k ~= "_G" then
                            table.insert(_G.FINAL_GLOBALS, tostring(k) .. " = " .. tostring(v))
                        end
                    end
                    
                    return true
                end
            """)
            runner(content, env)

            # --- ИЗВЛЕЧЕНИЕ ДАННЫХ ---
            
            # 1. Строки
            detected_strings = list(lua.globals().CAPTURED_DATA.strings)
            
            # 2. Remote Spy Logs (Важно!)
            remote_logs = list(lua.globals().CAPTURED_DATA.remotes)
            
            # 3. Глобалки
            global_dump = list(lua.globals().FINAL_GLOBALS)
            
            # 4. Логи действий
            action_log = list(lua.globals().ACTION_LOG)
            
            # 5. Чанки (если скрипт распаковал себя сам)
            chunks = lua.globals().CAPTURED_DATA.chunks
            best_chunk = None
            max_size = 0
            if len(chunks) > 0:
                for i in range(1, len(chunks) + 1):
                    c = chunks[i]
                    if c.size > max_size:
                        max_size = c.size
                        best_chunk = c.data
            
            target_code = best_chunk if best_chunk else content
            
            return self._finalize_output(target_code, detected_strings, remote_logs, global_dump, action_log, update_status)

        except Exception as e:
            return f"-- [CRASH ERROR]: {str(e)}\n-- Try running on a simpler script.".encode('utf-8')

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _clean_string(self, s):
        if isinstance(s, bytes):
            try: return s.decode('utf-8', errors='ignore')
            except: return str(s)
        return str(s)

    def _finalize_output(self, code_bytes, strings, remotes, globals_dump, logs, callback):
        """Собирает финальный файл"""
        
        if callback: callback("🧬 Попытка декомпиляции ядра (unluac)...")
        decompiled = self._try_decompile(code_bytes)
        
        final_text = "-- [[ ROBLOX DEOBFUSCATOR V2 REPORT ]] --\n\n"
        
        # 1. REMOTE SPY (Самое ценное для игроков)
        if remotes:
            final_text += "="*60 + "\n"
            final_text += "-- [[ 📡 REMOTE SPY LOGS (NETWORKING) ]] --\n"
            final_text += "-- This shows what the script sends to the server:\n\n"
            for r in remotes:
                final_text += f"{self._clean_string(r)}\n"
            final_text += "\n"

        # 2. STRINGS
        final_text += "="*60 + "\n"
        final_text += "-- [[ 📝 DECRYPTED STRINGS & ASSETS ]] --\n\n"
        sorted_strings = sorted(strings, key=lambda x: len(str(x)), reverse=True)
        seen = set()
        for s in sorted_strings:
            clean = self._clean_string(s).replace('\n', ' ').replace('\r', '')
            if clean not in seen and len(clean) > 3 and len(clean) < 200:
                final_text += f'-- "{clean}"\n'
                seen.add(clean)
        
        # 3. LOGS
        final_text += "\n" + "="*60 + "\n"
        final_text += "-- [[ 📜 EXECUTION LOGS ]] --\n"
        for l in logs[-100:]: 
            final_text += f"-- {self._clean_string(l)}\n"

        final_text += "\n" + "="*60 + "\n"
        
        # 4. CODE
        if decompiled:
            try:
                src = decompiled.decode('utf-8', 'ignore')
            except:
                src = decompiled.decode('latin-1', 'ignore')
            
            src = self._beautify_lua(src)
            final_text += "-- [[ DECOMPILED SOURCE (LOADER/VM) ]] --\n\n"
            final_text += src
        else:
            final_text += "-- [[ RAW BYTECODE ]] --\n"
            final_text += "-- Virtualization prevented full decompilation.\n"
            final_text += "-- Use the logs above to understand logic.\n\n"
            try:
                final_text += code_bytes.decode('utf-8', errors='ignore')
            except:
                final_text += "-- (Binary data suppressed)"

        return final_text.encode('utf-8')

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path): return None
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            res = subprocess.run(
                ["java", "-jar", self.unluac_path, path], 
                capture_output=True,
                timeout=15
            )
            os.remove(path)
            
            if res.returncode == 0 and len(res.stdout) > 0: 
                return res.stdout
            return None
        except: return None

    def _beautify_lua(self, source_code):
        source_code = re.sub(r'(\s)(local|return|if|for|while|repeat|function)(\s)', r'\n\2 ', source_code)
        replacements = {
            " then ": " then\n", " do ": " do\n", " end ": "\nend\n",
            " repeat ": "\nrepeat\n", " until ": "\nuntil ", ";": ";\n"
        }
        for k, v in replacements.items():
            source_code = source_code.replace(k, v)
        
        formatted = []
        indent = 0
        for line in source_code.splitlines():
            line = line.strip()
            if not line: continue
            if line.startswith("--"): 
                formatted.append(line)
                continue
            if line.startswith(("end", "until", "}", "]", ")", "else", "elseif")):
                indent = max(0, indent - 1)
            formatted.append("\t" * indent + line)
            if line.endswith(("then", "do", "repeat", "{", "(")) or \
               ("function" in line and not line.endswith("end")):
                indent += 1
            if line.startswith(("else", "elseif")):
                indent += 1
        return "\n".join(formatted)
