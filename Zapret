import lupa
from lupa import LuaRuntime
import re

class DeobfuscatorEngine:
    def __init__(self):
        # Создаем чистый Lua-движок
        self.lua = LuaRuntime(unpack_returned_tuples=True)

    def process_text(self, content):
        if "MoonSec" in content:
            return self.run_in_sandbox(content)
        return "-- [!] Пожалуйста, отправь файл MoonSec V3."

    def run_in_sandbox(self, obfuscated_code):
        """Запуск кода в эмуляторе с перехватом данных"""
        logs = ["-- [[ Dynamic Analysis Result ]] --\n"]
        
        # 1. Создаем хуки (перехватчики)
        def hooked_loadstring(code, *args):
            logs.append("-- [CAPTURED CODE]:\n" + str(code))
            return lambda: None # Возвращаем пустую функцию, чтобы код не шел дальше

        def hooked_print(*args):
            logs.append(f"-- [PRINT]: {' '.join(map(str, args))}")

        # 2. Настраиваем окружение Roblox
        g = self.lua.globals()
        g['loadstring'] = hooked_loadstring
        g['print'] = hooked_print
        
        # Имитируем объект game
        g['game'] = self.lua.table(
            GetService = lambda s, name: self.lua.table(name=name, SetCore=lambda *a: None)
        )
        
        # Добавляем стандартные функции, которые часто ищет MoonSec
        g['setclipboard'] = lambda val: logs.append(f"-- [CLIPBOARD]: {val}")
        g['getgenv'] = lambda: g

        try:
            # 3. Пытаемся запустить обфускатор
            # Мы ограничиваем время выполнения (псевдо-защита от вечных циклов)
            self.lua.execute(obfuscated_code)
        except Exception as e:
            logs.append(f"\n-- [!] Анализ прерван: {e}")
            logs.append("-- (Это нормально, если мы перехватили loadstring до завершения)")

        return "\n".join(logs)
