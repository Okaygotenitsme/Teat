    def _get_bit_polyfill(self) -> str:
        """Полифилл для битовых операций (bit/bit32)"""
        return """
        -- === BIT OPERATIONS POLYFILL ===
        local bit = {}
        
        function bit.tobit(x)
            x = x % 4294967296
            if x >= 2147483648 then 
                x = x - 4294967296 
            end
            return x
        end
        
        function bit.bnot(x)
            return 4294967295 - (x % 4294967296)
        end
        
        local function bit_operation(a, b, oper)
            local result, modulo, sum = 0, 2^31, nil
            repeat
                sum = a + b + modulo
                a, b = a % modulo, b % modulo
                result = result + modulo * oper % (sum - a - b)
                modulo = modulo / 2
            until modulo < 1
            return result
        end
        
        function bit.band(a, b) return bit_operation(a, b, 4) end
        function bit.bor(a, b) return bit_operation(a, b, 1) end
        function bit.bxor(a, b) return bit_operation(a, b, 3) end
        
        function bit.lshift(a, disp)
            return (a * 2^disp) % 4294967296
        end
        
        function bit.rshift(a, disp)
            return math.floor(a / 2^disp) % 4294967296
        end
        
        function bit.arshift(a, disp)
            local result = math.floor(a / 2^disp) % 4294967296
            if a >= 2147483648 then
                result = result + 4294967296 - 2^(32 - disp)
            end
            return result
        end
        
        -- Регистрируем в глобальном окружении
        package.loaded.bit = bit
        package.loaded.bit32 = bit
        _G.bit = bit
        _G.bit32 = bit
        """

    def _get_roblox_environment(self) -> str:
        """Полная эмуляция Roblox API"""
        return """
        -- === ROBLOX ENVIRONMENT EMULATION ===
        
        -- :: SIGNAL (СОБЫТИЯ) ::
        local function CreateSignal()
            local connections = {}
            local signal = {}
            
            function signal:Connect(callback)
                local connection = {
                    Connected = true,
                    Disconnect = function(self)
                        self.Connected = false
                        for i, conn in ipairs(connections) do
                            if conn == self then
                                table.remove(connections, i)
                                break
                            end
                        end
                    end
                }
                table.insert(connections, connection)
                connection._callback = callback
                return connection
            end
            
            function signal:Fire(...)
                for _, conn in ipairs(connections) do
                    if conn.Connected then
                        local success, err = pcall(conn._callback, ...)
                        if not success then
                            warn("Signal callback error:", err)
                        end
                    end
                end
            end
            
            function signal:Wait()
                local thread = coroutine.running()
                local connection
                connection = signal:Connect(function(...)
                    connection:Disconnect()
                    coroutine.resume(thread, ...)
                end)
                return coroutine.yield()
            end
            
            return signal
        end
        
        -- :: INSTANCE ::
        _G.Instance = {}
        _G.Instance.__index = _G.Instance
        
        function _G.Instance.new(className, parent)
            local instance = setmetatable({}, _G.Instance)
            
            -- Базовые свойства
            instance.ClassName = className or "Part"
            instance.Name = className or "Part"
            instance.Parent = parent
            instance.Archivable = true
            
            -- События
            instance.Changed = CreateSignal()
            instance.ChildAdded = CreateSignal()
            instance.ChildRemoved = CreateSignal()
            instance.Destroying = CreateSignal()
            
            -- Дочерние объекты
            instance._children = {}
            
            -- Методы
            function instance:Destroy()
                self.Destroying:Fire()
                self.Parent = nil
                for _, child in ipairs(self._children) do
                    child:Destroy()
                end
                self._children = {}
            end
            
            function instance:Clone()
                return _G.Instance.new(self.ClassName, nil)
            end
            
            function instance:ClearAllChildren()
                for _, child in ipairs(self._children) do
                    child:Destroy()
                end
                self._children = {}
            end
            
            function instance:FindFirstChild(name, recursive)
                for _, child in ipairs(self._children) do
                    if child.Name == name then
                        return child
                    end
                    if recursive then
                        local found = child:FindFirstChild(name, true)
                        if found then return found end
                    end
                end
                return nil
            end
            
            function instance:WaitForChild(name, timeout)
                local found = self:FindFirstChild(name)
                if found then return found end
                -- Эмуляция ожидания
                return _G.Instance.new("Folder", self)
            end
            
            function instance:GetChildren()
                return self._children
            end
            
            function instance:GetDescendants()
                local descendants = {}
                for _, child in ipairs(self._children) do
                    table.insert(descendants, child)
                    for _, desc in ipairs(child:GetDescendants()) do
                        table.insert(descendants, desc)
                    end
                end
                return descendants
            end
            
            function instance:IsA(className)
                return self.ClassName == className
            end
            
            function instance:GetService(serviceName)
                return _G.game:GetService(serviceName)
            end
            
            -- Добавляем дочерний элемент при установке Parent
            if parent then
                table.insert(parent._children, instance)
                parent.ChildAdded:Fire(instance)
            end
            
            return instance
        end
        
        -- :: VECTOR3 ::
        _G.Vector3 = {}
        _G.Vector3.__index = _G.Vector3
        
        function _G.Vector3.new(x, y, z)
            local self = setmetatable({}, _G.Vector3)
            self.X = x or 0
            self.Y = y or 0
            self.Z = z or 0
            return self
        end
        
        _G.Vector3.zero = _G.Vector3.new(0, 0, 0)
        _G.Vector3.one = _G.Vector3.new(1, 1, 1)
        
        function _G.Vector3.__add(a, b)
            return _G.Vector3.new(a.X + b.X, a.Y + b.Y, a.Z + b.Z)
        end
        
        function _G.Vector3.__sub(a, b)
            return _G.Vector3.new(a.X - b.X, a.Y - b.Y, a.Z - b.Z)
        end
        
        function _G.Vector3.__mul(a, b)
            if type(b) == "number" then
                return _G.Vector3.new(a.X * b, a.Y * b, a.Z * b)
            end
            return _G.Vector3.new(a.X * b.X, a.Y * b.Y, a.Z * b.Z)
        end
        
        function _G.Vector3.__div(a, b)
            if type(b) == "number" then
                return _G.Vector3.new(a.X / b, a.Y / b, a.Z / b)
            end
            return _G.Vector3.new(a.X / b.X, a.Y / b.Y, a.Z / b.Z)
        end
        
        function _G.Vector3:Dot(other)
            return self.X * other.X + self.Y * other.Y + self.Z * other.Z
        end
        
        function _G.Vector3:Cross(other)
            return _G.Vector3.new(
                self.Y * other.Z - self.Z * other.Y,
                self.Z * other.X - self.X * other.Z,
                self.X * other.Y - self.Y * other.X
            )
        end
        
        -- :: CFRAME ::
        _G.CFrame = {}
        _G.CFrame.__index = _G.CFrame
        
        function _G.CFrame.new(...)
            local args = {...}
            local self = setmetatable({}, _G.CFrame)
            
            if #args == 3 then
                self.Position = _G.Vector3.new(args[1], args[2], args[3])
            elseif #args == 12 then
                self.Position = _G.Vector3.new(args[1], args[2], args[3])
            else
                self.Position = _G.Vector3.zero
            end
            
            return self
        end
        
        _G.CFrame.Angles = function(rx, ry, rz)
            return _G.CFrame.new(0, 0, 0)
        end
        
        function _G.CFrame:GetComponents()
            return 0, 0, 0, 1, 0, 0, 0, 1, 0, 0, 0, 1
        end
        
        function _G.CFrame.__mul(a, b)
            if type(b) == "table" and b.X then
                return a.Position + b
            end
            return a
        end
        
        -- :: UDIM2 ::
        _G.UDim2 = {}
        function _G.UDim2.new(xScale, xOffset, yScale, yOffset)
            return {
                X = {Scale = xScale or 0, Offset = xOffset or 0},
                Y = {Scale = yScale or 0, Offset = yOffset or 0}
            }
        end
        
        -- :: COLOR3 ::
        _G.Color3 = {}
        function _G.Color3.new(r, g, b)
            return {R = r or 0, G = g or 0, B = b or 0}
        end
        
        function _G.Color3.fromRGB(r, g, b)
            return _G.Color3.new(r/255, g/255, b/255)
        end
        
        -- :: ENUM ::
        _G.Enum = setmetatable({}, {
            __index = function(t, k)
                return setmetatable({}, {
                    __index = function(t2, k2)
                        return {Value = 1, Name = k2, EnumType = k}
                    end
                })
            end
        })
        
        -- :: TASK LIBRARY ::
        _G.task = {
            wait = function(duration)
                return duration or 0
            end,
            spawn = function(func, ...)
                local success, err = pcall(func, ...)
                if not success then
                    warn("task.spawn error:", err)
                end
            end,
            defer = function(func, ...)
                _G.task.spawn(func, ...)
            end,
            delay = function(duration, func, ...)
                _G.task.spawn(func, ...)
            end
        }
        
        _G.wait = _G.task.wait
        _G.spawn = _G.task.spawn
        _G.delay = _G.task.delay
        
        -- :: GAME СТРУКТУРА ::
        _G.game = _G.Instance.new("DataModel")
        _G.game.Name = "Game"
        
        -- Players
        _G.game.Players = _G.Instance.new("Players", _G.game)
        _G.game.Players.LocalPlayer = _G.Instance.new("Player", _G.game.Players)
        _G.game.Players.LocalPlayer.Name = "DeobfUser"
        _G.game.Players.LocalPlayer.UserId = 123456789
        _G.game.Players.LocalPlayer.Character = _G.Instance.new("Model", _G.workspace)
        
        -- RunService
        _G.game.RunService = _G.Instance.new("RunService", _G.game)
        _G.game.RunService.RenderStepped = CreateSignal()
        _G.game.RunService.Heartbeat = CreateSignal()
        _G.game.RunService.Stepped = CreateSignal()
        
        function _G.game.RunService:IsStudio() return false end
        function _G.game.RunService:IsClient() return true end
        function _G.game.RunService:IsServer() return false end
        
        -- HttpService
        _G.game.HttpService = _G.Instance.new("HttpService", _G.game)
        function _G.game.HttpService:JSONDecode(str) return {} end
        function _G.game.HttpService:JSONEncode(tbl) return "{}" end
        function _G.game.HttpService:GetAsync(url) return "" end
        function _G.game.HttpService:PostAsync(url, data) return "" end
        
        -- GetService
        function _G.game:GetService(serviceName)
            if serviceName == "Players" then return self.Players end
            if serviceName == "RunService" then return self.RunService end
            if serviceName == "HttpService" then return self.HttpService end
            if serviceName == "Workspace" then return _G.workspace end
            
            -- Создаём сервис если не существует
            local service = self:FindFirstChild(serviceName)
            if not service then
                service = _G.Instance.new(serviceName, self)
            end
            return service
        end
        
        -- Workspace
        _G.workspace = _G.Instance.new("Workspace", _G.game)
        _G.workspace.Name = "Workspace"
        _G.workspace.CurrentCamera = _G.Instance.new("Camera", _G.workspace)
        
        -- Script
        _G.script = _G.Instance.new("LocalScript", _G.workspace)
        _G.script.Name = "DeobfScript"
        
        -- :: EXECUTOR FUNCTIONS ::
        _G.getgenv = function() return _G end
        _G.getrenv = function() return _G end
        _G.getreg = function() return {} end
        _G.getgc = function(include_tables) return {} end
        _G.checkcaller = function() return true end
        _G.islclosure = function(func) return type(func) == "function" end
        _G.iscclosure = function(func) return false end
        _G.newcclosure = function(func) return func end
        _G.clonefunction = function(func) return func end
