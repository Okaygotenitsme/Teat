def gen_junk_name(length=10):
    """Генерирует имена типа _7d8a9s или lIl1l1"""
    # Микс из стилей MoonSec и IronBrew
    styles = [
        lambda: "_" + "".join(random.choices(string.ascii_letters + string.digits, k=length)),
        lambda: "".join(random.choices(['l', 'I', '1', 'i'], k=length + 2))
    ]
    return random.choice(styles)()

def encrypt_byte_table(source_code):
    """Превращает весь код в таблицу чисел (Bytecode simulation)"""
    key = random.randint(15, 200)
    # Сжимаем код в одну строку
    compact_code = source_code
    
    # Превращаем в массив байтов, XORим каждый байт
    bytecode = [ord(c) ^ key for c in compact_code]
    return bytecode, key

def meloten_vm_builder(source):
    """Строит структуру Виртуальной Машины"""
    
    # 1. Основные переменные VM
    vm_table_name = gen_junk_name()  # Таблица байткода
    vm_runner = gen_junk_name()      # Функция запуска
    var_stack = gen_junk_name()      # Виртуальный стек
    pc_pointer = gen_junk_name()     # Program Counter
    string_decoder = gen_junk_name() # Функция расшифровки
    
    # 2. Шифруем исходник
    bytecode, key = encrypt_byte_table(source)
    
    # Разбиваем огромный массив байтов на строки, чтобы Telegram не ругался на длину строки
    chunk_size = 300
    byte_str = ""
    for i in range(0, len(bytecode), chunk_size):
        chunk = bytecode[i:i + chunk_size]
        byte_str += "{" + ",".join(map(str, chunk)) + "},"
    
    # 3. Генерируем "Мусор" (Junk Code) как в MoonSec (циклы while, странные вычисления)
    junk_code = ""
    for _ in range(5):
        v1 = gen_junk_name()
        v2 = gen_junk_name()
        junk_code += f"local {v1} = {random.randint(100,9999)}; local {v2} = {v1} * 2;\n"

    # 4. СОБИРАЕМ ЛУА СКРИПТ (VM TEMPLATE)
    # Это эмуляция VM. Она берет байты, расшифровывает их в рантайме и исполняет через loadstring
    # Но выглядит это как сложная обработка регистров.
    
    lua_vm = f"""--[[ 
    Protected with Meloten VM V7 (Supreme) 
    Secure Virtualization Logic
]]
local {vm_table_name} = {{
    {byte_str}
}}
local {gen_junk_name()} = {key}

{junk_code}

local function {string_decoder}(code_table, k)
    local raw_str = ""
    for _, chunk in ipairs(code_table) do
        for _, byte in ipairs(chunk) do
            -- Bitwise XOR simulation for compatibility
            local decoded = byte - k
            if decoded < 0 then decoded = decoded + 256 end
            -- В простых VM используем базовую арифметику для XOR эмуляции если bit32 недоступен
            -- Но здесь для MoonSec стиля делаем вид сложной обработки
            raw_str = raw_str .. string.char((byte ~ k)) 
        end
    end
    return raw_str
end

local function {vm_runner}()
    local {var_stack} = {{}}
    local {pc_pointer} = 0
    
    -- Virtual Machine Dispatcher Loop
    while true do
        {pc_pointer} = {pc_pointer} + 1
        if {pc_pointer} > 1 then break end 
        
        local _vm_chunk = {string_decoder}({vm_table_name}, {key})
        
        -- Dynamic Loader (Hide loadstring)
        local _loader = getfenv()["\\108\\111\\97\\100\\115\\116\\114\\105\\110\\103"] or load
        
        if _loader then
            local _payload = _loader(_vm_chunk)
            if _payload then
                _payload()
            end
        end
    end
end

-- Entry Point
if ({gen_junk_name()} > 0) then
    {vm_runner}()
end
"""
    return lua_vm

