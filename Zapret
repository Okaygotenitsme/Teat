class MelotenUltraVM:
    def __init__(self, source: str, bind_place: bool = False):
        self.source = source
        self.bind_place = bind_place
        self._salt = random.getrandbits(32)

    def _generate_map(self):
        arr = list(range(256))
        random.shuffle(arr)
        return arr

    def _apply_map(self, bytes_seq, mapping):
        return [mapping[b] for b in bytes_seq]

    def _xor_layer(self, bytes_seq, key32):
        out = []
        for i, b in enumerate(bytes_seq):
            shift = (i % 4) * 8
            kbyte = (key32 >> shift) & 0xFF
            out.append(b ^ kbyte)
        return out

    def _build_opcode_stream(self, payload_bytes):
        # Opcodes:
        # 1 N <N bytes>      - append N bytes
        # 2 Delta            - key ^= Delta
        # 3 DeriveFlag       - derive key variant
        # 4 JunkLoopCount    - do junk loop (mutates internal derived key)
        # 5 End
        ops = []
        chunks = list(_chunker(payload_bytes, 8, 28))
        for chunk in chunks:
            # random junk ops
            for _ in range(random.randint(0, 2)):
                if random.random() < 0.6:
                    ops += [4, random.randint(1, 12)]
                else:
                    ops += [3, random.randint(0, 1)]
            # append real chunk
            ops.append(1)
            ops.append(len(chunk))
            ops += chunk
            # sometimes mutate key
            if random.random() < 0.45:
                ops += [2, random.randint(1, 255)]
        ops += [5, 0]
        return ops

    def _lua_table_literal(self, arr):
        parts = []
        line = []
        for i, v in enumerate(arr, start=1):
            line.append(str(v))
            if len(line) >= 20:
                parts.append(", ".join(line))
                line = []
        if line:
            parts.append(", ".join(line))
        return ", ".join(parts)

    def _random_junk_block(self):
        name = _rand_name("junk")
        var = _rand_name("x")
        body = f"""
