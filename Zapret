class AdminPistol : Weapon
{
    Default
    {
        // Характеристики оружия
        Weapon.SelectionOrder 100;
        Weapon.AmmoUse 0;            // Не тратит патроны
        Weapon.SlotNumber 2;         // Будет в слоте "2"
        Inventory.PickupMessage "Вы получили Админ-Пушку. Повелевайте!";
        Tag "Уничтожитель";
    }

    States
    {
    Ready:
        PISG A 1 A_WeaponReady; // Оружие готово к стрельбе
        Loop;
    Deselect:
        PISG A 1 A_Lower;      // Анимация убирания оружия
        Loop;
    Select:
        PISG A 1 A_Raise;      // Анимация доставания оружия
        Loop;
    Fire:
        PISG A 4;
        // Функция выстрела: 
        // 0, 0 - разброс пуль (идеально точно)
        // 1 - количество пуль
        // 1000000 - УРОН (хватит для любого босса)
        PISG B 0 A_FireBullets(0, 0, 1, 1000000, "BulletPuff");
        PISG B 6 A_StartSound("weapons/pistol", CHAN_WEAPON);
        PISG C 4;
        PISG B 5 A_ReFire;     // Позволяет зажать кнопку для автострельбы
        Goto Ready;
    Flash:
        PISF A 7 Bright A_Light1;
        Goto LightDone;
    }
}
