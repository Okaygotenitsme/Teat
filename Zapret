local troop = script.Parent
local humanoid = troop:WaitForChild("Humanoid")
local root = troop:WaitForChild("HumanoidRootPart")

local damage = troop:GetAttribute("Damage")
local attackRange = troop:GetAttribute("Range")
local attackSpeed = troop:GetAttribute("AttackSpeed")

local function findTarget()
	local target = nil
	local minDist = math.huge
	
	for _, obj in pairs(workspace:GetChildren()) do
		if obj:FindFirstChild("Humanoid") and obj ~= troop then
			local targetRoot = obj:FindFirstChild("HumanoidRootPart")
			if targetRoot then
				local dist = (root.Position - targetRoot.Position).Magnitude
				if dist < minDist then
					minDist = dist
					target = obj
				end
			end
		end
	end
	
	return target or workspace:FindFirstChild("EnemyTower")
end

while task.wait(0.5) do
	local target = findTarget()
	if target and target:FindFirstChild("HumanoidRootPart") then
		local targetPart = target.HumanoidRootPart
		local distance = (root.Position - targetPart.Position).Magnitude
		
		if distance <= attackRange then
			humanoid:MoveTo(root.Position)
			local targetHum = target:FindFirstChild("Humanoid")
			if targetHum and targetHum.Health > 0 then
				targetHum:TakeDamage(damage)
				task.wait(attackSpeed)
			end
		else
			humanoid:MoveTo(targetPart.Position)
		end
	end
end
