        self.source = source
        self.key = random.randint(50, 200)
        self.seed = random.randint(1000, 5000)
        # Имена переменных в стиле "невидимок"
        self.vars = {f"v{i}": self._rand_name() for i in range(20)}

    def _rand_name(self):
        """Создает путаные имена, которые выглядят почти одинаково."""
        chars = "Il1"
        return "Meloten_" + "".join(random.choices(chars, k=random.randint(10, 15)))

    def _get_math_junk(self, target_num):
        """Превращает число в математическое выражение."""
        offset = random.randint(1, 50)
        return f"({target_num + offset} - {offset})"

    def _generate_complex_junk(self):
        """Генерирует тяжелый мусорный код."""
        junk_parts = [
            f"local {self._rand_name()} = function() for i=1,10 do end return {random.randint(1,100)} end;",
            f"local {self._rand_name()} = {{[{random.randint(1,500)}] = '{self._rand_name()}'}};",
            f"if {random.randint(1,10)} > 20 then print('{self._rand_name()}') end;",
            f"local {self._rand_name()} = math.sin({random.randint(1,100)}) + math.cos({random.randint(1,100)});"
        ]
        return "".join(random.sample(junk_parts, k=2))

