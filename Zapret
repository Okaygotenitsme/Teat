"""

        # 10) final assembly - compress spacing for one-line style (but keep readable)
        final = "\n".join(line for line in lua_vm.splitlines())

        # 11) wrap final lua in a single string with minimal whitespace
        final_one_liner = " ".join(final.split())
        return final_one_liner

