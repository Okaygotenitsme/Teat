@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    file_name = message.document.file_name
    
    # Пути для сохранения
    input_path = f"temp_in_{user_id}_{file_name}"
    output_path = f"Deobfuscated_{file_name}"

    status_msg = await message.answer("⏳ **Скачиваю файл...**", parse_mode="Markdown")
    
    # ### ИСПРАВЛЕНИЕ 1: Получаем loop здесь, в главном потоке ###
    loop = asyncio.get_running_loop()

    # Хак для обновления статуса
    last_status = [""]
    
    def sync_status_updater(text):
        if text == last_status[0]: return
        last_status[0] = text
        
        async def edit_coro():
            try:
                # Добавил проверку, чтобы текст не был пустым
                if text:
                    await status_msg.edit_text(f"⚙️ **Статус:** {text}", parse_mode="Markdown")
            except TelegramBadRequest: 
                pass 
        
        # ### ИСПРАВЛЕНИЕ 2: Используем переменную loop, захваченную выше ###
        # Мы НЕ вызываем get_running_loop() здесь, так как этот код выполняется в другом потоке
        if not loop.is_closed():
            asyncio.run_coroutine_threadsafe(edit_coro(), loop)

    try:
        # 1. Скачиваем файл
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "rb") as f: content = f.read()

        # 2. Запускаем движок в отдельном потоке
        try:
            result_data = await asyncio.wait_for(
                asyncio.to_thread(engine.process, content, sync_status_updater),
                timeout=180.0
            )
        except asyncio.TimeoutError:
            result_data = b"-- [TIMEOUT] Process took too long ( > 3 mins)."
            await status_msg.edit_text("❌ **Ошибка:** Время обработки истекло.")

        # 3. Сохраняем результат
        with open(output_path, "wb") as f: f.write(result_data)

        # 4. Отправляем пользователю
        out_file = FSInputFile(output_path)
        caption = "✅ **Готово!**"
        
        # Проверяем байты, так как result_data - это bytes
        if b"Decompiled with unluac" in result_data:
            caption += "\n📜 Байткод успешно декомпилирован в исходник."
        elif b"WARNING: Decompilation failed" in result_data:
            caption += "\n🧩 Байткод пойман, но декомпилятор (Java) вернул ошибку."
        elif b"[FAIL]" in result_data:
            caption = "❌ **Не удалось:** Скрипт не удалось распаковать (см. логи)."

        await message.answer_document(out_file, caption=caption)

    except Exception as e:
        logger.error(f"Global Error: {e}")
        # Используем try-except на случай, если сообщение уже удалено или недоступно
        try:
            await status_msg.edit_text(f"❌ Критическая ошибка бота: {e}")
        except:
            await message.answer(f"❌ Критическая ошибка бота: {e}")
            
    finally:
        # Удаляем временные файлы
        for p in [input_path, output_path]:
            if os.path.exists(p): 
                try: os.remove(p)
                except: pass
