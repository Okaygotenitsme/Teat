import asyncio
import os
import logging
import uuid
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command

# Импортируем наш обновленный движок из engine.py
from engine import DeobfuscatorEngine

# --- НАСТРОЙКИ ---
API_TOKEN = 'ТВОЙ_ТОКЕН_СЮДА'

# Настройка логирования для отладки
logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(message)s")
logger = logging.getLogger("DeobfBot")

bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "🤖 **Roblox Deobfuscator V2 (Advanced)**\n\n"
        "Отправь мне файл `.lua` или `.txt`. Я применю агрессивные хуки для обхода защиты IronBrew и MoonSec.\n\n"
        "Что я умею:\n"
        "✅ Перехват динамических строк (`string.char`)\n"
        "✅ Извлечение скрытого кода из `loadstring`\n"
        "✅ Сбор констант из виртуальной машины (VM)\n"
        "✅ Эмуляция окружения Roblox",
        parse_mode="Markdown"
    )

@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    unique_id = uuid.uuid4().hex[:8]
    file_name = message.document.file_name or "script.lua"
    
    # Пути для временных файлов
    input_path = f"temp_{user_id}_{unique_id}.lua"
    output_path = f"Result_{unique_id}_{file_name}.txt"

    status_msg = await message.answer("⏳ **Инициализация эмулятора...**", parse_mode="Markdown")
    
    loop = asyncio.get_running_loop()
    
    # Функция для обновления статуса в Телеграме прямо из недр движка
    def sync_status_updater(text):
        async def edit_coro():
            try:
                await status_msg.edit_text(f"⚙️ **Статус:** {text}", parse_mode="Markdown")
            except Exception: pass 
        
        if not loop.is_closed():
            asyncio.run_coroutine_threadsafe(edit_coro(), loop)

    try:
        # 1. Скачиваем файл пользователя
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "rb") as f: 
            content = f.read()

        # 2. Запуск движка в отдельном потоке (чтобы бот не "зависал")
        # Мы ставим таймаут 2 минуты, так как сложные VM могут долго "раздупляться"
        result_data = await asyncio.wait_for(
            loop.run_in_executor(None, engine.process, content, sync_status_updater),
            timeout=120.0 
        )

        # 3. Сохраняем и отправляем результат
        with open(output_path, "wb") as f: 
            f.write(result_data)
        
        out_file = FSInputFile(output_path)
        
        # Формируем умную подпись к файлу
        caption = "✅ **Анализ завершен!**\n"
        
        if b"LOADSTRING CAUGHT" in result_data:
            caption += "🔥 **Вскрыто:** Найден скрытый `loadstring` (чистый код)!\n"
        if b"DECRYPTED STRINGS" in result_data:
            caption += "🔎 **Строки:** Извлечены ключи и вебхуки.\n"
        if b"DECOMPILED SOURCE" in result_data:
            caption += "📜 **Код:** Байткод успешно декомпилирован.\n"
        if b"Runtime Error" in result_data:
            caption += "⚠️ **Внимание:** Скрипт выдал ошибку при выполнении, но данные собраны.\n"

        await message.answer_document(out_file, caption=caption, parse_mode="Markdown")

    except asyncio.TimeoutError:
        await status_msg.edit_text("❌ **Ошибка:** Превышено время ожидания (2 мин). Скрипт слишком тяжелый.")
    except Exception as e:
        logger.error(f"Error: {e}")
        await message.answer(f"❌ Произошла критическая ошибка: `{str(e)[:100]}`", parse_mode="Markdown")
    finally:
        # Уборка за собой
        await status_msg.delete()
        for p in [input_path, output_path]:
            if os.path.exists(p):
                try: os.remove(p)
                except: pass

async def main():
    logger.info("--- Бот запущен и готов к деобфускации ---")
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    if os.name == 'nt': # Фикс для Windows
        asyncio.set_event_loop_policy(asyncio.WindowsSelectorEventLoopPolicy())
    try:
        asyncio.run(main())
    except KeyboardInterrupt:
        pass
