import lupa
from lupa import LuaRuntime
import re
import logging
import asyncio

# Логгер
logger = logging.getLogger("DeobfuscatorEngine")

class DeobfuscatorEngine:
    def __init__(self):
        pass

    def process(self, content, status_callback=None):
        """
        Главный метод обработки.
        """
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        # --- ЭТАП 1: Подготовка (Lua 5.1/5.4) ---
        update_status("🛠 Подготовка 'Черной дыры' (Universal Proxy)...")
        
        try:
            # unpack_returned_tuples=True важен для получения нескольких значений из return
            lua = LuaRuntime(unpack_returned_tuples=True)
        except Exception as e:
            return f"-- [FATAL]: Ошибка старта Lua: {e}"

        # --- ЭТАП 2: Полифилл BIT (Для MoonSec/IronBrew) ---
        bit_polyfill = """
        local bit = {}
        function bit.tobit(x) x = x % 4294967296; if x >= 2147483648 then x = x - 4294967296 end; return x end
        function bit.bnot(x) return 4294967295 - x % 4294967296 end
        
        local function bit_oper(a, b, oper)
            local r, m, s = 0, 2^31, nil
            repeat
                s,a,b = a+b+m, a%m, b%m
                r,m = r + m*oper%(s-a-b), m/2
            until m < 1
            return r
        end
        
        function bit.band(a, b) return bit_oper(a, b, 4) end
        function bit.bor(a, b)  return bit_oper(a, b, 1) end
        function bit.bxor(a, b) return bit_oper(a, b, 3) end
        function bit.lshift(a, b) return (a * 2^b) % 4294967296 end
        function bit.rshift(a, b) return math.floor(a / 2^b) % 4294967296 end
        
        package.loaded.bit = bit
        _G.bit = bit
        _G.bit32 = bit
        """

        # --- ЭТАП 3: Создание Среды-Ловушки ---
        update_status("🛡️ Активация режима эмуляции эксплойта...")
        
        sandbox_setup = bit_polyfill + """
        _G.CAPTURED = nil
        _G.LOGS = {}
        
        -- [[ ИСПРАВЛЕНИЕ: Делаем log глобальным ]] --
        _G.log = function(msg) 
            table.insert(_G.LOGS, msg) 
        end
        
        -- Локальная ссылка для использования внутри этого блока
        local log = _G.log

        -- [[ ХУК STRING.DUMP ]] --
        local real_dump = string.dump
        local function hooked_dump(func)
            log("[HOOK] Попытка string.dump!")
            local success, bytecode = pcall(real_dump, func)
            if success and #bytecode > 50 then
                 _G.CAPTURED = bytecode
                 log("[!!!] ДЖЕКПОТ! string.dump перехвачен.")
            end
            return bytecode or ""
        end

        -- [[ ХУК LOADSTRING ]] --
        local function hooked_loadstring(chunk, chunkname)
            if type(chunk) == "string" and #chunk > 50 then
                _G.CAPTURED = chunk
                log("[!!!] ДЖЕКПОТ! loadstring перехватил код.")
                return function() end 
            end
            
            -- Пытаемся загрузить как есть
            local f, err = load(chunk)
            if not f then
                log("[Load Error] " .. tostring(err))
                return function() end
            end
            return f
        end

        -- [[ PROXY OBJECTS ]] --
        local function create_proxy(name)
            local proxy = {}
            local meta = {}
            
            -- Рекурсивное создание прокси при обращении к полям
            meta.__index = function(t, k) return create_proxy(name .. "." .. tostring(k)) end
            meta.__call = function(t, ...) return create_proxy(name .. "()") end
            meta.__tostring = function() return name end
            meta.__len = function() return 0 end
            
            -- Математические заглушки (чтобы не крашило)
            meta.__add = function() return 0 end
            meta.__sub = function() return 0 end
            meta.__mul = function() return 0 end
            meta.__div = function() return 1 end -- Возвращаем 1 при делении, чтобы избежать div by zero
            meta.__mod = function() return 0 end
            meta.__pow = function() return 0 end
            meta.__unm = function() return 0 end
            
            -- Логические заглушки
            meta.__eq = function() return true end 
            meta.__lt = function() return false end
            meta.__le = function() return false end
            
            meta.__metatable = "LOCKED"
            setmetatable(proxy, meta)
            return proxy
        end

        -- [[ СБОРКА ОКРУЖЕНИЯ (ENV) ]] --
        local env = {
            -- Хуки
            loadstring = hooked_loadstring,
            load = hooked_loadstring,
            
            -- Библиотеки
            string = string, math = math, table = table, 
            bit = _G.bit, bit32 = _G.bit,
            pairs = pairs, ipairs = ipairs, next = next,
            type = type, tostring = tostring, tonumber = tonumber,
            pcall = pcall, xpcall = xpcall, select = select,
            error = error, unpack = unpack or table.unpack,
            assert = assert,
            
            -- Эксплойт-функции
            getgenv = function() return _G.sandbox_env end,
            getrenv = function() return _G.sandbox_env end,
            getreg = function() return {} end,
            getgc = function() return {} end,
            checkcaller = function() return true end,
            iscclosure = function() return false end,
            islclosure = function() return true end,
            
            -- getfenv / setfenv (КРИТИЧНО для IronBrew/MoonSec)
            getfenv = function(f) return _G.sandbox_env end,
            setfenv = function(f, t) return f end,
            
            -- Roblox API
            game = create_proxy("game"),
            workspace = create_proxy("workspace"),
            script = create_proxy("script"),
            task = { wait = function() end, spawn = function(f) f() end, delay = function(t, f) f() end },
            Instance = { new = function(n) return create_proxy("Instance.new("..n..")") end }
        }
        
        -- Перехват string.dump внутри окружения
        env.string.dump = hooked_dump

        -- Метатаблица для глобального окружения скрипта
        setmetatable(env, {
            __index = function(t, k)
                -- Если скрипт просит переменную, которой нет, даем Proxy
                return create_proxy(tostring(k))
            end
        })

        env._G = env
        env.shared = env
        _G.sandbox_env = env
        
        return env
        """

        # --- ЭТАП 4: Исполнение ---
        update_status("🚀 Запуск (режим Deep Capture)...")
        
        try:
            env = lua.execute(sandbox_setup)
            
            # Runner исполняется в глобальном контексте, но использует _G.log
            runner = lua.eval("""
                function(code, env)
                    -- Проверяем наличие логгера
                    local log = _G.log or function() end
                    
                    local f, err = load(code, "obf_script", "t", env)
                    if not f then return false, "Syntax Error: " .. tostring(err) end
                    
                    log("Запуск обфусцированного кода...")
                    
                    -- Запускаем скрипт и ловим return
                    local status, res = pcall(f)
                    
                    if not status then
                        log("[ERROR] Скрипт упал: " .. tostring(res))
                        return false, res
                    end
                    
                    log("Скрипт завершился успешно.")
                    
                    -- Проверяем, вернул ли скрипт функцию (частая техника)
                    if type(res) == "function" then
                        log("[HOOK] Скрипт вернул функцию! Пытаемся дампить...")
                        local s, dumped = pcall(string.dump, res)
                        if s and #dumped > 50 then
                             _G.CAPTURED = dumped
                             log("[!!!] ДЖЕКПОТ! Пойман return function")
                        end
                    end
                    
                    return true, "Executed"
                end
            """)
            
            runner(content, env)
            
            # Проверяем улов
            captured = lua.globals().CAPTURED
            logs = list(lua.globals().LOGS)
            
            if captured:
                update_status("✅ УСПЕХ! Скрытый код найден.")
                return self._clean_code(str(captured))
            else:
                log_str = "\n".join([str(l) for l in logs])
                return f"-- [FAIL] Не удалось перехватить код.\n-- ЛОГИ ПЕСОЧНИЦЫ:\n{log_str}"

        except Exception as e:
            return f"-- [CRASH]: {e}"

    def _clean_code(self, code):
        """Чистка кода или вывод информации о байткоде"""
        
        # Проверка на Lua Bytecode (начинается с ESC Lua)
        if code.startswith('\x1bLua') or code.startswith('\x1b\x4c'):
            hex_preview = " ".join("{:02x}".format(ord(c)) for c in code[:16])
            return (
                f"-- [[ SUCCESS: BYTECODE CAPTURED ]]\n"
                f"-- Этот код является скомпилированным Lua (Bytecode).\n"
                f"-- Python не умеет декомпилировать байткод в текст.\n"
                f"-- \n"
                f"-- Сохраните этот файл и используйте 'unluac.jar' для декомпиляции:\n"
                f"-- java -jar unluac.jar output.lua > source.lua\n"
                f"-- \n"
                f"-- Header Preview: {hex_preview}...\n\n"
                f"{code}"
            )

        # Обычная очистка текста
        code = code.replace(";", "\n")
        lines = code.split('\n')
        indent = 0
        formatted = []
        for line in lines:
            line = line.strip()
            if not line: continue
            
            if re.match(r"^(end|until|else|elseif)", line):
                indent = max(0, indent - 1)
            
            formatted.append(("\t" * indent) + line)
            
            if re.search(r"\b(function|then|do|repeat)\b", line) and not line.endswith("end"):
                indent += 1
            if line.endswith("{"):
                indent += 1
            if line.endswith("}"):
                indent = max(0, indent - 1)

        return "-- [[ DEOBFUSCATED RESULT ]]\n\n" + "\n".join(formatted)
