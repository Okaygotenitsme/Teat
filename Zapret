def _rand_name(prefix: str = "Mel") -> str:
    chars = "abcdefghijklmnopqrstuvwxyzABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"
    return prefix + "_" + "".join(secrets.choice(chars) for _ in range(random.randint(10, 16)))


def _chunker(seq: List[int], min_size: int = 6, max_size: int = 24):
    i = 0
    while i < len(seq):
        size = random.randint(min_size, max_size)
        yield seq[i:i+size]
        i += size


