async def main():
    """Точка входа"""
    logger.info("="*60)
    logger.info("MoonVeil Deobfuscator Bot Starting...")
    logger.info("="*60)
    
    # Регистрируем shutdown handler
    dp.shutdown.register(on_shutdown)
    
    # Удаляем старые обновления
    await bot.delete_webhook(drop_pending_updates=True)
    
    logger.info("✅ Bot is ready! Polling started...")
    
    # Запускаем polling
    await dp.start_polling(bot)


