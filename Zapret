-- Заменить старую функцию updatePreviewPosition на эту:
local function updatePreviewPosition()
    if not previewModel or not previewModel.PrimaryPart then return end

    local rayParams = RaycastParams.new()
    rayParams.FilterDescendantsInstances = {player.Character, previewModel}
    rayParams.FilterType = Enum.RaycastFilterType.Blacklist
    rayParams.IgnoreWater = false

    -- получаем экранную позицию курсора (удобнее через mouse.Hit)
    local targetPos = nil
    if mouse.Target then
        targetPos = mouse.Hit.Position
    else
        -- fallback: рейкаст от камеры через курсор
        local cam = workspace.CurrentCamera
        local mouseX, mouseY = UserInputService:GetMouseLocation().X, UserInputService:GetMouseLocation().Y
        local ray = cam:ScreenPointToRay(mouseX, mouseY)
        local result = workspace:Raycast(ray.Origin, ray.Direction * 5000, rayParams)
        if result then
            targetPos = result.Position
        end
    end

    if not targetPos then return end

    -- Найдём высоту превью (первый BasePart)
    local root
    for _, v in ipairs(previewModel:GetDescendants()) do
        if v:IsA("BasePart") then
            root = v
            break
        end
    end
    local yOffset = 0
    if root then yOffset = root.Size.Y / 2 end

    -- Raycast вниз от чуть выше точки (на случай неровностей поверхности) чтобы точно положить на поверхность
    local downOrigin = targetPos + Vector3.new(0, 5, 0)
    local downResult = workspace:Raycast(downOrigin, Vector3.new(0, -30, 0), rayParams)
    local finalPos = targetPos
    if downResult then finalPos = downResult.Position end

    -- Ставим превью так, чтобы оно просто стояло на поверхности, без поворота к камере:
    local newCFrame = CFrame.new(finalPos + Vector3.new(0, yOffset, 0))
    -- если есть PrimaryPart, используем SetPrimaryPartCFrame; иначе пробуем сдвинуть все BasePart'ы относительно смещения
    if previewModel.PrimaryPart then
        pcall(function() previewModel:SetPrimaryPartCFrame(newCFrame) end)
    else
        local offset = newCFrame.p
        for _, p in ipairs(previewModel:GetDescendants()) do
            if p:IsA("BasePart") then
                p.CFrame = CFrame.new(offset)
            end
        end
    end
end
