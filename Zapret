@dp.message(F.document)
async def handle_document(message: types.Message):
    doc = message.document
    fname = (doc.file_name or "source").lower()
    if not fname.endswith(ALLOWED_EXTS):
        await message.answer("❌ Поддерживаются только .lua и .txt файлы.")
        return

    # quick size check if available
    if getattr(doc, "file_size", None):
        if doc.file_size > MAX_FILE_SIZE:
            await message.answer(f"❌ Файл слишком большой ({doc.file_size} bytes). Лимит {MAX_FILE_SIZE} bytes.")
            return

    status = await message.answer("🛡 Запускаю Meloten ULTRA обфускацию — подожди секунду...")
    try:
        mem = io.BytesIO()

        # Универсальная загрузка: сначала try Document.download, потом fallback
        downloaded = False
        try:
            # some aiogram versions have Document.download
            if hasattr(doc, "download"):
                await doc.download(destination=mem)  # type: ignore
                downloaded = True
        except Exception:
            downloaded = False

        if not downloaded:
            # fallback: use bot.get_file + bot.download_file (works for many aiogram versions)
            try:
                file = await bot.get_file(doc.file_id)
                # try bot.download_file (aiogram v3 style)
                await bot.download_file(file.file_path, destination=mem)  # type: ignore
                downloaded = True
            except Exception:
                downloaded = False

        if not downloaded:
            # last-resort: try message.bot.get_file (compat)
            try:
                file = await message.bot.get_file(doc.file_id)
                await message.bot.download_file(file.file_path, destination=mem)  # type: ignore
                downloaded = True
            except Exception as e:
                logger.exception("Failed to download file with all methods")
                raise RuntimeError("Не удалось скачать файл (несовместимая версия aiogram).") from e

        mem.seek(0)
        data = mem.getvalue()
        if len(data) > MAX_FILE_SIZE:
            await status.delete()
            await message.answer(f"❌ Файл после загрузки слишком большой ({len(data)} bytes). Лимит {MAX_FILE_SIZE} bytes.")
            return

        source_code = data.decode("utf-8", errors="ignore")

        # run obfuscator
        obf = MelotenUltraVM(source_code, bind_place=True)
        protected = obf.build()

        out_name = f"Protected_{doc.file_name}"
        out_mem = io.BytesIO(protected.encode("utf-8"))
        out_mem.seek(0)

        input_file = InputFile(out_mem, filename=out_name)
        await message.answer_document(input_file, caption="✅ Код обфусцирован (Meloten ULTRA VM).")
        await status.delete()
    except Exception as e:
        logger.exception("Error while handling document")
        try:
            await status.delete()
        except Exception:
            pass
        await message.answer(f"⚠️ Ошибка: {str(e)}")


