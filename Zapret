    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _clean_str(self, s):
        if isinstance(s, bytes): return s.decode('utf-8', 'ignore')
        return str(s)

    def _extract_ascii(self, data):
        """Хардкорный поиск строк в бинарнике"""
        text = ""
        try:
            if isinstance(data, str): data = data.encode('utf-8', 'ignore')
            # Регулярка для URL и длинных слов
            patterns = [
                rb'https?://[a-zA-Z0-9./_?=-]+', # URL
                rb'[a-zA-Z0-9_]{5,}',             # Переменные/Ключи
            ]
            
            results = set()
            for p in patterns:
                for match in re.finditer(p, data):
                    try: results.add(match.group().decode('utf-8'))
                    except: pass
            
            return list(results)
        except: return []

    def _finalize_output(self, code, strings, globals_dump, logs, callback, force_raw=False):
        if callback: callback("🧬 Сборка результатов...")
        
        # 1. Попытка декомпиляции (только если не принудительный raw режим)
        decompiled = None
        if not force_raw:
            # Проверяем заголовок, если это Luau (Roblox Bytecode), unluac не поможет
            if isinstance(code, bytes) and (code.startswith(b'\x1BLua') or len(code) > 0 and code[0] < 32):
                 logs.append("⚠️ Detected Binary Bytecode (likely Luau). Decompilation skipped.")
            elif isinstance(code, str) and (code.startswith('\x1BLua') or len(code) > 0 and ord(code[0]) < 32):
                 logs.append("⚠️ Detected Binary Bytecode inside String. Decompilation skipped.")
            else:
                decompiled = self._try_decompile(code)

        # 2. Объединяем строки (из хуков Lua и статического анализа Python)
        static_strings = self._extract_ascii(code)
        all_strings = set()
        for s in strings: all_strings.add(self._clean_str(s))
        for s in static_strings: all_strings.add(self._clean_str(s))
        
        # Сортируем и чистим
        final_list = []
        ignore_list = ["Instance", "Vector3", "CFrame", "table", "math", "string", "char", "byte", "insert", "concat"]
        for s in all_strings:
            s = s.strip()
            if len(s) > 3 and s not in ignore_list and not s.isdigit():
                final_list.append(s)
        
        final_list.sort(key=len, reverse=True) # Сначала длинные (URL, ключи)

        # 3. Формируем отчет
        out = []
        out.append("-- [[ MEL DEOBFUSCATOR V3 - ULTIMATE DUMP ]] --")
        out.append(f"-- Total Strings Found: {len(final_list)}")
        out.append("-- Auto-generated variable names used below.\n")

        # Вывод строк как переменных
        for i, s in enumerate(final_list):
            safe_s = s.replace('"', '\\"').replace('\n', ' ')
            out.append(f'local mel_{i+1} = "{safe_s}"')

        if logs:
            out.append("\n" + "="*40)
            out.append("-- [[ EXECUTION LOGS ]] --")
            for l in logs: out.append(f"-- {l}")
        
        out.append("\n" + "="*40)
        out.append("-- [[ CODE SECTION ]] --\n")
        
        if decompiled:
            try: src = decompiled.decode('utf-8')
            except: src = decompiled.decode('latin-1')
            out.append(self._beautify_lua(src))
        else:
            out.append("-- [INFO] Decompilation unavailable for this chunk type.")
            out.append("-- [INFO] Showing RAW Content (Bytecode/Text view):\n")
            if isinstance(code, bytes):
                # Пробуем показать как текст, если не выходит - HEX
                try: out.append(code.decode('utf-8'))
                except: 
                    hex_dump = binascii.hexlify(code).decode('utf-8')
                    # Разбиваем hex на строки для читаемости
                    chunks_hex = [hex_dump[i:i+80] for i in range(0, len(hex_dump), 80)]
                    out.append(f"-- HEX DUMP ({len(code)} bytes):")
                    out.append("\n".join(chunks_hex))
            else:
                out.append(str(code))

        return "\n".join(out).encode('utf-8')

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path): return None
        # Если это строка, кодируем в байты
        if isinstance(bytecode, str): bytecode = bytecode.encode('utf-8')
        
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua", mode='wb') as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            # Unluac работает ТОЛЬКО с Lua 5.1 заголовками. 
            # Если заголовок кривой, он ничего не вернет.
            res = subprocess.run(
                ["java", "-jar", self.unluac_path, path], 
                capture_output=True, timeout=10
            )
            os.remove(path)
            
            if res.returncode == 0 and len(res.stdout) > 5:
                return res.stdout
            return None
        except: return None

    def _beautify_lua(self, src):
        # Базовое форматирование
        src = re.sub(r';', ';\n', src)
        src = re.sub(r' (then|do) ', r' \1\n    ', src)
        src = re.sub(r' end ', r'\nend\n', src)
        return src
