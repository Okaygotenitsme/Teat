import lupa
from lupa import LuaRuntime
import logging
import subprocess
import os
import tempfile
import re

# Настройка логгера
logger = logging.getLogger("DeobfuscatorEngine")
logging.basicConfig(level=logging.INFO)

class DeobfuscatorEngine:
    def __init__(self):
        # Определяем пути
        base_dir = os.path.dirname(os.path.abspath(__file__))
        self.unluac_path = os.path.join(base_dir, "unluac.jar")
        
        logger.info(f"📁 Рабочая папка: {base_dir}")
        logger.info(f"☕ Путь к Unluac: {self.unluac_path}")

    def _beautify_lua(self, source_code):
        """
        Улучшенный Lua-форматтер. 
        MoonSec V3 после unluac часто выглядит как каша из-за Control Flow Flattening.
        """
        indent = 0
        formatted = []
        
        # Предварительная очистка: разбиваем длинные цепочки ключевых слов
        # (часто бывает в декомпилированных VM)
        source_code = source_code.replace("; ", ";\n")
        source_code = re.sub(r'(\b(then|do|repeat)\b)', r'\1\n', source_code)
        source_code = re.sub(r'(\b(else|elseif)\b)', r'\n\1\n', source_code)
        source_code = source_code.replace(" end ", "\nend\n")
        
        lines = source_code.splitlines()

        for line in lines:
            line = line.strip()
            if not line: continue
            
            # Уменьшаем отступ перед проверкой текущей строки
            if line.startswith("end") or line.startswith("until") or line.startswith("}"):
                indent = max(0, indent - 1)
            elif line == "else" or line.startswith("elseif"):
                indent = max(0, indent - 1)
            
            formatted.append("    " * indent + line)
            
            # Увеличиваем отступ для следующей строки
            if (line.endswith("then") or line.endswith("do") or 
                line.endswith("repeat") or line.endswith("{") or 
                "function(" in line or line.startswith("function ")):
                
                # Если функция не однострочная
                if not (line.endswith("end") or line.endswith("end;")):
                    indent += 1
            
            if line == "else" or line.startswith("elseif"):
                indent += 1
                
        return "\n".join(formatted)

    def process(self, content, status_callback=None):
        def update_status(msg):
            if status_callback: status_callback(msg)
            logger.info(f"[STATUS] {msg}")

        if not self._check_java():
            return b"-- [FATAL] Java not found! Please install JRE."

        update_status("🛠 Инициализация Lua VM (MoonSec Edition)...")

        try:
            lua = LuaRuntime(unpack_returned_tuples=True, encoding=None)
        except Exception as e:
            return f"-- [FATAL]: Ошибка старта Lua: {e}".encode('utf-8')

        # Полифилл bit-операций (MoonSec их обожает)
        bit_polyfill = """
        local bit = {}
        function bit.tobit(x) x = x % 4294967296; if x >= 2147483648 then x = x - 4294967296 end; return x end
        function bit.bnot(x) return 4294967295 - x % 4294967296 end
        local function bit_oper(a, b, oper)
            local r, m, s = 0, 2^31, nil
            repeat
                s,a,b = a+b+m, a%m, b%m
                r,m = r + m*oper%(s-a-b), m/2
            until m < 1
            return r
        end
        function bit.band(a, b) return bit_oper(a, b, 4) end
        function bit.bor(a, b)  return bit_oper(a, b, 1) end
        function bit.bxor(a, b) return bit_oper(a, b, 3) end
        function bit.lshift(a, b) return (a * 2^b) % 4294967296 end
        function bit.rshift(a, b) return math.floor(a / 2^b) % 4294967296 end
        package.loaded.bit = bit
        _G.bit = bit
        _G.bit32 = bit 
        """

        # Среда-ловушка для перехвата MoonSec
        sandbox_setup = bit_polyfill + """
        _G.CAPTURED_CHUNKS = {}
        _G.LOGS = {}
        
        local function log(msg) table.insert(_G.LOGS, tostring(msg)) end
        _G.log = log

        local real_load = load
        local function hooked_load(chunk, name, mode, env)
            if type(chunk) == "string" then
                local len = #chunk
                -- MoonSec часто грузит байткод через load
                if len > 20 then
                    log("[HOOK] Перехвачен блок: " .. len .. " байт")
                    table.insert(_G.CAPTURED_CHUNKS, {data = chunk, size = len})
                end
            end
            return real_load(chunk, name, mode, env)
        end

        local function create_proxy(name)
            local proxy = {}
            setmetatable(proxy, {
                __index = function(t, k) 
                    if tostring(k) == "ClassName" then return name end
                    return create_proxy(name .. "." .. tostring(k)) 
                end,
                __call = function() return create_proxy(name .. ":Method") end,
                __tostring = function() return name end
            })
            return proxy
        end

        local env = {
            loadstring = hooked_load, load = hooked_load,
            print = log, warn = log,
            string = string, math = math, table = table, coroutine = coroutine,
            bit = bit, bit32 = bit,
            pairs = pairs, ipairs = ipairs, next = next, type = type,
            pcall = pcall, xpcall = xpcall, setmetatable = setmetatable,
            getmetatable = getmetatable, os = {time = os.time, clock = os.clock},
            game = create_proxy("game"), workspace = create_proxy("workspace"),
            script = create_proxy("script"), Instance = {new = function() return create_proxy("Instance") end}
        }
        env._G = env
        return env
        """

        try:
            env = lua.execute(sandbox_setup)
            runner = lua.eval("function(code, env) return pcall(load(code, 'src', 'bt', env)) end")
            
            update_status("🚀 Выполнение (эмуляция MoonSec)...")
            success, err = runner(content, env)
            
            chunks = lua.globals().CAPTURED_CHUNKS
            logs = list(lua.globals().LOGS)

            if len(chunks) > 0:
                update_status(f"💎 Найдено фрагментов: {len(chunks)}. Декомпиляция...")
                
                # Ищем самый крупный фрагмент (обычно это само ядро скрипта)
                best_chunk = None
                max_size = 0
                for i in range(1, len(chunks) + 1):
                    c = chunks[i]
                    if c.size > max_size:
                        max_size = c.size
                        best_chunk = c.data
                
                return self._clean_code(best_chunk, logs, update_status)
            else:
                return self._format_logs(logs, fail=True)

        except Exception as e:
            return f"-- [CRASH]: {str(e)}".encode('utf-8')

    def _check_java(self):
        try:
            subprocess.run(["java", "-version"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
            return True
        except: return False

    def _try_decompile(self, bytecode):
        if not os.path.exists(self.unluac_path): return None
        try:
            with tempfile.NamedTemporaryFile(delete=False, suffix=".lua") as tmp:
                tmp.write(bytecode)
                path = tmp.name
            
            res = subprocess.run(["java", "-jar", self.unluac_path, path], capture_output=True)
            os.remove(path)
            
            if res.returncode == 0: return res.stdout
            return None
        except: return None

    def _clean_code(self, code_obj, logs, status_callback=None):
        res = self._try_decompile(code_obj)
        if res:
            try:
                text = res.decode('utf-8', 'ignore')
                if status_callback: status_callback("💅 Форматирование кода...")
                text = self._beautify_lua(text)
                return f"-- [[ MoonSec V3 Unpacked & Beautified ]] --\n\n{text}".encode('utf-8')
            except:
                return b"-- [[ Decompiled but encoding error ]] --\n" + res
        
        return b"-- [[ Could not decompile, returning raw captured data ]] --\n" + code_obj

    def _format_logs(self, logs, fail=False):
        header = "-- [FAIL] Не удалось перехватить чистый код.\n" if fail else ""
        log_str = "\n".join([f"-- {l}" for l in logs[-50:]])
        return (header + "-- [[ LOGS ]] --\n" + log_str).encode('utf-8')
