def generate_junk():
    """Создает мусорные переменные, чтобы запутать декомпилятор"""
    junk_codes = [
        f"local {''.join(random.choices(string.ascii_letters, k=7))} = {random.randint(1, 9999)};",
        f"if {random.randint(1, 10)} > 20 then print('Error') end;",
        f"local function {''.join(random.choices(string.ascii_letters, k=5))}() return nil end;"
    ]
    return "\n".join(random.sample(junk_codes, 2))

def obfuscate_lua(source_code):
    """Превращает Lua код в защищенный байт-код для Roblox"""
    
    # 1. Шифрование исходного текста (XOR + Смещение)
    key = random.randint(10, 100)
    encrypted_bytes = [(ord(char) ^ key) for char in source_code]
    bytes_as_string = "{" + ",".join(map(str, encrypted_bytes)) + "}"
    
    # 2. Сборка Виртуальной Машины (Runtime)
    # Этот код будет работать в Roblox Studio и Инжекторах
    protected_script = f"""--[[ 
    STRICTLY PROTECTED BY PROGRAMMER PARTNER VM
    VERSION: 1.0.4 [ULTRA]
]]

{generate_junk()}

local _VM_DATA = {bytes_as_string}
local _KEY = {key}

local function _EXECUTE_()
    local _DECODED = ""
    for _i = 1, #_VM_DATA do
        -- Математическая декомпрессия байт-кода
        local _byte = _VM_DATA[_i]
        _DECODED = _DECODED .. string.char(bit32.bxor(_byte, _KEY))
    end
    
    {generate_junk()}
    
    local _RUN, _ERR = loadstring(_DECODED)
    if not _RUN then
        warn("[VM ERROR]: Code integrity compromised! " .. tostring(_ERR))
        return
    end
    
    {generate_junk()}
    _RUN()
end

task.spawn(_EXECUTE_)
{generate_junk()}
"""
    return protected_script

