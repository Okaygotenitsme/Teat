class MelotenObfuscator:
    def __init__(self, source):
        self.source = source
        self.key = random.randint(100, 255)
        self.v_data = self._rand_name()
        self.v_key = self._rand_name()
        self.v_res = self._rand_name()
        self.v_func = self._rand_name()

    def _rand_name(self):
        """Создает нечитаемые имена переменных типа lIlIIllIlI"""
        return "l" + "".join(random.choices("Il1", k=random.randint(12, 18)))

    def _generate_junk(self):
        """Создает мусорный код для запутывания декомпиляторов"""
        junk_names = [self._rand_name() for _ in range(3)]
        return f"local {junk_names[0]}={random.randint(1,999)};local {junk_names[1]}='{junk_names[2]}';"

    def build(self):
        # Кодируем исходник в Base64
        b64_source = base64.b64encode(self.source.encode()).decode()
        
        header = f"--[[Protected by Meloten Obfuscator]]\n--[[News: @MelotenBot]]\n"
        
        # Сложная VM структура: декодирование Base64 + XOR шифрование кадра
        vm_logic = (
            f"{self._generate_junk()}"
            f"local {self.v_data}='{b64_source}';"
            f"local {self.v_key}={self.key};"
            f"local function {self.v_res}(d) "
            f"local b='ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/' "
            f"d=d:gsub('[^'..b..'..'=]', '') "
            f"return (d:gsub('.', function(x) "
            f"if x=='=' then return '' end "
            f"local r,f='', (b:find(x)-1) "
            f"for i=6,1,-1 do r=r..(f%2^i-f%2^(i-1)>0 and '1' or '0') end "
            f"return r; end):gsub('%d%d%d%d%d%d%d%d', function(x) "
            f"local c=0 for i=1,8 do c=c+(x:sub(i,i)=='1' and 2^(8-i) or 0) end "
            f"return string.char(bit32.bxor(c,{self.v_key})) end)) end;"
            f"local {self.v_func}=loadstring({self.v_res}({self.v_data}));"
            f"{self._generate_junk()}"
            f"if {self.v_func} then task.spawn({self.v_func}) end"
        )
        
        return header + vm_logic.replace("    ", "")

