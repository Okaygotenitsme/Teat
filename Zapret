        raise Exception("Lua syntax error detected")

    key = random.randint(20, 240)
    byte_table = encrypt_to_byte_table(source, key)

    v_tbl = gen_var()
    v_out = gen_var()
    v_i = gen_var()
    v_load = gen_var()
    v_env = gen_var()

    if env == "roblox_exec":
        loader = "loadstring or load"
        env_setup = "local _ENV = getfenv and getfenv() or _G"
    elif env == "studio":
        loader = "loadstring or load"
        env_setup = "local _ENV = {}"
    else:
        loader = "loadstring or load"
        env_setup = "local _ENV = _G"

    lua_bytes = ",".join(str(b) for b in byte_table)

    final = f'''
