import asyncio
import os
import logging
import uuid
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command

# Импортируем движок
from engine import DeobfuscatorEngine

# --- КОНФИГУРАЦИЯ ---
API_TOKEN = 'ТВОЙ_ТОКЕН_СЮДА' # <--- ВСТАВЬ ТОКЕН

# Логирование
logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(message)s")
logger = logging.getLogger("DeobfBot")

bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "🔮 **Ultima Deobfuscator Bot**\n\n"
        "Отправь мне Lua скрипт (файл).\n"
        "Я прогоню его через эмулятор Roblox и попробую:\n"
        "1. Вскрыть виртуализацию (IronBrew/MoonSec)\n"
        "2. Перехватить `Http` и `Remote` запросы\n"
        "3. Достать все спрятанные строки\n\n"
        "Ожидание может занять до 30 секунд.",
        parse_mode="Markdown"
    )

@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    unique_id = uuid.uuid4().hex[:6]
    file_name = message.document.file_name or "script.lua"
    
    input_path = f"in_{unique_id}.lua"
    output_path = f"out_{unique_id}.txt" # txt чтобы телеграм открыл предпросмотр

    status_msg = await message.answer("⏳ **Загрузка в песочницу...**", parse_mode="Markdown")
    
    loop = asyncio.get_running_loop()
    
    # Механизм обновления статуса
    last_text = [""]
    def sync_status(text):
        if text == last_text[0]: return
        last_text[0] = text
        if loop.is_closed(): return
        asyncio.run_coroutine_threadsafe(
            status_msg.edit_text(f"⚙️ {text}"), loop
        )

    try:
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "rb") as f: content = f.read()

        # Запуск движка в отдельном потоке
        # Тайм-аут 45 секунд, так как эмуляция тяжелая
        result_data = await asyncio.wait_for(
            loop.run_in_executor(None, engine.process, content, sync_status),
            timeout=45.0 
        )

        with open(output_path, "wb") as f: f.write(result_data)
        
        caption = "✅ **Готово!**\n"
        if b"DECOMPILED SOURCE" in result_data:
            caption += "📜 Код восстановлен.\n"
        if b"FOUND STRINGS" in result_data:
            caption += "🔎 Найдены скрытые данные."

        await message.answer_document(FSInputFile(output_path), caption=caption)

    except asyncio.TimeoutError:
        await status_msg.edit_text("❌ **Тайм-аут:** Скрипт слишком сложный или завис в бесконечном цикле.")
    except Exception as e:
        logger.error(f"Error: {e}")
        await status_msg.edit_text(f"❌ **Ошибка:** {str(e)}")
    finally:
        for p in [input_path, output_path]:
            if os.path.exists(p):
                try: os.remove(p)
                except: pass

async def main():
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    if os.name == 'nt':
        asyncio.set_event_loop_policy(asyncio.WindowsSelectorEventLoopPolicy())
    asyncio.run(main())
