# ------------------ BEAUTIFIER (упрощённый, но рабочий) ------------------
class LuaBeautifier:
    def __init__(self, source: str):
        self.source = source

    def format(self) -> str:
        # осторожное форматирование отступов, не меняющее кода (не удаляем строки)
        lines = self.source.splitlines()
        out = []
        indent = 0
        for raw in lines:
            s = raw.strip()
            if not s:
                out.append("")  # сохраняем пустые строки
                continue
            # уменьшение отступа для закрывающих ключевых слов
            if s.startswith(("end", "until", "elseif", "else", ")")):
                indent = max(0, indent - 1)
            out.append("    " * indent + s)
            # увеличение отступа для открывающих
            if s.startswith(("function", "then", "do", "repeat")) or s.endswith("then") or s.endswith("do"):
                indent += 1
        return "\n".join(out)


