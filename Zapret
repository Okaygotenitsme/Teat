import asyncio
import os
import logging
import uuid
from aiogram import Bot, Dispatcher, F, types
from aiogram.types import FSInputFile
from aiogram.filters import Command

# Импорт обновленного движка
from engine import DeobfuscatorEngine

# --- НАСТРОЙКИ ---
API_TOKEN = 'ТВОЙ_ТОКЕН_ЗДЕСЬ' 

logging.basicConfig(level=logging.INFO, format="%(asctime)s - %(name)s - %(message)s")
logger = logging.getLogger("DeobfBot")

bot = Bot(token=API_TOKEN)
dp = Dispatcher()
engine = DeobfuscatorEngine()

@dp.message(Command("start"))
async def cmd_start(message: types.Message):
    await message.answer(
        "🤖 **Roblox Deobfuscator V2.0 (Deep Trace)**\n\n"
        "Отправь мне `.lua` или `.txt` файл.\n"
        "Я запущу его в эмуляторе и запишу каждое действие.\n\n"
        "🛠 **Возможности:**\n"
        "✅ Эмуляция `game`, `workspace`, `HTTP`\n"
        "✅ Перехват `loadstring` (распаковка)\n"
        "✅ Логирование всех вызовов (Spyware Log)\n"
        "✅ Попытка декомпиляции через unluac",
        parse_mode="Markdown"
    )

@dp.message(F.document)
async def handle_document(message: types.Message):
    user_id = message.from_user.id
    unique_id = uuid.uuid4().hex[:8]
    
    # Очистка имени файла
    orig_name = message.document.file_name or "script.lua"
    file_name = "".join([c for c in orig_name if c.isalnum() or c in "._-"])
    
    input_path = f"temp_{user_id}_{unique_id}.lua"
    output_path = f"Deobf_{unique_id}_{file_name}.txt"

    status_msg = await message.answer("⏳ **Загрузка и запуск эмулятора...**", parse_mode="Markdown")
    
    loop = asyncio.get_running_loop()
    
    # Механизм обновления статуса
    last_status = [""]
    
    def sync_status_updater(text):
        if text == last_status[0]: return
        last_status[0] = text
        async def edit_coro():
            try:
                if text: await status_msg.edit_text(f"⚙️ **Статус:** {text}", parse_mode="Markdown")
            except: pass 
        if not loop.is_closed():
            asyncio.run_coroutine_threadsafe(edit_coro(), loop)

    try:
        file = await bot.get_file(message.document.file_id)
        await bot.download_file(file.file_path, input_path)

        with open(input_path, "rb") as f: content = f.read()

        # Запуск движка в отдельном потоке
        result_data = await asyncio.wait_for(
            loop.run_in_executor(None, engine.process, content, sync_status_updater),
            timeout=180.0 # 3 минуты тайм-аут для сложных скриптов
        )

        with open(output_path, "wb") as f: f.write(result_data)
        out_file = FSInputFile(output_path)
        
        caption = "✅ **Анализ завершен!**\n\n"
        if b"EXECUTION LOG" in result_data:
            caption += "🕵️ Добавлен лог действий (Execution Log)\n"
        if b"DUMPED STRINGS" in result_data:
            caption += "🔎 Строки извлечены\n"
        if b"CAPTURED LOAD" in result_data:
            caption += "🔥 Перехвачен распакованный код!\n"
        
        await message.answer_document(out_file, caption=caption)

    except asyncio.TimeoutError:
        await status_msg.edit_text("❌ **Тайм-аут:** Скрипт слишком сложный или зациклился.")
    except Exception as e:
        logger.error(f"Error: {e}")
        await status_msg.edit_text(f"❌ Ошибка: {str(e)}")
    finally:
        for p in [input_path, output_path]:
            if os.path.exists(p):
                try: os.remove(p)
                except: pass

async def main():
    logger.info("Бот V2.0 запускается...")
    await bot.delete_webhook(drop_pending_updates=True)
    await dp.start_polling(bot)

if __name__ == "__main__":
    try:
        if os.name == 'nt':
            asyncio.set_event_loop_policy(asyncio.WindowsSelectorEventLoopPolicy())
        asyncio.run(main())
    except KeyboardInterrupt:
        print("Бот остановлен.")
