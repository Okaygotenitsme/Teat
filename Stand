local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local CoreGui = game:GetService("CoreGui") -- Используем системный уровень
local player = Players.LocalPlayer

-- Параметры
local IDLE_OFFSET = Vector3.new(3, 2.5, 4.5) 
local ATTACK_OFFSET = Vector3.new(0, 0, -8) 
local ATTACK_DURATION = 1.8
local STAND_TRANSPARENCY = 0.5

local isAttacking = false
local currentOffset = IDLE_OFFSET

-- Принудительное создание GUI в CoreGui
local function createMobileGui()
    if CoreGui:FindFirstChild("StandMobileSystem") then
        CoreGui.StandMobileSystem:Destroy()
    end

    local sg = Instance.new("ScreenGui")
    sg.Name = "StandMobileSystem"
    sg.Parent = CoreGui -- Игра не увидит этот GUI в PlayerGui

    local mainFrame = Instance.new("Frame")
    mainFrame.Size = UDim2.new(0, 280, 0, 70)
    mainFrame.Position = UDim2.new(0.5, -140, 0.2, 0) -- Сместил вверх, чтобы точно увидел
    mainFrame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    mainFrame.BackgroundTransparency = 0.5
    mainFrame.Active = true
    mainFrame.Draggable = true -- Можно двигать пальцем по экрану
    mainFrame.Parent = sg

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 0, 20)
    label.Text = "STAND CONTROL (DRAG ME)"
    label.TextColor3 = Color3.fromRGB(255, 255, 0)
    label.BackgroundTransparency = 1
    label.TextSize = 10
    label.Parent = mainFrame

    for i = 1, 4 do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(0, 60, 0, 40)
        btn.Position = UDim2.new(0, (i-1)*70 + 5, 0, 25)
        btn.Text = "SKILL " .. i
        btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Parent = mainFrame
        
        btn.MouseButton1Click:Connect(function()
            if _G.PerformStandAttack then _G.PerformStandAttack(i) end
        end)
    end
end

createMobileGui()

local function setupStand(character)
    -- Ждем полной загрузки корня
    local root = character:WaitForChild("HumanoidRootPart", 20)
    if not root then return end

    -- Создаем Стенд через задержку, чтобы избежать багов загрузки
    task.wait(1)
    character.Archivable = true
    local stand = character:Clone()
    character.Archivable = false

    -- Очистка и прозрачность
    for _, v in pairs(stand:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Transparency = STAND_TRANSPARENCY
            v.CanCollide = false
            v.Massless = true
        elseif v:IsA("Script") or v:IsA("LocalScript") or v:IsA("Decal") then
            if v.Name ~= "Face" then v:Destroy() end -- Оставляем лицо, убираем остальное
        elseif v:IsA("SelectionBox") or v:IsA("ParticleEmitter") then
            v:Destroy()
        end
    end

    local standRoot = stand:WaitForChild("HumanoidRootPart")
    local standHumanoid = stand:WaitForChild("Humanoid")
    local standAnimator = standHumanoid:FindFirstChildOfClass("Animator") or Instance.new("Animator", standHumanoid)
    stand.Parent = workspace
    stand.Name = "JOJO_STAND"

    local bp = Instance.new("BodyPosition", standRoot)
    bp.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bp.P = 50000
    
    local bg = Instance.new("BodyGyro", standRoot)
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bg.P = 30000

    _G.PerformStandAttack = function(index)
        if isAttacking then return end
        local tool = player.Backpack:GetChildren()[index]
        if tool then
            isAttacking = true
            currentOffset = ATTACK_OFFSET
            
            local pHum = character:FindFirstChildOfClass("Humanoid")
            pHum:EquipTool(tool)
            
            -- Визуальный эффект для стенда
            local toolClone = tool:Clone()
            toolClone.Parent = stand
            standHumanoid:EquipTool(toolClone)
            
            tool:Activate()

            -- Перехват анимации
            task.spawn(function()
                task.wait(0.1)
                for _, t in pairs(pHum:GetPlayingAnimationTracks()) do
                    local st = standAnimator:LoadAnimation(t.Animation)
                    st:Play()
                    t:Stop()
                end
            end)

            task.wait(ATTACK_DURATION)
            toolClone:Destroy()
            currentOffset = IDLE_OFFSET
            isAttacking = false
        end
    end

    RunService.RenderStepped:Connect(function()
        if not character.Parent or not root.Parent then stand:Destroy() return end
        bp.Position = (root.CFrame * CFrame.new(currentOffset)).Position
        bg.CFrame = root.CFrame
    end)
end

player.CharacterAdded:Connect(setupStand)
if player.Character then setupStand(player.Character) end
