   Name = "Anti-AFK (Защита от кика)",
   CurrentValue = false,
   Flag = "AntiAfkToggle", 
   Callback = function(Value)
        _G.AntiAfk = Value
        if Value then
            local bb = game:GetService("VirtualUser")
            -- Привязываем к событию Idled: как только игра считает, что игрок бездействует, 
            -- мы выполняем команду, которая сбрасывает таймер.
            game:GetService("Players").LocalPlayer.Idled:Connect(function()
                if _G.AntiAfk then
                    bb:CaptureController() -- Захват ввода
                    bb:ClickButton2(Vector2.new()) -- Имитация правого клика в случайном месте
                    print("Anti-AFK: Активность имитирована.")
